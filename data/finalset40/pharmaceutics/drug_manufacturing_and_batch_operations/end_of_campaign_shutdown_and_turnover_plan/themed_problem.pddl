    (checklist_document_available turnover_checklist_beta)
    (zone_associated_with_primary_line turnover_zone_alpha primary_production_line)
    (zone_associated_with_primary_line turnover_zone_beta primary_production_line)
    (zone_associated_with_support_line turnover_zone_alpha support_production_line)
    (zone_associated_with_support_line turnover_zone_beta support_production_line)
    (zone_associated_with_turnover_record turnover_zone_alpha turnover_record_alpha)
    (zone_associated_with_turnover_record turnover_zone_beta turnover_record_alpha)
    (zone_associated_with_checklist_document turnover_zone_alpha turnover_checklist_alpha)
    (zone_associated_with_checklist_document turnover_zone_beta turnover_checklist_beta)
    (spare_component_available spare_component_alpha)
    (spare_component_available spare_component_beta)
    (inspection_evidence_available inspection_evidence_alpha)
    (inspection_evidence_available inspection_evidence_beta)
    (release_certificate_available release_certificate_alpha)
    (cleaning_procedure_available cleaning_procedure_run)
    (authorization_token_available authorization_token_alpha)
    (zone_bound_to_authorization_token turnover_zone_alpha authorization_token_alpha)
    (zone_bound_to_authorization_token turnover_zone_beta authorization_token_beta)
