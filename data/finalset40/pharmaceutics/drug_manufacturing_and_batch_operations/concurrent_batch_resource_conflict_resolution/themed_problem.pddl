(define (problem concurrent_batch_conflict_case)
  (:domain concurrent_batch_resource_conflict_resolution)
  (:objects upstream_segment_1 - upstream_segment downstream_segment_1 - downstream_segment batch_record_1 - batch_record batch_record_2 - batch_record equipment_slot_1 - equipment_resource equipment_slot_2 - equipment_resource equipment_slot_3 - equipment_resource operator_1 - transient_resource support_equipment_1 - support_equipment consumable_reagent_1 - consumable_material equipment_port_a_1 - equipment_port_a equipment_port_b_1 - equipment_port_b shared_unit_1 - shared_unit qc_sample_container_1 - qc_sample_container qc_sample_container_2 - qc_sample_container packaging_slot_1 - packaging_slot packaging_slot_2 - packaging_slot quality_inspector_1 - quality_inspector quality_inspector_2 - quality_inspector release_document_1 - release_document calibration_certificate_1 - calibration_certificate approval_token_1 - approval_token approval_token_2 - approval_token regulatory_signoff_1 - regulatory_signoff)
  (:init
    (equipment_available equipment_slot_1)
    (equipment_available equipment_slot_2)
    (equipment_available equipment_slot_3)
    (transient_resource_available operator_1)
    (support_equipment_available support_equipment_1)
    (consumable_available consumable_reagent_1)
    (segment_port_compatibility upstream_segment_1 equipment_port_a_1)
    (segment_port_b_compatibility downstream_segment_1 equipment_port_b_1)
    (shared_unit_available shared_unit_1)
    (qc_sample_container_available qc_sample_container_1)
    (qc_sample_container_available qc_sample_container_2)
    (record_associated_with_upstream_segment batch_record_1 upstream_segment_1)
    (record_associated_with_upstream_segment batch_record_2 upstream_segment_1)
    (record_associated_with_downstream_segment batch_record_1 downstream_segment_1)
    (record_associated_with_downstream_segment batch_record_2 downstream_segment_1)
    (record_associated_with_shared_unit batch_record_1 shared_unit_1)
    (record_associated_with_shared_unit batch_record_2 shared_unit_1)
    (record_linked_to_qc_sample_container batch_record_1 qc_sample_container_1)
    (record_linked_to_qc_sample_container batch_record_2 qc_sample_container_2)
    (packaging_slot_available packaging_slot_1)
    (packaging_slot_available packaging_slot_2)
    (quality_inspector_available quality_inspector_1)
    (quality_inspector_available quality_inspector_2)
    (release_document_available release_document_1)
    (calibration_certificate_available calibration_certificate_1)
    (approval_available approval_token_1)
    (record_linked_to_approval_token batch_record_1 approval_token_1)
    (record_linked_to_approval_token batch_record_2 approval_token_2)
    (regulatory_signoff_available regulatory_signoff_1)
  )
  (:goal
    (and
      (release_activated upstream_segment_1)
      (release_activated downstream_segment_1)
      (release_activated batch_record_1)
      (release_activated batch_record_2)
    )
  )
)
