(define (problem dose_strength_ladder_planning_problem)
  (:domain pharmaceutics_dose_strength_ladder_planning_domain)
  (:objects dose_level_instance - dose_level dose_level_variant_instance - dose_level_variant formulation_campaign_instance_1 - formulation_campaign formulation_campaign_instance_2 - formulation_campaign raw_material_batch_instance_1 - raw_material_batch raw_material_batch_instance_2 - raw_material_batch raw_material_batch_instance_3 - raw_material_batch analytical_resource_instance - analytical_resource equipment_or_expertise_instance - equipment_or_expertise excipient_material_instance - excipient_material strength_profile_low_instance - strength_profile_low strength_profile_high_instance - strength_profile_high formulation_prototype_instance - formulation_prototype stability_protocol_instance_1 - stability_protocol stability_protocol_instance_2 - stability_protocol packaging_option_instance_1 - packaging_option packaging_option_instance_2 - packaging_option regulatory_document_instance_1 - regulatory_document regulatory_document_instance_2 - regulatory_document evidence_item_instance - evidence_item manufacturing_process_instance - manufacturing_process risk_item_instance_1 - risk_item risk_item_instance_2 - risk_item critical_quality_attribute_instance - critical_quality_attribute)
  (:init
    (raw_material_available raw_material_batch_instance_1)
    (raw_material_available raw_material_batch_instance_2)
    (raw_material_available raw_material_batch_instance_3)
    (analytical_resource_available analytical_resource_instance)
    (equipment_available equipment_or_expertise_instance)
    (excipient_available excipient_material_instance)
    (dose_low_profile_linked dose_level_instance strength_profile_low_instance)
    (variant_high_profile_linked dose_level_variant_instance strength_profile_high_instance)
    (prototype_slot_unallocated formulation_prototype_instance)
    (stability_protocol_available stability_protocol_instance_1)
    (stability_protocol_available stability_protocol_instance_2)
    (campaign_includes_dose_level formulation_campaign_instance_1 dose_level_instance)
    (campaign_includes_dose_level formulation_campaign_instance_2 dose_level_instance)
    (campaign_includes_dose_variant formulation_campaign_instance_1 dose_level_variant_instance)
    (campaign_includes_dose_variant formulation_campaign_instance_2 dose_level_variant_instance)
    (campaign_includes_prototype formulation_campaign_instance_1 formulation_prototype_instance)
    (campaign_includes_prototype formulation_campaign_instance_2 formulation_prototype_instance)
    (campaign_has_stability_protocol formulation_campaign_instance_1 stability_protocol_instance_1)
    (campaign_has_stability_protocol formulation_campaign_instance_2 stability_protocol_instance_2)
    (packaging_option_available packaging_option_instance_1)
    (packaging_option_available packaging_option_instance_2)
    (regulatory_document_available regulatory_document_instance_1)
    (regulatory_document_available regulatory_document_instance_2)
    (evidence_item_available evidence_item_instance)
    (manufacturing_process_available manufacturing_process_instance)
    (risk_item_available risk_item_instance_1)
    (campaign_has_risk_item formulation_campaign_instance_1 risk_item_instance_1)
    (campaign_has_risk_item formulation_campaign_instance_2 risk_item_instance_2)
    (critical_quality_attribute_available critical_quality_attribute_instance)
  )
  (:goal
    (and
      (scale_up_ready dose_level_instance)
      (scale_up_ready dose_level_variant_instance)
      (scale_up_ready formulation_campaign_instance_1)
      (scale_up_ready formulation_campaign_instance_2)
    )
  )
)
