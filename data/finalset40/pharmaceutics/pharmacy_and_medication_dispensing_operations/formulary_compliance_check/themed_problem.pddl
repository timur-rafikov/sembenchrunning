(define (problem formulary_compliance_case)
  (:domain pharmacy_formulary_compliance)
  (:objects dispense_job_1 - dispense_job dispensing_session_1 - dispensing_session pharmacist_1 - pharmacist pharmacist_2 - pharmacist formulary_option_1 - formulary_option formulary_option_2 - formulary_option formulary_option_3 - formulary_option clinical_rule_1 - clinical_rule approver_1 - approver substitution_token_1 - substitution_token patient_profile_1 - patient_profile packaging_spec_1 - packaging_spec medication_package_1 - medication_package packaging_component_1 - packaging_component packaging_component_2 - packaging_component aux_label_template_1 - aux_label_template aux_label_template_2 - aux_label_template instruction_template_1 - instruction_template instruction_template_2 - instruction_template patient_instruction_1 - patient_instruction safety_check_template_1 - safety_check_template authorization_request_1 - authorization_request authorization_request_2 - authorization_request approval_document_1 - approval_document)
  (:init
    (formulary_option_available formulary_option_1)
    (formulary_option_available formulary_option_2)
    (formulary_option_available formulary_option_3)
    (clinical_rule_available clinical_rule_1)
    (approver_available approver_1)
    (substitution_token_available substitution_token_1)
    (dispense_job_has_patient_profile dispense_job_1 patient_profile_1)
    (session_has_packaging_spec dispensing_session_1 packaging_spec_1)
    (medication_package_available medication_package_1)
    (packaging_component_available packaging_component_1)
    (packaging_component_available packaging_component_2)
    (pharmacist_assigned_to_dispense_job pharmacist_1 dispense_job_1)
    (pharmacist_assigned_to_dispense_job pharmacist_2 dispense_job_1)
    (pharmacist_assigned_to_session pharmacist_1 dispensing_session_1)
    (pharmacist_assigned_to_session pharmacist_2 dispensing_session_1)
    (pharmacist_assigned_to_package pharmacist_1 medication_package_1)
    (pharmacist_assigned_to_package pharmacist_2 medication_package_1)
    (pharmacist_selected_packaging_component pharmacist_1 packaging_component_1)
    (pharmacist_selected_packaging_component pharmacist_2 packaging_component_2)
    (aux_label_template_available aux_label_template_1)
    (aux_label_template_available aux_label_template_2)
    (instruction_template_available instruction_template_1)
    (instruction_template_available instruction_template_2)
    (patient_instruction_available patient_instruction_1)
    (safety_check_template_available safety_check_template_1)
    (authorization_request_available authorization_request_1)
    (pharmacist_assigned_authorization_request pharmacist_1 authorization_request_1)
    (pharmacist_assigned_authorization_request pharmacist_2 authorization_request_2)
    (approval_document_available approval_document_1)
  )
  (:goal
    (and
      (formulary_compliance_cleared dispense_job_1)
      (formulary_compliance_cleared dispensing_session_1)
      (formulary_compliance_cleared pharmacist_1)
      (formulary_compliance_cleared pharmacist_2)
    )
  )
)
