(define (problem idempotency_strategy_scenario)
  (:domain idempotency_strategy_design)
  (:objects primary_participant_1 - primary_participant replica_participant_1 - replica_participant idempotency_controller_1 - idempotency_controller idempotency_controller_2 - idempotency_controller worker_slot_1 - worker_capacity_slot worker_slot_2 - worker_capacity_slot worker_slot_3 - worker_capacity_slot payload_1 - operation_payload resource_endpoint_1 - resource_endpoint claim_ticket_1 - claim_ticket primary_session_1 - primary_session_token replica_session_1 - replica_session_token commit_artifact_1 - commit_artifact dedup_key_1 - deduplication_key dedup_key_2 - deduplication_key retry_policy_1 - retry_policy retry_policy_2 - retry_policy routing_tag_1 - routing_tag routing_tag_2 - routing_tag audit_entry_1 - audit_entry primary_result_1 - primary_result replica_result_1 - replica_result replica_result_2 - replica_result consensus_signal_1 - consensus_signal)
  (:init
    (worker_slot_available worker_slot_1)
    (worker_slot_available worker_slot_2)
    (worker_slot_available worker_slot_3)
    (payload_available payload_1)
    (resource_endpoint_available resource_endpoint_1)
    (claim_ticket_available claim_ticket_1)
    (participant_primary_session_assigned primary_participant_1 primary_session_1)
    (participant_replica_session_assigned replica_participant_1 replica_session_1)
    (commit_artifact_available commit_artifact_1)
    (deduplication_key_available dedup_key_1)
    (deduplication_key_available dedup_key_2)
    (controller_bound_primary_participant idempotency_controller_1 primary_participant_1)
    (controller_bound_primary_participant idempotency_controller_2 primary_participant_1)
    (controller_bound_replica_participant idempotency_controller_1 replica_participant_1)
    (controller_bound_replica_participant idempotency_controller_2 replica_participant_1)
    (controller_bound_commit_artifact idempotency_controller_1 commit_artifact_1)
    (controller_bound_commit_artifact idempotency_controller_2 commit_artifact_1)
    (controller_dedup_key_assigned idempotency_controller_1 dedup_key_1)
    (controller_dedup_key_assigned idempotency_controller_2 dedup_key_2)
    (retry_policy_available retry_policy_1)
    (retry_policy_available retry_policy_2)
    (routing_tag_available routing_tag_1)
    (routing_tag_available routing_tag_2)
    (audit_entry_available audit_entry_1)
    (primary_result_available primary_result_1)
    (replica_result_available replica_result_1)
    (controller_has_replica_result idempotency_controller_1 replica_result_1)
    (controller_has_replica_result idempotency_controller_2 replica_result_2)
    (consensus_signal_available consensus_signal_1)
  )
  (:goal
    (and
      (instance_finalized primary_participant_1)
      (instance_finalized replica_participant_1)
      (instance_finalized idempotency_controller_1)
      (instance_finalized idempotency_controller_2)
    )
  )
)
