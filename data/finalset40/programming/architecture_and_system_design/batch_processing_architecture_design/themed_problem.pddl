(define (problem batch_job_orchestration)
  (:domain batch_processing_architecture)
  (:objects source_job_1 - source_job sink_job_1 - sink_job processing_coordinator_1 - processing_coordinator processing_coordinator_2 - processing_coordinator compute_slot_1 - compute_slot compute_slot_2 - compute_slot compute_slot_3 - compute_slot input_shard_1 - input_shard executor_instance_1 - executor_instance configuration_artifact_1 - configuration_artifact input_channel_1 - input_channel output_channel_1 - output_channel batch_package_1 - batch_package library_artifact_1 - library_artifact library_artifact_2 - library_artifact credential_1 - credential credential_2 - credential policy_1 - policy policy_2 - policy storage_endpoint_1 - storage_endpoint tuning_parameter_1 - tuning_parameter priority_tag_1 - priority_tag priority_tag_2 - priority_tag deployment_descriptor_1 - deployment_descriptor)
  (:init
    (compute_slot_available compute_slot_1)
    (compute_slot_available compute_slot_2)
    (compute_slot_available compute_slot_3)
    (input_shard_available input_shard_1)
    (executor_available executor_instance_1)
    (configuration_artifact_available configuration_artifact_1)
    (source_job_input_channel_binding source_job_1 input_channel_1)
    (sink_job_output_channel_binding sink_job_1 output_channel_1)
    (package_unstaged batch_package_1)
    (library_artifact_available library_artifact_1)
    (library_artifact_available library_artifact_2)
    (coordinator_manages_source_job processing_coordinator_1 source_job_1)
    (coordinator_manages_source_job processing_coordinator_2 source_job_1)
    (coordinator_manages_sink_job processing_coordinator_1 sink_job_1)
    (coordinator_manages_sink_job processing_coordinator_2 sink_job_1)
    (coordinator_assigned_package processing_coordinator_1 batch_package_1)
    (coordinator_assigned_package processing_coordinator_2 batch_package_1)
    (coordinator_has_library processing_coordinator_1 library_artifact_1)
    (coordinator_has_library processing_coordinator_2 library_artifact_2)
    (credential_available credential_1)
    (credential_available credential_2)
    (policy_available policy_1)
    (policy_available policy_2)
    (storage_endpoint_available storage_endpoint_1)
    (tuning_parameter_available tuning_parameter_1)
    (priority_tag_available priority_tag_1)
    (coordinator_has_priority_tag processing_coordinator_1 priority_tag_1)
    (coordinator_has_priority_tag processing_coordinator_2 priority_tag_2)
    (deployment_descriptor_available deployment_descriptor_1)
  )
  (:goal
    (and
      (job_completed source_job_1)
      (job_completed sink_job_1)
      (job_completed processing_coordinator_1)
      (job_completed processing_coordinator_2)
    )
  )
)
