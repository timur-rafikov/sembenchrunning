(define (problem concurrent_violation_repair_case)
  (:domain concurrent_constraint_violation_fix)
  (:objects service_alpha - service_instance subsystem_beta - subsystem_instance module_auth - code_module module_payment - code_module agent_alice - repair_agent agent_bob - repair_agent agent_ci - repair_agent diag_tool_tracer - diagnostic_agent lock_main - exclusive_lock_agent fixture_sandbox - test_fixture constraint_a1 - service_constraint constraint_b1 - subsystem_constraint candidate_patch_v1 - fix_candidate tc_regression_1 - test_case tc_concurrency_1 - test_case config_variant_debug - config_variant config_variant_release - config_variant review_token_qa_1 - review_token review_token_lead_1 - review_token trace_log_01 - trace_log build_artifact_v1 - build_artifact dependency_lib_a - dependency_token dependency_lib_b - dependency_token approval_token_team - approval_token)
  (:init
    (agent_available agent_alice)
    (agent_available agent_bob)
    (agent_available agent_ci)
    (diagnostic_agent_available diag_tool_tracer)
    (exclusive_lock_available lock_main)
    (fixture_available fixture_sandbox)
    (service_has_constraint service_alpha constraint_a1)
    (subsystem_has_constraint subsystem_beta constraint_b1)
    (fix_candidate_available candidate_patch_v1)
    (test_case_available tc_regression_1)
    (test_case_available tc_concurrency_1)
    (module_associated_with_service module_auth service_alpha)
    (module_associated_with_service module_payment service_alpha)
    (module_associated_with_subsystem module_auth subsystem_beta)
    (module_associated_with_subsystem module_payment subsystem_beta)
    (module_has_fix_candidate module_auth candidate_patch_v1)
    (module_has_fix_candidate module_payment candidate_patch_v1)
    (module_has_test_case module_auth tc_regression_1)
    (module_has_test_case module_payment tc_concurrency_1)
    (config_variant_available config_variant_debug)
    (config_variant_available config_variant_release)
    (review_token_available review_token_qa_1)
    (review_token_available review_token_lead_1)
    (trace_log_available trace_log_01)
    (build_artifact_available build_artifact_v1)
    (dependency_available dependency_lib_a)
    (module_has_dependency module_auth dependency_lib_a)
    (module_has_dependency module_payment dependency_lib_b)
    (approval_token_available approval_token_team)
  )
  (:goal
    (and
      (repaired service_alpha)
      (repaired subsystem_beta)
      (repaired module_auth)
      (repaired module_payment)
    )
  )
)
