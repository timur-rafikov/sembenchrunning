    (frame_requires_machine schedule_frame_2 machine_1)
    (frame_requires_human schedule_frame_1 human_1)
    (frame_requires_human schedule_frame_2 human_1)
    (frame_has_assignment_candidate schedule_frame_1 assignment_candidate_1)
    (frame_has_assignment_candidate schedule_frame_2 assignment_candidate_1)
    (frame_has_material_unit schedule_frame_1 material_unit_1)
    (frame_has_material_unit schedule_frame_2 material_unit_2)
    (priority_token_available priority_token_1)
    (priority_token_available priority_token_2)
    (qualification_available qualification_1)
    (qualification_available qualification_2)
    (location_token_available location_marker_1)
    (equipment_available equipment_1)
    (supervisor_available supervisor_token_1)
    (frame_has_supervisor_token schedule_frame_1 supervisor_token_1)
    (frame_has_supervisor_token schedule_frame_2 supervisor_token_2)
    (operation_mode_available operation_mode_1)
  )
  (:goal
    (and
      (scheduled machine_1)
      (scheduled human_1)
      (scheduled schedule_frame_1)
      (scheduled schedule_frame_2)
    )
  )
