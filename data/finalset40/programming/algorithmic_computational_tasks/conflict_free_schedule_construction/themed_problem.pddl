(define (problem conflict_free_schedule_problem)
  (:domain conflict_free_schedule_domain)
  (:objects machine_1 - machine_agent human_1 - human_agent schedule_frame_1 - schedule_frame schedule_frame_2 - schedule_frame resource_pool_1 - resource_pool resource_pool_2 - resource_pool resource_pool_3 - resource_pool time_slot_1 - time_slot workstation_1 - workstation consumable_1 - consumable_item machine_slot_1 - machine_slot human_slot_1 - human_slot assignment_candidate_1 - assignment_candidate material_unit_1 - material_unit material_unit_2 - material_unit priority_token_1 - priority_token priority_token_2 - priority_token qualification_1 - qualification qualification_2 - qualification location_marker_1 - location_marker equipment_1 - equipment supervisor_token_1 - supervisor_token supervisor_token_2 - supervisor_token operation_mode_1 - operation_mode)
  (:init
    (resource_pool_available resource_pool_1)
    (resource_pool_available resource_pool_2)
    (resource_pool_available resource_pool_3)
    (time_slot_available time_slot_1)
    (workstation_available workstation_1)
    (consumable_available consumable_1)
    (machine_has_slot machine_1 machine_slot_1)
    (human_has_slot human_1 human_slot_1)
    (candidate_open assignment_candidate_1)
    (material_unit_available material_unit_1)
    (material_unit_available material_unit_2)
