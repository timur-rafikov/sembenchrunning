(define (problem bipartite_matching_instance)
  (:domain bipartite_matching_under_constraints)
  (:objects proposer_group_a_obj - proposer_group_a proposer_group_b_obj - proposer_group_b target_position_obj1 - target_position target_position_obj2 - target_position partner_token_obj1 - partner_token partner_token_obj2 - partner_token partner_token_obj3 - partner_token proposal_option_obj - proposal_option intermediary_obj - intermediary consumable_resource_obj - consumable_resource resource_dimension_a_obj - resource_dimension_a resource_dimension_b_obj - resource_dimension_b assignment_record_obj - assignment_record constraint_marker_obj1 - constraint_marker constraint_marker_obj2 - constraint_marker static_attribute_a_obj1 - static_attribute_a static_attribute_a_obj2 - static_attribute_a static_attribute_b_obj1 - static_attribute_b static_attribute_b_obj2 - static_attribute_b external_constraint_token_obj - external_constraint_token optional_qualifier_obj - optional_qualifier slot_type_obj1 - slot_type slot_type_obj2 - slot_type priority_flag_obj - priority_flag)
  (:init
    (partner_token_available partner_token_obj1)
    (partner_token_available partner_token_obj2)
    (partner_token_available partner_token_obj3)
    (proposal_option_available proposal_option_obj)
    (intermediary_available intermediary_obj)
    (consumable_resource_available consumable_resource_obj)
    (groupa_resource_dimension_link proposer_group_a_obj resource_dimension_a_obj)
    (groupb_resource_dimension_link proposer_group_b_obj resource_dimension_b_obj)
    (assignment_record_available assignment_record_obj)
    (constraint_marker_available constraint_marker_obj1)
    (constraint_marker_available constraint_marker_obj2)
    (position_associated_with_group_a target_position_obj1 proposer_group_a_obj)
    (position_associated_with_group_a target_position_obj2 proposer_group_a_obj)
    (position_associated_with_group_b target_position_obj1 proposer_group_b_obj)
    (position_associated_with_group_b target_position_obj2 proposer_group_b_obj)
    (position_assignment_record_link target_position_obj1 assignment_record_obj)
    (position_assignment_record_link target_position_obj2 assignment_record_obj)
    (position_constraint_link target_position_obj1 constraint_marker_obj1)
    (position_constraint_link target_position_obj2 constraint_marker_obj2)
    (static_attribute_a_available static_attribute_a_obj1)
    (static_attribute_a_available static_attribute_a_obj2)
    (static_attribute_b_available static_attribute_b_obj1)
    (static_attribute_b_available static_attribute_b_obj2)
    (external_constraint_token_available external_constraint_token_obj)
    (optional_qualifier_available optional_qualifier_obj)
    (slot_type_available slot_type_obj1)
    (position_slot_link target_position_obj1 slot_type_obj1)
    (position_slot_link target_position_obj2 slot_type_obj2)
    (priority_flag_available priority_flag_obj)
  )
  (:goal
    (and
      (match_committed proposer_group_a_obj)
      (match_committed proposer_group_b_obj)
      (match_committed target_position_obj1)
      (match_committed target_position_obj2)
    )
  )
)
