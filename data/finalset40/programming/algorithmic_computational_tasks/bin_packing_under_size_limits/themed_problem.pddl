(define (problem bin_packing_instance)
  (:domain bin_packing_under_size_limits)
  (:objects item_a1 - item_type_a item_b1 - item_type_b packing_plan1 - packing_plan packing_plan2 - packing_plan bin_token1 - bin_token bin_token2 - bin_token bin_token3 - bin_token size_attr1 - size_attribute constraint_tag1 - constraint_tag transient_marker1 - transient_marker bin_feature_a1 - bin_feature_a bin_feature_b1 - bin_feature_b bin_candidate1 - bin_candidate item_unit1 - item_unit item_unit2 - item_unit label_type1 - label_type label_type2 - label_type policy_token1 - policy_token policy_token2 - policy_token final_artifact1 - final_artifact resource1_1 - handler_resource attribute_type1 - attribute_type attribute_type2 - attribute_type resource2_1 - inspector_resource)
  (:init
    (bin_token_available bin_token1)
    (bin_token_available bin_token2)
    (bin_token_available bin_token3)
    (size_attr_available size_attr1)
    (constraint_tag_available constraint_tag1)
    (marker_available transient_marker1)
    (item_a_feature_match item_a1 bin_feature_a1)
    (item_b_feature_match item_b1 bin_feature_b1)
    (bin_candidate_available bin_candidate1)
    (unit_available item_unit1)
    (unit_available item_unit2)
    (plan_has_item_a packing_plan1 item_a1)
    (plan_has_item_a packing_plan2 item_a1)
    (plan_has_item_b packing_plan1 item_b1)
    (plan_has_item_b packing_plan2 item_b1)
    (plan_has_candidate packing_plan1 bin_candidate1)
    (plan_has_candidate packing_plan2 bin_candidate1)
    (plan_has_unit packing_plan1 item_unit1)
    (plan_has_unit packing_plan2 item_unit2)
    (label_available label_type1)
    (label_available label_type2)
    (policy_token_available policy_token1)
    (policy_token_available policy_token2)
    (artifact_available final_artifact1)
    (handler_available resource1_1)
    (attribute_available attribute_type1)
    (plan_has_attribute packing_plan1 attribute_type1)
    (plan_has_attribute packing_plan2 attribute_type2)
    (inspector_available resource2_1)
  )
  (:goal
    (and
      (committed item_a1)
      (committed item_b1)
      (committed packing_plan1)
      (committed packing_plan2)
    )
  )
)
