(define (problem combinatorial_search_instance)
  (:domain combinatorial_generation_with_pruning)
  (:objects left_partition_node_1 - left_partition_node right_partition_node_1 - right_partition_node search_node_1 - search_node search_node_2 - search_node label_a - label_token label_b - label_token label_c - label_token candidate_1 - candidate_value guard_1 - guard_token marker_1 - ephemeral_marker left_index_1 - left_index right_index_1 - right_index partial_solution_1 - partial_solution component_1 - component component_2 - component feature_option_1 - feature_option feature_option_2 - feature_option strategy_option_1 - strategy_option strategy_option_2 - strategy_option finalizer_1 - finalizer_token attribute_type_1 - attribute_type selector_1 - selector selector_2 - selector validator_1 - validator)
  (:init
    (label_token_available label_a)
    (label_token_available label_b)
    (label_token_available label_c)
    (candidate_value_available candidate_1)
    (guard_token_available guard_1)
    (ephemeral_marker_available marker_1)
    (left_node_index_binding left_partition_node_1 left_index_1)
    (right_node_index_binding right_partition_node_1 right_index_1)
    (partial_solution_slot_available partial_solution_1)
    (component_available component_1)
    (component_available component_2)
    (search_node_left_link search_node_1 left_partition_node_1)
    (search_node_left_link search_node_2 left_partition_node_1)
    (search_node_right_link search_node_1 right_partition_node_1)
    (search_node_right_link search_node_2 right_partition_node_1)
    (search_node_partial_solution_link search_node_1 partial_solution_1)
    (search_node_partial_solution_link search_node_2 partial_solution_1)
    (search_node_component_binding search_node_1 component_1)
    (search_node_component_binding search_node_2 component_2)
    (feature_option_available feature_option_1)
    (feature_option_available feature_option_2)
    (strategy_option_available strategy_option_1)
    (strategy_option_available strategy_option_2)
    (finalizer_token_available finalizer_1)
    (attribute_type_available attribute_type_1)
    (selector_available selector_1)
    (search_node_selector_binding search_node_1 selector_1)
    (search_node_selector_binding search_node_2 selector_2)
    (validator_available validator_1)
  )
  (:goal
    (and
      (target_committed left_partition_node_1)
      (target_committed right_partition_node_1)
      (target_committed search_node_1)
      (target_committed search_node_2)
    )
  )
)
