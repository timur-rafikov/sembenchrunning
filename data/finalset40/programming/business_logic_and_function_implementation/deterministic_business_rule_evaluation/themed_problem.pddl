(define (problem case_evaluation_scenario)
  (:domain deterministic_business_rule_evaluation)
  (:objects evaluator_a_1 - evaluator_stage_a evaluator_b_1 - evaluator_stage_b decision_document_1 - decision_document decision_document_2 - decision_document processor_slot_1 - processor_slot processor_slot_2 - processor_slot processor_slot_3 - processor_slot input_signal_1 - input_signal tool_1 - tool attribute_token_1 - attribute_token context_key_a_1 - context_key_a context_key_b_1 - context_key_b outcome_record_1 - outcome_record feature_flag_1 - feature_flag feature_flag_2 - feature_flag option_choice_1 - option_choice option_choice_2 - option_choice adjustment_1 - adjustment adjustment_2 - adjustment correlation_id_1 - correlation_id action_template_1 - action_template label_1 - label label_2 - label strategy_1 - strategy)
  (:init
    (processor_slot_available processor_slot_1)
    (processor_slot_available processor_slot_2)
    (processor_slot_available processor_slot_3)
    (input_signal_available input_signal_1)
    (tool_available tool_1)
    (attribute_token_available attribute_token_1)
    (evaluator_a_has_context evaluator_a_1 context_key_a_1)
    (evaluator_b_has_context evaluator_b_1 context_key_b_1)
    (outcome_record_available outcome_record_1)
    (feature_flag_available feature_flag_1)
    (feature_flag_available feature_flag_2)
    (document_associated_with_evaluator_a decision_document_1 evaluator_a_1)
    (document_associated_with_evaluator_a decision_document_2 evaluator_a_1)
    (document_associated_with_evaluator_b decision_document_1 evaluator_b_1)
    (document_associated_with_evaluator_b decision_document_2 evaluator_b_1)
    (document_has_outcome_record decision_document_1 outcome_record_1)
    (document_has_outcome_record decision_document_2 outcome_record_1)
    (document_has_feature_flag decision_document_1 feature_flag_1)
    (document_has_feature_flag decision_document_2 feature_flag_2)
    (option_choice_available option_choice_1)
    (option_choice_available option_choice_2)
    (adjustment_available adjustment_1)
    (adjustment_available adjustment_2)
    (correlation_id_available correlation_id_1)
    (action_template_available action_template_1)
    (label_available label_1)
    (document_has_label decision_document_1 label_1)
    (document_has_label decision_document_2 label_2)
    (strategy_available strategy_1)
  )
  (:goal
    (and
      (evaluation_unit_finalized evaluator_a_1)
      (evaluation_unit_finalized evaluator_b_1)
      (evaluation_unit_finalized decision_document_1)
      (evaluation_unit_finalized decision_document_2)
    )
  )
)
