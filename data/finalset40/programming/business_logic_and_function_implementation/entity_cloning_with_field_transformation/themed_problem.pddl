(define (problem entity_clone_problem)
  (:domain entity_cloning_domain)
  (:objects source_record_1 - source_record target_record_1 - target_record clone_job_1 - clone_job clone_job_2 - clone_job resource_token_a - resource_token resource_token_b - resource_token resource_token_c - resource_token field_identifier_1 - field_identifier worker_1 - actor_worker attribute_value_1 - attribute_value field_slot_1 - field_slot alt_field_slot_1 - alternate_field_slot artifact_1 - clone_artifact template_fragment_1 - template_fragment template_fragment_2 - template_fragment policy_tag_a - policy_tag policy_tag_b - policy_tag postprocess_config_a - postprocess_config postprocess_config_b - postprocess_config input_parameter_1 - input_parameter variant_option_a - variant_option external_ref_1 - external_reference external_ref_2 - external_reference validation_rule_1 - validation_rule)
  (:init
    (resource_token_available resource_token_a)
    (resource_token_available resource_token_b)
    (resource_token_available resource_token_c)
    (field_identifier_available field_identifier_1)
    (worker_available worker_1)
    (attribute_value_available attribute_value_1)
    (record_slot_bound source_record_1 field_slot_1)
    (record_alt_slot_bound target_record_1 alt_field_slot_1)
    (artifact_uninitialized artifact_1)
    (template_fragment_available template_fragment_1)
    (template_fragment_available template_fragment_2)
    (clone_job_source_link clone_job_1 source_record_1)
    (clone_job_source_link clone_job_2 source_record_1)
    (clone_job_target_link clone_job_1 target_record_1)
    (clone_job_target_link clone_job_2 target_record_1)
    (clone_job_artifact_link clone_job_1 artifact_1)
    (clone_job_artifact_link clone_job_2 artifact_1)
    (clone_job_fragment_link clone_job_1 template_fragment_1)
    (clone_job_fragment_link clone_job_2 template_fragment_2)
    (policy_tag_available policy_tag_a)
    (policy_tag_available policy_tag_b)
    (postprocess_config_available postprocess_config_a)
    (postprocess_config_available postprocess_config_b)
    (input_parameter_available input_parameter_1)
    (variant_option_available variant_option_a)
    (external_reference_available external_ref_1)
    (clone_job_external_reference_link clone_job_1 external_ref_1)
    (clone_job_external_reference_link clone_job_2 external_ref_2)
    (validation_rule_available validation_rule_1)
  )
  (:goal
    (and
      (entity_committed source_record_1)
      (entity_committed target_record_1)
      (entity_committed clone_job_1)
      (entity_committed clone_job_2)
    )
  )
)
