(define (problem attraction_closure_substitution_problem)
  (:domain tourism_attraction_closure_substitution)
  (:objects scheduled_attraction_1 - scheduled_attraction scheduled_addon_1 - scheduled_addon support_case_1 - support_case support_case_2 - support_case substitute_option_1 - substitute_option substitute_option_2 - substitute_option substitute_option_3 - substitute_option availability_check_1 - availability_check supplier_contact_1 - supplier_contact remediation_offer_1 - remediation_offer closure_notice_1 - closure_notice customer_preference_1 - customer_preference replacement_booking_slot_1 - replacement_booking ancillary_item_1 - ancillary_item ancillary_item_2 - ancillary_item escalation_tag_1 - escalation_tag escalation_tag_2 - escalation_tag compensation_package_1 - compensation_package compensation_package_2 - compensation_package refund_instrument_1 - refund_instrument logistics_resource_1 - logistics_resource partner_approval_1 - partner_approval partner_approval_2 - partner_approval manager_approval_1 - manager_approval)
  (:init
    (substitute_available substitute_option_1)
    (substitute_available substitute_option_2)
    (substitute_available substitute_option_3)
    (availability_check_pending availability_check_1)
    (supplier_contact_available supplier_contact_1)
    (remediation_offer_available remediation_offer_1)
    (closure_notice_for_attraction scheduled_attraction_1 closure_notice_1)
    (addon_preference_link scheduled_addon_1 customer_preference_1)
    (replacement_booking_draft replacement_booking_slot_1)
    (ancillary_item_available ancillary_item_1)
    (ancillary_item_available ancillary_item_2)
    (case_involves_attraction support_case_1 scheduled_attraction_1)
    (case_involves_attraction support_case_2 scheduled_attraction_1)
    (case_involves_addon support_case_1 scheduled_addon_1)
    (case_involves_addon support_case_2 scheduled_addon_1)
    (case_links_booking support_case_1 replacement_booking_slot_1)
    (case_links_booking support_case_2 replacement_booking_slot_1)
    (case_has_ancillary support_case_1 ancillary_item_1)
    (case_has_ancillary support_case_2 ancillary_item_2)
    (escalation_tag_available escalation_tag_1)
    (escalation_tag_available escalation_tag_2)
    (compensation_package_available compensation_package_1)
    (compensation_package_available compensation_package_2)
    (refund_instrument_available refund_instrument_1)
    (logistics_resource_available logistics_resource_1)
    (partner_approval_available partner_approval_1)
    (case_has_partner_approval support_case_1 partner_approval_1)
    (case_has_partner_approval support_case_2 partner_approval_2)
    (manager_approval_available manager_approval_1)
  )
  (:goal
    (and
      (itinerary_element_resolved scheduled_attraction_1)
      (itinerary_element_resolved scheduled_addon_1)
      (itinerary_element_resolved support_case_1)
      (itinerary_element_resolved support_case_2)
    )
  )
)
