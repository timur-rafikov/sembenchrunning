(define (problem itinerary_fallback_scenario)
  (:domain late_arrival_fallback_preparation)
  (:objects arriving_leg_1 - arriving_leg departing_leg_1 - departing_leg coordinator_alpha - coordination_agent coordinator_beta - coordination_agent vehicle_candidate_1 - transport_asset_candidate vehicle_candidate_2 - transport_asset_candidate vehicle_candidate_3 - transport_asset_candidate schedule_slot_1 - schedule_slot local_agent_1 - local_agent local_mode_option_1 - local_mode_option arrival_node_1 - arrival_node departure_node_1 - departure_node assignment_record_1 - vehicle_assignment_record asset_token_1 - asset_token asset_token_2 - asset_token vehicle_feature_1 - vehicle_feature vehicle_feature_2 - vehicle_feature passenger_preference_1 - passenger_preference passenger_preference_2 - passenger_preference fallback_mode_taxi - fallback_mode onboard_equipment_1 - onboard_equipment contract_option_1 - contractual_option contract_option_2 - contractual_option authorization_token_1 - authorization_token)
  (:init
    (asset_candidate_available vehicle_candidate_1)
    (asset_candidate_available vehicle_candidate_2)
    (asset_candidate_available vehicle_candidate_3)
    (schedule_slot_available schedule_slot_1)
    (local_agent_available local_agent_1)
    (local_mode_option_available local_mode_option_1)
    (arriving_leg_arrival_node_link arriving_leg_1 arrival_node_1)
    (departing_leg_departure_node_link departing_leg_1 departure_node_1)
    (assignment_record_available assignment_record_1)
    (asset_token_available asset_token_1)
    (asset_token_available asset_token_2)
    (coordinator_arriving_leg_link coordinator_alpha arriving_leg_1)
    (coordinator_arriving_leg_link coordinator_beta arriving_leg_1)
    (coordinator_departing_leg_link coordinator_alpha departing_leg_1)
    (coordinator_departing_leg_link coordinator_beta departing_leg_1)
    (coordinator_assignment_link coordinator_alpha assignment_record_1)
    (coordinator_assignment_link coordinator_beta assignment_record_1)
    (coordinator_asset_token_link coordinator_alpha asset_token_1)
    (coordinator_asset_token_link coordinator_beta asset_token_2)
    (vehicle_feature_available vehicle_feature_1)
    (vehicle_feature_available vehicle_feature_2)
    (passenger_preference_available passenger_preference_1)
    (passenger_preference_available passenger_preference_2)
    (fallback_mode_available fallback_mode_taxi)
    (onboard_equipment_available onboard_equipment_1)
    (contract_option_available contract_option_1)
    (coordinator_contract_option_link coordinator_alpha contract_option_1)
    (coordinator_contract_option_link coordinator_beta contract_option_2)
    (authorization_token_available authorization_token_1)
  )
  (:goal
    (and
      (assignment_committed arriving_leg_1)
      (assignment_committed departing_leg_1)
      (assignment_committed coordinator_alpha)
      (assignment_committed coordinator_beta)
    )
  )
)
