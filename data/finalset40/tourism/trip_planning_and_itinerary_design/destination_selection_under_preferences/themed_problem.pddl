(define (problem destination_selection_preferences_problem)
  (:domain destination_selection_planning_domain)
  (:objects primary_day_segment_obj - primary_day_segment_type secondary_day_segment_obj - secondary_day_segment_type itinerary_variant_alpha_obj - itinerary_variant_type itinerary_variant_beta_obj - itinerary_variant_type coach_transfer_obj - transport_option_type rail_connection_obj - transport_option_type private_transfer_obj - transport_option_type museum_visit_obj - activity_option_type boutique_hotel_obj - accommodation_option_type guided_excursion_addon_obj - auxiliary_addon_type airport_arrival_slot_obj - access_option_type local_shuttle_obj - local_access_option_type destination_proposal_obj - destination_proposal_type activity_bundle_alpha_obj - activity_bundle_type activity_bundle_beta_obj - activity_bundle_type culture_theme_obj - itinerary_theme_type coastal_theme_obj - itinerary_theme_type adventure_traveler_profile_obj - traveler_profile_type budget_conscious_traveler_profile_obj - traveler_profile_type budget_constraint_obj - trip_constraint_type guided_service_addon_obj - service_addon_type early_booking_promotion_obj - promotion_option_type package_discount_promotion_obj - promotion_option_type morning_time_window_obj - time_window_type)
  (:init
    (transport_available_state coach_transfer_obj)
    (transport_available_state rail_connection_obj)
    (transport_available_state private_transfer_obj)
    (activity_available_state museum_visit_obj)
    (accommodation_available_state boutique_hotel_obj)
    (addon_available_state guided_excursion_addon_obj)
    (primary_access_link primary_day_segment_obj airport_arrival_slot_obj)
    (secondary_local_access_link secondary_day_segment_obj local_shuttle_obj)
    (proposal_draft_state destination_proposal_obj)
    (activity_bundle_available_state activity_bundle_alpha_obj)
    (activity_bundle_available_state activity_bundle_beta_obj)
    (variant_primary_segment_link itinerary_variant_alpha_obj primary_day_segment_obj)
    (variant_primary_segment_link itinerary_variant_beta_obj primary_day_segment_obj)
    (variant_secondary_segment_link itinerary_variant_alpha_obj secondary_day_segment_obj)
    (variant_secondary_segment_link itinerary_variant_beta_obj secondary_day_segment_obj)
    (variant_proposal_link itinerary_variant_alpha_obj destination_proposal_obj)
    (variant_proposal_link itinerary_variant_beta_obj destination_proposal_obj)
    (variant_bundle_link itinerary_variant_alpha_obj activity_bundle_alpha_obj)
    (variant_bundle_link itinerary_variant_beta_obj activity_bundle_beta_obj)
    (theme_available_state culture_theme_obj)
    (theme_available_state coastal_theme_obj)
    (traveler_profile_available_state adventure_traveler_profile_obj)
    (traveler_profile_available_state budget_conscious_traveler_profile_obj)
    (trip_constraint_available_state budget_constraint_obj)
    (service_addon_available_state guided_service_addon_obj)
    (promotion_available_state early_booking_promotion_obj)
    (variant_promotion_link itinerary_variant_alpha_obj early_booking_promotion_obj)
    (variant_promotion_link itinerary_variant_beta_obj package_discount_promotion_obj)
    (time_window_available_state morning_time_window_obj)
  )
  (:goal
    (and
      (planning_entity_finalized_state primary_day_segment_obj)
      (planning_entity_finalized_state secondary_day_segment_obj)
      (planning_entity_finalized_state itinerary_variant_alpha_obj)
      (planning_entity_finalized_state itinerary_variant_beta_obj)
    )
  )
)
