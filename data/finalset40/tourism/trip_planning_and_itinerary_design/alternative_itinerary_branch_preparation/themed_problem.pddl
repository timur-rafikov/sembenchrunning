(define (problem example_trip_alternative_branch)
  (:domain alternative_itinerary_branch_preparation)
  (:objects day_slot_primary_1 - day_slot_primary day_slot_secondary_1 - day_slot_secondary segment_proposal_1 - segment_proposal segment_proposal_2 - segment_proposal transport_option_train_1 - transport_option transport_option_bus_1 - transport_option transport_option_ferry_1 - transport_option activity_template_morning_walk - activity_template service_provider_local_guide - service_provider activity_option_museum_tour - activity_option location_context_primary_city_center - location_context_primary location_context_secondary_central_hub - location_context_secondary proposal_bundle_1 - proposal_bundle venue_feature_history_museum - venue_feature venue_feature_city_park - venue_feature attraction_category_cultural - attraction_category attraction_category_nature - attraction_category logistics_option_meal_plan - logistics_option logistics_option_accommodation - logistics_option traveler_resource_profile_slot - traveler_resource amenity_wifi - amenity promotion_summer_discount - promotion promotion_partner_offer - promotion availability_constraint_morning_window - availability_constraint)
  (:init
    (transport_option_available transport_option_train_1)
    (transport_option_available transport_option_bus_1)
    (transport_option_available transport_option_ferry_1)
    (activity_template_available activity_template_morning_walk)
    (service_provider_available service_provider_local_guide)
    (activity_option_available activity_option_museum_tour)
    (day_slot_primary_has_location_context_primary day_slot_primary_1 location_context_primary_city_center)
    (day_slot_secondary_has_location_context_secondary day_slot_secondary_1 location_context_secondary_central_hub)
    (proposal_bundle_available proposal_bundle_1)
    (venue_feature_available venue_feature_history_museum)
    (venue_feature_available venue_feature_city_park)
    (segment_proposal_has_day_slot_primary segment_proposal_1 day_slot_primary_1)
    (segment_proposal_has_day_slot_primary segment_proposal_2 day_slot_primary_1)
    (segment_proposal_has_day_slot_secondary segment_proposal_1 day_slot_secondary_1)
    (segment_proposal_has_day_slot_secondary segment_proposal_2 day_slot_secondary_1)
    (segment_proposal_in_proposal_bundle segment_proposal_1 proposal_bundle_1)
    (segment_proposal_in_proposal_bundle segment_proposal_2 proposal_bundle_1)
    (segment_proposal_has_venue_feature segment_proposal_1 venue_feature_history_museum)
    (segment_proposal_has_venue_feature segment_proposal_2 venue_feature_city_park)
    (attraction_category_available attraction_category_cultural)
    (attraction_category_available attraction_category_nature)
    (logistics_option_available logistics_option_meal_plan)
    (logistics_option_available logistics_option_accommodation)
    (traveler_resource_available traveler_resource_profile_slot)
    (amenity_available amenity_wifi)
    (promotion_available promotion_summer_discount)
    (segment_assigned_promotion segment_proposal_1 promotion_summer_discount)
    (segment_assigned_promotion segment_proposal_2 promotion_partner_offer)
    (availability_constraint_available availability_constraint_morning_window)
  )
  (:goal
    (and
      (itinerary_element_finalized day_slot_primary_1)
      (itinerary_element_finalized day_slot_secondary_1)
      (itinerary_element_finalized segment_proposal_1)
      (itinerary_element_finalized segment_proposal_2)
    )
  )
)
