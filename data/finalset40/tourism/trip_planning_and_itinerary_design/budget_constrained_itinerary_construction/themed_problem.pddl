(define (problem budget_constrained_itinerary_problem)
  (:domain budget_constrained_itinerary_domain)
  (:objects day_slot_primary_1 - primary_day_slot day_slot_secondary_1 - secondary_day_slot itinerary_instance_a - itinerary_instance itinerary_instance_b - itinerary_instance transport_option_1 - transport_option transport_option_2 - transport_option transport_option_3 - transport_option sightseeing_tour_activity - activity venue_museum - venue_supplier general_admission_ticket - consumable_ticket morning_time_window - time_window_a afternoon_time_window - time_window_b daily_booking_candidate_1 - booking_candidate hotel_option_a - accommodation_option hotel_option_b - accommodation_option promo_offer_earlybird - promotional_offer promo_offer_weekend - promotional_offer ancillary_service_guide - ancillary_service ancillary_service_equipment_rental - ancillary_service budget_token_1 - budget_token supplier_service_variant_standard_room - supplier_service_variant preference_token_1 - preference_token preference_token_2 - preference_token accessibility_requirement - special_requirement_token)
  (:init
    (transport_available transport_option_1)
    (transport_available transport_option_2)
    (transport_available transport_option_3)
    (activity_available sightseeing_tour_activity)
    (venue_available venue_museum)
    (ticket_available general_admission_ticket)
    (primary_day_slot_time_window_a_assigned day_slot_primary_1 morning_time_window)
    (secondary_day_slot_time_window_b_assigned day_slot_secondary_1 afternoon_time_window)
    (booking_candidate_available daily_booking_candidate_1)
    (accommodation_available hotel_option_a)
    (accommodation_available hotel_option_b)
    (itinerary_primary_day_slot_association itinerary_instance_a day_slot_primary_1)
    (itinerary_primary_day_slot_association itinerary_instance_b day_slot_primary_1)
    (itinerary_secondary_day_slot_association itinerary_instance_a day_slot_secondary_1)
    (itinerary_secondary_day_slot_association itinerary_instance_b day_slot_secondary_1)
    (itinerary_has_booking_candidate itinerary_instance_a daily_booking_candidate_1)
    (itinerary_has_booking_candidate itinerary_instance_b daily_booking_candidate_1)
    (itinerary_has_accommodation_option itinerary_instance_a hotel_option_a)
    (itinerary_has_accommodation_option itinerary_instance_b hotel_option_b)
    (promotional_offer_available promo_offer_earlybird)
    (promotional_offer_available promo_offer_weekend)
    (ancillary_service_available ancillary_service_guide)
    (ancillary_service_available ancillary_service_equipment_rental)
    (budget_token_available budget_token_1)
    (supplier_service_variant_available supplier_service_variant_standard_room)
    (preference_available preference_token_1)
    (itinerary_preference_assignment itinerary_instance_a preference_token_1)
    (itinerary_preference_assignment itinerary_instance_b preference_token_2)
    (special_requirement_token_available accessibility_requirement)
  )
  (:goal
    (and
      (budget_allocated day_slot_primary_1)
      (budget_allocated day_slot_secondary_1)
      (budget_allocated itinerary_instance_a)
      (budget_allocated itinerary_instance_b)
    )
  )
)
