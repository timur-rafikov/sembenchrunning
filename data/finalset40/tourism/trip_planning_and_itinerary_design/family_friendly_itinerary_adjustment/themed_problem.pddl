(define (problem family_trip_itinerary_problem)
  (:domain family_friendly_itinerary_adjustment)
  (:objects day1_slot_type_a - day_slot_type_a day2_slot_type_b - day_slot_type_b participant_profile_1 - travel_participant_profile participant_profile_2 - travel_participant_profile destination_beach - destination_option destination_museum - destination_option destination_amusement_park - destination_option activity_museum_tour - activity_candidate service_slot_time_window_1 - service_slot aux_service_childcare - auxiliary_service_option segment_morning - day_segment_variant_a segment_afternoon - day_segment_variant_b scheduled_instance_1 - scheduled_instance attraction_variant_short_tour - attraction_variant attraction_variant_full_tour - attraction_variant accessibility_wheelchair - accessibility_tag accessibility_stroller_friendly - accessibility_tag preference_low_exertion - family_preference_tag preference_short_transit - family_preference_tag constraint_time_token_1 - constraint_token amenity_meal_package - amenity_option preexisting_booking_hotel - preexisting_booking_tag preexisting_booking_museum_ticket - preexisting_booking_tag age_tag_child - seasonal_or_age_tag)
  (:init
    (destination_option_available destination_beach)
    (destination_option_available destination_museum)
    (destination_option_available destination_amusement_park)
    (activity_candidate_available activity_museum_tour)
    (service_slot_available service_slot_time_window_1)
    (auxiliary_service_option_available aux_service_childcare)
    (day_slot_a_segment_variant_link day1_slot_type_a segment_morning)
    (day_slot_b_segment_variant_link day2_slot_type_b segment_afternoon)
    (scheduled_instance_available scheduled_instance_1)
    (attraction_variant_available attraction_variant_short_tour)
    (attraction_variant_available attraction_variant_full_tour)
    (participant_assigned_to_day_slot_a participant_profile_1 day1_slot_type_a)
    (participant_assigned_to_day_slot_a participant_profile_2 day1_slot_type_a)
    (participant_assigned_to_day_slot_b participant_profile_1 day2_slot_type_b)
    (participant_assigned_to_day_slot_b participant_profile_2 day2_slot_type_b)
    (participant_assigned_to_scheduled_instance participant_profile_1 scheduled_instance_1)
    (participant_assigned_to_scheduled_instance participant_profile_2 scheduled_instance_1)
    (profile_has_attraction_variant_option participant_profile_1 attraction_variant_short_tour)
    (profile_has_attraction_variant_option participant_profile_2 attraction_variant_full_tour)
    (accessibility_tag_available accessibility_wheelchair)
    (accessibility_tag_available accessibility_stroller_friendly)
    (family_preference_tag_available preference_low_exertion)
    (family_preference_tag_available preference_short_transit)
    (constraint_token_available constraint_time_token_1)
    (amenity_option_available amenity_meal_package)
    (preexisting_booking_tag_available preexisting_booking_hotel)
    (profile_has_preexisting_booking participant_profile_1 preexisting_booking_hotel)
    (profile_has_preexisting_booking participant_profile_2 preexisting_booking_museum_ticket)
    (seasonal_or_age_tag_available age_tag_child)
  )
  (:goal
    (and
      (itinerary_destination_confirmed day1_slot_type_a)
      (itinerary_destination_confirmed day2_slot_type_b)
      (itinerary_destination_confirmed participant_profile_1)
      (itinerary_destination_confirmed participant_profile_2)
    )
  )
)
