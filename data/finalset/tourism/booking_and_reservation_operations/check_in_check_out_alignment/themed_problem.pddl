(define (problem check_in_check_out_alignment_problem)
  (:domain tourism_booking_check_in_check_out)
  (:objects hotel_segment_1 - hotel_segment transport_segment_1 - transport_segment consolidated_itinerary_1 - consolidated_itinerary consolidated_itinerary_2 - consolidated_itinerary service_offer_1 - service_offer service_offer_2 - service_offer service_offer_3 - service_offer traveler_profile_1 - traveler_profile agent_1 - agent addon_service_1 - addon_service room_option_1 - room_option seat_option_1 - seat_option confirmation_document_template_1 - confirmation_document attachment_bundle_1 - attachment_bundle attachment_bundle_2 - attachment_bundle rate_plan_1 - rate_plan rate_plan_2 - rate_plan payment_instrument_1 - payment_instrument payment_instrument_2 - payment_instrument check_in_token_1 - check_in_token room_preference_1 - room_preference loyalty_program_1 - loyalty_program loyalty_program_2 - loyalty_program access_credential_1 - access_credential)
  (:init
    (service_offer_available service_offer_1)
    (service_offer_available service_offer_2)
    (service_offer_available service_offer_3)
    (traveler_profile_available traveler_profile_1)
    (agent_available agent_1)
    (addon_available addon_service_1)
    (hotel_segment_room_option hotel_segment_1 room_option_1)
    (transport_segment_seat_option transport_segment_1 seat_option_1)
    (confirmation_document_available confirmation_document_template_1)
    (attachment_bundle_available attachment_bundle_1)
    (attachment_bundle_available attachment_bundle_2)
    (itinerary_includes_hotel_segment consolidated_itinerary_1 hotel_segment_1)
    (itinerary_includes_hotel_segment consolidated_itinerary_2 hotel_segment_1)
    (itinerary_includes_transport_segment consolidated_itinerary_1 transport_segment_1)
    (itinerary_includes_transport_segment consolidated_itinerary_2 transport_segment_1)
    (itinerary_has_confirmation_document consolidated_itinerary_1 confirmation_document_template_1)
    (itinerary_has_confirmation_document consolidated_itinerary_2 confirmation_document_template_1)
    (itinerary_has_attachment_bundle consolidated_itinerary_1 attachment_bundle_1)
    (itinerary_has_attachment_bundle consolidated_itinerary_2 attachment_bundle_2)
    (rate_plan_available rate_plan_1)
    (rate_plan_available rate_plan_2)
    (payment_instrument_available payment_instrument_1)
    (payment_instrument_available payment_instrument_2)
    (check_in_token_available check_in_token_1)
    (room_preference_available room_preference_1)
    (loyalty_program_available loyalty_program_1)
    (itinerary_has_loyalty_program consolidated_itinerary_1 loyalty_program_1)
    (itinerary_has_loyalty_program consolidated_itinerary_2 loyalty_program_2)
    (access_credential_available access_credential_1)
  )
  (:goal
    (and
      (reservation_finalized hotel_segment_1)
      (reservation_finalized transport_segment_1)
      (reservation_finalized consolidated_itinerary_1)
      (reservation_finalized consolidated_itinerary_2)
    )
  )
)
