    (consolidation_session_record_external_reference_binding consolidation_session_record_2 external_reference_2)
    (verification_token_available verification_token_1)
  )
  (:goal
    (and
      (record_finalized primary_reservation_1)
      (record_finalized secondary_reservation_1)
      (record_finalized consolidation_session_record_1)
      (record_finalized consolidation_session_record_2)
