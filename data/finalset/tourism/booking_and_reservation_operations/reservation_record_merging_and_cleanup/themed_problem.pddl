    (supporting_document_unassigned supporting_document_1)
    (supporting_document_unassigned supporting_document_2)
    (consolidation_session_record_primary_binding consolidation_session_record_1 primary_reservation_1)
    (consolidation_session_record_primary_binding consolidation_session_record_2 primary_reservation_1)
    (consolidation_session_record_secondary_binding consolidation_session_record_1 secondary_reservation_1)
    (consolidation_session_record_secondary_binding consolidation_session_record_2 secondary_reservation_1)
    (consolidation_session_record_proposal_binding consolidation_session_record_1 merge_proposal_1)
    (consolidation_session_record_proposal_binding consolidation_session_record_2 merge_proposal_1)
    (consolidation_session_record_document_attachment consolidation_session_record_1 supporting_document_1)
    (consolidation_session_record_document_attachment consolidation_session_record_2 supporting_document_2)
    (feature_profile_available feature_profile_1)
    (feature_profile_available feature_profile_2)
    (consolidation_policy_available consolidation_policy_1)
    (consolidation_policy_available consolidation_policy_2)
    (audit_record_available audit_record_1)
    (payment_authorization_available payment_authorization_1)
    (external_reference_available external_reference_1)
