(define (problem split_stay_booking_scenario)
  (:domain tourism_split_stay_reservation_coordination)
  (:objects stay_segment_a_1 - stay_segment_a stay_segment_b_1 - stay_segment_b master_booking_1 - master_booking master_booking_2 - master_booking supplier_offer_alpha - supplier_offer supplier_offer_beta - supplier_offer supplier_offer_gamma - supplier_offer rate_option_standard - rate_option booking_channel_api - booking_channel breakfast_service - ancillary_service confirmation_token_a1 - confirmation_a confirmation_token_b1 - confirmation_b supplier_booking_record_1 - supplier_booking_record payment_voucher_1 - payment_voucher payment_voucher_2 - payment_voucher rate_plan_standard - rate_plan rate_plan_promo - rate_plan occupancy_profile_double - occupancy_profile occupancy_profile_single - occupancy_profile payment_method_card - payment_method supplementary_service_breakfast - supplementary_service_type special_request_accessibility - special_request special_request_late_arrival - special_request promotion_code_spring - promotion_code)
  (:init
    (supplier_offer_available supplier_offer_alpha)
    (supplier_offer_available supplier_offer_beta)
    (supplier_offer_available supplier_offer_gamma)
    (rate_option_available rate_option_standard)
    (booking_channel_available booking_channel_api)
    (ancillary_available breakfast_service)
    (segment_a_confirmation_link stay_segment_a_1 confirmation_token_a1)
    (segment_b_confirmation_link stay_segment_b_1 confirmation_token_b1)
    (supplier_booking_slot_available supplier_booking_record_1)
    (payment_voucher_available payment_voucher_1)
    (payment_voucher_available payment_voucher_2)
    (master_booking_includes_segment_a master_booking_1 stay_segment_a_1)
    (master_booking_includes_segment_a master_booking_2 stay_segment_a_1)
    (master_booking_includes_segment_b master_booking_1 stay_segment_b_1)
    (master_booking_includes_segment_b master_booking_2 stay_segment_b_1)
    (master_booking_includes_supplier_booking master_booking_1 supplier_booking_record_1)
    (master_booking_includes_supplier_booking master_booking_2 supplier_booking_record_1)
    (master_booking_has_payment_voucher master_booking_1 payment_voucher_1)
    (master_booking_has_payment_voucher master_booking_2 payment_voucher_2)
    (rate_plan_available rate_plan_standard)
    (rate_plan_available rate_plan_promo)
    (occupancy_profile_available occupancy_profile_double)
    (occupancy_profile_available occupancy_profile_single)
    (payment_method_available payment_method_card)
    (supplementary_service_type_available supplementary_service_breakfast)
    (special_request_available special_request_accessibility)
    (master_booking_has_special_request master_booking_1 special_request_accessibility)
    (master_booking_has_special_request master_booking_2 special_request_late_arrival)
    (promotion_code_available promotion_code_spring)
  )
  (:goal
    (and
      (booking_confirmed_with_supplier stay_segment_a_1)
      (booking_confirmed_with_supplier stay_segment_b_1)
      (booking_confirmed_with_supplier master_booking_1)
      (booking_confirmed_with_supplier master_booking_2)
    )
  )
)
