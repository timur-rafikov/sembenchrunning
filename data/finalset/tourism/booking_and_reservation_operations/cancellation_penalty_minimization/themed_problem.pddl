(define (problem minimize_cancellation_penalties_problem)
  (:domain cancellation_penalty_minimization_domain)
  (:objects primary_segment_1 - primary_segment secondary_segment_1 - secondary_segment booking_operator_1 - booking_operator booking_operator_2 - booking_operator service_offer_1 - service_offer service_offer_2 - service_offer service_offer_3 - service_offer selection_detail_1 - selection_detail provider_resource_1 - provider_resource penalty_waiver_1 - penalty_waiver_option segment_cancellation_rule_1 - segment_cancellation_rule counterparty_cancellation_rule_1 - counterparty_cancellation_rule itinerary_record_1 - itinerary_record fulfillment_document_1 - fulfillment_document fulfillment_document_2 - fulfillment_document optional_service_1 - optional_service optional_service_2 - optional_service confirmation_option_1 - confirmation_option confirmation_option_2 - confirmation_option refund_method_1 - refund_method billing_profile_1 - billing_profile approval_token_1 - approval_token approval_token_2 - approval_token external_authorization_1 - external_authorization)
  (:init
    (service_offer_available service_offer_1)
    (service_offer_available service_offer_2)
    (service_offer_available service_offer_3)
    (selection_detail_available selection_detail_1)
    (provider_resource_available provider_resource_1)
    (penalty_waiver_available penalty_waiver_1)
    (primary_segment_has_cancellation_rule primary_segment_1 segment_cancellation_rule_1)
    (secondary_segment_has_counterparty_rule secondary_segment_1 counterparty_cancellation_rule_1)
    (itinerary_record_slot_available itinerary_record_1)
    (fulfillment_document_available fulfillment_document_1)
    (fulfillment_document_available fulfillment_document_2)
    (operator_assigned_primary_segment booking_operator_1 primary_segment_1)
    (operator_assigned_primary_segment booking_operator_2 primary_segment_1)
    (operator_assigned_secondary_segment booking_operator_1 secondary_segment_1)
    (operator_assigned_secondary_segment booking_operator_2 secondary_segment_1)
    (operator_assigned_itinerary booking_operator_1 itinerary_record_1)
    (operator_assigned_itinerary booking_operator_2 itinerary_record_1)
    (operator_has_fulfillment_document booking_operator_1 fulfillment_document_1)
    (operator_has_fulfillment_document booking_operator_2 fulfillment_document_2)
    (optional_service_available optional_service_1)
    (optional_service_available optional_service_2)
    (confirmation_option_available confirmation_option_1)
    (confirmation_option_available confirmation_option_2)
    (refund_method_available refund_method_1)
    (billing_profile_available billing_profile_1)
    (approval_token_available approval_token_1)
    (operator_has_approval_token booking_operator_1 approval_token_1)
    (operator_has_approval_token booking_operator_2 approval_token_2)
    (external_authorization_available external_authorization_1)
  )
  (:goal
    (and
      (booking_entity_committed primary_segment_1)
      (booking_entity_committed secondary_segment_1)
      (booking_entity_committed booking_operator_1)
      (booking_entity_committed booking_operator_2)
    )
  )
)
