(define (problem overbooking_rerouting_problem)
  (:domain overbooking_rerouting_domain)
  (:objects original_primary_booking - primary_booking linked_booking_record - linked_booking rebooking_case_1 - reservation_case rebooking_case_2 - reservation_case transport_option_1 - transport_option transport_option_2 - transport_option transport_option_3 - transport_option confirmation_method_api - confirmation_method agent_representative_1 - agent_resource compensation_voucher_1 - compensation_voucher alternative_segment_1 - alternative_segment carrier_option_1 - carrier_option reroute_proposal_1 - reroute_proposal inventory_slot_1 - inventory_slot inventory_slot_2 - inventory_slot priority_benefit_1 - priority_benefit priority_benefit_2 - priority_benefit compensation_package_1 - compensation_package compensation_package_2 - compensation_package customer_contact_token_1 - customer_contact_token fare_quote_1 - fare_quote loyalty_preference_1 - loyalty_preference loyalty_preference_2 - loyalty_preference manual_override_1 - manual_override)
  (:init
    (transport_option_available transport_option_1)
    (transport_option_available transport_option_2)
    (transport_option_available transport_option_3)
    (confirmation_method_available confirmation_method_api)
    (agent_available agent_representative_1)
    (voucher_available compensation_voucher_1)
    (booking_alternative_segment original_primary_booking alternative_segment_1)
    (linked_booking_carrier_option linked_booking_record carrier_option_1)
    (proposal_available reroute_proposal_1)
    (inventory_slot_available inventory_slot_1)
    (inventory_slot_available inventory_slot_2)
    (case_includes_primary_booking rebooking_case_1 original_primary_booking)
    (case_includes_primary_booking rebooking_case_2 original_primary_booking)
    (case_includes_linked_booking rebooking_case_1 linked_booking_record)
    (case_includes_linked_booking rebooking_case_2 linked_booking_record)
    (case_links_proposal rebooking_case_1 reroute_proposal_1)
    (case_links_proposal rebooking_case_2 reroute_proposal_1)
    (case_inventory_reference rebooking_case_1 inventory_slot_1)
    (case_inventory_reference rebooking_case_2 inventory_slot_2)
    (priority_benefit_available priority_benefit_1)
    (priority_benefit_available priority_benefit_2)
    (compensation_package_available compensation_package_1)
    (compensation_package_available compensation_package_2)
    (customer_contact_token_available customer_contact_token_1)
    (fare_quote_available fare_quote_1)
    (loyalty_preference_available loyalty_preference_1)
    (case_loyalty_preference_link rebooking_case_1 loyalty_preference_1)
    (case_loyalty_preference_link rebooking_case_2 loyalty_preference_2)
    (manual_override_available manual_override_1)
  )
  (:goal
    (and
      (reservation_finalized original_primary_booking)
      (reservation_finalized linked_booking_record)
      (reservation_finalized rebooking_case_1)
      (reservation_finalized rebooking_case_2)
    )
  )
)
