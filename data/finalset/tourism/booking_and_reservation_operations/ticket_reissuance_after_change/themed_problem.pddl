(define (problem ticket_reissuance_after_change_scenario)
  (:domain ticket_reissuance_after_change_domain)
  (:objects orig_itinerary_1 - original_itinerary changed_itinerary_1 - changed_itinerary airline_record_supplier_a - airline_record airline_record_supplier_b - airline_record ticket_stock_a - ticket_stock ticket_stock_b - ticket_stock ticket_stock_c - ticket_stock fare_quote_1 - fare_quote service_agent_1 - service_agent payment_instrument_1 - payment_instrument original_fare_component_1 - original_fare_component new_fare_component_1 - new_fare_component ticket_document_1 - ticket_document ticket_coupon_1 - ticket_coupon ticket_coupon_2 - ticket_coupon authorization_code_1 - authorization_code authorization_code_2 - authorization_code ancillary_service_1 - ancillary_service ancillary_service_2 - ancillary_service exchange_receipt_1 - exchange_receipt payment_transaction_1 - payment_transaction supervisor_approval_1 - supervisor_approval supervisor_approval_2 - supervisor_approval ticketing_office_1 - ticketing_office)
  (:init
    (ticket_stock_available ticket_stock_a)
    (ticket_stock_available ticket_stock_b)
    (ticket_stock_available ticket_stock_c)
    (fare_quote_available fare_quote_1)
    (service_agent_available service_agent_1)
    (payment_instrument_available payment_instrument_1)
    (itinerary_has_original_fare_component orig_itinerary_1 original_fare_component_1)
    (changed_itinerary_has_new_fare_component changed_itinerary_1 new_fare_component_1)
    (ticket_document_available ticket_document_1)
    (ticket_coupon_available ticket_coupon_1)
    (ticket_coupon_available ticket_coupon_2)
    (airline_record_for_itinerary airline_record_supplier_a orig_itinerary_1)
    (airline_record_for_itinerary airline_record_supplier_b orig_itinerary_1)
    (airline_record_for_changed_itinerary airline_record_supplier_a changed_itinerary_1)
    (airline_record_for_changed_itinerary airline_record_supplier_b changed_itinerary_1)
    (airline_record_associated_ticket_document airline_record_supplier_a ticket_document_1)
    (airline_record_associated_ticket_document airline_record_supplier_b ticket_document_1)
    (airline_record_has_coupon airline_record_supplier_a ticket_coupon_1)
    (airline_record_has_coupon airline_record_supplier_b ticket_coupon_2)
    (authorization_code_available authorization_code_1)
    (authorization_code_available authorization_code_2)
    (ancillary_service_available ancillary_service_1)
    (ancillary_service_available ancillary_service_2)
    (exchange_receipt_available exchange_receipt_1)
    (payment_transaction_available payment_transaction_1)
    (supervisor_approval_available supervisor_approval_1)
    (airline_record_has_supervisor_approval airline_record_supplier_a supervisor_approval_1)
    (airline_record_has_supervisor_approval airline_record_supplier_b supervisor_approval_2)
    (ticketing_office_available ticketing_office_1)
  )
  (:goal
    (and
      (reissue_finalized orig_itinerary_1)
      (reissue_finalized changed_itinerary_1)
      (reissue_finalized airline_record_supplier_a)
      (reissue_finalized airline_record_supplier_b)
    )
  )
)
