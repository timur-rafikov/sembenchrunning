(define (problem round_trip_mobility_loop_design_problem)
  (:domain round_trip_mobility_loop_design_domain)
  (:objects outbound_leg_1 - outbound_leg inbound_leg_1 - inbound_leg mobility_loop_alpha - mobility_loop mobility_loop_bravo - mobility_loop transport_resource_bus_1 - transport_resource transport_resource_bus_2 - transport_resource transport_resource_bus_3 - transport_resource time_slot_0900 - time_slot transfer_node_main_hub - transfer_node passenger_group_1 - passenger_group outbound_transfer_edge_1 - outbound_transfer_edge inbound_transfer_edge_1 - inbound_transfer_edge vehicle_asset_1 - vehicle_asset boarding_gate_1 - boarding_asset boarding_gate_2 - boarding_asset route_option_scenic - route_option route_option_express - route_option service_option_premium - service_option service_option_extra_luggage - service_option return_resource_depot_slot_1 - return_resource vehicle_capability_accessible - vehicle_capability operator_credential_driver_1 - operator_credential operator_credential_driver_2 - operator_credential safety_certificate_inspection_1 - safety_certificate)
  (:init
    (transport_resource_available transport_resource_bus_1)
    (transport_resource_available transport_resource_bus_2)
    (transport_resource_available transport_resource_bus_3)
    (time_slot_available time_slot_0900)
    (transfer_node_available transfer_node_main_hub)
    (passenger_group_waiting passenger_group_1)
    (outbound_leg_assigned_outbound_edge outbound_leg_1 outbound_transfer_edge_1)
    (inbound_leg_assigned_inbound_edge inbound_leg_1 inbound_transfer_edge_1)
    (vehicle_available vehicle_asset_1)
    (boarding_asset_available boarding_gate_1)
    (boarding_asset_available boarding_gate_2)
    (loop_has_outbound_leg mobility_loop_alpha outbound_leg_1)
    (loop_has_outbound_leg mobility_loop_bravo outbound_leg_1)
    (loop_has_inbound_leg mobility_loop_alpha inbound_leg_1)
    (loop_has_inbound_leg mobility_loop_bravo inbound_leg_1)
    (loop_has_vehicle_assigned mobility_loop_alpha vehicle_asset_1)
    (loop_has_vehicle_assigned mobility_loop_bravo vehicle_asset_1)
    (loop_assigned_boarding_asset mobility_loop_alpha boarding_gate_1)
    (loop_assigned_boarding_asset mobility_loop_bravo boarding_gate_2)
    (route_option_available route_option_scenic)
    (route_option_available route_option_express)
    (service_option_available service_option_premium)
    (service_option_available service_option_extra_luggage)
    (return_resource_available return_resource_depot_slot_1)
    (vehicle_capability_available vehicle_capability_accessible)
    (operator_credential_available operator_credential_driver_1)
    (loop_assigned_operator_credential mobility_loop_alpha operator_credential_driver_1)
    (loop_assigned_operator_credential mobility_loop_bravo operator_credential_driver_2)
    (safety_certificate_available safety_certificate_inspection_1)
  )
  (:goal
    (and
      (segment_closed outbound_leg_1)
      (segment_closed inbound_leg_1)
      (segment_closed mobility_loop_alpha)
      (segment_closed mobility_loop_bravo)
    )
  )
)
