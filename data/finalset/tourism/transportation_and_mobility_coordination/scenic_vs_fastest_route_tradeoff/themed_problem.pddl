(define (problem scenic_vs_fastest_trip_planning_problem)
  (:domain scenic_vs_fastest_route_tradeoff_domain)
  (:objects outbound_leg_obj - outbound_leg inbound_leg_obj - inbound_leg itinerary_item_1 - itinerary_segment itinerary_item_2 - itinerary_segment vehicle_type_class_1 - vehicle_type vehicle_type_class_2 - vehicle_type vehicle_type_class_3 - vehicle_type transport_mode_obj - transport_mode transfer_node_obj - transfer_node local_option_choice - local_option path_option_scenic_obj - path_option_scenic path_option_fastest_variant_1 - path_option_fastest vehicle_unit_obj - vehicle_unit service_equipment_1 - service_equipment service_equipment_2 - service_equipment preference_token_1 - preference_token preference_token_2 - preference_token amenity_service_1 - amenity_service amenity_service_2 - amenity_service time_buffer_obj - time_buffer crew_member_1 - crew_member site_permit_1 - site_permit site_permit_2 - site_permit authorization_1 - authorization)
  (:init
    (vehicle_type_available vehicle_type_class_1)
    (vehicle_type_available vehicle_type_class_2)
    (vehicle_type_available vehicle_type_class_3)
    (transport_mode_available transport_mode_obj)
    (transfer_node_available transfer_node_obj)
    (local_option_available local_option_choice)
    (outbound_leg_has_scenic_path_option outbound_leg_obj path_option_scenic_obj)
    (inbound_leg_has_fastest_path_option inbound_leg_obj path_option_fastest_variant_1)
    (vehicle_unit_available vehicle_unit_obj)
    (equipment_available service_equipment_1)
    (equipment_available service_equipment_2)
    (itinerary_contains_outbound_leg itinerary_item_1 outbound_leg_obj)
    (itinerary_contains_outbound_leg itinerary_item_2 outbound_leg_obj)
    (itinerary_contains_inbound_leg itinerary_item_1 inbound_leg_obj)
    (itinerary_contains_inbound_leg itinerary_item_2 inbound_leg_obj)
    (itinerary_has_vehicle_unit itinerary_item_1 vehicle_unit_obj)
    (itinerary_has_vehicle_unit itinerary_item_2 vehicle_unit_obj)
    (itinerary_requires_equipment itinerary_item_1 service_equipment_1)
    (itinerary_requires_equipment itinerary_item_2 service_equipment_2)
    (preference_token_available preference_token_1)
    (preference_token_available preference_token_2)
    (amenity_available amenity_service_1)
    (amenity_available amenity_service_2)
    (time_buffer_available time_buffer_obj)
    (crew_available crew_member_1)
    (site_permit_available site_permit_1)
    (itinerary_has_site_permit itinerary_item_1 site_permit_1)
    (itinerary_has_site_permit itinerary_item_2 site_permit_2)
    (authorization_available authorization_1)
  )
  (:goal
    (and
      (trip_segment_completed outbound_leg_obj)
      (trip_segment_completed inbound_leg_obj)
      (trip_segment_completed itinerary_item_1)
      (trip_segment_completed itinerary_item_2)
    )
  )
)
