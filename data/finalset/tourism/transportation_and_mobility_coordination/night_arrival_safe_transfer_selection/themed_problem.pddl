(define (problem night_arrival_safe_transfer_scenario)
  (:domain night_arrival_safe_transfer_domain)
  (:objects incoming_segment_1 - incoming_segment outgoing_segment_1 - outgoing_segment transfer_plan_a - transfer_plan transfer_plan_b - transfer_plan vehicle_proposal_alpha - vehicle_proposal_option vehicle_proposal_beta - vehicle_proposal_option vehicle_proposal_gamma - vehicle_proposal_option local_transport_option_standard - local_transport_option escort_staff_on_duty - escort_staff assistive_service_wheelchair - assistive_service_option pickup_node_terminal - pickup_node dropoff_node_hotel - dropoff_node vehicle_asset_01 - transfer_vehicle_asset route_leg_a - route_leg route_leg_b - route_leg passenger_profile_vip - passenger_profile passenger_profile_standard - passenger_profile assignment_preference_quiet_ride - assignment_preference assignment_preference_window_seat - assignment_preference transfer_safety_team_1 - transfer_safety_resource vehicle_equipment_spec_child_seat - vehicle_equipment_spec special_handling_tag_vip - special_handling_tag special_handling_tag_medical - special_handling_tag operator_clearance_1 - operator_clearance)
  (:init
    (transfer_vehicle_proposal_available vehicle_proposal_alpha)
    (transfer_vehicle_proposal_available vehicle_proposal_beta)
    (transfer_vehicle_proposal_available vehicle_proposal_gamma)
    (transfer_local_option_available local_transport_option_standard)
    (transfer_escort_available escort_staff_on_duty)
    (transfer_assistive_service_available assistive_service_wheelchair)
    (transfer_segment_pickup_node_link incoming_segment_1 pickup_node_terminal)
    (transfer_segment_dropoff_node_link outgoing_segment_1 dropoff_node_hotel)
    (transfer_vehicle_asset_available vehicle_asset_01)
    (transfer_route_leg_available route_leg_a)
    (transfer_route_leg_available route_leg_b)
    (transfer_plan_includes_incoming_segment transfer_plan_a incoming_segment_1)
    (transfer_plan_includes_incoming_segment transfer_plan_b incoming_segment_1)
    (transfer_plan_includes_outgoing_segment transfer_plan_a outgoing_segment_1)
    (transfer_plan_includes_outgoing_segment transfer_plan_b outgoing_segment_1)
    (transfer_plan_assigned_vehicle_asset transfer_plan_a vehicle_asset_01)
    (transfer_plan_assigned_vehicle_asset transfer_plan_b vehicle_asset_01)
    (transfer_plan_has_route_leg transfer_plan_a route_leg_a)
    (transfer_plan_has_route_leg transfer_plan_b route_leg_b)
    (passenger_profile_available passenger_profile_vip)
    (passenger_profile_available passenger_profile_standard)
    (assignment_preference_available assignment_preference_quiet_ride)
    (assignment_preference_available assignment_preference_window_seat)
    (transfer_safety_resource_available transfer_safety_team_1)
    (vehicle_equipment_available vehicle_equipment_spec_child_seat)
    (special_handling_tag_available special_handling_tag_vip)
    (transfer_plan_special_handling_link transfer_plan_a special_handling_tag_vip)
    (transfer_plan_special_handling_link transfer_plan_b special_handling_tag_medical)
    (operator_clearance_available operator_clearance_1)
  )
  (:goal
    (and
      (transfer_confirmed incoming_segment_1)
      (transfer_confirmed outgoing_segment_1)
      (transfer_confirmed transfer_plan_a)
      (transfer_confirmed transfer_plan_b)
    )
  )
)
