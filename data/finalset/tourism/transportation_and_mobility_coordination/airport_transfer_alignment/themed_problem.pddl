(define (problem airport_transfer_alignment_scenario)
  (:domain airport_transfer_alignment)
  (:objects arrival_segment_1 - arrival_segment departure_segment_1 - departure_segment transfer_case_1 - transfer_case transfer_case_2 - transfer_case vehicle_option_sedan - vehicle_option vehicle_option_shuttle - vehicle_option vehicle_option_minivan - vehicle_option traveler_1 - traveler local_operator_1 - local_operator aux_resource_child_seat - auxiliary_resource pickup_node_terminal_curb - pickup_node dropoff_node_terminal_door - dropoff_node vehicle_unit_v001 - vehicle_unit booking_token_1 - booking_token booking_token_2 - booking_token service_option_priority_pickup - service_option service_option_standard - service_option passenger_option_vip_seat - passenger_option passenger_option_extra_luggage - passenger_option time_buffer_standard_15min - time_buffer equipment_wheelchair_ramp - equipment permit_airside_access_1 - permit permit_airside_access_2 - permit credential_driver_id_1 - credential)
  (:init
    (vehicle_option_available vehicle_option_sedan)
    (vehicle_option_available vehicle_option_shuttle)
    (vehicle_option_available vehicle_option_minivan)
    (traveler_available traveler_1)
    (operator_available local_operator_1)
    (auxiliary_resource_available aux_resource_child_seat)
    (arrival_segment_pickup_node arrival_segment_1 pickup_node_terminal_curb)
    (departure_segment_dropoff_node departure_segment_1 dropoff_node_terminal_door)
    (vehicle_unit_available vehicle_unit_v001)
    (booking_token_available booking_token_1)
    (booking_token_available booking_token_2)
    (case_has_arrival_segment transfer_case_1 arrival_segment_1)
    (case_has_arrival_segment transfer_case_2 arrival_segment_1)
    (case_has_departure_segment transfer_case_1 departure_segment_1)
    (case_has_departure_segment transfer_case_2 departure_segment_1)
    (case_assigned_vehicle_unit transfer_case_1 vehicle_unit_v001)
    (case_assigned_vehicle_unit transfer_case_2 vehicle_unit_v001)
    (case_has_booking_token transfer_case_1 booking_token_1)
    (case_has_booking_token transfer_case_2 booking_token_2)
    (service_option_available service_option_priority_pickup)
    (service_option_available service_option_standard)
    (passenger_option_available passenger_option_vip_seat)
    (passenger_option_available passenger_option_extra_luggage)
    (time_buffer_available time_buffer_standard_15min)
    (equipment_available equipment_wheelchair_ramp)
    (permit_available permit_airside_access_1)
    (case_has_permit transfer_case_1 permit_airside_access_1)
    (case_has_permit transfer_case_2 permit_airside_access_2)
    (credential_available credential_driver_id_1)
  )
  (:goal
    (and
      (alignment_finalized arrival_segment_1)
      (alignment_finalized departure_segment_1)
      (alignment_finalized transfer_case_1)
      (alignment_finalized transfer_case_2)
    )
  )
)
