(define (problem itinerary_connection_feasibility_problem)
  (:domain tourism_connection_time_feasibility_check)
  (:objects arrival_event_1 - arrival_event departure_event_1 - departure_event transfer_option_1 - transfer_option transfer_option_2 - transfer_option local_mode_shuttle - local_transport_mode local_mode_taxi - local_transport_mode local_mode_bus - local_transport_mode time_window_1 - time_window terminal_gate_a - terminal_gate auxiliary_service_standard - auxiliary_service arrival_access_point_a - arrival_access_point departure_access_point_a - departure_access_point connecting_vehicle_v1 - connecting_vehicle passenger_profile_1 - passenger_profile passenger_profile_2 - passenger_profile ticket_option_standard - ticket_option ticket_option_flexible - ticket_option service_option_meal - service_option service_option_assistance - service_option time_buffer_standard - time_buffer equipment_resource_wheelchair - equipment_resource special_request_group - special_request special_request_assistance - special_request operational_constraint_staffing - operational_constraint)
  (:init
    (local_mode_available local_mode_shuttle)
    (local_mode_available local_mode_taxi)
    (local_mode_available local_mode_bus)
    (time_window_available time_window_1)
    (terminal_gate_available terminal_gate_a)
    (auxiliary_service_available auxiliary_service_standard)
    (arrival_linked_access_point arrival_event_1 arrival_access_point_a)
    (departure_linked_access_point departure_event_1 departure_access_point_a)
    (connecting_vehicle_available connecting_vehicle_v1)
    (passenger_profile_available passenger_profile_1)
    (passenger_profile_available passenger_profile_2)
    (transfer_option_linked_arrival_event transfer_option_1 arrival_event_1)
    (transfer_option_linked_arrival_event transfer_option_2 arrival_event_1)
    (transfer_option_linked_departure_event transfer_option_1 departure_event_1)
    (transfer_option_linked_departure_event transfer_option_2 departure_event_1)
    (transfer_option_allocated_vehicle transfer_option_1 connecting_vehicle_v1)
    (transfer_option_allocated_vehicle transfer_option_2 connecting_vehicle_v1)
    (transfer_option_linked_passenger_profile transfer_option_1 passenger_profile_1)
    (transfer_option_linked_passenger_profile transfer_option_2 passenger_profile_2)
    (ticket_option_available ticket_option_standard)
    (ticket_option_available ticket_option_flexible)
    (service_option_available service_option_meal)
    (service_option_available service_option_assistance)
    (time_buffer_available time_buffer_standard)
    (equipment_resource_available equipment_resource_wheelchair)
    (special_request_available special_request_group)
    (transfer_option_linked_special_request transfer_option_1 special_request_group)
    (transfer_option_linked_special_request transfer_option_2 special_request_assistance)
    (operational_constraint_available operational_constraint_staffing)
  )
  (:goal
    (and
      (connection_validated arrival_event_1)
      (connection_validated departure_event_1)
      (connection_validated transfer_option_1)
      (connection_validated transfer_option_2)
    )
  )
)
