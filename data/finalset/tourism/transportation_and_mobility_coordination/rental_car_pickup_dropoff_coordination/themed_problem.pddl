(define (problem rental_car_pickup_dropoff_problem)
  (:domain rental_car_pickup_dropoff_coordination)
  (:objects pickup_leg_1 - pickup_leg dropoff_leg_1 - dropoff_leg reservation_record_1 - reservation_record reservation_record_2 - reservation_record vehicle_asset_1 - vehicle_asset vehicle_asset_2 - vehicle_asset vehicle_asset_3 - vehicle_asset arrival_event_1 - arrival_event counter_agent_1 - counter_agent accessory_item_1 - accessory_item pickup_transfer_option_1 - pickup_transfer_option dropoff_transfer_option_1 - dropoff_transfer_option vehicle_allocation_record_1 - vehicle_allocation_record inspection_point_1 - inspection_point inspection_point_2 - inspection_point vendor_service_option_1 - vendor_service_option vendor_service_option_2 - vendor_service_option payment_instrument_1 - payment_instrument payment_instrument_2 - payment_instrument timing_buffer_1 - timing_buffer_window vehicle_key_1 - vehicle_key provider_confirmation_token_1 - provider_confirmation_token provider_confirmation_token_2 - provider_confirmation_token provider_document_1 - provider_document)
  (:init
    (vehicle_available vehicle_asset_1)
    (vehicle_available vehicle_asset_2)
    (vehicle_available vehicle_asset_3)
    (arrival_event_available arrival_event_1)
    (agent_available counter_agent_1)
    (accessory_available accessory_item_1)
    (leg_has_transfer_option pickup_leg_1 pickup_transfer_option_1)
    (dropoff_leg_has_transfer_option dropoff_leg_1 dropoff_transfer_option_1)
    (allocation_record_available vehicle_allocation_record_1)
    (inspection_point_available inspection_point_1)
    (inspection_point_available inspection_point_2)
    (reservation_to_pickup_leg_link reservation_record_1 pickup_leg_1)
    (reservation_to_pickup_leg_link reservation_record_2 pickup_leg_1)
    (reservation_to_dropoff_leg_link reservation_record_1 dropoff_leg_1)
    (reservation_to_dropoff_leg_link reservation_record_2 dropoff_leg_1)
    (reservation_to_allocation_link reservation_record_1 vehicle_allocation_record_1)
    (reservation_to_allocation_link reservation_record_2 vehicle_allocation_record_1)
    (reservation_has_inspection_point reservation_record_1 inspection_point_1)
    (reservation_has_inspection_point reservation_record_2 inspection_point_2)
    (vendor_service_option_available vendor_service_option_1)
    (vendor_service_option_available vendor_service_option_2)
    (payment_method_available payment_instrument_1)
    (payment_method_available payment_instrument_2)
    (timing_buffer_available timing_buffer_1)
    (vehicle_key_available vehicle_key_1)
    (provider_confirmation_available provider_confirmation_token_1)
    (reservation_bound_to_provider_confirmation reservation_record_1 provider_confirmation_token_1)
    (reservation_bound_to_provider_confirmation reservation_record_2 provider_confirmation_token_2)
    (provider_document_available provider_document_1)
  )
  (:goal
    (and
      (handover_completed pickup_leg_1)
      (handover_completed dropoff_leg_1)
      (handover_completed reservation_record_1)
      (handover_completed reservation_record_2)
    )
  )
)
