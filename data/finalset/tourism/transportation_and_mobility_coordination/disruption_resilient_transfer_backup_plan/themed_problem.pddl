(define (problem disruption_resilient_transfer_backup_plan_problem)
  (:domain disruption_resilient_transfer_backup_plan_domain)
  (:objects inbound_leg_alpha - inbound_leg outbound_leg_alpha - outbound_leg traveler_alpha - traveler traveler_beta - traveler coach_service_option - service_option shuttle_service_option - service_option taxi_service_option - service_option transfer_slot_alpha - schedule_slot transfer_assistant - assistance_resource backup_shuttle - contingency_asset arrival_bay_a - arrival_point departure_bay_a - departure_point vehicle_alpha - vehicle_unit boarding_pass_alpha - boarding_pass boarding_pass_beta - boarding_pass standard_class - seat_class priority_class - seat_class priority_token_alpha - priority_token priority_token_beta - priority_token contingency_kit - contingency_equipment vehicle_assignment_token_alpha - vehicle_assignment_token voucher_code_alpha - voucher_code voucher_code_beta - voucher_code travel_document_alpha - travel_document)
  (:init
    (service_option_available coach_service_option)
    (service_option_available shuttle_service_option)
    (service_option_available taxi_service_option)
    (schedule_slot_available transfer_slot_alpha)
    (assistance_resource_available transfer_assistant)
    (contingency_asset_available backup_shuttle)
    (inbound_leg_arrival_linked inbound_leg_alpha arrival_bay_a)
    (outbound_leg_departure_linked outbound_leg_alpha departure_bay_a)
    (vehicle_available vehicle_alpha)
    (boarding_pass_available boarding_pass_alpha)
    (boarding_pass_available boarding_pass_beta)
    (traveler_inbound_leg_link traveler_alpha inbound_leg_alpha)
    (traveler_inbound_leg_link traveler_beta inbound_leg_alpha)
    (traveler_outbound_leg_link traveler_alpha outbound_leg_alpha)
    (traveler_outbound_leg_link traveler_beta outbound_leg_alpha)
    (traveler_vehicle_link traveler_alpha vehicle_alpha)
    (traveler_vehicle_link traveler_beta vehicle_alpha)
    (traveler_boarding_pass_link traveler_alpha boarding_pass_alpha)
    (traveler_boarding_pass_link traveler_beta boarding_pass_beta)
    (seat_class_available standard_class)
    (seat_class_available priority_class)
    (priority_token_available priority_token_alpha)
    (priority_token_available priority_token_beta)
    (contingency_equipment_available contingency_kit)
    (vehicle_assignment_token_available vehicle_assignment_token_alpha)
    (voucher_code_available voucher_code_alpha)
    (traveler_voucher_code_link traveler_alpha voucher_code_alpha)
    (traveler_voucher_code_link traveler_beta voucher_code_beta)
    (travel_document_available travel_document_alpha)
  )
  (:goal
    (and
      (transfer_entity_continuity_restored inbound_leg_alpha)
      (transfer_entity_continuity_restored outbound_leg_alpha)
      (transfer_entity_continuity_restored traveler_alpha)
      (transfer_entity_continuity_restored traveler_beta)
    )
  )
)
