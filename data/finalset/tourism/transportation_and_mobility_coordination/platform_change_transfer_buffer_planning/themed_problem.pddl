(define (problem platform_transfer_buffer_case)
  (:domain platform_change_transfer_buffer_planning)
  (:objects incoming_leg_1 - incoming_leg outgoing_leg_1 - outgoing_leg transfer_plan_1 - transfer_plan transfer_plan_2 - transfer_plan mobility_option_1 - local_mobility_option mobility_option_2 - local_mobility_option mobility_option_3 - local_mobility_option walking_time_estimate_1 - walking_time_estimate station_gate_1 - station_gate assistance_equipment_1 - assistance_equipment arrival_buffer_zone_1 - arrival_buffer_zone departure_buffer_zone_1 - departure_buffer_zone buffer_allocation_1 - buffer_allocation access_path_1 - access_path access_path_2 - access_path priority_pass_1 - priority_pass priority_pass_2 - priority_pass passenger_1 - passenger_id passenger_2 - passenger_id time_slot_token_1 - time_slot_token staff_resource_1 - staff_resource auth_token_1 - authorization_token auth_token_2 - authorization_token equipment_reservation_1 - equipment_reservation_token)
  (:init
    (mobility_option_available mobility_option_1)
    (mobility_option_available mobility_option_2)
    (mobility_option_available mobility_option_3)
    (walking_time_available walking_time_estimate_1)
    (gate_available station_gate_1)
    (equipment_available assistance_equipment_1)
    (arrival_buffer_assigned incoming_leg_1 arrival_buffer_zone_1)
    (departure_buffer_assigned outgoing_leg_1 departure_buffer_zone_1)
    (buffer_available buffer_allocation_1)
    (access_path_available access_path_1)
    (access_path_available access_path_2)
    (plan_includes_incoming_leg transfer_plan_1 incoming_leg_1)
    (plan_includes_incoming_leg transfer_plan_2 incoming_leg_1)
    (plan_includes_outgoing_leg transfer_plan_1 outgoing_leg_1)
    (plan_includes_outgoing_leg transfer_plan_2 outgoing_leg_1)
    (plan_assigned_allocation transfer_plan_1 buffer_allocation_1)
    (plan_assigned_allocation transfer_plan_2 buffer_allocation_1)
    (plan_assigned_access_path transfer_plan_1 access_path_1)
    (plan_assigned_access_path transfer_plan_2 access_path_2)
    (priority_pass_available priority_pass_1)
    (priority_pass_available priority_pass_2)
    (passenger_present passenger_1)
    (passenger_present passenger_2)
    (time_slot_available time_slot_token_1)
    (staff_available staff_resource_1)
    (auth_token_available auth_token_1)
    (auth_token_assigned_to_plan transfer_plan_1 auth_token_1)
    (auth_token_assigned_to_plan transfer_plan_2 auth_token_2)
    (equipment_reservation_available equipment_reservation_1)
  )
  (:goal
    (and
      (transfer_event_completed incoming_leg_1)
      (transfer_event_completed outgoing_leg_1)
      (transfer_event_completed transfer_plan_1)
      (transfer_event_completed transfer_plan_2)
    )
  )
)
