(define (problem station_transfer_scenario)
  (:domain station_transfer_coordination)
  (:objects arrival_segment_1 - incoming_segment departure_segment_1 - outgoing_segment transfer_case_alpha - transfer_case transfer_case_beta - transfer_case shuttle_1 - local_vehicle_unit shuttle_2 - local_vehicle_unit shuttle_3 - local_vehicle_unit transfer_option_walk_1 - transfer_option porter_1 - staff_resource baggage_1 - baggage_or_mobility_aid arrival_corridor_1 - incoming_access_path departure_corridor_1 - outgoing_access_path connector_gate_1 - connector_instance elevator_1 - facility_resource escalator_1 - facility_resource priority_service_vip - priority_service_type priority_service_fast_track - priority_service_type special_service_wheelchair - special_service_option special_service_assistance - special_service_option time_window_slot_1 - time_window vehicle_capability_standard - vehicle_capability passport_1 - document_or_authorization visa_1 - document_or_authorization operational_constraint_security_check - operational_constraint)
  (:init
    (vehicle_available shuttle_1)
    (vehicle_available shuttle_2)
    (vehicle_available shuttle_3)
    (transfer_option_available transfer_option_walk_1)
    (staff_available porter_1)
    (baggage_available baggage_1)
    (incoming_segment_on_access_path arrival_segment_1 arrival_corridor_1)
    (outgoing_segment_on_access_path departure_segment_1 departure_corridor_1)
    (connector_available connector_gate_1)
    (facility_available elevator_1)
    (facility_available escalator_1)
    (case_incoming_segment transfer_case_alpha arrival_segment_1)
    (case_incoming_segment transfer_case_beta arrival_segment_1)
    (case_outgoing_segment transfer_case_alpha departure_segment_1)
    (case_outgoing_segment transfer_case_beta departure_segment_1)
    (case_assigned_connector transfer_case_alpha connector_gate_1)
    (case_assigned_connector transfer_case_beta connector_gate_1)
    (case_requires_facility transfer_case_alpha elevator_1)
    (case_requires_facility transfer_case_beta escalator_1)
    (priority_service_available priority_service_vip)
    (priority_service_available priority_service_fast_track)
    (special_service_available special_service_wheelchair)
    (special_service_available special_service_assistance)
    (time_window_available time_window_slot_1)
    (vehicle_capability_available vehicle_capability_standard)
    (document_available passport_1)
    (case_document_linked transfer_case_alpha passport_1)
    (case_document_linked transfer_case_beta visa_1)
    (operational_constraint_available operational_constraint_security_check)
  )
  (:goal
    (and
      (handover_completed arrival_segment_1)
      (handover_completed departure_segment_1)
      (handover_completed transfer_case_alpha)
      (handover_completed transfer_case_beta)
    )
  )
)
