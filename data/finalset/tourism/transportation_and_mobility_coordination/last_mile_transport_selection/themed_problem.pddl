(define (problem tourism_last_mile_transport_selection_instance)
  (:domain tourism_last_mile_transport_selection)
  (:objects origin_segment_1 - origin_segment destination_segment_1 - destination_segment itinerary_candidate_1 - itinerary_candidate itinerary_candidate_2 - itinerary_candidate provider_option_1 - provider_option provider_option_2 - provider_option provider_option_3 - provider_option time_window_1 - time_window operator_resource_1 - operator_resource transfer_point_1 - transfer_point pickup_point_1 - pickup_point dropoff_point_1 - dropoff_point vehicle_unit_1 - vehicle_unit route_variant_1 - route_variant route_variant_2 - route_variant fare_option_1 - fare_option fare_option_2 - fare_option passenger_preference_1 - passenger_preference passenger_preference_2 - passenger_preference timing_buffer_1 - timing_buffer vehicle_attribute_1 - vehicle_attribute operator_credential_1 - operator_credential operator_credential_2 - operator_credential service_option_1 - service_option)
  (:init
    (provider_option_available provider_option_1)
    (provider_option_available provider_option_2)
    (provider_option_available provider_option_3)
    (time_window_available time_window_1)
    (operator_resource_available operator_resource_1)
    (transfer_point_available transfer_point_1)
    (origin_segment_pickup_point_binding origin_segment_1 pickup_point_1)
    (destination_segment_dropoff_point_binding destination_segment_1 dropoff_point_1)
    (vehicle_unit_available vehicle_unit_1)
    (route_variant_available route_variant_1)
    (route_variant_available route_variant_2)
    (itinerary_origin_segment_association itinerary_candidate_1 origin_segment_1)
    (itinerary_origin_segment_association itinerary_candidate_2 origin_segment_1)
    (itinerary_destination_segment_association itinerary_candidate_1 destination_segment_1)
    (itinerary_destination_segment_association itinerary_candidate_2 destination_segment_1)
    (itinerary_candidate_vehicle_binding itinerary_candidate_1 vehicle_unit_1)
    (itinerary_candidate_vehicle_binding itinerary_candidate_2 vehicle_unit_1)
    (itinerary_candidate_route_variant_binding itinerary_candidate_1 route_variant_1)
    (itinerary_candidate_route_variant_binding itinerary_candidate_2 route_variant_2)
    (fare_option_available fare_option_1)
    (fare_option_available fare_option_2)
    (passenger_preference_available passenger_preference_1)
    (passenger_preference_available passenger_preference_2)
    (timing_buffer_available timing_buffer_1)
    (vehicle_attribute_available vehicle_attribute_1)
    (operator_credential_available operator_credential_1)
    (itinerary_candidate_operator_credential_binding itinerary_candidate_1 operator_credential_1)
    (itinerary_candidate_operator_credential_binding itinerary_candidate_2 operator_credential_2)
    (service_option_available service_option_1)
  )
  (:goal
    (and
      (segment_committed origin_segment_1)
      (segment_committed destination_segment_1)
      (segment_committed itinerary_candidate_1)
      (segment_committed itinerary_candidate_2)
    )
  )
)
