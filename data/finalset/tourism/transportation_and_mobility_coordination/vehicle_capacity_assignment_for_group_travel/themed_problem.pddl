(define (problem group_travel_assignment_problem)
  (:domain tourism_vehicle_capacity_assignment)
  (:objects subgroup_a_1 - passenger_subgroup_a subgroup_b_1 - passenger_subgroup_b dispatch_case_1 - dispatch_case dispatch_case_2 - dispatch_case vehicle_pool_alpha - vehicle_pool vehicle_pool_beta - vehicle_pool vehicle_pool_gamma - vehicle_pool time_slot_0900 - time_slot local_shuttle_option - local_transfer_option equipment_luggage_trolley - equipment_option pickup_node_main_station - pickup_node dropoff_node_city_terminal - dropoff_node vehicle_bus_101 - vehicle_asset boarding_position_front_row - boarding_position boarding_position_rear_row - boarding_position vehicle_feature_wifi - vehicle_feature_option vehicle_feature_wheelchair_ramp - vehicle_feature_option service_option_priority_boarding - service_option service_option_meal_service - service_option timing_buffer_15min - timing_buffer certification_token_safety_check - certification_token authorization_token_special_access - authorization_token authorization_token_staff_approval - authorization_token operational_credential_driver_license - operational_credential)
  (:init
    (vehicle_pool_available vehicle_pool_alpha)
    (vehicle_pool_available vehicle_pool_beta)
    (vehicle_pool_available vehicle_pool_gamma)
    (time_slot_available time_slot_0900)
    (transfer_option_available local_shuttle_option)
    (equipment_available equipment_luggage_trolley)
    (subgroup_a_pickup_link subgroup_a_1 pickup_node_main_station)
    (subgroup_b_dropoff_link subgroup_b_1 dropoff_node_city_terminal)
    (vehicle_asset_available vehicle_bus_101)
    (boarding_position_available boarding_position_front_row)
    (boarding_position_available boarding_position_rear_row)
    (dispatch_has_subgroup_a dispatch_case_1 subgroup_a_1)
    (dispatch_has_subgroup_a dispatch_case_2 subgroup_a_1)
    (dispatch_has_subgroup_b dispatch_case_1 subgroup_b_1)
    (dispatch_has_subgroup_b dispatch_case_2 subgroup_b_1)
    (dispatch_vehicle_binding dispatch_case_1 vehicle_bus_101)
    (dispatch_vehicle_binding dispatch_case_2 vehicle_bus_101)
    (dispatch_boarding_position_binding dispatch_case_1 boarding_position_front_row)
    (dispatch_boarding_position_binding dispatch_case_2 boarding_position_rear_row)
    (vehicle_feature_option_available vehicle_feature_wifi)
    (vehicle_feature_option_available vehicle_feature_wheelchair_ramp)
    (service_option_available service_option_priority_boarding)
    (service_option_available service_option_meal_service)
    (timing_buffer_available timing_buffer_15min)
    (certification_token_available certification_token_safety_check)
    (authorization_token_available authorization_token_special_access)
    (dispatch_authorization_binding dispatch_case_1 authorization_token_special_access)
    (dispatch_authorization_binding dispatch_case_2 authorization_token_staff_approval)
    (operational_credential_available operational_credential_driver_license)
  )
  (:goal
    (and
      (travel_unit_assigned subgroup_a_1)
      (travel_unit_assigned subgroup_b_1)
      (travel_unit_assigned dispatch_case_1)
      (travel_unit_assigned dispatch_case_2)
    )
  )
)
