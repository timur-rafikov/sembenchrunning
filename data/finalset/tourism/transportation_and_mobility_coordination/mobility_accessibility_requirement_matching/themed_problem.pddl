(define (problem tourist_multi_segment_accessibility_matching)
  (:domain mobility_accessibility_requirement_matching)
  (:objects boarding_activity_1 - boarding_activity alighting_activity_1 - alighting_activity itinerary_segment_1 - itinerary_segment itinerary_segment_2 - itinerary_segment transport_resource_1 - transport_resource transport_resource_2 - transport_resource transport_resource_3 - transport_resource requirement_wheelchair - accessibility_requirement assistance_staff_ramp - local_assistance aux_item_ramp - auxiliary_item_type transfer_node_inbound_a - transfer_node_inbound transfer_node_outbound_b - transfer_node_outbound vehicle_unit_1 - vehicle_unit equipment_ramp_1 - equipment_instance equipment_ramp_2 - equipment_instance preference_seat_near_door - passenger_preference preference_aisle_seat - passenger_preference operator_credential_certified_lift - operator_credential operator_credential_medical_trained - operator_credential accessibility_tag_priority - accessibility_tag vehicle_feature_low_floor - vehicle_feature policy_wheelchair_access - policy_document policy_service_animals - policy_document service_attribute_staff_assist - service_attribute)
  (:init
    (resource_available transport_resource_1)
    (resource_available transport_resource_2)
    (resource_available transport_resource_3)
    (requirement_available requirement_wheelchair)
    (assistance_available assistance_staff_ramp)
    (aux_item_type_available aux_item_ramp)
    (activity_inbound_node boarding_activity_1 transfer_node_inbound_a)
    (activity_outbound_node alighting_activity_1 transfer_node_outbound_b)
    (vehicle_available vehicle_unit_1)
    (equipment_available equipment_ramp_1)
    (equipment_available equipment_ramp_2)
    (segment_has_boarding_activity itinerary_segment_1 boarding_activity_1)
    (segment_has_boarding_activity itinerary_segment_2 boarding_activity_1)
    (segment_has_alighting_activity itinerary_segment_1 alighting_activity_1)
    (segment_has_alighting_activity itinerary_segment_2 alighting_activity_1)
    (segment_associated_vehicle itinerary_segment_1 vehicle_unit_1)
    (segment_associated_vehicle itinerary_segment_2 vehicle_unit_1)
    (segment_equipment_association itinerary_segment_1 equipment_ramp_1)
    (segment_equipment_association itinerary_segment_2 equipment_ramp_2)
    (preference_available preference_seat_near_door)
    (preference_available preference_aisle_seat)
    (operator_credential_available operator_credential_certified_lift)
    (operator_credential_available operator_credential_medical_trained)
    (accessibility_tag_available accessibility_tag_priority)
    (vehicle_feature_available vehicle_feature_low_floor)
    (policy_document_available policy_wheelchair_access)
    (segment_policy_document itinerary_segment_1 policy_wheelchair_access)
    (segment_policy_document itinerary_segment_2 policy_service_animals)
    (service_attribute_available service_attribute_staff_assist)
  )
  (:goal
    (and
      (assignment_finalized boarding_activity_1)
      (assignment_finalized alighting_activity_1)
      (assignment_finalized itinerary_segment_1)
      (assignment_finalized itinerary_segment_2)
    )
  )
)
