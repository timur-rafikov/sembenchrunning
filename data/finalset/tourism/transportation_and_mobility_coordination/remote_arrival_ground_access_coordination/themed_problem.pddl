(define (problem remote_arrival_handoff_problem)
  (:domain remote_arrival_ground_access_coordination)
  (:objects arrival_segment_1 - arrival_segment onward_segment_1 - onward_segment guest_itinerary_1 - guest_itinerary guest_itinerary_2 - guest_itinerary operator_slot_1 - operator_slot operator_slot_2 - operator_slot operator_slot_3 - operator_slot mode_candidate_shuttle - transport_mode_candidate local_provider_1 - local_provider access_token_1 - access_token pickup_zone_gate_a - pickup_location dropoff_zone_gate_a - dropoff_location vehicle_1 - vehicle boarding_area_1 - boarding_area boarding_area_2 - boarding_area preference_profile_standard - preference_profile preference_profile_family - preference_profile service_option_priority_boarding - service_option service_option_luggage_assist - service_option timing_buffer_standard - timing_buffer vehicle_feature_wheelchair_access - vehicle_feature amenity_request_wifi - amenity_request amenity_request_meal - amenity_request staff_assignment_driver_1 - staff_assignment)
  (:init
    (operator_slot_available operator_slot_1)
    (operator_slot_available operator_slot_2)
    (operator_slot_available operator_slot_3)
    (mode_candidate_available mode_candidate_shuttle)
    (local_provider_available local_provider_1)
    (access_token_available access_token_1)
    (segment_has_pickup_location arrival_segment_1 pickup_zone_gate_a)
    (onward_has_dropoff_location onward_segment_1 dropoff_zone_gate_a)
    (vehicle_available vehicle_1)
    (boarding_area_available boarding_area_1)
    (boarding_area_available boarding_area_2)
    (itinerary_linked_to_arrival_segment guest_itinerary_1 arrival_segment_1)
    (itinerary_linked_to_arrival_segment guest_itinerary_2 arrival_segment_1)
    (itinerary_linked_to_onward_segment guest_itinerary_1 onward_segment_1)
    (itinerary_linked_to_onward_segment guest_itinerary_2 onward_segment_1)
    (itinerary_assigned_vehicle guest_itinerary_1 vehicle_1)
    (itinerary_assigned_vehicle guest_itinerary_2 vehicle_1)
    (itinerary_assigned_boarding_area guest_itinerary_1 boarding_area_1)
    (itinerary_assigned_boarding_area guest_itinerary_2 boarding_area_2)
    (preference_profile_available preference_profile_standard)
    (preference_profile_available preference_profile_family)
    (service_option_available service_option_priority_boarding)
    (service_option_available service_option_luggage_assist)
    (timing_buffer_available timing_buffer_standard)
    (vehicle_feature_available vehicle_feature_wheelchair_access)
    (amenity_request_available amenity_request_wifi)
    (itinerary_amenity_assigned guest_itinerary_1 amenity_request_wifi)
    (itinerary_amenity_assigned guest_itinerary_2 amenity_request_meal)
    (staff_assignment_available staff_assignment_driver_1)
  )
  (:goal
    (and
      (access_allocated_to_entity arrival_segment_1)
      (access_allocated_to_entity onward_segment_1)
      (access_allocated_to_entity guest_itinerary_1)
      (access_allocated_to_entity guest_itinerary_2)
    )
  )
)
