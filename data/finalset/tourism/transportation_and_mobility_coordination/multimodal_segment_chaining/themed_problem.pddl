(define (problem tourist_multimodal_planning_problem)
  (:domain multimodal_segment_chaining_domain)
  (:objects upstream_segment_context_1 - upstream_segment_context downstream_segment_context_1 - downstream_segment_context itinerary_element_1 - itinerary_element itinerary_element_2 - itinerary_element transfer_slot_a - transfer_slot transfer_slot_b - transfer_slot transfer_slot_c - transfer_slot service_option_1 - service_option service_provider_1 - service_provider fare_option_standard - fare_option_location origin_stop_station_a - origin_stop_location destination_stop_station_b - destination_stop_location vehicle_unit_101 - vehicle_unit passenger_group_adults - passenger_group passenger_group_family - passenger_group seat_option_window - seat_or_cabin_option seat_option_aisle - seat_or_cabin_option ancillary_service_luggage - ancillary_service ancillary_service_priority_boarding - ancillary_service time_buffer_min_connect - time_buffer equipment_request_bike_rack - equipment_request credential_passport - credential credential_visa - credential schedule_slot_0900 - schedule_slot)
  (:init
    (transfer_slot_available transfer_slot_a)
    (transfer_slot_available transfer_slot_b)
    (transfer_slot_available transfer_slot_c)
    (service_option_available service_option_1)
    (service_provider_available service_provider_1)
    (fare_option_available fare_option_standard)
    (upstream_context_origin_stop upstream_segment_context_1 origin_stop_station_a)
    (downstream_context_destination_stop downstream_segment_context_1 destination_stop_station_b)
    (vehicle_unit_available vehicle_unit_101)
    (passenger_group_available passenger_group_adults)
    (passenger_group_available passenger_group_family)
    (itinerary_element_has_upstream_context itinerary_element_1 upstream_segment_context_1)
    (itinerary_element_has_upstream_context itinerary_element_2 upstream_segment_context_1)
    (itinerary_element_has_downstream_context itinerary_element_1 downstream_segment_context_1)
    (itinerary_element_has_downstream_context itinerary_element_2 downstream_segment_context_1)
    (itinerary_element_assigned_vehicle itinerary_element_1 vehicle_unit_101)
    (itinerary_element_assigned_vehicle itinerary_element_2 vehicle_unit_101)
    (itinerary_element_has_passenger_group itinerary_element_1 passenger_group_adults)
    (itinerary_element_has_passenger_group itinerary_element_2 passenger_group_family)
    (seat_option_available seat_option_window)
    (seat_option_available seat_option_aisle)
    (ancillary_service_available ancillary_service_luggage)
    (ancillary_service_available ancillary_service_priority_boarding)
    (time_buffer_available time_buffer_min_connect)
    (equipment_request_available equipment_request_bike_rack)
    (credential_available credential_passport)
    (itinerary_has_credential itinerary_element_1 credential_passport)
    (itinerary_has_credential itinerary_element_2 credential_visa)
    (schedule_slot_available schedule_slot_0900)
  )
  (:goal
    (and
      (entity_confirmed upstream_segment_context_1)
      (entity_confirmed downstream_segment_context_1)
      (entity_confirmed itinerary_element_1)
      (entity_confirmed itinerary_element_2)
    )
  )
)
