(define (problem early_departure_scenario)
  (:domain early_departure_ground_transport_arrangement)
  (:objects pickup_unit_1 - pickup_unit dropoff_unit_1 - dropoff_unit dispatch_record_1 - dispatch_record dispatch_record_2 - dispatch_record vehicle_1 - vehicle_unit vehicle_2 - vehicle_unit vehicle_3 - vehicle_unit time_slot_1 - time_slot driver_1 - driver auxiliary_resource_1 - auxiliary_resource pickup_zone_1 - pickup_zone dropoff_zone_1 - dropoff_zone location_reservation_1 - location_reservation equipment_asset_1 - equipment_asset equipment_asset_2 - equipment_asset passenger_preference_1 - passenger_preference passenger_preference_2 - passenger_preference capacity_profile_1 - capacity_profile capacity_profile_2 - capacity_profile location_reference_1 - location_reference vehicle_feature_1 - vehicle_feature special_permit_1 - special_permit special_permit_2 - special_permit operator_certificate_1 - operator_certificate)
  (:init
    (vehicle_available vehicle_1)
    (vehicle_available vehicle_2)
    (vehicle_available vehicle_3)
    (time_slot_available time_slot_1)
    (driver_available driver_1)
    (auxiliary_resource_available auxiliary_resource_1)
    (pickup_zone_compatible pickup_unit_1 pickup_zone_1)
    (dropoff_assigned_zone dropoff_unit_1 dropoff_zone_1)
    (vehicle_reservation_unallocated location_reservation_1)
    (equipment_asset_available equipment_asset_1)
    (equipment_asset_available equipment_asset_2)
    (dispatch_to_pickup dispatch_record_1 pickup_unit_1)
    (dispatch_to_pickup dispatch_record_2 pickup_unit_1)
    (dispatch_to_dropoff dispatch_record_1 dropoff_unit_1)
    (dispatch_to_dropoff dispatch_record_2 dropoff_unit_1)
    (dispatch_to_reservation dispatch_record_1 location_reservation_1)
    (dispatch_to_reservation dispatch_record_2 location_reservation_1)
    (dispatch_planned_equipment dispatch_record_1 equipment_asset_1)
    (dispatch_planned_equipment dispatch_record_2 equipment_asset_2)
    (passenger_preference_available passenger_preference_1)
    (passenger_preference_available passenger_preference_2)
    (capacity_profile_available capacity_profile_1)
    (capacity_profile_available capacity_profile_2)
    (location_reference_available location_reference_1)
    (vehicle_feature_available vehicle_feature_1)
    (special_permit_available special_permit_1)
    (dispatch_assigned_permit dispatch_record_1 special_permit_1)
    (dispatch_assigned_permit dispatch_record_2 special_permit_2)
    (operator_certificate_available operator_certificate_1)
  )
  (:goal
    (and
      (planning_completed pickup_unit_1)
      (planning_completed dropoff_unit_1)
      (planning_completed dispatch_record_1)
      (planning_completed dispatch_record_2)
    )
  )
)
