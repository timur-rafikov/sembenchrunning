(define (problem visa_requirement_assessment_problem)
  (:domain visa_requirement_assessment)
  (:objects primary_applicant_1 - primary_applicant secondary_applicant_1 - secondary_applicant visa_case_1 - visa_case visa_case_2 - visa_case issuing_authority_1 - issuing_authority issuing_authority_2 - issuing_authority issuing_authority_3 - issuing_authority passport_document - document_type assessor_officer_1 - assessor invitation_letter - evidence_item origin_profile_1 - origin_policy_profile destination_profile_1 - destination_policy_profile decision_package_1 - decision_package checklist_item_identity_verification - checklist_item checklist_item_purpose_of_travel - checklist_item special_condition_medical - special_condition special_condition_diplomatic - special_condition fee_option_standard - fee_option fee_option_expedited - fee_option policy_source_official - policy_source waiver_provision_general - waiver_provision exception_category_medical - exception_category exception_category_diplomatic - exception_category exception_claim_1 - exception_claim)
  (:init
    (authority_available issuing_authority_1)
    (authority_available issuing_authority_2)
    (authority_available issuing_authority_3)
    (document_available passport_document)
    (assessor_available assessor_officer_1)
    (evidence_available invitation_letter)
    (primary_has_origin_policy_profile primary_applicant_1 origin_profile_1)
    (secondary_has_destination_policy_profile secondary_applicant_1 destination_profile_1)
    (decision_package_available decision_package_1)
    (checklist_item_available checklist_item_identity_verification)
    (checklist_item_available checklist_item_purpose_of_travel)
    (case_has_primary_applicant visa_case_1 primary_applicant_1)
    (case_has_primary_applicant visa_case_2 primary_applicant_1)
    (case_has_secondary_applicant visa_case_1 secondary_applicant_1)
    (case_has_secondary_applicant visa_case_2 secondary_applicant_1)
    (case_linked_to_decision_package visa_case_1 decision_package_1)
    (case_linked_to_decision_package visa_case_2 decision_package_1)
    (case_has_checklist_item visa_case_1 checklist_item_identity_verification)
    (case_has_checklist_item visa_case_2 checklist_item_purpose_of_travel)
    (special_condition_available special_condition_medical)
    (special_condition_available special_condition_diplomatic)
    (fee_option_available fee_option_standard)
    (fee_option_available fee_option_expedited)
    (policy_source_available policy_source_official)
    (waiver_provision_available waiver_provision_general)
    (exception_category_available exception_category_medical)
    (case_has_exception_category visa_case_1 exception_category_medical)
    (case_has_exception_category visa_case_2 exception_category_diplomatic)
    (exception_claim_available exception_claim_1)
  )
  (:goal
    (and
      (entry_requirement_resolved primary_applicant_1)
      (entry_requirement_resolved secondary_applicant_1)
      (entry_requirement_resolved visa_case_1)
      (entry_requirement_resolved visa_case_2)
    )
  )
)
