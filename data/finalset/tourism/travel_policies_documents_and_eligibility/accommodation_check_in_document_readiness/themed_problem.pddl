(define (problem accommodation_checkin_readiness_problem)
  (:domain accommodation_checkin_document_readiness)
  (:objects lead_guest_1 - lead_guest co_guest_1 - co_guest reservation_1 - reservation_record reservation_2 - reservation_record verifier_1 - verifier_resource verifier_2 - verifier_resource verifier_3 - verifier_resource document_1 - document_instance staff_1 - frontline_staff evidence_type_1 - supporting_evidence_type lead_requirement_profile_1 - lead_requirement_profile co_requirement_profile_1 - co_requirement_profile accommodation_option_1 - accommodation_option id_document_type_1 - identity_document_type id_document_type_2 - identity_document_type preference_code_1 - preference_code preference_code_2 - preference_code payment_method_1 - payment_method payment_method_2 - payment_method eligibility_code_1 - eligibility_code staff_credential_1 - staff_credential manager_approval_token_1 - manager_approval_token manager_approval_token_2 - manager_approval_token supervisor_authorization_1 - supervisor_authorization)
  (:init
    (verifier_resource_available verifier_1)
    (verifier_resource_available verifier_2)
    (verifier_resource_available verifier_3)
    (document_available document_1)
    (frontline_staff_available staff_1)
    (supporting_evidence_available evidence_type_1)
    (lead_has_requirement_profile lead_guest_1 lead_requirement_profile_1)
    (co_has_requirement_profile co_guest_1 co_requirement_profile_1)
    (option_available accommodation_option_1)
    (identity_document_type_available id_document_type_1)
    (identity_document_type_available id_document_type_2)
    (reservation_has_lead reservation_1 lead_guest_1)
    (reservation_has_lead reservation_2 lead_guest_1)
    (reservation_has_co_guest reservation_1 co_guest_1)
    (reservation_has_co_guest reservation_2 co_guest_1)
    (reservation_has_option reservation_1 accommodation_option_1)
    (reservation_has_option reservation_2 accommodation_option_1)
    (reservation_has_identity_document_type reservation_1 id_document_type_1)
    (reservation_has_identity_document_type reservation_2 id_document_type_2)
    (preference_code_available preference_code_1)
    (preference_code_available preference_code_2)
    (payment_method_available payment_method_1)
    (payment_method_available payment_method_2)
    (eligibility_code_available eligibility_code_1)
    (staff_credential_available staff_credential_1)
    (manager_approval_token_available manager_approval_token_1)
    (reservation_has_manager_approval reservation_1 manager_approval_token_1)
    (reservation_has_manager_approval reservation_2 manager_approval_token_2)
    (supervisor_authorization_available supervisor_authorization_1)
  )
  (:goal
    (and
      (ready_for_checkin lead_guest_1)
      (ready_for_checkin co_guest_1)
      (ready_for_checkin reservation_1)
      (ready_for_checkin reservation_2)
    )
  )
)
