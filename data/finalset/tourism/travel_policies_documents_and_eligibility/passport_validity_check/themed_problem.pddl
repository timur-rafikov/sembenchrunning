(define (problem passport_validity_case)
  (:domain passport_validity_check)
  (:objects primary_traveler_1 - primary_traveler secondary_traveler_1 - secondary_traveler assessment_task_1 - assessment_task assessment_task_2 - assessment_task jurisdiction_country_a - jurisdiction jurisdiction_country_b - jurisdiction jurisdiction_country_c - jurisdiction planned_travel_date_1 - travel_date inspector_1 - inspector passport_document_1 - passport_document validity_flag_sufficient - validity_flag entry_condition_standard - entry_condition advice_package_1 - advice_package supporting_doc_type_visa - supporting_document_type supporting_doc_type_ticket - supporting_document_type exemption_type_medical - exemption_type exemption_type_diplomatic - exemption_type service_option_expedited - service_option service_option_premium - service_option policy_ref_visa_rule - policy_reference fee_item_processing - fee_item mitigating_evidence_medical_note - mitigating_evidence mitigating_evidence_diplomatic_note - mitigating_evidence waiver_rule_emergency - waiver_rule)
  (:init
    (jurisdiction_available jurisdiction_country_a)
    (jurisdiction_available jurisdiction_country_b)
    (jurisdiction_available jurisdiction_country_c)
    (travel_date_available planned_travel_date_1)
    (inspector_available inspector_1)
    (passport_document_available passport_document_1)
    (primary_traveler_flag_link primary_traveler_1 validity_flag_sufficient)
    (secondary_traveler_has_entry_condition secondary_traveler_1 entry_condition_standard)
    (advice_package_available advice_package_1)
    (supporting_document_type_available supporting_doc_type_visa)
    (supporting_document_type_available supporting_doc_type_ticket)
    (task_associated_primary_traveler assessment_task_1 primary_traveler_1)
    (task_associated_primary_traveler assessment_task_2 primary_traveler_1)
    (task_associated_secondary_traveler assessment_task_1 secondary_traveler_1)
    (task_associated_secondary_traveler assessment_task_2 secondary_traveler_1)
    (task_associated_advice_package assessment_task_1 advice_package_1)
    (task_associated_advice_package assessment_task_2 advice_package_1)
    (task_requires_supporting_document_type assessment_task_1 supporting_doc_type_visa)
    (task_requires_supporting_document_type assessment_task_2 supporting_doc_type_ticket)
    (exemption_type_available exemption_type_medical)
    (exemption_type_available exemption_type_diplomatic)
    (service_option_available service_option_expedited)
    (service_option_available service_option_premium)
    (policy_reference_available policy_ref_visa_rule)
    (fee_item_available fee_item_processing)
    (mitigating_evidence_available mitigating_evidence_medical_note)
    (task_has_mitigating_evidence assessment_task_1 mitigating_evidence_medical_note)
    (task_has_mitigating_evidence assessment_task_2 mitigating_evidence_diplomatic_note)
    (waiver_rule_available waiver_rule_emergency)
  )
  (:goal
    (and
      (case_approved primary_traveler_1)
      (case_approved secondary_traveler_1)
      (case_approved assessment_task_1)
      (case_approved assessment_task_2)
    )
  )
)
