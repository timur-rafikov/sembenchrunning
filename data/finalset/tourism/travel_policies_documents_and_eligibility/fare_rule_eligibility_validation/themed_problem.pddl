    (fare_rule_matches_primary_itinerary fare_rule_case_1 primary_itinerary_1)
    (fare_rule_matches_primary_itinerary fare_rule_case_2 primary_itinerary_1)
    (fare_rule_matches_companion_itinerary fare_rule_case_1 companion_itinerary_1)
    (fare_rule_matches_companion_itinerary fare_rule_case_2 companion_itinerary_1)
