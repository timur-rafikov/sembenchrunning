    (destination_segment_fare_rule_link destination_segment_primary fare_rule_discount_eligibility)
    (travel_option_available travel_option_candidate_1)
    (document_template_available document_template_passport)
    (document_template_available document_template_visa)
    (request_origin_link policy_exception_request_1 origin_segment_primary)
    (request_origin_link policy_exception_request_2 origin_segment_primary)
    (request_destination_link policy_exception_request_1 destination_segment_primary)
    (request_destination_link policy_exception_request_2 destination_segment_primary)
    (request_option_link policy_exception_request_1 travel_option_candidate_1)
    (request_option_link policy_exception_request_2 travel_option_candidate_1)
    (request_template_form_link policy_exception_request_1 document_template_passport)
    (request_template_form_link policy_exception_request_2 document_template_visa)
    (supporting_requirement_available supporting_requirement_form_a)
    (supporting_requirement_available supporting_requirement_form_b)
    (approver_authority_available approver_authority_manager)
    (approver_authority_available approver_authority_supervisor)
    (exception_token_available exception_token_temp_allowance)
    (specialist_available specialist_reviewer_medical)
