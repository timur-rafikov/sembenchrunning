(define (problem destination_permit_case)
  (:domain destination_permit_adjudication)
  (:objects primary_traveler_lead - primary_traveler companion_traveler_1 - companion_traveler application_case_1 - application_case application_case_2 - application_case permit_option_1 - permit_type_option permit_option_2 - permit_type_option permit_option_3 - permit_type_option destination_jurisdiction_1 - destination_jurisdiction service_channel_consulate - service_channel supporting_document_passport - supporting_document_type condition_profile_primary_1 - condition_profile_primary condition_profile_companion_1 - condition_profile_companion permit_product_variant_1 - permit_product_variant requirement_item_passport_copy - document_requirement_item requirement_item_invitation - document_requirement_item policy_exception_tag_medical - policy_exception_tag policy_exception_tag_humanitarian - policy_exception_tag fee_option_standard - fee_option fee_option_expedited - fee_option verification_token_1 - verification_token health_certificate_vaccine - health_certificate_type sponsorship_document_invitation - sponsorship_document sponsorship_document_affidavit - sponsorship_document clearance_certificate_1 - clearance_certificate)
  (:init
    (permit_option_available permit_option_1)
    (permit_option_available permit_option_2)
    (permit_option_available permit_option_3)
    (jurisdiction_rule_available destination_jurisdiction_1)
    (service_channel_available service_channel_consulate)
    (supporting_document_available supporting_document_passport)
    (primary_condition_profile_linked primary_traveler_lead condition_profile_primary_1)
    (companion_condition_profile_linked companion_traveler_1 condition_profile_companion_1)
    (product_variant_available permit_product_variant_1)
    (requirement_item_available requirement_item_passport_copy)
    (requirement_item_available requirement_item_invitation)
    (case_includes_primary_traveler application_case_1 primary_traveler_lead)
    (case_includes_primary_traveler application_case_2 primary_traveler_lead)
    (case_includes_companion_traveler application_case_1 companion_traveler_1)
    (case_includes_companion_traveler application_case_2 companion_traveler_1)
    (case_includes_product_variant application_case_1 permit_product_variant_1)
    (case_includes_product_variant application_case_2 permit_product_variant_1)
    (case_has_requirement_item application_case_1 requirement_item_passport_copy)
    (case_has_requirement_item application_case_2 requirement_item_invitation)
    (policy_exception_available policy_exception_tag_medical)
    (policy_exception_available policy_exception_tag_humanitarian)
    (fee_option_available fee_option_standard)
    (fee_option_available fee_option_expedited)
    (verification_token_available verification_token_1)
    (health_certificate_available health_certificate_vaccine)
    (sponsorship_document_available sponsorship_document_invitation)
    (case_has_sponsorship_document application_case_1 sponsorship_document_invitation)
    (case_has_sponsorship_document application_case_2 sponsorship_document_affidavit)
    (clearance_certificate_available clearance_certificate_1)
  )
  (:goal
    (and
      (permit_determination_flag primary_traveler_lead)
      (permit_determination_flag companion_traveler_1)
      (permit_determination_flag application_case_1)
      (permit_determination_flag application_case_2)
    )
  )
)
