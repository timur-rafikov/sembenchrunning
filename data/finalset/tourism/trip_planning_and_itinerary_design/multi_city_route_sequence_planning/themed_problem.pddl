(define (problem multi_city_itinerary_problem)
  (:domain multi_city_route_sequence_planning)
  (:objects city_occurrence_a_1 - city_occurrence_outbound city_occurrence_b_1 - city_occurrence_inbound itinerary_segment_1 - itinerary_segment itinerary_segment_2 - itinerary_segment transport_resource_1 - transport_asset transport_resource_2 - transport_asset transport_resource_3 - transport_asset activity_category_1 - activity_category venue_1 - venue_or_service auxiliary_resource_1 - auxiliary_resource outbound_option_1 - outbound_option inbound_option_1 - inbound_option booking_candidate_1 - booking_candidate attraction_choice_1 - attraction_choice attraction_choice_2 - attraction_choice special_request_1 - special_request special_request_2 - special_request accommodation_option_1 - accommodation_option accommodation_option_2 - accommodation_option time_window_1 - time_window preference_tag_a_1 - preference_tag_a constraint_tag_b_1 - constraint_tag_b constraint_tag_b_2 - constraint_tag_b preference_tag_b_1 - preference_tag_b)
  (:init
    (transport_resource_available transport_resource_1)
    (transport_resource_available transport_resource_2)
    (transport_resource_available transport_resource_3)
    (activity_category_available activity_category_1)
    (venue_available venue_1)
    (auxiliary_resource_available auxiliary_resource_1)
    (occurrence_outbound_to_outbound_option city_occurrence_a_1 outbound_option_1)
    (occurrence_inbound_to_inbound_option city_occurrence_b_1 inbound_option_1)
    (booking_slot_available booking_candidate_1)
    (attraction_choice_available attraction_choice_1)
    (attraction_choice_available attraction_choice_2)
    (segment_to_occurrence_outbound_compat itinerary_segment_1 city_occurrence_a_1)
    (segment_to_occurrence_outbound_compat itinerary_segment_2 city_occurrence_a_1)
    (segment_to_occurrence_inbound_compat itinerary_segment_1 city_occurrence_b_1)
    (segment_to_occurrence_inbound_compat itinerary_segment_2 city_occurrence_b_1)
    (segment_to_booking_candidate_compat itinerary_segment_1 booking_candidate_1)
    (segment_to_booking_candidate_compat itinerary_segment_2 booking_candidate_1)
    (segment_attraction_compatibility itinerary_segment_1 attraction_choice_1)
    (segment_attraction_compatibility itinerary_segment_2 attraction_choice_2)
    (special_request_available special_request_1)
    (special_request_available special_request_2)
    (accommodation_option_available accommodation_option_1)
    (accommodation_option_available accommodation_option_2)
    (time_window_available time_window_1)
    (preference_tag_a_available preference_tag_a_1)
    (constraint_tag_available constraint_tag_b_1)
    (segment_constraint_binding itinerary_segment_1 constraint_tag_b_1)
    (segment_constraint_binding itinerary_segment_2 constraint_tag_b_2)
    (preference_tag_b_available preference_tag_b_1)
  )
  (:goal
    (and
      (reservation_confirmed city_occurrence_a_1)
      (reservation_confirmed city_occurrence_b_1)
      (reservation_confirmed itinerary_segment_1)
      (reservation_confirmed itinerary_segment_2)
    )
  )
)
