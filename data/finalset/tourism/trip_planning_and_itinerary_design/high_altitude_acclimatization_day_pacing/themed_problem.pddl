(define (problem high_altitude_day_pacing_problem)
  (:domain high_altitude_acclimatization_domain)
  (:objects acclimatization_day_1 - acclimatization_day activity_day_1 - activity_day itinerary_variant_1 - itinerary_variant itinerary_variant_2 - itinerary_variant transport_option_1 - transport_option transport_option_2 - transport_option transport_option_3 - transport_option time_slot_morning - time_slot personnel_guide_1 - personnel_resource equipment_oxygen_kit_1 - consumable_equipment altitude_zone_3000m - altitude_zone terrain_class_alpine - terrain_class accommodation_basecamp_1 - accommodation permit_area_1 - permit_document permit_area_2 - permit_document meal_option_standard - meal_option meal_option_high_calorie - meal_option weather_window_morning_clear - weather_window weather_window_afternoon_clear - weather_window acclimatization_profile_standard - acclimatization_profile medical_supply_first_aid_kit_1 - medical_supply optional_excursion_side_trip_1 - optional_excursion optional_excursion_side_trip_2 - optional_excursion safety_briefing_standard - safety_briefing)
  (:init
    (transport_available transport_option_1)
    (transport_available transport_option_2)
    (transport_available transport_option_3)
    (time_slot_available time_slot_morning)
    (personnel_available personnel_guide_1)
    (equipment_available equipment_oxygen_kit_1)
    (day_in_altitude_zone acclimatization_day_1 altitude_zone_3000m)
    (activity_day_in_terrain_class activity_day_1 terrain_class_alpine)
    (accommodation_available accommodation_basecamp_1)
    (permit_available permit_area_1)
    (permit_available permit_area_2)
    (variant_includes_acclimatization_day itinerary_variant_1 acclimatization_day_1)
    (variant_includes_acclimatization_day itinerary_variant_2 acclimatization_day_1)
    (variant_includes_activity_day itinerary_variant_1 activity_day_1)
    (variant_includes_activity_day itinerary_variant_2 activity_day_1)
    (variant_includes_accommodation itinerary_variant_1 accommodation_basecamp_1)
    (variant_includes_accommodation itinerary_variant_2 accommodation_basecamp_1)
    (variant_has_permit_requirement itinerary_variant_1 permit_area_1)
    (variant_has_permit_requirement itinerary_variant_2 permit_area_2)
    (meal_option_available meal_option_standard)
    (meal_option_available meal_option_high_calorie)
    (weather_window_available weather_window_morning_clear)
    (weather_window_available weather_window_afternoon_clear)
    (acclimatization_profile_available acclimatization_profile_standard)
    (medical_supply_available medical_supply_first_aid_kit_1)
    (optional_excursion_available optional_excursion_side_trip_1)
    (variant_has_optional_excursion itinerary_variant_1 optional_excursion_side_trip_1)
    (variant_has_optional_excursion itinerary_variant_2 optional_excursion_side_trip_2)
    (safety_briefing_available safety_briefing_standard)
  )
  (:goal
    (and
      (itinerary_element_confirmed acclimatization_day_1)
      (itinerary_element_confirmed activity_day_1)
      (itinerary_element_confirmed itinerary_variant_1)
      (itinerary_element_confirmed itinerary_variant_2)
    )
  )
)
