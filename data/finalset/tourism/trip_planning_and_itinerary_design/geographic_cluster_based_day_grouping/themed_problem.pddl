(define (problem itinerary_geocluster_instance)
  (:domain tourism_geocluster_day_grouping)
  (:objects cluster_slot_a_1 - geo_cluster_slot_a cluster_slot_b_1 - geo_cluster_slot_b day_plan_1 - day_plan day_plan_2 - day_plan transfer_shuttle_1 - transport_resource transfer_shuttle_2 - transport_resource transfer_taxi_1 - transport_resource time_window_1 - time_window service_provider_1 - service_provider activity_token_1 - activity_token geo_zone_central - geo_zone subzone_east - subzone day_package_1 - day_package attraction_museum - attraction attraction_park - attraction optional_service_meal_standard - optional_service optional_service_guide_upgrade - optional_service preference_profile_leisure - preference_profile preference_profile_active - preference_profile constraint_dietary - constraint_tag feature_priority_access - feature_flag promotion_early_bird - promotion promotion_bundle - promotion time_preference_early_start - time_preference)
  (:init
    (transport_available transfer_shuttle_1)
    (transport_available transfer_shuttle_2)
    (transport_available transfer_taxi_1)
    (time_window_available time_window_1)
    (provider_available service_provider_1)
    (activity_token_available activity_token_1)
    (cluster_slot_mapped_to_zone cluster_slot_a_1 geo_zone_central)
    (cluster_slot_mapped_to_subzone cluster_slot_b_1 subzone_east)
    (day_package_available day_package_1)
    (attraction_available attraction_museum)
    (attraction_available attraction_park)
    (day_plan_includes_cluster_slot_a day_plan_1 cluster_slot_a_1)
    (day_plan_includes_cluster_slot_a day_plan_2 cluster_slot_a_1)
    (day_plan_includes_cluster_slot_b day_plan_1 cluster_slot_b_1)
    (day_plan_includes_cluster_slot_b day_plan_2 cluster_slot_b_1)
    (day_plan_assigned_package day_plan_1 day_package_1)
    (day_plan_assigned_package day_plan_2 day_package_1)
    (day_plan_has_attraction day_plan_1 attraction_museum)
    (day_plan_has_attraction day_plan_2 attraction_park)
    (optional_service_available optional_service_meal_standard)
    (optional_service_available optional_service_guide_upgrade)
    (preference_profile_available preference_profile_leisure)
    (preference_profile_available preference_profile_active)
    (constraint_tag_available constraint_dietary)
    (feature_flag_available feature_priority_access)
    (promotion_available promotion_early_bird)
    (day_plan_has_promotion day_plan_1 promotion_early_bird)
    (day_plan_has_promotion day_plan_2 promotion_bundle)
    (time_preference_available time_preference_early_start)
  )
  (:goal
    (and
      (item_finalized cluster_slot_a_1)
      (item_finalized cluster_slot_b_1)
      (item_finalized day_plan_1)
      (item_finalized day_plan_2)
    )
  )
)
