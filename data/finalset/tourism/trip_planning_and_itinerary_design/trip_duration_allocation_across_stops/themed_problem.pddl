(define (problem trip_duration_allocation_problem)
  (:domain trip_duration_allocation_domain)
  (:objects stop_slot_a_1 - stop_slot_a stop_slot_b_1 - stop_slot_b itinerary_element_1 - itinerary_day itinerary_element_2 - itinerary_day time_allocation_unit_1 - time_allocation_unit time_allocation_unit_2 - time_allocation_unit time_allocation_unit_3 - time_allocation_unit activity_template_1 - activity_template service_option_1 - service_option experience_preference_1 - experience_preference_token route_leg_1 - route_leg time_window_slot_1 - time_window_slot allocation_package_1 - allocation_package booking_option_1 - booking_option booking_option_2 - booking_option site_attribute_1 - site_attribute site_attribute_2 - site_attribute traveler_constraint_1 - traveler_constraint traveler_constraint_2 - traveler_constraint available_time_budget_1 - available_time_budget upgrade_option_1 - upgrade_option preference_tag_1 - preference_tag preference_tag_2 - preference_tag temporal_preference_1 - temporal_preference_token)
  (:init
    (time_allocation_unit_available time_allocation_unit_1)
    (time_allocation_unit_available time_allocation_unit_2)
    (time_allocation_unit_available time_allocation_unit_3)
    (activity_template_available activity_template_1)
    (service_option_available service_option_1)
    (experience_preference_available experience_preference_1)
    (stop_slot_a_assigned_route_leg stop_slot_a_1 route_leg_1)
    (stop_slot_b_assigned_time_window stop_slot_b_1 time_window_slot_1)
    (allocation_package_available allocation_package_1)
    (booking_option_available booking_option_1)
    (booking_option_available booking_option_2)
    (itinerary_element_assigned_stop_slot_a itinerary_element_1 stop_slot_a_1)
    (itinerary_element_assigned_stop_slot_a itinerary_element_2 stop_slot_a_1)
    (itinerary_element_assigned_stop_slot_b itinerary_element_1 stop_slot_b_1)
    (itinerary_element_assigned_stop_slot_b itinerary_element_2 stop_slot_b_1)
    (itinerary_element_assigned_allocation_package itinerary_element_1 allocation_package_1)
    (itinerary_element_assigned_allocation_package itinerary_element_2 allocation_package_1)
    (itinerary_element_assigned_booking_option itinerary_element_1 booking_option_1)
    (itinerary_element_assigned_booking_option itinerary_element_2 booking_option_2)
    (site_attribute_available site_attribute_1)
    (site_attribute_available site_attribute_2)
    (traveler_constraint_available traveler_constraint_1)
    (traveler_constraint_available traveler_constraint_2)
    (available_time_budget_available available_time_budget_1)
    (upgrade_option_available upgrade_option_1)
    (preference_tag_available preference_tag_1)
    (itinerary_element_assigned_preference_tag itinerary_element_1 preference_tag_1)
    (itinerary_element_assigned_preference_tag itinerary_element_2 preference_tag_2)
    (temporal_preference_available temporal_preference_1)
  )
  (:goal
    (and
      (itinerary_element_finalized stop_slot_a_1)
      (itinerary_element_finalized stop_slot_b_1)
      (itinerary_element_finalized itinerary_element_1)
      (itinerary_element_finalized itinerary_element_2)
    )
  )
)
