(define (problem trip_itinerary_weather_reordering_problem)
  (:domain weather_aware_itinerary_planning_domain)
  (:objects day1_morning_segment - day_segment_a day1_afternoon_segment - day_segment_b primary_itinerary_plan - itinerary_plan alternate_itinerary_plan - itinerary_plan transport_option_train - transport_option transport_option_bus - transport_option transport_option_taxi - transport_option weather_forecast_day1 - weather_forecast venue_art_museum - venue activity_sightseeing_tour - activity_candidate weather_window_precipitation_ok - weather_window_type_a weather_window_temperature_ok - weather_window_type_b reservation_slot_1 - reservation time_window_morning - time_window time_window_afternoon - time_window special_request_accessibility - special_request special_request_dietary - special_request preference_relaxed_pace - traveler_preference preference_active_pace - traveler_preference weather_constraint_no_heavy_rain - weather_constraint equipment_raincoat - equipment_provision guideline_safety_brief - guideline guideline_crowd_control - guideline contingency_indoor_tour - contingency_option)
  (:init
    (transport_available transport_option_train)
    (transport_available transport_option_bus)
    (transport_available transport_option_taxi)
    (forecast_available weather_forecast_day1)
    (venue_available venue_art_museum)
    (activity_candidate_available activity_sightseeing_tour)
    (day_segment_a_weather_window_binding day1_morning_segment weather_window_precipitation_ok)
    (day_segment_b_weather_window_binding day1_afternoon_segment weather_window_temperature_ok)
    (reservation_slot_available reservation_slot_1)
    (time_window_available time_window_morning)
    (time_window_available time_window_afternoon)
    (plan_has_daysegment_a_association primary_itinerary_plan day1_morning_segment)
    (plan_has_daysegment_a_association alternate_itinerary_plan day1_morning_segment)
    (plan_has_daysegment_b_association primary_itinerary_plan day1_afternoon_segment)
    (plan_has_daysegment_b_association alternate_itinerary_plan day1_afternoon_segment)
    (plan_has_reservation_binding primary_itinerary_plan reservation_slot_1)
    (plan_has_reservation_binding alternate_itinerary_plan reservation_slot_1)
    (plan_has_timewindow_binding primary_itinerary_plan time_window_morning)
    (plan_has_timewindow_binding alternate_itinerary_plan time_window_afternoon)
    (special_request_available special_request_accessibility)
    (special_request_available special_request_dietary)
    (traveler_preference_available preference_relaxed_pace)
    (traveler_preference_available preference_active_pace)
    (weather_constraint_available weather_constraint_no_heavy_rain)
    (equipment_available equipment_raincoat)
    (guideline_available guideline_safety_brief)
    (plan_has_guideline_binding primary_itinerary_plan guideline_safety_brief)
    (plan_has_guideline_binding alternate_itinerary_plan guideline_crowd_control)
    (contingency_option_available contingency_indoor_tour)
  )
  (:goal
    (and
      (slot_integration_completed day1_morning_segment)
      (slot_integration_completed day1_afternoon_segment)
      (slot_integration_completed primary_itinerary_plan)
      (slot_integration_completed alternate_itinerary_plan)
    )
  )
)
