(define (problem itinerary_planning_instance)
  (:domain low_transfer_fatigue_route_design)
  (:objects origin_segment_1 - origin_segment destination_segment_1 - destination_segment stop_plan_1 - stop_plan stop_plan_2 - stop_plan transport_option_1 - transport_option transport_option_2 - transport_option transport_option_3 - transport_option time_profile_1 - time_profile service_resource_1 - service_resource activity_option_1 - activity_option transfer_in_node_1 - transfer_in transfer_out_node_1 - transfer_out itinerary_proposal_1 - itinerary_proposal accommodation_option_1 - accommodation_option accommodation_option_2 - accommodation_option theme_preference_1 - theme_preference theme_preference_2 - theme_preference traveler_preference_1 - traveler_preference traveler_preference_2 - traveler_preference fatigue_profile_1 - fatigue_profile service_option_1 - service_option site_permit_1 - site_permit site_permit_2 - site_permit temporal_constraint_1 - temporal_constraint)
  (:init
    (transport_available transport_option_1)
    (transport_available transport_option_2)
    (transport_available transport_option_3)
    (time_profile_available time_profile_1)
    (service_resource_available service_resource_1)
    (activity_available activity_option_1)
    (origin_segment_has_transfer_in origin_segment_1 transfer_in_node_1)
    (destination_segment_has_transfer_out destination_segment_1 transfer_out_node_1)
    (itinerary_proposal_available itinerary_proposal_1)
    (accommodation_available accommodation_option_1)
    (accommodation_available accommodation_option_2)
    (stop_plan_origin_segment_link stop_plan_1 origin_segment_1)
    (stop_plan_origin_segment_link stop_plan_2 origin_segment_1)
    (stop_plan_destination_segment_link stop_plan_1 destination_segment_1)
    (stop_plan_destination_segment_link stop_plan_2 destination_segment_1)
    (stop_plan_in_proposal stop_plan_1 itinerary_proposal_1)
    (stop_plan_in_proposal stop_plan_2 itinerary_proposal_1)
    (stop_plan_has_accommodation_option stop_plan_1 accommodation_option_1)
    (stop_plan_has_accommodation_option stop_plan_2 accommodation_option_2)
    (theme_preference_available theme_preference_1)
    (theme_preference_available theme_preference_2)
    (traveler_preference_available traveler_preference_1)
    (traveler_preference_available traveler_preference_2)
    (fatigue_profile_available fatigue_profile_1)
    (service_option_available service_option_1)
    (site_permit_available site_permit_1)
    (stop_plan_has_site_permit stop_plan_1 site_permit_1)
    (stop_plan_has_site_permit stop_plan_2 site_permit_2)
    (temporal_constraint_available temporal_constraint_1)
  )
  (:goal
    (and
      (transfer_assigned origin_segment_1)
      (transfer_assigned destination_segment_1)
      (transfer_assigned stop_plan_1)
      (transfer_assigned stop_plan_2)
    )
  )
)
