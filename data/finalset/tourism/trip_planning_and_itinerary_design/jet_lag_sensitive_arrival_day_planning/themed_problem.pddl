(define (problem arrival_day_planning_problem)
  (:domain jet_lag_arrival_day_planning)
  (:objects slot_primary_arrival - itinerary_slot_primary slot_secondary_arrival - itinerary_slot_secondary itinerary_template_1 - itinerary_template itinerary_template_2 - itinerary_template flight_option_1 - transport_option flight_option_2 - transport_option flight_option_3 - transport_option arrival_window_morning - arrival_time_window airport_transfer_standard - transfer_service amenity_breakfast_included - amenity_option daypart_morning - daypart activity_light - activity_category hotel_standard_room - accommodation_option package_meal_included - package_component package_welcome_kit - package_component room_feature_quiet_floor - room_feature room_feature_extra_bed - room_feature special_service_priority_checkin - special_service special_service_accessibility_support - special_service circadian_profile_standard - circadian_profile priority_service_express_checkin - priority_service special_request_early_checkin - special_request special_request_late_checkout - special_request health_recommendation_jetlag_guidance - health_recommendation)
  (:init
    (transport_option_available flight_option_1)
    (transport_option_available flight_option_2)
    (transport_option_available flight_option_3)
    (arrival_window_available arrival_window_morning)
    (transfer_service_available airport_transfer_standard)
    (amenity_available amenity_breakfast_included)
    (slot_daypart_compatible slot_primary_arrival daypart_morning)
    (slot_activity_compatible slot_secondary_arrival activity_light)
    (accommodation_available hotel_standard_room)
    (package_component_available package_meal_included)
    (package_component_available package_welcome_kit)
    (template_includes_primary_slot itinerary_template_1 slot_primary_arrival)
    (template_includes_primary_slot itinerary_template_2 slot_primary_arrival)
    (template_includes_secondary_slot itinerary_template_1 slot_secondary_arrival)
    (template_includes_secondary_slot itinerary_template_2 slot_secondary_arrival)
    (template_offers_accommodation itinerary_template_1 hotel_standard_room)
    (template_offers_accommodation itinerary_template_2 hotel_standard_room)
    (template_includes_package_component itinerary_template_1 package_meal_included)
    (template_includes_package_component itinerary_template_2 package_welcome_kit)
    (room_feature_available room_feature_quiet_floor)
    (room_feature_available room_feature_extra_bed)
    (special_service_available special_service_priority_checkin)
    (special_service_available special_service_accessibility_support)
    (circadian_profile_available circadian_profile_standard)
    (priority_service_available priority_service_express_checkin)
    (special_request_available special_request_early_checkin)
    (template_has_special_request itinerary_template_1 special_request_early_checkin)
    (template_has_special_request itinerary_template_2 special_request_late_checkout)
    (health_recommendation_available health_recommendation_jetlag_guidance)
  )
  (:goal
    (and
      (entity_transport_binding_confirmed slot_primary_arrival)
      (entity_transport_binding_confirmed slot_secondary_arrival)
      (entity_transport_binding_confirmed itinerary_template_1)
      (entity_transport_binding_confirmed itinerary_template_2)
    )
  )
)
