(define (problem attraction_priority_day_planning_problem)
  (:domain attraction_priority_day_planning_domain)
  (:objects day_instance - day day_section_instance - day_section visit_plan_1 - visit_plan visit_plan_2 - visit_plan attraction_candidate_1 - attraction_candidate attraction_candidate_2 - attraction_candidate attraction_candidate_3 - attraction_candidate time_window_instance - time_window transport_option_instance - transport_option preference_token_instance - temporal_preference_token slot_a_instance - slot_a slot_b_instance - slot_b tour_block_instance - tour_block logistic_item_1 - logistic_item logistic_item_2 - logistic_item special_request_1 - special_request special_request_2 - special_request service_1 - service service_2 - service priority_token_instance - location_priority_token optional_feature_instance - optional_feature attraction_attribute_1 - attraction_attribute attraction_attribute_2 - attraction_attribute guide_option_instance - guide_option)
  (:init
    (candidate_available attraction_candidate_1)
    (candidate_available attraction_candidate_2)
    (candidate_available attraction_candidate_3)
    (time_window_available time_window_instance)
    (transport_available transport_option_instance)
    (temporal_preference_token_available preference_token_instance)
    (day_slot_a_link day_instance slot_a_instance)
    (day_section_slot_b_link day_section_instance slot_b_instance)
    (tour_block_available tour_block_instance)
    (logistic_item_available logistic_item_1)
    (logistic_item_available logistic_item_2)
    (itinerary_element_assigned_day visit_plan_1 day_instance)
    (itinerary_element_assigned_day visit_plan_2 day_instance)
    (itinerary_element_assigned_day_section visit_plan_1 day_section_instance)
    (itinerary_element_assigned_day_section visit_plan_2 day_section_instance)
    (itinerary_element_in_tour_block visit_plan_1 tour_block_instance)
    (itinerary_element_in_tour_block visit_plan_2 tour_block_instance)
    (itinerary_element_has_logistic visit_plan_1 logistic_item_1)
    (itinerary_element_has_logistic visit_plan_2 logistic_item_2)
    (special_request_available special_request_1)
    (special_request_available special_request_2)
    (service_available service_1)
    (service_available service_2)
    (location_priority_token_available priority_token_instance)
    (optional_feature_available optional_feature_instance)
    (attraction_attribute_available attraction_attribute_1)
    (itinerary_element_has_attraction_attribute visit_plan_1 attraction_attribute_1)
    (itinerary_element_has_attraction_attribute visit_plan_2 attraction_attribute_2)
    (guide_option_available guide_option_instance)
  )
  (:goal
    (and
      (itinerary_element_confirmed day_instance)
      (itinerary_element_confirmed day_section_instance)
      (itinerary_element_confirmed visit_plan_1)
      (itinerary_element_confirmed visit_plan_2)
    )
  )
)
