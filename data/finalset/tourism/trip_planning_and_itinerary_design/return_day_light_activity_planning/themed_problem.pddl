(define (problem return_day_light_activity_planning_problem)
  (:domain return_day_light_activity_planning_domain)
  (:objects primary_return_leg_1 - return_leg_primary secondary_return_leg_1 - return_leg_secondary itinerary_proposal_a - itinerary_proposal itinerary_proposal_b - itinerary_proposal transport_option_1 - transport_option transport_option_2 - transport_option transport_option_3 - transport_option activity_option_1 - activity_option venue_service_1 - venue_or_service optional_experience_1 - optional_experience daylight_window_primary_1 - daylight_window_primary daylight_window_secondary_1 - daylight_window_secondary activity_bundle_1 - activity_bundle_reservation sub_activity_1 - sub_activity_option sub_activity_2 - sub_activity_option scenic_feature_1 - scenic_feature scenic_feature_2 - scenic_feature service_addon_1 - service_addon service_addon_2 - service_addon time_constraint_1 - time_constraint logistics_option_1 - logistics_option promotional_offer_1 - promotional_offer promotional_offer_2 - promotional_offer special_requirement_1 - special_requirement)
  (:init
    (transport_option_available transport_option_1)
    (transport_option_available transport_option_2)
    (transport_option_available transport_option_3)
    (activity_option_available activity_option_1)
    (venue_available venue_service_1)
    (optional_experience_available optional_experience_1)
    (primary_leg_daylight_window_link primary_return_leg_1 daylight_window_primary_1)
    (secondary_leg_daylight_window_link secondary_return_leg_1 daylight_window_secondary_1)
    (bundle_slot_available activity_bundle_1)
    (sub_activity_available sub_activity_1)
    (sub_activity_available sub_activity_2)
    (proposal_primary_leg_link itinerary_proposal_a primary_return_leg_1)
    (proposal_primary_leg_link itinerary_proposal_b primary_return_leg_1)
    (proposal_secondary_leg_link itinerary_proposal_a secondary_return_leg_1)
    (proposal_secondary_leg_link itinerary_proposal_b secondary_return_leg_1)
    (proposal_bundle_link itinerary_proposal_a activity_bundle_1)
    (proposal_bundle_link itinerary_proposal_b activity_bundle_1)
    (proposal_sub_activity_link itinerary_proposal_a sub_activity_1)
    (proposal_sub_activity_link itinerary_proposal_b sub_activity_2)
    (scenic_feature_available scenic_feature_1)
    (scenic_feature_available scenic_feature_2)
    (service_addon_available service_addon_1)
    (service_addon_available service_addon_2)
    (time_constraint_available time_constraint_1)
    (logistics_option_available logistics_option_1)
    (promotional_offer_available promotional_offer_1)
    (proposal_promotional_offer_link itinerary_proposal_a promotional_offer_1)
    (proposal_promotional_offer_link itinerary_proposal_b promotional_offer_2)
    (special_requirement_available special_requirement_1)
  )
  (:goal
    (and
      (confirmed primary_return_leg_1)
      (confirmed secondary_return_leg_1)
      (confirmed itinerary_proposal_a)
      (confirmed itinerary_proposal_b)
    )
  )
)
