(define (problem mixed_interest_trip_instance)
  (:domain mixed_interest_group_itinerary_planning)
  (:objects day_slot_primary_1 - primary_day_slot day_slot_secondary_1 - secondary_day_slot itinerary_segment_morning - itinerary_segment itinerary_segment_afternoon - itinerary_segment vendor_option_transport - vendor_option vendor_option_accommodation - vendor_option vendor_option_tour_operator - vendor_option activity_proposal_museum_visit - activity_proposal service_provider_museum_guide - service_provider preference_group_dining - shared_preference_option location_a_city_center - location_type_a location_b_national_park - location_type_b schedule_slot_day1_morning - schedule_slot package_option_combined_ticket - package_option package_option_meal_addon - package_option amenity_wifi - amenity amenity_parking - amenity role_leader - participant_role role_participant - participant_role temporal_constraint_morning_only - temporal_constraint special_service_private_guide - special_service policy_option_group_discount - policy_option policy_option_special_waiver - policy_option regulatory_requirement_permit - regulatory_requirement)
  (:init
    (vendor_option_available vendor_option_transport)
    (vendor_option_available vendor_option_accommodation)
    (vendor_option_available vendor_option_tour_operator)
    (activity_proposal_available activity_proposal_museum_visit)
    (service_provider_available service_provider_museum_guide)
    (preference_option_available preference_group_dining)
    (primary_slot_at_location_a day_slot_primary_1 location_a_city_center)
    (secondary_slot_at_location_b day_slot_secondary_1 location_b_national_park)
    (schedule_slot_open schedule_slot_day1_morning)
    (package_option_available package_option_combined_ticket)
    (package_option_available package_option_meal_addon)
    (segment_primary_slot_link itinerary_segment_morning day_slot_primary_1)
    (segment_primary_slot_link itinerary_segment_afternoon day_slot_primary_1)
    (segment_secondary_slot_link itinerary_segment_morning day_slot_secondary_1)
    (segment_secondary_slot_link itinerary_segment_afternoon day_slot_secondary_1)
    (segment_schedule_slot_link itinerary_segment_morning schedule_slot_day1_morning)
    (segment_schedule_slot_link itinerary_segment_afternoon schedule_slot_day1_morning)
    (segment_package_link itinerary_segment_morning package_option_combined_ticket)
    (segment_package_link itinerary_segment_afternoon package_option_meal_addon)
    (amenity_available amenity_wifi)
    (amenity_available amenity_parking)
    (participant_role_available role_leader)
    (participant_role_available role_participant)
    (temporal_constraint_available temporal_constraint_morning_only)
    (special_service_available special_service_private_guide)
    (policy_option_available policy_option_group_discount)
    (segment_policy_link itinerary_segment_morning policy_option_group_discount)
    (segment_policy_link itinerary_segment_afternoon policy_option_special_waiver)
    (regulatory_requirement_available regulatory_requirement_permit)
  )
  (:goal
    (and
      (reservation_confirmed day_slot_primary_1)
      (reservation_confirmed day_slot_secondary_1)
      (reservation_confirmed itinerary_segment_morning)
      (reservation_confirmed itinerary_segment_afternoon)
    )
  )
)
