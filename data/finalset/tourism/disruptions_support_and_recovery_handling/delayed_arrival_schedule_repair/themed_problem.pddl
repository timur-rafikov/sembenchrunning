(define (problem delayed_arrival_recovery_problem)
  (:domain delayed_arrival_schedule_repair_domain)
  (:objects arrival_segment_1 - arrival_segment connecting_segment_1 - connecting_segment recovery_coordinator_1 - recovery_coordinator recovery_coordinator_2 - recovery_coordinator communication_channel_1 - communication_channel communication_channel_2 - communication_channel communication_channel_3 - communication_channel affected_booking_1 - affected_booking provider_representative_1 - provider_representative compensation_option_1 - compensation_option arrival_delay_scenario_1 - arrival_delay_scenario connection_delay_scenario_1 - connection_delay_scenario itinerary_proposal_1 - itinerary_proposal vendor_confirmation_document_1 - vendor_confirmation_document vendor_confirmation_document_2 - vendor_confirmation_document policy_reference_1 - policy_reference policy_reference_2 - policy_reference escalation_path_1 - escalation_path escalation_path_2 - escalation_path compensation_claim_1 - compensation_claim accommodation_offer_1 - accommodation_offer voucher_offer_1 - voucher_offer voucher_offer_2 - voucher_offer third_party_contact_1 - third_party_contact)
  (:init
    (entity_available_communication_channel communication_channel_1)
    (entity_available_communication_channel communication_channel_2)
    (entity_available_communication_channel communication_channel_3)
    (entity_available_affected_booking affected_booking_1)
    (entity_available_provider_representative provider_representative_1)
    (entity_available_compensation_option compensation_option_1)
    (arrival_segment_has_delay_scenario arrival_segment_1 arrival_delay_scenario_1)
    (connecting_segment_has_connection_delay_scenario connecting_segment_1 connection_delay_scenario_1)
    (entity_available_itinerary_proposal itinerary_proposal_1)
    (vendor_confirmation_document_available vendor_confirmation_document_1)
    (vendor_confirmation_document_available vendor_confirmation_document_2)
    (coordinator_responsible_for_arrival_segment recovery_coordinator_1 arrival_segment_1)
    (coordinator_responsible_for_arrival_segment recovery_coordinator_2 arrival_segment_1)
    (coordinator_responsible_for_connecting_segment recovery_coordinator_1 connecting_segment_1)
    (coordinator_responsible_for_connecting_segment recovery_coordinator_2 connecting_segment_1)
    (coordinator_responsible_for_itinerary_proposal recovery_coordinator_1 itinerary_proposal_1)
    (coordinator_responsible_for_itinerary_proposal recovery_coordinator_2 itinerary_proposal_1)
    (coordinator_attached_vendor_confirmation_document recovery_coordinator_1 vendor_confirmation_document_1)
    (coordinator_attached_vendor_confirmation_document recovery_coordinator_2 vendor_confirmation_document_2)
    (policy_reference_available policy_reference_1)
    (policy_reference_available policy_reference_2)
    (escalation_path_available escalation_path_1)
    (escalation_path_available escalation_path_2)
    (compensation_claim_available compensation_claim_1)
    (accommodation_offer_available accommodation_offer_1)
    (voucher_offer_available voucher_offer_1)
    (coordinator_linked_voucher_offer recovery_coordinator_1 voucher_offer_1)
    (coordinator_linked_voucher_offer recovery_coordinator_2 voucher_offer_2)
    (third_party_contact_available third_party_contact_1)
  )
  (:goal
    (and
      (entity_recovery_finalized arrival_segment_1)
      (entity_recovery_finalized connecting_segment_1)
      (entity_recovery_finalized recovery_coordinator_1)
      (entity_recovery_finalized recovery_coordinator_2)
    )
  )
)
