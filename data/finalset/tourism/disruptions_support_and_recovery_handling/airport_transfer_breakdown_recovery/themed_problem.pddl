(define (problem airport_transfer_breakdown_case)
  (:domain airport_transfer_breakdown_recovery)
  (:objects local_unit_1 - local_transfer_unit partner_unit_1 - partner_transfer_unit recovery_coordinator_1 - recovery_coordinator recovery_coordinator_2 - recovery_coordinator replacement_vehicle_1 - replacement_vehicle replacement_vehicle_2 - replacement_vehicle replacement_vehicle_3 - replacement_vehicle transport_option_1 - transport_option third_party_provider_1 - third_party_provider compensation_offer_1 - compensation_offer pickup_location_1 - pickup_location dropoff_location_1 - dropoff_location recovery_plan_1 - recovery_plan itinerary_segment_1 - itinerary_segment itinerary_segment_2 - itinerary_segment policy_document_1 - policy_document policy_document_2 - policy_document authorization_credential_1 - authorization_credential authorization_credential_2 - authorization_credential payment_instruction_1 - payment_instruction maintenance_resource_1 - maintenance_resource insurer_claim_1 - insurer_claim insurer_claim_2 - insurer_claim safety_report_1 - safety_report)
  (:init
    (replacement_available replacement_vehicle_1)
    (replacement_available replacement_vehicle_2)
    (replacement_available replacement_vehicle_3)
    (transport_option_available transport_option_1)
    (third_party_provider_available third_party_provider_1)
    (compensation_offer_available compensation_offer_1)
    (local_unit_assigned_pickup local_unit_1 pickup_location_1)
    (partner_unit_assigned_dropoff partner_unit_1 dropoff_location_1)
    (plan_pending recovery_plan_1)
    (itinerary_segment_pending itinerary_segment_1)
    (itinerary_segment_pending itinerary_segment_2)
    (coordinator_allocated_local_unit recovery_coordinator_1 local_unit_1)
    (coordinator_allocated_local_unit recovery_coordinator_2 local_unit_1)
    (coordinator_allocated_partner_unit recovery_coordinator_1 partner_unit_1)
    (coordinator_allocated_partner_unit recovery_coordinator_2 partner_unit_1)
    (coordinator_linked_recovery_plan recovery_coordinator_1 recovery_plan_1)
    (coordinator_linked_recovery_plan recovery_coordinator_2 recovery_plan_1)
    (coordinator_has_itinerary_segment recovery_coordinator_1 itinerary_segment_1)
    (coordinator_has_itinerary_segment recovery_coordinator_2 itinerary_segment_2)
    (policy_document_available policy_document_1)
    (policy_document_available policy_document_2)
    (authorization_credential_available authorization_credential_1)
    (authorization_credential_available authorization_credential_2)
    (payment_instruction_available payment_instruction_1)
    (maintenance_resource_available maintenance_resource_1)
    (insurer_claim_available insurer_claim_1)
    (coordinator_linked_claim recovery_coordinator_1 insurer_claim_1)
    (coordinator_linked_claim recovery_coordinator_2 insurer_claim_2)
    (safety_report_available safety_report_1)
  )
  (:goal
    (and
      (entity_closure_recorded local_unit_1)
      (entity_closure_recorded partner_unit_1)
      (entity_closure_recorded recovery_coordinator_1)
      (entity_closure_recorded recovery_coordinator_2)
    )
  )
)
