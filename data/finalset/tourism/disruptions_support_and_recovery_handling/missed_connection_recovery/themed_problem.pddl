(define (problem missed_connection_recovery_problem)
  (:domain missed_connection_recovery_domain)
  (:objects inbound_segment_1 - inbound_flight_segment outbound_segment_1 - outbound_flight_segment support_team_alpha - support_agent_team support_team_beta - support_agent_team agent_slot_1 - agent_resource_slot agent_slot_2 - agent_resource_slot agent_slot_3 - agent_resource_slot flight_leg_1 - flight_leg service_desk_main - service_desk meal_voucher_1 - consumable_voucher alt_option_a1 - alternative_option_a alt_option_b1 - alternative_option_b recovery_package_template_1 - recovery_package document_bundle_1 - document_bundle document_bundle_2 - document_bundle compensation_scheme_standard - compensation_scheme compensation_scheme_exception - compensation_scheme followup_task_contact_passenger - followup_task followup_task_quality_check - followup_task contact_channel_email - contact_channel compensation_offer_standard - compensation_offer policy_reference_1 - policy_reference policy_reference_2 - policy_reference assistance_resource_1 - assistance_resource)
  (:init
    (agent_slot_available agent_slot_1)
    (agent_slot_available agent_slot_2)
    (agent_slot_available agent_slot_3)
    (flight_leg_available flight_leg_1)
    (service_desk_available service_desk_main)
    (voucher_available meal_voucher_1)
    (inbound_has_alternative_a inbound_segment_1 alt_option_a1)
    (outbound_has_alternative_b outbound_segment_1 alt_option_b1)
    (recovery_package_pending recovery_package_template_1)
    (document_bundle_available document_bundle_1)
    (document_bundle_available document_bundle_2)
    (team_assigned_to_inbound_segment support_team_alpha inbound_segment_1)
    (team_assigned_to_inbound_segment support_team_beta inbound_segment_1)
    (team_assigned_to_outbound_segment support_team_alpha outbound_segment_1)
    (team_assigned_to_outbound_segment support_team_beta outbound_segment_1)
    (team_assigned_to_recovery_package support_team_alpha recovery_package_template_1)
    (team_assigned_to_recovery_package support_team_beta recovery_package_template_1)
    (team_has_document_bundle support_team_alpha document_bundle_1)
    (team_has_document_bundle support_team_beta document_bundle_2)
    (compensation_scheme_available compensation_scheme_standard)
    (compensation_scheme_available compensation_scheme_exception)
    (followup_task_available followup_task_contact_passenger)
    (followup_task_available followup_task_quality_check)
    (contact_channel_available contact_channel_email)
    (compensation_offer_available compensation_offer_standard)
    (policy_reference_available policy_reference_1)
    (team_has_policy_reference support_team_alpha policy_reference_1)
    (team_has_policy_reference support_team_beta policy_reference_2)
    (assistance_resource_available assistance_resource_1)
  )
  (:goal
    (and
      (work_item_confirmed inbound_segment_1)
      (work_item_confirmed outbound_segment_1)
      (work_item_confirmed support_team_alpha)
      (work_item_confirmed support_team_beta)
    )
  )
)
