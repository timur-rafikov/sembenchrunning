(define (problem vehicle_breakdown_case_problem)
  (:domain vehicle_breakdown_trip_continuity_domain)
  (:objects vehicle_primary - vehicle associated_party_1 - associated_vehicle_or_party handler_agent_1 - case_handler handler_agent_2 - case_handler provider_tow_1 - service_provider provider_roadside_1 - service_provider provider_repair_1 - service_provider comm_channel_1 - communication_channel field_agent_1 - field_agent repair_resource_spare_tire - repair_resource site_location_1 - site_location alt_site_repair_shop_1 - alternative_site continuity_option_1 - continuity_option payment_token_1 - payment_token payment_token_2 - payment_token authorization_escalation_1 - authorization authorization_escalation_2 - authorization compensation_package_standard - compensation_package compensation_package_premium - compensation_package payment_method_bank_transfer - payment_method technical_resource_mobile_jack - technical_resource local_partner_alpha - local_partner local_partner_bravo - local_partner regulatory_approval_safety_clearance - regulatory_approval)
  (:init
    (provider_available provider_tow_1)
    (provider_available provider_roadside_1)
    (provider_available provider_repair_1)
    (channel_available comm_channel_1)
    (field_agent_available field_agent_1)
    (repair_resource_available repair_resource_spare_tire)
    (vehicle_at_site vehicle_primary site_location_1)
    (associated_linked_alternative_site associated_party_1 alt_site_repair_shop_1)
    (continuity_option_offered continuity_option_1)
    (payment_token_available payment_token_1)
    (payment_token_available payment_token_2)
    (handler_assigned_vehicle handler_agent_1 vehicle_primary)
    (handler_assigned_vehicle handler_agent_2 vehicle_primary)
    (handler_assigned_associated handler_agent_1 associated_party_1)
    (handler_assigned_associated handler_agent_2 associated_party_1)
    (handler_selected_continuity_option handler_agent_1 continuity_option_1)
    (handler_selected_continuity_option handler_agent_2 continuity_option_1)
    (handler_allocated_payment_token handler_agent_1 payment_token_1)
    (handler_allocated_payment_token handler_agent_2 payment_token_2)
    (authorization_available authorization_escalation_1)
    (authorization_available authorization_escalation_2)
    (compensation_package_available compensation_package_standard)
    (compensation_package_available compensation_package_premium)
    (payment_method_available payment_method_bank_transfer)
    (technical_resource_available technical_resource_mobile_jack)
    (local_partner_available local_partner_alpha)
    (handler_linked_local_partner handler_agent_1 local_partner_alpha)
    (handler_linked_local_partner handler_agent_2 local_partner_bravo)
    (regulatory_approval_available regulatory_approval_safety_clearance)
  )
  (:goal
    (and
      (continuity_restored vehicle_primary)
      (continuity_restored associated_party_1)
      (continuity_restored handler_agent_1)
      (continuity_restored handler_agent_2)
    )
  )
)
