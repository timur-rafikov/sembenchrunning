(define (problem severe_weather_case_instance)
  (:domain severe_weather_itinerary_revision_domain)
  (:objects itinerary_segment_1 - itinerary_segment traveler_reservation_1 - traveler_reservation case_handler_primary - case_handler case_handler_secondary - case_handler frontline_provider_1 - frontline_provider frontline_provider_2 - frontline_provider frontline_provider_3 - frontline_provider communication_channel_1 - communication_channel on_site_staff_1 - on_site_staff service_option_1 - service_option location_option_1 - location_option transport_option_1 - transport_option supplier_confirmation_1 - supplier_confirmation voucher_document_1 - voucher_document voucher_document_2 - voucher_document policy_document_1 - policy_document policy_document_2 - policy_document compensation_option_refund - compensation_option compensation_option_voucher - compensation_option compensation_resource_pool - compensation_resource expert_team_1 - expert_team partner_organization_1 - partner_organization partner_organization_2 - partner_organization regulatory_clearance_1 - regulatory_clearance)
  (:init
