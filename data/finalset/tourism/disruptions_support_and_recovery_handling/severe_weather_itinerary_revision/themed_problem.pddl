    (provider_available frontline_provider_2)
    (provider_available frontline_provider_3)
    (channel_available communication_channel_1)
    (staff_available on_site_staff_1)
    (service_option_available service_option_1)
    (segment_location_option itinerary_segment_1 location_option_1)
    (reservation_transport_option traveler_reservation_1 transport_option_1)
    (supplier_confirmation_pending supplier_confirmation_1)
    (voucher_available voucher_document_1)
    (voucher_available voucher_document_2)
    (handler_responsible_for_segment case_handler_primary itinerary_segment_1)
    (handler_responsible_for_segment case_handler_secondary itinerary_segment_1)
    (handler_responsible_for_reservation case_handler_primary traveler_reservation_1)
    (handler_responsible_for_reservation case_handler_secondary traveler_reservation_1)
    (handler_requested_confirmation case_handler_primary supplier_confirmation_1)
    (handler_requested_confirmation case_handler_secondary supplier_confirmation_1)
    (handler_has_voucher case_handler_primary voucher_document_1)
    (handler_has_voucher case_handler_secondary voucher_document_2)
    (policy_document_available policy_document_1)
    (policy_document_available policy_document_2)
    (compensation_option_available compensation_option_refund)
    (compensation_option_available compensation_option_voucher)
    (compensation_resource_available compensation_resource_pool)
    (expert_team_available expert_team_1)
    (partner_available partner_organization_1)
    (handler_partner_assigned case_handler_primary partner_organization_1)
    (handler_partner_assigned case_handler_secondary partner_organization_2)
    (regulatory_clearance_available regulatory_clearance_1)
  )
  (:goal
    (and
      (marked_resolved itinerary_segment_1)
      (marked_resolved traveler_reservation_1)
      (marked_resolved case_handler_primary)
      (marked_resolved case_handler_secondary)
    )
  )
)
