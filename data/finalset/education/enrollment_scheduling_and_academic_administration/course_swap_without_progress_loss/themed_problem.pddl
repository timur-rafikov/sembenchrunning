(define (problem course_swap_scenario_1)
  (:domain course_swap_without_progress_loss)
  (:objects student_enrollment_src_1 - student_enrollment requested_enrollment_tgt_1 - requested_enrollment course_section_a - course_section course_section_b - course_section section_seat_1 - section_seat section_seat_2 - section_seat section_seat_3 - section_seat timetable_slot_1 - timetable_slot administrator_1 - administrator supporting_document_1 - supporting_document venue_1 - venue instructor_schedule_1 - instructor_schedule swap_case_1 - swap_case registrar_fragment_1 - registrar_record_fragment registrar_fragment_2 - registrar_record_fragment department_constraint_1 - department_constraint department_constraint_2 - department_constraint policy_consent_1 - policy_consent policy_consent_2 - policy_consent deadline_token_1 - deadline_token instructor_approval_token_1 - instructor_approval_token department_approval_token_1 - department_approval_token department_approval_token_2 - department_approval_token venue_approval_token_1 - venue_approval_token)
  (:init
    (seat_available section_seat_1)
    (seat_available section_seat_2)
    (seat_available section_seat_3)
    (slot_available timetable_slot_1)
    (administrator_available administrator_1)
    (supporting_document_available supporting_document_1)
    (enrollment_assigned_venue student_enrollment_src_1 venue_1)
    (requested_enrollment_assigned_instructor_schedule requested_enrollment_tgt_1 instructor_schedule_1)
    (case_unallocated swap_case_1)
    (registrar_fragment_available registrar_fragment_1)
    (registrar_fragment_available registrar_fragment_2)
    (section_has_student_enrollment course_section_a student_enrollment_src_1)
    (section_has_student_enrollment course_section_b student_enrollment_src_1)
    (section_has_requested_enrollment course_section_a requested_enrollment_tgt_1)
    (section_has_requested_enrollment course_section_b requested_enrollment_tgt_1)
    (section_associated_with_case course_section_a swap_case_1)
    (section_associated_with_case course_section_b swap_case_1)
    (section_has_registrar_fragment course_section_a registrar_fragment_1)
    (section_has_registrar_fragment course_section_b registrar_fragment_2)
    (department_constraint_available department_constraint_1)
    (department_constraint_available department_constraint_2)
    (policy_consent_available policy_consent_1)
    (policy_consent_available policy_consent_2)
    (deadline_token_available deadline_token_1)
    (instructor_approval_token_available instructor_approval_token_1)
    (department_approval_token_available department_approval_token_1)
    (section_has_department_approval_token course_section_a department_approval_token_1)
    (section_has_department_approval_token course_section_b department_approval_token_2)
    (venue_approval_token_available venue_approval_token_1)
  )
  (:goal
    (and
      (enrollment_committed student_enrollment_src_1)
      (enrollment_committed requested_enrollment_tgt_1)
      (enrollment_committed course_section_a)
      (enrollment_committed course_section_b)
    )
  )
)
