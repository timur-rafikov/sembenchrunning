(define (problem cross_department_registration_scenario)
  (:domain cross_department_registration_coordination)
  (:objects home_case_1 - home_department_case requested_case_1 - requested_department_case central_case_1 - central_registrar_case central_case_2 - central_registrar_case approver_1 - department_approver approver_2 - department_approver approver_3 - department_approver proposed_time_slot_1 - proposed_time_slot reviewer_1 - department_reviewer supporting_doc_1 - supporting_document home_time_option_1 - home_time_option requested_time_option_1 - requested_time_option provisional_section_1 - provisional_section room_101 - room room_102 - room aux_resource_1 - auxiliary_resource aux_resource_2 - auxiliary_resource policy_exception_type_1 - policy_exception_type policy_exception_type_2 - policy_exception_type deadline_document_1 - deadline_document instructor_availability_1 - instructor_availability external_authorization_1 - external_authorization external_authorization_2 - external_authorization escalation_approval_1 - escalation_approval)
  (:init
    (approver_available approver_1)
    (approver_available approver_2)
    (approver_available approver_3)
    (proposed_time_slot_available proposed_time_slot_1)
    (reviewer_available reviewer_1)
    (supporting_doc_available supporting_doc_1)
    (home_case_time_option home_case_1 home_time_option_1)
    (requested_case_time_option requested_case_1 requested_time_option_1)
    (section_unallocated provisional_section_1)
    (room_available room_101)
    (room_available room_102)
    (central_has_home_case central_case_1 home_case_1)
    (central_has_home_case central_case_2 home_case_1)
    (central_has_requested_case central_case_1 requested_case_1)
    (central_has_requested_case central_case_2 requested_case_1)
    (central_has_provisional_section central_case_1 provisional_section_1)
    (central_has_provisional_section central_case_2 provisional_section_1)
    (central_has_room_option central_case_1 room_101)
    (central_has_room_option central_case_2 room_102)
    (aux_resource_available aux_resource_1)
    (aux_resource_available aux_resource_2)
    (policy_exception_available policy_exception_type_1)
    (policy_exception_available policy_exception_type_2)
    (deadline_document_available deadline_document_1)
    (instructor_availability_available instructor_availability_1)
    (external_authorization_available external_authorization_1)
    (central_has_external_authorization central_case_1 external_authorization_1)
    (central_has_external_authorization central_case_2 external_authorization_2)
    (escalation_approval_available escalation_approval_1)
  )
  (:goal
    (and
      (case_finalized home_case_1)
      (case_finalized requested_case_1)
      (case_finalized central_case_1)
      (case_finalized central_case_2)
    )
  )
)
