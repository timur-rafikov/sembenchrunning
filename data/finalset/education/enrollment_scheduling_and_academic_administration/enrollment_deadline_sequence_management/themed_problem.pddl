(define (problem enrollment_deadline_sequence_problem)
  (:domain enrollment_deadline_sequence_management)
  (:objects student_primary_1 - student_record_primary student_secondary_1 - student_record_secondary course_offering_1 - course_offering course_offering_2 - course_offering seat_pool_1 - seat_pool seat_pool_2 - seat_pool seat_pool_3 - seat_pool section_slot_1 - section_slot administrative_reviewer_1 - administrative_reviewer supporting_document_1 - supporting_document student_timeslot_1 - student_timeslot course_timeslot_1 - course_timeslot schedule_proposal_1 - schedule_proposal room_resource_1 - room_resource room_resource_2 - room_resource room_feature_1 - room_feature room_feature_2 - room_feature instructor_preference_1 - instructor_preference instructor_preference_2 - instructor_preference deadline_token_1 - enrollment_deadline_token compliance_document_1 - compliance_document prerequisite_document_1 - prerequisite_document prerequisite_document_2 - prerequisite_document escalation_approval_1 - escalation_approval)
  (:init
    (seat_pool_available seat_pool_1)
    (seat_pool_available seat_pool_2)
    (seat_pool_available seat_pool_3)
    (section_slot_available section_slot_1)
    (reviewer_available administrative_reviewer_1)
    (supporting_document_available supporting_document_1)
    (student_to_student_timeslot_link student_primary_1 student_timeslot_1)
    (offering_to_course_timeslot_link student_secondary_1 course_timeslot_1)
    (schedule_proposal_slot_free schedule_proposal_1)
    (room_resource_available room_resource_1)
    (room_resource_available room_resource_2)
    (offering_supports_student_type_primary course_offering_1 student_primary_1)
    (offering_supports_student_type_primary course_offering_2 student_primary_1)
    (offering_supports_student_type_secondary course_offering_1 student_secondary_1)
    (offering_supports_student_type_secondary course_offering_2 student_secondary_1)
    (offering_linked_to_proposal course_offering_1 schedule_proposal_1)
    (offering_linked_to_proposal course_offering_2 schedule_proposal_1)
    (offering_has_candidate_room course_offering_1 room_resource_1)
    (offering_has_candidate_room course_offering_2 room_resource_2)
    (room_feature_token_available room_feature_1)
    (room_feature_token_available room_feature_2)
    (instructor_preference_available instructor_preference_1)
    (instructor_preference_available instructor_preference_2)
    (deadline_token_available deadline_token_1)
    (compliance_document_available compliance_document_1)
    (prerequisite_document_available prerequisite_document_1)
    (offering_has_prereq_document course_offering_1 prerequisite_document_1)
    (offering_has_prereq_document course_offering_2 prerequisite_document_2)
    (escalation_approval_available escalation_approval_1)
  )
  (:goal
    (and
      (entity_enrollment_confirmed student_primary_1)
      (entity_enrollment_confirmed student_secondary_1)
      (entity_enrollment_confirmed course_offering_1)
      (entity_enrollment_confirmed course_offering_2)
    )
  )
)
