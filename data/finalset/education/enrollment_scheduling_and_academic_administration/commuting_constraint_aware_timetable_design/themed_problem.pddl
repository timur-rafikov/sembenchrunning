(define (problem commuting_constraint_aware_timetable_design_problem)
  (:domain commuting_constraint_aware_timetable_design_domain)
  (:objects primary_student_profile_instance - primary_student_profile secondary_student_profile_instance - secondary_student_profile course_section_a - course_section course_section_b - course_section commute_option_a - commute_option commute_option_b - commute_option commute_option_c - commute_option meeting_time_window - meeting_time academic_officer_instance - academic_officer mobility_accommodation_instance - mobility_accommodation origin_commute_slot_instance - origin_commute_slot destination_commute_slot_instance - destination_commute_slot timetable_proposal_instance - timetable_proposal classroom_a - classroom classroom_b - classroom curriculum_attribute_a - curriculum_attribute curriculum_attribute_b - curriculum_attribute delivery_format_a - delivery_format delivery_format_b - delivery_format commute_token_instance - commute_token instructor_instance - instructor special_permission_a - special_permission special_permission_b - special_permission safety_certificate_instance - safety_certificate)
  (:init
    (commute_option_available commute_option_a)
    (commute_option_available commute_option_b)
    (commute_option_available commute_option_c)
    (meeting_time_available meeting_time_window)
    (academic_officer_available academic_officer_instance)
    (accommodation_available mobility_accommodation_instance)
    (primary_origin_slot_linked primary_student_profile_instance origin_commute_slot_instance)
    (secondary_destination_slot_linked secondary_student_profile_instance destination_commute_slot_instance)
    (proposal_available timetable_proposal_instance)
    (classroom_available classroom_a)
    (classroom_available classroom_b)
    (section_primary_student_linked course_section_a primary_student_profile_instance)
    (section_primary_student_linked course_section_b primary_student_profile_instance)
    (section_secondary_student_linked course_section_a secondary_student_profile_instance)
    (section_secondary_student_linked course_section_b secondary_student_profile_instance)
    (section_proposal_linked course_section_a timetable_proposal_instance)
    (section_proposal_linked course_section_b timetable_proposal_instance)
    (section_classroom_assigned course_section_a classroom_a)
    (section_classroom_assigned course_section_b classroom_b)
    (curriculum_attribute_available curriculum_attribute_a)
    (curriculum_attribute_available curriculum_attribute_b)
    (delivery_format_available delivery_format_a)
    (delivery_format_available delivery_format_b)
    (commute_token_available commute_token_instance)
    (instructor_available instructor_instance)
    (special_permission_available special_permission_a)
    (section_permission_linked course_section_a special_permission_a)
    (section_permission_linked course_section_b special_permission_b)
    (safety_certificate_available safety_certificate_instance)
  )
  (:goal
    (and
      (enrollment_closed primary_student_profile_instance)
      (enrollment_closed secondary_student_profile_instance)
      (enrollment_closed course_section_a)
      (enrollment_closed course_section_b)
    )
  )
)
