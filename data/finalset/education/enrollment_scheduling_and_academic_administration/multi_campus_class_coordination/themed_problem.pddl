(define (problem multi_campus_class_coordination_problem)
  (:domain multi_campus_class_coordination_domain)
  (:objects section_variant_a_1 - section_variant_a section_variant_b_1 - section_variant_b course_offering_1 - course_offering course_offering_2 - course_offering enrollment_officer_1 - enrollment_officer enrollment_officer_2 - enrollment_officer enrollment_officer_3 - enrollment_officer requested_timeslot_pref_1 - requested_timeslot_preference department_approver_1 - department_approver aux_resource_1 - auxiliary_resource timeslot_candidate_a_1 - timeslot_candidate_a timeslot_candidate_b_1 - timeslot_candidate_b classroom_resource_1 - classroom_resource instructional_package_1 - instructional_package instructional_package_2 - instructional_package crosslisting_slot_1 - crosslisting_slot crosslisting_slot_2 - crosslisting_slot academic_term_1 - academic_term academic_term_2 - academic_term student_record_1 - student_record instructor_1 - instructor curriculum_representative_1 - curriculum_representative curriculum_representative_2 - curriculum_representative accreditation_officer_1 - accreditation_officer)
  (:init
    (enrollment_officer_available enrollment_officer_1)
    (enrollment_officer_available enrollment_officer_2)
    (enrollment_officer_available enrollment_officer_3)
    (timeslot_preference_available requested_timeslot_pref_1)
    (department_approver_available department_approver_1)
    (auxiliary_resource_available aux_resource_1)
    (section_variant_a_claims_timeslot_candidate section_variant_a_1 timeslot_candidate_a_1)
    (section_variant_b_claims_timeslot_candidate section_variant_b_1 timeslot_candidate_b_1)
    (classroom_resource_available classroom_resource_1)
    (instructional_package_available instructional_package_1)
    (instructional_package_available instructional_package_2)
    (offering_includes_variant_a course_offering_1 section_variant_a_1)
    (offering_includes_variant_a course_offering_2 section_variant_a_1)
    (offering_includes_variant_b course_offering_1 section_variant_b_1)
    (offering_includes_variant_b course_offering_2 section_variant_b_1)
    (offering_associated_classroom course_offering_1 classroom_resource_1)
    (offering_associated_classroom course_offering_2 classroom_resource_1)
    (offering_has_instructional_package course_offering_1 instructional_package_1)
    (offering_has_instructional_package course_offering_2 instructional_package_2)
    (crosslisting_slot_available crosslisting_slot_1)
    (crosslisting_slot_available crosslisting_slot_2)
    (academic_term_available academic_term_1)
    (academic_term_available academic_term_2)
    (student_record_available student_record_1)
    (instructor_available instructor_1)
    (curriculum_representative_available curriculum_representative_1)
    (offering_assigned_curriculum_representative course_offering_1 curriculum_representative_1)
    (offering_assigned_curriculum_representative course_offering_2 curriculum_representative_2)
    (accreditation_officer_available accreditation_officer_1)
  )
  (:goal
    (and
      (finalized_for_subject section_variant_a_1)
      (finalized_for_subject section_variant_b_1)
      (finalized_for_subject course_offering_1)
      (finalized_for_subject course_offering_2)
    )
  )
)
