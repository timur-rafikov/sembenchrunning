(define (problem semester_enrollment_scheduling_problem)
  (:domain lecture_lab_tutorial_alignment_domain)
  (:objects lecture_section_1 - lecture_section lab_section_1 - lab_section course_offering_1 - course_offering course_offering_2 - course_offering registration_slot_token_1 - registration_slot_token registration_slot_token_2 - registration_slot_token registration_slot_token_3 - registration_slot_token timeslot_preference_1 - timeslot_preference instructor_availability_1 - instructor_availability ancillary_resource_1 - ancillary_resource_token lecture_timeslot_1 - lecture_timeslot lab_timeslot_1 - lab_timeslot room_101 - physical_room room_timeslot_block_1 - room_timeslot_block room_timeslot_block_2 - room_timeslot_block session_type_lecture - session_type_attribute session_type_lab - session_type_attribute scheduling_profile_standard - scheduling_profile scheduling_profile_lab - scheduling_profile deadline_token_1 - deadline_token room_feature_token_projector - room_feature_token external_approval_token_dept - external_approval_token external_approval_token_prog - external_approval_token special_approval_token_1 - special_approval_token)
  (:init
    (registration_slot_available registration_slot_token_1)
    (registration_slot_available registration_slot_token_2)
    (registration_slot_available registration_slot_token_3)
    (timeslot_preference_available timeslot_preference_1)
    (instructor_available instructor_availability_1)
    (ancillary_resource_available ancillary_resource_1)
    (lecture_section_timeslot_link lecture_section_1 lecture_timeslot_1)
    (lab_section_timeslot_link lab_section_1 lab_timeslot_1)
    (room_available room_101)
    (room_timeslot_block_available room_timeslot_block_1)
    (room_timeslot_block_available room_timeslot_block_2)
    (offering_has_lecture_section course_offering_1 lecture_section_1)
    (offering_has_lecture_section course_offering_2 lecture_section_1)
    (offering_has_lab_section course_offering_1 lab_section_1)
    (offering_has_lab_section course_offering_2 lab_section_1)
    (offering_room_candidate course_offering_1 room_101)
    (offering_room_candidate course_offering_2 room_101)
    (offering_room_block_link course_offering_1 room_timeslot_block_1)
    (offering_room_block_link course_offering_2 room_timeslot_block_2)
    (session_type_attribute_available session_type_lecture)
    (session_type_attribute_available session_type_lab)
    (scheduling_profile_available scheduling_profile_standard)
    (scheduling_profile_available scheduling_profile_lab)
    (deadline_token_available deadline_token_1)
    (room_feature_token_available room_feature_token_projector)
    (external_approval_token_available external_approval_token_dept)
    (offering_external_approval_link course_offering_1 external_approval_token_dept)
    (offering_external_approval_link course_offering_2 external_approval_token_prog)
    (special_approval_token_available special_approval_token_1)
  )
  (:goal
    (and
      (scheduling_finalized lecture_section_1)
      (scheduling_finalized lab_section_1)
      (scheduling_finalized course_offering_1)
      (scheduling_finalized course_offering_2)
    )
  )
)
