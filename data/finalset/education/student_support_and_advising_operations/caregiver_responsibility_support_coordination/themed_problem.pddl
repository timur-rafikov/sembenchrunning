    (document_packet_available document_packet_1)
    (document_packet_available document_packet_2)
    (coordinator_linked_primary_caregiver case_coordinator_1 primary_caregiver_instance)
    (coordinator_linked_primary_caregiver case_coordinator_2 primary_caregiver_instance)
    (coordinator_linked_secondary_contact case_coordinator_1 secondary_contact_instance)
    (coordinator_linked_secondary_contact case_coordinator_2 secondary_contact_instance)
    (coordinator_has_plan_document case_coordinator_1 support_plan_document_instance)
    (coordinator_has_plan_document case_coordinator_2 support_plan_document_instance)
    (coordinator_has_document_packet case_coordinator_1 document_packet_1)
    (coordinator_has_document_packet case_coordinator_2 document_packet_2)
    (intervention_option_available intervention_option_1)
    (intervention_option_available intervention_option_2)
    (follow_up_task_available follow_up_task_1)
    (follow_up_task_available follow_up_task_2)
    (external_reference_available external_reference_instance)
    (specialist_consult_available specialist_consult_instance)
    (external_authority_available external_authority_1)
    (coordinator_linked_external_authority case_coordinator_1 external_authority_1)
    (coordinator_linked_external_authority case_coordinator_2 external_authority_2)
