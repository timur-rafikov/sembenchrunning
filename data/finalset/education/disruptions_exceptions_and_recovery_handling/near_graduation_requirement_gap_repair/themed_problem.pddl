(define (problem near_graduation_repair_problem)
  (:domain near_graduation_requirement_gap_repair_domain)
  (:objects student_primary - student student_peer - peer_student case_administrator_1 - case_administrator case_administrator_2 - case_administrator resource_token_1 - resource_token resource_token_2 - resource_token resource_token_3 - resource_token evidence_transcript_excerpt_1 - evidence_document faculty_reviewer_1 - faculty_reviewer remediation_option_makeup_course - remediation_option requirement_deficit_missing_course - requirement_deficit peer_requirement_deficit_missing_course - requirement_deficit_peer repair_proposal_draft_1 - repair_proposal transcript_entry_1 - transcript_entry transcript_entry_2 - transcript_entry external_waiver_doc_1 - external_waiver_document external_waiver_doc_2 - external_waiver_document scheduling_slot_morning - scheduling_slot scheduling_slot_afternoon - scheduling_slot approval_artifact_1 - approval_artifact override_authorization_1 - override_authorization exception_request_doc_1 - exception_request_document exception_request_doc_2 - exception_request_document escalation_record_1 - escalation_record)
  (:init
    (resource_token_available resource_token_1)
    (resource_token_available resource_token_2)
    (resource_token_available resource_token_3)
    (evidence_document_available evidence_transcript_excerpt_1)
    (faculty_reviewer_available faculty_reviewer_1)
    (remediation_option_available remediation_option_makeup_course)
    (student_has_deficit student_primary requirement_deficit_missing_course)
    (peer_has_deficit student_peer peer_requirement_deficit_missing_course)
    (proposal_resource_available repair_proposal_draft_1)
    (transcript_entry_available transcript_entry_1)
    (transcript_entry_available transcript_entry_2)
    (case_admin_assigned_student case_administrator_1 student_primary)
    (case_admin_assigned_student case_administrator_2 student_primary)
    (case_admin_assigned_peer case_administrator_1 student_peer)
    (case_admin_assigned_peer case_administrator_2 student_peer)
    (case_admin_assigned_proposal case_administrator_1 repair_proposal_draft_1)
    (case_admin_assigned_proposal case_administrator_2 repair_proposal_draft_1)
    (case_admin_has_transcript_entry case_administrator_1 transcript_entry_1)
    (case_admin_has_transcript_entry case_administrator_2 transcript_entry_2)
    (external_waiver_document_available external_waiver_doc_1)
    (external_waiver_document_available external_waiver_doc_2)
    (scheduling_slot_available scheduling_slot_morning)
    (scheduling_slot_available scheduling_slot_afternoon)
    (approval_artifact_available approval_artifact_1)
    (override_authorization_available override_authorization_1)
    (exception_request_document_available exception_request_doc_1)
    (case_admin_linked_exception_request case_administrator_1 exception_request_doc_1)
    (case_admin_linked_exception_request case_administrator_2 exception_request_doc_2)
    (escalation_record_available escalation_record_1)
  )
  (:goal
    (and
      (administrative_correction_recorded student_primary)
      (administrative_correction_recorded student_peer)
      (administrative_correction_recorded case_administrator_1)
      (administrative_correction_recorded case_administrator_2)
    )
  )
)
