(define (problem prerequisite_chain_completion_problem)
  (:domain prerequisite_chain_completion_planning_domain)
  (:objects required_course_instance_1 - required_course_instance elective_course_instance_1 - elective_course_instance student_record_1 - student_record student_record_2 - student_record instructor_resource_1 - instructor_resource instructor_resource_2 - instructor_resource instructor_resource_3 - instructor_resource section_offering_1 - section_offering assessment_event_1 - assessment_event credit_token_1 - credit_token required_term_slot_1 - required_term_slot elective_term_slot_1 - elective_term_slot program_milestone_1 - program_milestone capstone_requirement_1 - capstone_requirement capstone_requirement_2 - capstone_requirement external_approval_document_1 - external_approval_document external_approval_document_2 - external_approval_document elective_option_1 - elective_option elective_option_2 - elective_option credit_unit_1 - credit_unit grading_artifact_1 - grading_artifact recommendation_letter_1 - recommendation_letter recommendation_letter_2 - recommendation_letter capstone_advisor_1 - capstone_advisor)
  (:init
    (instructor_available instructor_resource_1)
    (instructor_available instructor_resource_2)
    (instructor_available instructor_resource_3)
    (section_available section_offering_1)
    (assessment_event_available assessment_event_1)
    (credit_token_available credit_token_1)
    (required_instance_term_slot required_course_instance_1 required_term_slot_1)
    (elective_instance_term_slot elective_course_instance_1 elective_term_slot_1)
    (program_milestone_available program_milestone_1)
    (capstone_requirement_available capstone_requirement_1)
    (capstone_requirement_available capstone_requirement_2)
    (student_has_required_instance student_record_1 required_course_instance_1)
    (student_has_required_instance student_record_2 required_course_instance_1)
    (student_has_elective_instance student_record_1 elective_course_instance_1)
    (student_has_elective_instance student_record_2 elective_course_instance_1)
    (student_has_program_milestone student_record_1 program_milestone_1)
    (student_has_program_milestone student_record_2 program_milestone_1)
    (student_has_capstone_requirement student_record_1 capstone_requirement_1)
    (student_has_capstone_requirement student_record_2 capstone_requirement_2)
    (external_approval_available external_approval_document_1)
    (external_approval_available external_approval_document_2)
    (elective_option_available elective_option_1)
    (elective_option_available elective_option_2)
    (credit_unit_available credit_unit_1)
    (grading_artifact_available grading_artifact_1)
    (recommendation_letter_available recommendation_letter_1)
    (student_recommendation_link student_record_1 recommendation_letter_1)
    (student_recommendation_link student_record_2 recommendation_letter_2)
    (capstone_advisor_available capstone_advisor_1)
  )
  (:goal
    (and
      (instance_completed required_course_instance_1)
      (instance_completed elective_course_instance_1)
      (instance_completed student_record_1)
      (instance_completed student_record_2)
    )
  )
)
