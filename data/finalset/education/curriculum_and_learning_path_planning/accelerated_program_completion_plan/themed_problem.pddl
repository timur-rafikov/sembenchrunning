(define (problem accelerated_program_completion_plan_problem)
  (:domain accelerated_program_completion_plan_domain)
  (:objects primary_student_1 - primary_student peer_student_1 - peer_student program_advisor_unit_1 - program_advisor_unit program_advisor_unit_2 - program_advisor_unit academic_advisor_1 - academic_advisor academic_advisor_2 - academic_advisor academic_advisor_3 - academic_advisor course_section_1 - course_section instructor_1 - instructor seat_slot_1 - seat_slot timeslot_1 - timeslot session_1 - session accelerated_term_bundle_1 - accelerated_term_bundle assessment_component_1 - assessment_component assessment_component_2 - assessment_component waiver_document_1 - waiver_document waiver_document_2 - waiver_document elective_offer_1 - elective_offer elective_offer_2 - elective_offer conferral_token_1 - conferral_token lab_placement_1 - lab_placement department_approval_1 - department_approval department_approval_2 - department_approval external_certificate_1 - external_certificate)
  (:init
    (advisor_available academic_advisor_1)
    (advisor_available academic_advisor_2)
    (advisor_available academic_advisor_3)
    (course_section_has_capacity course_section_1)
    (instructor_available instructor_1)
    (seat_slot_available seat_slot_1)
    (student_assigned_timeslot primary_student_1 timeslot_1)
    (peer_assigned_session peer_student_1 session_1)
    (bundle_available accelerated_term_bundle_1)
    (assessment_available assessment_component_1)
    (assessment_available assessment_component_2)
    (unit_assigned_primary_student program_advisor_unit_1 primary_student_1)
    (unit_assigned_primary_student program_advisor_unit_2 primary_student_1)
    (unit_assigned_peer_student program_advisor_unit_1 peer_student_1)
    (unit_assigned_peer_student program_advisor_unit_2 peer_student_1)
    (unit_manages_bundle program_advisor_unit_1 accelerated_term_bundle_1)
    (unit_manages_bundle program_advisor_unit_2 accelerated_term_bundle_1)
    (unit_has_assessment program_advisor_unit_1 assessment_component_1)
    (unit_has_assessment program_advisor_unit_2 assessment_component_2)
    (waiver_available waiver_document_1)
    (waiver_available waiver_document_2)
    (elective_available elective_offer_1)
    (elective_available elective_offer_2)
    (conferral_token_available conferral_token_1)
    (lab_placement_available lab_placement_1)
    (department_approval_available department_approval_1)
    (unit_has_department_approval program_advisor_unit_1 department_approval_1)
    (unit_has_department_approval program_advisor_unit_2 department_approval_2)
    (external_certificate_available external_certificate_1)
  )
  (:goal
    (and
      (completion_cleared primary_student_1)
      (completion_cleared peer_student_1)
      (completion_cleared program_advisor_unit_1)
      (completion_cleared program_advisor_unit_2)
    )
  )
)
