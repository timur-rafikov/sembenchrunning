(define (problem semester_course_load_balancing_problem)
  (:domain semester_course_load_balancing)
  (:objects student_primary_1 - student_primary student_secondary_1 - student_secondary semester_plan_1 - semester_plan semester_plan_2 - semester_plan course_section_a - course_section course_section_b - course_section course_section_c - course_section course_offering_1 - course_offering advisor_1 - advisor elective_option_a - elective_option timeslot_group_a_1 - timeslot_group_a timeslot_group_b_1 - timeslot_group_b scheduled_instance_1 - scheduled_course_instance milestone_template_midterm - milestone_template milestone_template_final - milestone_template special_project_option_a - special_project_option special_project_option_b - special_project_option resource_token_a - resource_token resource_token_b - resource_token credit_unit_1 - credit_unit capacity_slot_1 - capacity_slot portfolio_artifact_a - portfolio_artifact portfolio_artifact_b - portfolio_artifact external_certification_1 - external_certification)
  (:init
    (section_available course_section_a)
    (section_available course_section_b)
    (section_available course_section_c)
    (offering_available course_offering_1)
    (advisor_available advisor_1)
    (elective_option_available elective_option_a)
    (student_timeslot_group_a_assigned student_primary_1 timeslot_group_a_1)
    (student_secondary_timeslot_group_b_assigned student_secondary_1 timeslot_group_b_1)
    (scheduled_instance_slot_available scheduled_instance_1)
    (milestone_template_available milestone_template_midterm)
    (milestone_template_available milestone_template_final)
    (plan_has_primary_student semester_plan_1 student_primary_1)
    (plan_has_primary_student semester_plan_2 student_primary_1)
    (plan_has_secondary_student semester_plan_1 student_secondary_1)
    (plan_has_secondary_student semester_plan_2 student_secondary_1)
    (plan_includes_scheduled_instance semester_plan_1 scheduled_instance_1)
    (plan_includes_scheduled_instance semester_plan_2 scheduled_instance_1)
    (plan_has_milestone_template semester_plan_1 milestone_template_midterm)
    (plan_has_milestone_template semester_plan_2 milestone_template_final)
    (special_project_option_available special_project_option_a)
    (special_project_option_available special_project_option_b)
    (resource_token_available resource_token_a)
    (resource_token_available resource_token_b)
    (credit_unit_available credit_unit_1)
    (capacity_slot_available capacity_slot_1)
    (portfolio_artifact_available portfolio_artifact_a)
    (plan_has_portfolio_artifact semester_plan_1 portfolio_artifact_a)
    (plan_has_portfolio_artifact semester_plan_2 portfolio_artifact_b)
    (external_certification_available external_certification_1)
  )
  (:goal
    (and
      (enrollment_confirmed student_primary_1)
      (enrollment_confirmed student_secondary_1)
      (enrollment_confirmed semester_plan_1)
      (enrollment_confirmed semester_plan_2)
    )
  )
)
