(define (problem final_year_consolidation_problem)
  (:domain final_year_requirement_consolidation_domain)
  (:objects student_record_1 - student_record peer_group_1 - student_peer_group program_plan_alpha - program_consolidation_plan program_plan_beta - program_consolidation_plan advisor_slot_1 - advisor_slot advisor_slot_2 - advisor_slot advisor_slot_3 - advisor_slot course_option_1 - course_option faculty_approver_1 - faculty_approver elective_token_1 - elective_token milestone_1 - milestone schedule_window_1 - schedule_window requirement_record_1 - graduation_requirement_record supporting_document_1 - supporting_document supporting_document_2 - supporting_document special_condition_1 - special_condition special_condition_2 - special_condition endorsement_token_1 - endorsement_token endorsement_token_2 - endorsement_token assessment_slot_1 - assessment_slot competency_evidence_1 - competency_evidence external_certificate_1 - external_certificate external_certificate_2 - external_certificate accreditation_flag_1 - accreditation_flag)
  (:init
    (advisor_slot_available advisor_slot_1)
    (advisor_slot_available advisor_slot_2)
    (advisor_slot_available advisor_slot_3)
    (course_option_available course_option_1)
    (faculty_approver_available faculty_approver_1)
    (elective_token_available elective_token_1)
    (student_linked_milestone student_record_1 milestone_1)
    (peer_group_has_schedule_window peer_group_1 schedule_window_1)
    (requirement_record_available requirement_record_1)
    (supporting_document_available supporting_document_1)
    (supporting_document_available supporting_document_2)
    (plan_includes_student_record program_plan_alpha student_record_1)
    (plan_includes_student_record program_plan_beta student_record_1)
    (plan_includes_peer_group program_plan_alpha peer_group_1)
    (plan_includes_peer_group program_plan_beta peer_group_1)
    (plan_includes_requirement_record program_plan_alpha requirement_record_1)
    (plan_includes_requirement_record program_plan_beta requirement_record_1)
    (plan_has_supporting_document program_plan_alpha supporting_document_1)
    (plan_has_supporting_document program_plan_beta supporting_document_2)
    (special_condition_available special_condition_1)
    (special_condition_available special_condition_2)
    (endorsement_token_available endorsement_token_1)
    (endorsement_token_available endorsement_token_2)
    (assessment_slot_available assessment_slot_1)
    (competency_evidence_available competency_evidence_1)
    (external_certificate_available external_certificate_1)
    (plan_has_external_certificate program_plan_alpha external_certificate_1)
    (plan_has_external_certificate program_plan_beta external_certificate_2)
    (accreditation_flag_available accreditation_flag_1)
  )
  (:goal
    (and
      (consolidation_subject_finalized student_record_1)
      (consolidation_subject_finalized peer_group_1)
      (consolidation_subject_finalized program_plan_alpha)
      (consolidation_subject_finalized program_plan_beta)
    )
  )
)
