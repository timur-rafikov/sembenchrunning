(define (problem study_abroad_term_integration_problem)
  (:domain study_abroad_term_integration)
  (:objects advisor_home_1 - home_advisor advisor_host_1 - host_advisor student_alex - student student_bianca - student partner_slot_1 - partner_university_slot partner_slot_2 - partner_university_slot partner_slot_3 - partner_university_slot host_course_proposal_1 - course_proposal course_coordinator_1 - course_coordinator credit_equivalency_proposal_1 - credit_equivalency_proposal home_term_spring_2025 - home_term host_term_fall_2025 - host_term placement_record_1 - placement_record host_course_listing_1 - host_course_listing host_course_listing_2 - host_course_listing scholarship_offer_1 - scholarship_offer scholarship_offer_2 - scholarship_offer predeparture_clearance_1 - predeparture_clearance predeparture_clearance_2 - predeparture_clearance immigration_document_passport - immigration_document credit_transfer_item_1 - credit_transfer_item department_endorsement_1 - department_endorsement department_endorsement_2 - department_endorsement host_institution_approval_1 - host_institution_approval)
  (:init
    (partner_slot_available partner_slot_1)
    (partner_slot_available partner_slot_2)
    (partner_slot_available partner_slot_3)
    (course_proposal_submitted host_course_proposal_1)
    (coordinator_available course_coordinator_1)
    (credit_equivalency_proposal_available credit_equivalency_proposal_1)
    (advisor_assigned_home_term advisor_home_1 home_term_spring_2025)
    (host_advisor_assigned_host_term advisor_host_1 host_term_fall_2025)
    (placement_record_available placement_record_1)
    (host_course_listing_available host_course_listing_1)
    (host_course_listing_available host_course_listing_2)
    (student_has_home_advisor student_alex advisor_home_1)
    (student_has_home_advisor student_bianca advisor_home_1)
    (student_has_host_advisor student_alex advisor_host_1)
    (student_has_host_advisor student_bianca advisor_host_1)
    (student_has_placement_record student_alex placement_record_1)
    (student_has_placement_record student_bianca placement_record_1)
    (student_selected_host_course student_alex host_course_listing_1)
    (student_selected_host_course student_bianca host_course_listing_2)
    (scholarship_offer_available scholarship_offer_1)
    (scholarship_offer_available scholarship_offer_2)
    (predeparture_clearance_available predeparture_clearance_1)
    (predeparture_clearance_available predeparture_clearance_2)
    (immigration_document_available immigration_document_passport)
    (credit_transfer_item_available credit_transfer_item_1)
    (department_endorsement_available department_endorsement_1)
    (student_has_department_endorsement student_alex department_endorsement_1)
    (student_has_department_endorsement student_bianca department_endorsement_2)
    (host_institution_approval_available host_institution_approval_1)
  )
  (:goal
    (and
      (mobility_record_finalized advisor_home_1)
      (mobility_record_finalized advisor_host_1)
      (mobility_record_finalized student_alex)
      (mobility_record_finalized student_bianca)
    )
  )
)
