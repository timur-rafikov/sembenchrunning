(define (problem student_minor_integration_problem)
  (:domain minor_program_integration_domain)
  (:objects major_program_instance_1 - major_program_instance minor_program_instance_1 - minor_program_instance integration_case_1 - integration_case integration_case_2 - integration_case advisor_slot_1 - advisor_slot advisor_slot_2 - advisor_slot advisor_slot_3 - advisor_slot course_offering_1 - course_offering instructor_approval_token_1 - instructor_approval_token curriculum_resource_1 - curriculum_resource major_term_1 - major_term minor_term_1 - minor_term integration_plan_document_1 - integration_plan_document curriculum_artifact_1 - curriculum_artifact curriculum_artifact_2 - curriculum_artifact course_category_1 - course_category course_category_2 - course_category elective_bundle_1 - elective_bundle elective_bundle_2 - elective_bundle credit_unit_1 - credit_unit accreditation_unit_1 - accreditation_unit credential_1 - credential credential_2 - credential compliance_document_1 - compliance_document)
  (:init
    (advisor_slot_available advisor_slot_1)
    (advisor_slot_available advisor_slot_2)
    (advisor_slot_available advisor_slot_3)
    (course_seat_available course_offering_1)
    (approval_token_available instructor_approval_token_1)
    (curriculum_resource_available curriculum_resource_1)
    (major_term_assigned major_program_instance_1 major_term_1)
    (minor_term_assigned minor_program_instance_1 minor_term_1)
    (integration_plan_draft integration_plan_document_1)
    (curriculum_artifact_available curriculum_artifact_1)
    (curriculum_artifact_available curriculum_artifact_2)
    (case_links_major_program integration_case_1 major_program_instance_1)
    (case_links_major_program integration_case_2 major_program_instance_1)
    (case_links_minor_program integration_case_1 minor_program_instance_1)
    (case_links_minor_program integration_case_2 minor_program_instance_1)
    (case_links_integration_plan integration_case_1 integration_plan_document_1)
    (case_links_integration_plan integration_case_2 integration_plan_document_1)
    (case_has_curriculum_artifact integration_case_1 curriculum_artifact_1)
    (case_has_curriculum_artifact integration_case_2 curriculum_artifact_2)
    (course_category_available course_category_1)
    (course_category_available course_category_2)
    (elective_bundle_available elective_bundle_1)
    (elective_bundle_available elective_bundle_2)
    (credit_unit_available credit_unit_1)
    (accreditation_unit_available accreditation_unit_1)
    (credential_available credential_1)
    (case_has_credential integration_case_1 credential_1)
    (case_has_credential integration_case_2 credential_2)
    (compliance_document_available compliance_document_1)
  )
  (:goal
    (and
      (integration_finalized major_program_instance_1)
      (integration_finalized minor_program_instance_1)
      (integration_finalized integration_case_1)
      (integration_finalized integration_case_2)
    )
  )
)
