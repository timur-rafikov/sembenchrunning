(define (problem grade_appeal_case)
  (:domain grade_appeal_evidence_submission_domain)
  (:objects appellant_record_1 - appellant_record respondent_record_1 - respondent_record appeal_dossier_1 - appeal_dossier appeal_dossier_2 - appeal_dossier submission_channel_1 - submission_channel submission_channel_2 - submission_channel submission_channel_3 - submission_channel evidence_document_1 - evidence_document reviewer_1 - reviewer supplementary_material_1 - supplementary_material appellant_deadline_slot_1 - appellant_deadline_slot respondent_deadline_slot_1 - respondent_deadline_slot appeal_packet_1 - appeal_packet document_batch_1 - document_batch document_batch_2 - document_batch expedited_authorization_1 - expedited_authorization expedited_authorization_2 - expedited_authorization committee_assignment_token_1 - committee_assignment_token committee_assignment_token_2 - committee_assignment_token notification_token_1 - notification_token committee_review_token_1 - committee_review_token external_authorization_1 - external_authorization external_authorization_2 - external_authorization committee_decision_token_1 - committee_decision_token)
  (:init
    (channel_available submission_channel_1)
    (channel_available submission_channel_2)
    (channel_available submission_channel_3)
    (evidence_available evidence_document_1)
    (reviewer_available reviewer_1)
    (supplementary_available supplementary_material_1)
    (participant_to_deadline appellant_record_1 appellant_deadline_slot_1)
    (respondent_to_deadline respondent_record_1 respondent_deadline_slot_1)
    (packet_slot_available appeal_packet_1)
    (batch_available document_batch_1)
    (batch_available document_batch_2)
    (dossier_appellant_link appeal_dossier_1 appellant_record_1)
    (dossier_appellant_link appeal_dossier_2 appellant_record_1)
    (dossier_respondent_link appeal_dossier_1 respondent_record_1)
    (dossier_respondent_link appeal_dossier_2 respondent_record_1)
    (dossier_packet_link appeal_dossier_1 appeal_packet_1)
    (dossier_packet_link appeal_dossier_2 appeal_packet_1)
    (dossier_has_batch appeal_dossier_1 document_batch_1)
    (dossier_has_batch appeal_dossier_2 document_batch_2)
    (expedited_authorization_available expedited_authorization_1)
    (expedited_authorization_available expedited_authorization_2)
    (committee_assignment_token_available committee_assignment_token_1)
    (committee_assignment_token_available committee_assignment_token_2)
    (notification_token_available notification_token_1)
    (committee_review_token_available committee_review_token_1)
    (external_authorization_available external_authorization_1)
    (dossier_external_authorization_link appeal_dossier_1 external_authorization_1)
    (dossier_external_authorization_link appeal_dossier_2 external_authorization_2)
    (committee_decision_token_available committee_decision_token_1)
  )
  (:goal
    (and
      (finalized_record appellant_record_1)
      (finalized_record respondent_record_1)
      (finalized_record appeal_dossier_1)
      (finalized_record appeal_dossier_2)
    )
  )
)
