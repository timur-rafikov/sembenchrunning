(define (problem field_transition_preparation_problem)
  (:domain end_of_season_transition_domain)
  (:objects primary_section_1 - primary_field_section secondary_section_1 - secondary_field_section transition_plan_1 - transition_plan transition_plan_2 - transition_plan equipment_unit_1 - equipment_unit equipment_unit_2 - equipment_unit equipment_unit_3 - equipment_unit operation_task_1 - operation_task crew_team_alpha - crew_team material_batch_1 - input_material_batch time_window_a_1 - primary_time_window time_window_b_1 - secondary_time_window staging_unit_1 - staging_unit supply_container_1 - supply_container supply_container_2 - supply_container inspection_kit_1 - site_inspection_kit inspection_kit_2 - site_inspection_kit compliance_certificate_1 - compliance_certificate compliance_certificate_2 - compliance_certificate transition_checklist_doc_1 - transition_checklist calibration_tool_1 - calibration_tool inspection_report_1 - inspection_report inspection_report_2 - inspection_report regulatory_approval_1 - regulatory_approval)
  (:init
    (equipment_available equipment_unit_1)
    (equipment_available equipment_unit_2)
    (equipment_available equipment_unit_3)
    (operation_task_available operation_task_1)
    (crew_available crew_team_alpha)
    (material_batch_available material_batch_1)
    (section_primary_time_window_assigned primary_section_1 time_window_a_1)
    (section_secondary_time_window_assigned secondary_section_1 time_window_b_1)
    (staging_unit_available staging_unit_1)
    (supply_container_available supply_container_1)
    (supply_container_available supply_container_2)
    (plan_associated_with_primary_section transition_plan_1 primary_section_1)
    (plan_associated_with_primary_section transition_plan_2 primary_section_1)
    (plan_associated_with_secondary_section transition_plan_1 secondary_section_1)
    (plan_associated_with_secondary_section transition_plan_2 secondary_section_1)
    (plan_assigned_to_staging_unit transition_plan_1 staging_unit_1)
    (plan_assigned_to_staging_unit transition_plan_2 staging_unit_1)
    (plan_has_supply_container transition_plan_1 supply_container_1)
    (plan_has_supply_container transition_plan_2 supply_container_2)
    (inspection_kit_available inspection_kit_1)
    (inspection_kit_available inspection_kit_2)
    (compliance_certificate_available compliance_certificate_1)
    (compliance_certificate_available compliance_certificate_2)
    (transition_checklist_available transition_checklist_doc_1)
    (calibration_tool_available calibration_tool_1)
    (inspection_report_available inspection_report_1)
    (plan_has_inspection_report transition_plan_1 inspection_report_1)
    (plan_has_inspection_report transition_plan_2 inspection_report_2)
    (regulatory_approval_available regulatory_approval_1)
  )
  (:goal
    (and
      (transition_finalized primary_section_1)
      (transition_finalized secondary_section_1)
      (transition_finalized transition_plan_1)
      (transition_finalized transition_plan_2)
    )
  )
)
