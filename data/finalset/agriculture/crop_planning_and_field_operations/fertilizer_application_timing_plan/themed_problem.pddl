    (equipment_available equipment_spreader_1)
    (equipment_available equipment_sprayer_1)
    (product_available fertilizer_product_npk)
    (operator_available operator_lead_crew1)
    (fertilizer_batch_available fertilizer_batch_001)
    (primary_section_has_timing_window primary_section_1 timing_window_phase_1)
    (secondary_section_has_weather_window secondary_section_1 weather_window_morning_1)
    (slot_available application_slot_001)
    (attachment_kit_available attachment_kit_nozzles)
    (attachment_kit_available attachment_kit_boombit)
    (plan_targets_primary_section task_plan_alpha primary_section_1)
    (plan_targets_primary_section task_plan_beta primary_section_1)
    (plan_targets_secondary_section task_plan_alpha secondary_section_1)
    (plan_targets_secondary_section task_plan_beta secondary_section_1)
    (plan_assigned_slot task_plan_alpha application_slot_001)
    (plan_assigned_slot task_plan_beta application_slot_001)
    (plan_assigned_attachment_kit task_plan_alpha attachment_kit_nozzles)
    (plan_assigned_attachment_kit task_plan_beta attachment_kit_boombit)
    (supplier_certificate_available supplier_cert_acme)
    (supplier_certificate_available supplier_cert_baker)
    (calibration_record_available calibration_record_001)
    (calibration_record_available calibration_record_002)
    (soil_sample_available soil_sample_01)
    (approval_document_available approval_document_internal_1)
    (operator_credential_available operator_credential_cert1)
    (plan_operator_credential_present task_plan_alpha operator_credential_cert1)
    (plan_operator_credential_present task_plan_beta operator_credential_cert2)
    (regulatory_permit_available regulatory_permit_01)
