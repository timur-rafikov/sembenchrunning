(define (problem staggered_planting_scenario)
  (:domain staggered_planting_domain)
  (:objects early_cohort_1 - early_planting_cohort late_cohort_1 - late_planting_cohort field_season_plan_1 - field_season_plan field_season_plan_2 - field_season_plan tractor_1 - machinery_unit tractor_2 - machinery_unit seed_drill_1 - machinery_unit seed_variety_a - seed_variety technician_1 - technician fertilizer_1 - input_material planting_window_1 - planting_window irrigation_window_1 - irrigation_window harvest_lot_1 - harvest_lot storage_unit_1 - storage_unit storage_unit_2 - storage_unit processing_line_1 - processing_resource processing_line_2 - processing_resource qc_kit_1 - quality_test_kit qc_kit_2 - quality_test_kit truck_1 - logistics_asset nutrient_treatment_1 - nutrient_treatment cert_doc_1 - certification_document cert_doc_2 - certification_document inspection_slot_1 - inspection_slot)
  (:init
    (machinery_available tractor_1)
    (machinery_available tractor_2)
    (machinery_available seed_drill_1)
    (seed_variety_available seed_variety_a)
    (technician_available technician_1)
    (input_material_available fertilizer_1)
    (early_cohort_planting_window_assigned early_cohort_1 planting_window_1)
    (late_cohort_irrigation_window_assigned late_cohort_1 irrigation_window_1)
    (harvest_lot_unallocated harvest_lot_1)
    (storage_unit_available storage_unit_1)
    (storage_unit_available storage_unit_2)
    (plan_has_early_cohort field_season_plan_1 early_cohort_1)
    (plan_has_early_cohort field_season_plan_2 early_cohort_1)
    (plan_has_late_cohort field_season_plan_1 late_cohort_1)
    (plan_has_late_cohort field_season_plan_2 late_cohort_1)
    (plan_linked_harvest_lot field_season_plan_1 harvest_lot_1)
    (plan_linked_harvest_lot field_season_plan_2 harvest_lot_1)
    (plan_assigned_storage field_season_plan_1 storage_unit_1)
    (plan_assigned_storage field_season_plan_2 storage_unit_2)
    (processing_resource_available processing_line_1)
    (processing_resource_available processing_line_2)
    (quality_test_kit_available qc_kit_1)
    (quality_test_kit_available qc_kit_2)
    (logistics_asset_available truck_1)
    (nutrient_treatment_available nutrient_treatment_1)
    (certification_document_available cert_doc_1)
    (plan_has_certification_document field_season_plan_1 cert_doc_1)
    (plan_has_certification_document field_season_plan_2 cert_doc_2)
    (inspection_slot_available inspection_slot_1)
  )
  (:goal
    (and
      (finalized early_cohort_1)
      (finalized late_cohort_1)
      (finalized field_season_plan_1)
      (finalized field_season_plan_2)
    )
  )
)
