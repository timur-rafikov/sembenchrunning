(define (problem farm_operation_schedule_problem)
  (:domain machinery_availability_aware_operation_planning)
  (:objects field_parcel_1 - field_parcel field_subparcel_1 - field_subparcel machine_unit_1 - machine_unit machine_unit_2 - machine_unit tractor_1 - tractor_unit tractor_2 - tractor_unit tractor_3 - tractor_unit time_slot_1 - time_slot crew_1 - operator_crew consumable_seed_1 - consumable_item slot_type_a_1 - slot_type_a slot_type_b_1 - slot_type_b implement_sprayer_1 - implement_unit material_batch_1 - material_batch material_batch_2 - material_batch season_spring - seasonal_label season_autumn - seasonal_label priority_high - priority_tag priority_low - priority_tag logistic_trailer_1 - logistic_resource attachment_spec_standard - attachment_spec policy_safety - policy_tag policy_environmental - policy_tag operator_certification_1 - certification)
  (:init
    (tractor_available tractor_1)
    (tractor_available tractor_2)
    (tractor_available tractor_3)
    (time_slot_available time_slot_1)
    (operator_available crew_1)
    (consumable_available consumable_seed_1)
    (parcel_has_slot_type_a field_parcel_1 slot_type_a_1)
    (subparcel_has_slot_type_b field_subparcel_1 slot_type_b_1)
    (implement_available implement_sprayer_1)
    (batch_available material_batch_1)
    (batch_available material_batch_2)
    (machine_linked_to_parcel machine_unit_1 field_parcel_1)
    (machine_linked_to_parcel machine_unit_2 field_parcel_1)
    (machine_linked_to_subparcel machine_unit_1 field_subparcel_1)
    (machine_linked_to_subparcel machine_unit_2 field_subparcel_1)
    (machine_mounted_with_implement machine_unit_1 implement_sprayer_1)
    (machine_mounted_with_implement machine_unit_2 implement_sprayer_1)
    (machine_assigned_batch machine_unit_1 material_batch_1)
    (machine_assigned_batch machine_unit_2 material_batch_2)
    (seasonal_label_available season_spring)
    (seasonal_label_available season_autumn)
    (priority_tag_available priority_high)
    (priority_tag_available priority_low)
    (logistic_resource_available logistic_trailer_1)
    (attachment_spec_available attachment_spec_standard)
    (policy_tag_available policy_safety)
    (machine_has_policy_tag machine_unit_1 policy_safety)
    (machine_has_policy_tag machine_unit_2 policy_environmental)
    (certification_available operator_certification_1)
  )
  (:goal
    (and
      (operation_completed field_parcel_1)
      (operation_completed field_subparcel_1)
      (operation_completed machine_unit_1)
      (operation_completed machine_unit_2)
    )
  )
)
