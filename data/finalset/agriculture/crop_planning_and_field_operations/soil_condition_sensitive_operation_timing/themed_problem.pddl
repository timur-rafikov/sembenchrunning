(define (problem soil_condition_sensitive_operation_timing_problem)
  (:domain soil_condition_sensitive_operation_timing_domain)
  (:objects mech_operation_1 - mechanized_operation manual_operation_1 - manual_operation field_parcel_1 - field_parcel field_parcel_2 - field_parcel machine_unit_1 - machine_unit machine_unit_2 - machine_unit machine_unit_3 - machine_unit operation_type_planting - operation_type crew_team_1 - crew input_resource_seed_lot_1 - input_resource soil_condition_slot_1 - soil_condition_slot weather_window_1 - weather_window work_order_1 - work_order inventory_item_batch_1 - inventory_item inventory_item_batch_2 - inventory_item attachment_spec_front_harrow - equipment_attachment_spec attachment_spec_sprayer - equipment_attachment_spec application_profile_seed_rate_1 - application_profile application_profile_spray_rate_1 - application_profile season_timing_slot_spring - season_timing_slot implement_variant_harrow_1 - implement_variant permit_contractor_1 - permit permit_site_specific_1 - permit inspection_record_1 - inspection_record)
  (:init
    (machine_available machine_unit_1)
    (machine_available machine_unit_2)
    (machine_available machine_unit_3)
    (execution_type_available operation_type_planting)
    (crew_available crew_team_1)
    (input_resource_available input_resource_seed_lot_1)
    (mechanized_operation_assigned_soil_slot mech_operation_1 soil_condition_slot_1)
    (manual_operation_assigned_weather_window manual_operation_1 weather_window_1)
    (work_order_pending work_order_1)
    (inventory_item_available inventory_item_batch_1)
    (inventory_item_available inventory_item_batch_2)
    (parcel_has_mechanized_operation field_parcel_1 mech_operation_1)
    (parcel_has_mechanized_operation field_parcel_2 mech_operation_1)
    (parcel_has_manual_operation field_parcel_1 manual_operation_1)
    (parcel_has_manual_operation field_parcel_2 manual_operation_1)
    (parcel_has_work_order field_parcel_1 work_order_1)
    (parcel_has_work_order field_parcel_2 work_order_1)
    (parcel_allocated_inventory_item field_parcel_1 inventory_item_batch_1)
    (parcel_allocated_inventory_item field_parcel_2 inventory_item_batch_2)
    (attachment_spec_available attachment_spec_front_harrow)
    (attachment_spec_available attachment_spec_sprayer)
    (application_profile_available application_profile_seed_rate_1)
    (application_profile_available application_profile_spray_rate_1)
    (season_timing_slot_available season_timing_slot_spring)
    (implement_variant_available implement_variant_harrow_1)
    (permit_available permit_contractor_1)
    (parcel_bound_to_permit field_parcel_1 permit_contractor_1)
    (parcel_bound_to_permit field_parcel_2 permit_site_specific_1)
    (inspection_record_available inspection_record_1)
  )
  (:goal
    (and
      (execution_completed mech_operation_1)
      (execution_completed manual_operation_1)
      (execution_completed field_parcel_1)
      (execution_completed field_parcel_2)
    )
  )
)
