    (batch_available harvest_batch_1)
    (quality_test_available moisture_test)
    (quality_test_available protein_test)
    (work_order_contains_unit crop_work_order_1 harvest_unit_1)
    (work_order_contains_unit crop_work_order_2 harvest_unit_1)
    (work_order_contains_transport_unit crop_work_order_1 transport_unit_1)
    (work_order_contains_transport_unit crop_work_order_2 transport_unit_1)
    (work_order_assigned_batch crop_work_order_1 harvest_batch_1)
    (work_order_assigned_batch crop_work_order_2 harvest_batch_1)
    (work_order_has_test crop_work_order_1 moisture_test)
    (work_order_has_test crop_work_order_2 protein_test)
    (market_constraint_available market_constraint_premium_delivery)
    (market_constraint_available market_constraint_bulk_discount)
    (quality_requirement_available quality_requirement_moisture_threshold)
    (quality_requirement_available quality_requirement_impurity_threshold)
    (storage_slot_available storage_slot_silo_1)
    (processing_option_available processing_option_drying)
    (market_contract_window_available market_contract_window_jan10)
    (work_order_has_market_contract_window crop_work_order_1 market_contract_window_jan10)
    (work_order_has_market_contract_window crop_work_order_2 market_contract_window_jan11)
    (weather_constraint_available weather_constraint_clear_skies)
