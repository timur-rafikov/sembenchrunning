(define (problem field_to_crop_assignment_problem)
  (:domain field_to_crop_assignment_domain)
  (:objects irrigation_subunit_1 - irrigation_subunit harvest_subunit_1 - harvest_subunit work_order_1 - work_order work_order_2 - work_order crop_variety_1 - crop_variety crop_variety_2 - crop_variety crop_variety_3 - crop_variety planting_window_1 - planting_window equipment_1 - equipment input_batch_1 - agricultural_input_batch irrigation_window_1 - irrigation_window harvest_window_1 - harvest_window operation_batch_1 - operation_batch material_lot_1 - material_lot material_lot_2 - material_lot contract_spec_1 - contract_specification contract_spec_2 - contract_specification market_destination_1 - market_destination market_destination_2 - market_destination production_season_1 - production_season primary_product_1 - primary_product contract_identifier_1 - contract_identifier contract_identifier_2 - contract_identifier regulatory_permit_1 - regulatory_permit)
  (:init
    (crop_variety_available crop_variety_1)
    (crop_variety_available crop_variety_2)
    (crop_variety_available crop_variety_3)
    (planting_window_available planting_window_1)
    (equipment_available equipment_1)
    (input_batch_available input_batch_1)
    (irrigation_window_assigned_to_subunit irrigation_subunit_1 irrigation_window_1)
    (harvest_window_assigned_to_subunit harvest_subunit_1 harvest_window_1)
    (operation_batch_available operation_batch_1)
    (material_lot_available material_lot_1)
    (material_lot_available material_lot_2)
    (work_order_has_irrigation_subunit work_order_1 irrigation_subunit_1)
    (work_order_has_irrigation_subunit work_order_2 irrigation_subunit_1)
    (work_order_has_harvest_subunit work_order_1 harvest_subunit_1)
    (work_order_has_harvest_subunit work_order_2 harvest_subunit_1)
    (work_order_includes_operation_batch work_order_1 operation_batch_1)
    (work_order_includes_operation_batch work_order_2 operation_batch_1)
    (work_order_material_lot_assigned work_order_1 material_lot_1)
    (work_order_material_lot_assigned work_order_2 material_lot_2)
    (contract_specification_available contract_spec_1)
    (contract_specification_available contract_spec_2)
    (market_destination_available market_destination_1)
    (market_destination_available market_destination_2)
    (production_season_available production_season_1)
    (primary_product_available primary_product_1)
    (contract_identifier_available contract_identifier_1)
    (work_order_has_contract_identifier work_order_1 contract_identifier_1)
    (work_order_has_contract_identifier work_order_2 contract_identifier_2)
    (regulatory_permit_available regulatory_permit_1)
  )
  (:goal
    (and
      (work_unit_assignment_confirmed irrigation_subunit_1)
      (work_unit_assignment_confirmed harvest_subunit_1)
      (work_unit_assignment_confirmed work_order_1)
      (work_unit_assignment_confirmed work_order_2)
    )
  )
)
