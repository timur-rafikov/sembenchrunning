(define (problem planting_density_adjustment_case)
  (:domain planting_density_adjustment_domain)
  (:objects field_zone_1 - field_zone field_strip_1 - field_strip prescription_1 - planting_prescription prescription_2 - planting_prescription planter_1 - seed_equipment planter_2 - seed_equipment planter_3 - seed_equipment variety_hybrid_a - crop_variety operator_1 - operator seed_batch_a - seed_batch soil_condition_1 - soil_condition operation_window_1 - operation_window job_slot_1 - planting_job rate_profile_high - seeding_rate_profile rate_profile_low - seeding_rate_profile calibration_a - equipment_calibration calibration_b - equipment_calibration fert_plan_a - fertilizer_plan fert_plan_b - fertilizer_plan season_slot_1 - season_slot irrigation_plan_standard - irrigation_plan history_2023 - field_history_record history_2022 - field_history_record yield_target_1 - yield_target)
  (:init
    (seed_equipment_available planter_1)
    (seed_equipment_available planter_2)
    (seed_equipment_available planter_3)
    (crop_variety_available variety_hybrid_a)
    (operator_available operator_1)
    (seed_batch_available seed_batch_a)
    (field_zone_soil_condition_binding field_zone_1 soil_condition_1)
    (field_strip_operation_window_binding field_strip_1 operation_window_1)
    (planting_job_slot_available job_slot_1)
    (seeding_rate_profile_available rate_profile_high)
    (seeding_rate_profile_available rate_profile_low)
    (prescription_field_zone_binding prescription_1 field_zone_1)
    (prescription_field_zone_binding prescription_2 field_zone_1)
    (prescription_field_strip_binding prescription_1 field_strip_1)
    (prescription_field_strip_binding prescription_2 field_strip_1)
    (prescription_assigned_to_job prescription_1 job_slot_1)
    (prescription_assigned_to_job prescription_2 job_slot_1)
    (prescription_has_seeding_rate_profile prescription_1 rate_profile_high)
    (prescription_has_seeding_rate_profile prescription_2 rate_profile_low)
    (equipment_calibration_available calibration_a)
    (equipment_calibration_available calibration_b)
    (fertilizer_plan_available fert_plan_a)
    (fertilizer_plan_available fert_plan_b)
    (season_slot_available season_slot_1)
    (irrigation_plan_available irrigation_plan_standard)
    (field_history_available history_2023)
    (prescription_field_history_binding prescription_1 history_2023)
    (prescription_field_history_binding prescription_2 history_2022)
    (yield_target_available yield_target_1)
  )
  (:goal
    (and
      (released_for_planting field_zone_1)
      (released_for_planting field_strip_1)
      (released_for_planting prescription_1)
      (released_for_planting prescription_2)
    )
  )
)
