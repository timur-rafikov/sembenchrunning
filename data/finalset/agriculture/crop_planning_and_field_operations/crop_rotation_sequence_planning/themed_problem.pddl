(define (problem crop_rotation_sequence_planning_problem)
  (:domain crop_rotation_sequence_planning_domain)
  (:objects field1_season - plot_season field2_neighbor_season - neighbor_plot_season crop_slot_1 - plan_slot crop_slot_2 - plan_slot harvester_1 - equipment_unit harvester_2 - equipment_unit sprayer_1 - equipment_unit seed_variety_a - seed_variety treatment_product_a - treatment_product input_batch_a - input_batch irrigation_window_1 - irrigation_window harvest_window_1 - harvest_window operation_job_1 - operation_job storage_site_a - storage_site storage_site_b - storage_site certification_tag_1 - certification_tag certification_tag_2 - certification_tag labor_shift_morning - labor_shift labor_shift_evening - labor_shift market_slot_day1 - market_slot nutrient_type_standard - nutrient_type regulatory_permit_1 - regulatory_permit regulatory_permit_2 - regulatory_permit weather_window_good - weather_window)
  (:init
    (equipment_available harvester_1)
    (equipment_available harvester_2)
    (equipment_available sprayer_1)
    (seed_available seed_variety_a)
    (treatment_available treatment_product_a)
    (input_batch_available input_batch_a)
    (plot_season_irrigation_window_assigned field1_season irrigation_window_1)
    (neighbor_plot_season_harvest_window_assigned field2_neighbor_season harvest_window_1)
    (operation_job_slot_available operation_job_1)
    (storage_site_available storage_site_a)
    (storage_site_available storage_site_b)
    (slot_assigned_to_plot_season crop_slot_1 field1_season)
    (slot_assigned_to_plot_season crop_slot_2 field1_season)
    (slot_assigned_to_neighbor_plot_season crop_slot_1 field2_neighbor_season)
    (slot_assigned_to_neighbor_plot_season crop_slot_2 field2_neighbor_season)
    (plan_slot_assigned_to_operation_job crop_slot_1 operation_job_1)
    (plan_slot_assigned_to_operation_job crop_slot_2 operation_job_1)
    (slot_has_storage_site crop_slot_1 storage_site_a)
    (slot_has_storage_site crop_slot_2 storage_site_b)
    (certification_tag_available certification_tag_1)
    (certification_tag_available certification_tag_2)
    (labor_shift_available labor_shift_morning)
    (labor_shift_available labor_shift_evening)
    (market_slot_available market_slot_day1)
    (nutrient_available nutrient_type_standard)
    (permit_available regulatory_permit_1)
    (slot_permit_assigned crop_slot_1 regulatory_permit_1)
    (slot_permit_assigned crop_slot_2 regulatory_permit_2)
    (weather_window_available weather_window_good)
  )
  (:goal
    (and
      (entity_rotation_completed field1_season)
      (entity_rotation_completed field2_neighbor_season)
      (entity_rotation_completed crop_slot_1)
      (entity_rotation_completed crop_slot_2)
    )
  )
)
