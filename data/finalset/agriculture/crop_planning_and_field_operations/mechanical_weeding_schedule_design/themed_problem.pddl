(define (problem weeding_schedule_scenario)
  (:domain mechanical_weeding_domain)
  (:objects field_plot_1 - field_plot field_block_1 - field_block weeding_plan_1 - weeding_plan weeding_plan_2 - weeding_plan method_tine_weeder - weeding_method method_finger_weeder - weeding_method method_interrow_hoe - weeding_method growth_stage_1 - growth_stage operator_role_primary - operator_role tool_module_blade - tool_module condition_profile_high_weeds - field_condition_profile route_1 - operational_route machine_unit_tractor_1 - machine_unit field_zone_1 - field_zone field_zone_2 - field_zone soil_condition_loamy - soil_condition soil_condition_clay - soil_condition shift_morning - operator_shift shift_afternoon - operator_shift calendar_window_spring - calendar_window attachment_setting_default - attachment_setting certification_level_1 - certification certification_level_2 - certification sensor_payload_ndvi - sensor_payload)
  (:init
    (method_available method_tine_weeder)
    (method_available method_finger_weeder)
    (method_available method_interrow_hoe)
    (growth_stage_available growth_stage_1)
    (operator_available operator_role_primary)
    (tool_module_available tool_module_blade)
    (plot_has_condition_profile field_plot_1 condition_profile_high_weeds)
    (block_route_assigned field_block_1 route_1)
    (machine_available machine_unit_tractor_1)
    (zone_available field_zone_1)
    (zone_available field_zone_2)
    (plan_covers_plot weeding_plan_1 field_plot_1)
    (plan_covers_plot weeding_plan_2 field_plot_1)
    (plan_covers_block weeding_plan_1 field_block_1)
    (plan_covers_block weeding_plan_2 field_block_1)
    (plan_assigned_machine weeding_plan_1 machine_unit_tractor_1)
    (plan_assigned_machine weeding_plan_2 machine_unit_tractor_1)
    (plan_zone_assigned weeding_plan_1 field_zone_1)
    (plan_zone_assigned weeding_plan_2 field_zone_2)
    (soil_condition_available soil_condition_loamy)
    (soil_condition_available soil_condition_clay)
    (operator_shift_available shift_morning)
    (operator_shift_available shift_afternoon)
    (calendar_window_available calendar_window_spring)
    (attachment_setting_available attachment_setting_default)
    (certification_available certification_level_1)
    (plan_certification_assigned weeding_plan_1 certification_level_1)
    (plan_certification_assigned weeding_plan_2 certification_level_2)
    (sensor_payload_available sensor_payload_ndvi)
  )
  (:goal
    (and
      (weeding_completed field_plot_1)
      (weeding_completed field_block_1)
      (weeding_completed weeding_plan_1)
      (weeding_completed weeding_plan_2)
    )
  )
)
