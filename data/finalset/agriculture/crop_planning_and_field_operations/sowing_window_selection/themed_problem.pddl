(define (problem sowing_window_selection_problem)
  (:domain sowing_window_selection_domain)
  (:objects field_plan_01 - field_plan field_schedule_01 - field_schedule management_unit_alpha - management_unit management_unit_beta - management_unit seeder_01 - machinery_unit seeder_02 - machinery_unit seeder_03 - machinery_unit seed_variety_a - seed_variety operator_team_a - operator_team input_material_seed_mix - input_material sowing_window_spring_1 - sowing_window weather_window_optimal_1 - weather_window operation_slot_template_1 - operation_slot input_batch_fert_001 - input_batch input_batch_seed_001 - input_batch equipment_type_trailed_seeder - equipment_type equipment_type_tractor_drawn - equipment_type task_requirement_soil_preparation - task_requirement task_requirement_compaction_check - task_requirement irrigation_slot_morning_1 - irrigation_slot fertilizer_npk - fertilizer_type regulatory_constraint_buffer_zone - regulatory_constraint regulatory_constraint_pesticide_restriction - regulatory_constraint pest_control_agent_insecticide_a - pest_control_agent)
  (:init
    (machinery_available seeder_01)
    (machinery_available seeder_02)
    (machinery_available seeder_03)
    (seed_variety_available seed_variety_a)
    (operator_team_available operator_team_a)
    (input_material_available input_material_seed_mix)
    (plan_sowing_window_candidate field_plan_01 sowing_window_spring_1)
    (schedule_weather_window_candidate field_schedule_01 weather_window_optimal_1)
    (operation_slot_template_available operation_slot_template_1)
    (input_batch_available input_batch_fert_001)
    (input_batch_available input_batch_seed_001)
    (management_unit_has_plan management_unit_alpha field_plan_01)
    (management_unit_has_plan management_unit_beta field_plan_01)
    (management_unit_has_schedule management_unit_alpha field_schedule_01)
    (management_unit_has_schedule management_unit_beta field_schedule_01)
    (management_unit_slot_assignment management_unit_alpha operation_slot_template_1)
    (management_unit_slot_assignment management_unit_beta operation_slot_template_1)
    (management_unit_has_batch management_unit_alpha input_batch_fert_001)
    (management_unit_has_batch management_unit_beta input_batch_seed_001)
    (equipment_type_available equipment_type_trailed_seeder)
    (equipment_type_available equipment_type_tractor_drawn)
    (task_requirement_available task_requirement_soil_preparation)
    (task_requirement_available task_requirement_compaction_check)
    (irrigation_slot_available irrigation_slot_morning_1)
    (fertilizer_available fertilizer_npk)
    (regulatory_constraint_available regulatory_constraint_buffer_zone)
    (management_unit_regulatory_requirement management_unit_alpha regulatory_constraint_buffer_zone)
    (management_unit_regulatory_requirement management_unit_beta regulatory_constraint_pesticide_restriction)
    (pest_control_agent_available pest_control_agent_insecticide_a)
  )
  (:goal
    (and
      (confirmed_for_sowing field_plan_01)
      (confirmed_for_sowing field_schedule_01)
      (confirmed_for_sowing management_unit_alpha)
      (confirmed_for_sowing management_unit_beta)
    )
  )
)
