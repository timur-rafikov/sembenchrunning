(define (problem pesticide_treatment_planning_problem)
  (:domain pesticide_treatment_window_selection)
  (:objects field_primary_1 - primary_field_unit field_secondary_1 - secondary_field_unit treatment_plan_alpha - treatment_plan treatment_plan_beta - treatment_plan sprayer_1 - application_equipment sprayer_2 - application_equipment sprayer_3 - application_equipment pesticide_product_a - pesticide_product crew_alpha - crew_or_operator adjuvant_batch_1 - consumable_item weather_window_1 - weather_window time_slot_variant_1 - time_slot_variant application_task_1 - application_task material_batch_1 - material_batch material_batch_2 - material_batch compliance_doc_1 - compliance_document compliance_doc_2 - compliance_document regulatory_approval_1 - regulatory_approval regulatory_approval_2 - regulatory_approval schedule_slot_1 - schedule_slot safety_equipment_1 - safety_equipment site_marker_1 - site_condition_marker site_marker_2 - site_condition_marker permit_1 - permit)
  (:init
    (equipment_available sprayer_1)
    (equipment_available sprayer_2)
    (equipment_available sprayer_3)
    (product_available pesticide_product_a)
    (crew_available crew_alpha)
    (consumable_available adjuvant_batch_1)
    (candidate_window_for_primary_field field_primary_1 weather_window_1)
    (candidate_time_variant_for_secondary_field field_secondary_1 time_slot_variant_1)
    (task_available_for_staging application_task_1)
    (material_batch_available material_batch_1)
    (material_batch_available material_batch_2)
    (plan_targets_primary_field treatment_plan_alpha field_primary_1)
    (plan_targets_primary_field treatment_plan_beta field_primary_1)
    (plan_targets_secondary_field treatment_plan_alpha field_secondary_1)
    (plan_targets_secondary_field treatment_plan_beta field_secondary_1)
    (plan_associated_with_task treatment_plan_alpha application_task_1)
    (plan_associated_with_task treatment_plan_beta application_task_1)
    (plan_has_material_batch treatment_plan_alpha material_batch_1)
    (plan_has_material_batch treatment_plan_beta material_batch_2)
    (compliance_document_available compliance_doc_1)
    (compliance_document_available compliance_doc_2)
    (regulatory_approval_available regulatory_approval_1)
    (regulatory_approval_available regulatory_approval_2)
    (schedule_slot_available schedule_slot_1)
    (safety_equipment_available safety_equipment_1)
    (site_condition_marker_available site_marker_1)
    (plan_has_site_condition_marker treatment_plan_alpha site_marker_1)
    (plan_has_site_condition_marker treatment_plan_beta site_marker_2)
    (permit_available permit_1)
  )
  (:goal
    (and
      (application_assigned field_primary_1)
      (application_assigned field_secondary_1)
      (application_assigned treatment_plan_alpha)
      (application_assigned treatment_plan_beta)
    )
  )
)
