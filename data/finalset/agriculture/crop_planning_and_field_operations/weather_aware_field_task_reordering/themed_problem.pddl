(define (problem weather_aware_field_task_reordering_problem)
  (:domain agriculture_weather_aware_reordering_domain)
  (:objects field_task_primary_1 - field_task_primary field_task_secondary_1 - field_task_secondary operation_plan_1 - field_operation_plan operation_plan_2 - field_operation_plan equipment_tractor_1 - equipment_unit equipment_sprayer_1 - equipment_unit equipment_planter_1 - equipment_unit weather_window_1 - weather_window crew_alpha - crew_unit seed_lot_a - agro_input_unit time_slot_primary_1 - field_time_slot_primary time_slot_secondary_1 - field_time_slot_secondary work_order_1 - work_order material_batch_1 - material_batch material_batch_2 - material_batch compliance_certificate_1 - compliance_certificate compliance_certificate_2 - compliance_certificate logistics_truck_1 - logistical_resource logistics_truck_2 - logistical_resource forecast_block_72h - forecast_block treatment_type_npk - treatment_type quality_check_soil_sample_1 - quality_check quality_check_visual_inspection_1 - quality_check regulatory_approval_pesticide - regulatory_approval)
  (:init
    (equipment_available equipment_tractor_1)
    (equipment_available equipment_sprayer_1)
    (equipment_available equipment_planter_1)
    (weather_window_available weather_window_1)
    (crew_available crew_alpha)
    (agro_input_available seed_lot_a)
    (task_has_primary_slot field_task_primary_1 time_slot_primary_1)
    (task_has_secondary_slot field_task_secondary_1 time_slot_secondary_1)
    (work_order_available work_order_1)
    (material_batch_available material_batch_1)
    (material_batch_available material_batch_2)
    (plan_has_primary_task operation_plan_1 field_task_primary_1)
    (plan_has_primary_task operation_plan_2 field_task_primary_1)
    (plan_has_secondary_task operation_plan_1 field_task_secondary_1)
    (plan_has_secondary_task operation_plan_2 field_task_secondary_1)
    (plan_linked_work_order operation_plan_1 work_order_1)
    (plan_linked_work_order operation_plan_2 work_order_1)
    (plan_has_material_batch operation_plan_1 material_batch_1)
    (plan_has_material_batch operation_plan_2 material_batch_2)
    (compliance_certificate_available compliance_certificate_1)
    (compliance_certificate_available compliance_certificate_2)
    (logistical_resource_available logistics_truck_1)
    (logistical_resource_available logistics_truck_2)
    (forecast_block_available forecast_block_72h)
    (treatment_type_available treatment_type_npk)
    (quality_check_available quality_check_soil_sample_1)
    (plan_linked_quality_check operation_plan_1 quality_check_soil_sample_1)
    (plan_linked_quality_check operation_plan_2 quality_check_visual_inspection_1)
    (regulatory_approval_available regulatory_approval_pesticide)
  )
  (:goal
    (and
      (work_entity_closed field_task_primary_1)
      (work_entity_closed field_task_secondary_1)
      (work_entity_closed operation_plan_1)
      (work_entity_closed operation_plan_2)
    )
  )
)
