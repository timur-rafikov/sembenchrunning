    (schedule_assigned_strategy irrigation_schedule_instance_2 irrigation_strategy_instance_2)
    (regulatory_constraint_available regulatory_constraint_instance_1)
  )
  (:goal
    (and
      (irrigation_application_finalized primary_field_block_instance_1)
      (irrigation_application_finalized secondary_field_block_instance_1)
      (irrigation_application_finalized irrigation_schedule_instance_1)
      (irrigation_application_finalized irrigation_schedule_instance_2)
    )
  )
)
