    (irrigation_job_draft irrigation_job_instance_1)
    (sensor_available sensor_node_instance_1)
    (sensor_available sensor_node_instance_2)
    (schedule_assigned_primary_block irrigation_schedule_instance_1 primary_field_block_instance_1)
    (schedule_assigned_primary_block irrigation_schedule_instance_2 primary_field_block_instance_1)
    (schedule_assigned_secondary_block irrigation_schedule_instance_1 secondary_field_block_instance_1)
    (schedule_assigned_secondary_block irrigation_schedule_instance_2 secondary_field_block_instance_1)
    (schedule_has_job irrigation_schedule_instance_1 irrigation_job_instance_1)
    (schedule_has_job irrigation_schedule_instance_2 irrigation_job_instance_1)
    (schedule_has_sensor irrigation_schedule_instance_1 sensor_node_instance_1)
    (schedule_has_sensor irrigation_schedule_instance_2 sensor_node_instance_2)
    (irrigation_mode_available irrigation_mode_instance_1)
    (irrigation_mode_available irrigation_mode_instance_2)
    (operation_template_available operation_template_instance_1)
    (operation_template_available operation_template_instance_2)
    (permit_record_available permit_record_instance_1)
    (equipment_model_available equipment_model_instance_1)
    (irrigation_strategy_available irrigation_strategy_instance_1)
