(define (problem post_harvest_loss_minimization_rotation_problem)
  (:domain post_harvest_loss_minimization_rotation_domain)
  (:objects storage_unit_a - storage_unit outbound_batch_a - outbound_batch handling_unit_a - handling_unit handling_unit_b - handling_unit grading_station_1 - grading_station grading_station_2 - grading_station grading_station_3 - grading_station inspector_1 - quality_inspector operator_1 - operator treatment_kit_1 - treatment_kit storage_condition_1 - storage_condition channel_condition_1 - channel_condition container_1 - container packaging_material_type_a - packaging_material packaging_material_type_b - packaging_material label_spec_standard - label_spec label_spec_special - label_spec packing_config_a - packing_configuration packing_config_b - packing_configuration release_slot_1 - release_slot temp_profile_cold - temperature_profile certification_phytosanitary - certification certification_organic - certification handling_protocol_standard - handling_protocol)
  (:init
    (grading_station_available grading_station_1)
    (grading_station_available grading_station_2)
    (grading_station_available grading_station_3)
    (inspector_available inspector_1)
    (operator_available operator_1)
    (treatment_kit_available treatment_kit_1)
    (storage_unit_has_condition storage_unit_a storage_condition_1)
    (outbound_batch_has_channel_condition outbound_batch_a channel_condition_1)
    (container_available container_1)
    (packaging_material_available packaging_material_type_a)
    (packaging_material_available packaging_material_type_b)
    (handling_unit_linked_to_storage_unit handling_unit_a storage_unit_a)
    (handling_unit_linked_to_storage_unit handling_unit_b storage_unit_a)
    (handling_unit_linked_to_outbound_batch handling_unit_a outbound_batch_a)
    (handling_unit_linked_to_outbound_batch handling_unit_b outbound_batch_a)
    (handling_unit_assigned_container handling_unit_a container_1)
    (handling_unit_assigned_container handling_unit_b container_1)
    (handling_unit_has_packaging_material handling_unit_a packaging_material_type_a)
    (handling_unit_has_packaging_material handling_unit_b packaging_material_type_b)
    (label_spec_available label_spec_standard)
    (label_spec_available label_spec_special)
    (packing_configuration_available packing_config_a)
    (packing_configuration_available packing_config_b)
    (release_slot_available release_slot_1)
    (temperature_profile_available temp_profile_cold)
    (certification_available certification_phytosanitary)
    (handling_unit_assigned_certification handling_unit_a certification_phytosanitary)
    (handling_unit_assigned_certification handling_unit_b certification_organic)
    (handling_protocol_available handling_protocol_standard)
  )
  (:goal
    (and
      (released_for_distribution storage_unit_a)
      (released_for_distribution outbound_batch_a)
      (released_for_distribution handling_unit_a)
      (released_for_distribution handling_unit_b)
    )
  )
)
