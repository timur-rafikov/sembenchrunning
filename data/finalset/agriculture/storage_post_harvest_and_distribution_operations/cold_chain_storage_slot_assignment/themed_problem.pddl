(define (problem cold_chain_slot_assignment_problem)
  (:domain cold_chain_storage_slot_assignment)
  (:objects inbound_pallet_1 - inbound_pallet outbound_pallet_1 - outbound_pallet storage_slot_1 - storage_slot storage_slot_2 - storage_slot grading_station_1 - grading_station grading_station_2 - grading_station grading_station_3 - grading_station inspection_device_1 - inspection_device handling_team_1 - handling_team aux_material_1 - auxiliary_material temperature_zone_1 - temperature_zone distribution_channel_1 - distribution_channel storage_block_1 - storage_block transfer_tray_1 - transfer_tray transfer_tray_2 - transfer_tray slot_config_attr_1 - slot_configuration_attribute slot_config_attr_2 - slot_configuration_attribute picking_profile_1 - picking_profile picking_profile_2 - picking_profile release_window_1 - release_window temperature_profile_1 - temperature_profile carrier_1 - carrier carrier_2 - carrier quality_certificate_1 - quality_certificate)
  (:init
    (grader_available grading_station_1)
    (grader_available grading_station_2)
    (grader_available grading_station_3)
    (inspection_device_available inspection_device_1)
    (handler_available handling_team_1)
    (auxiliary_material_available aux_material_1)
    (inbound_compatible_with_zone inbound_pallet_1 temperature_zone_1)
    (outbound_compatible_with_channel outbound_pallet_1 distribution_channel_1)
    (storage_block_available storage_block_1)
    (transfer_tray_available transfer_tray_1)
    (transfer_tray_available transfer_tray_2)
    (slot_associated_with_inbound_pallet storage_slot_1 inbound_pallet_1)
    (slot_associated_with_inbound_pallet storage_slot_2 inbound_pallet_1)
    (slot_associated_with_outbound_pallet storage_slot_1 outbound_pallet_1)
    (slot_associated_with_outbound_pallet storage_slot_2 outbound_pallet_1)
    (slot_within_storage_block storage_slot_1 storage_block_1)
    (slot_within_storage_block storage_slot_2 storage_block_1)
    (slot_has_transfer_tray storage_slot_1 transfer_tray_1)
    (slot_has_transfer_tray storage_slot_2 transfer_tray_2)
    (slot_configuration_attribute_available slot_config_attr_1)
    (slot_configuration_attribute_available slot_config_attr_2)
    (picking_profile_available picking_profile_1)
    (picking_profile_available picking_profile_2)
    (release_window_available release_window_1)
    (temperature_profile_available temperature_profile_1)
    (carrier_available carrier_1)
    (slot_associated_with_carrier storage_slot_1 carrier_1)
    (slot_associated_with_carrier storage_slot_2 carrier_2)
    (quality_certificate_available quality_certificate_1)
  )
  (:goal
    (and
      (released_for_dispatch inbound_pallet_1)
      (released_for_dispatch outbound_pallet_1)
      (released_for_dispatch storage_slot_1)
      (released_for_dispatch storage_slot_2)
    )
  )
)
