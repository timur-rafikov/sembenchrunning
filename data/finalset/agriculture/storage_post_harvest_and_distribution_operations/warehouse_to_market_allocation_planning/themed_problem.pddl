(define (problem warehouse_to_market_allocation_scenario)
  (:domain warehouse_to_market_allocation_planning)
  (:objects storage_batch_1 - storage_batch market_batch_1 - market_batch allocation_record_1 - allocation_record allocation_record_2 - allocation_record transport_unit_1 - transport_unit transport_unit_2 - transport_unit transport_unit_3 - transport_unit grading_station_1 - grading_station conditioning_unit_1 - conditioning_unit packaging_kit_1 - packaging_kit storage_slot_1 - storage_slot market_channel_1 - market_channel shipment_1 - shipment container_1 - container container_2 - container route_option_1 - route_option route_option_2 - route_option delivery_window_1 - delivery_window delivery_window_2 - delivery_window waybill_1 - waybill quality_certificate_1 - quality_certificate buyer_contract_1 - buyer_contract buyer_contract_2 - buyer_contract regulatory_approval_1 - regulatory_approval)
  (:init
    (transport_unit_available transport_unit_1)
    (transport_unit_available transport_unit_2)
    (transport_unit_available transport_unit_3)
    (grading_station_available grading_station_1)
    (conditioning_unit_available conditioning_unit_1)
    (packaging_kit_available packaging_kit_1)
    (storage_slot_link storage_batch_1 storage_slot_1)
    (market_channel_link market_batch_1 market_channel_1)
    (shipment_slot_available shipment_1)
    (container_available container_1)
    (container_available container_2)
    (allocation_assigned_storage_batch allocation_record_1 storage_batch_1)
    (allocation_assigned_storage_batch allocation_record_2 storage_batch_1)
    (allocation_assigned_market_batch allocation_record_1 market_batch_1)
    (allocation_assigned_market_batch allocation_record_2 market_batch_1)
    (allocation_assigned_shipment allocation_record_1 shipment_1)
    (allocation_assigned_shipment allocation_record_2 shipment_1)
    (allocation_has_container allocation_record_1 container_1)
    (allocation_has_container allocation_record_2 container_2)
    (route_option_available route_option_1)
    (route_option_available route_option_2)
    (delivery_window_available delivery_window_1)
    (delivery_window_available delivery_window_2)
    (waybill_available waybill_1)
    (quality_certificate_available quality_certificate_1)
    (buyer_contract_available buyer_contract_1)
    (buyer_contract_assigned_to_allocation allocation_record_1 buyer_contract_1)
    (buyer_contract_assigned_to_allocation allocation_record_2 buyer_contract_2)
    (regulatory_approval_available regulatory_approval_1)
  )
  (:goal
    (and
      (released_for_dispatch storage_batch_1)
      (released_for_dispatch market_batch_1)
      (released_for_dispatch allocation_record_1)
      (released_for_dispatch allocation_record_2)
    )
  )
)
