(define (problem harvest_drying_allocation_problem)
  (:domain drying_capacity_allocation)
  (:objects collection_batch_1 - collection_batch farm_batch_1 - farm_batch processing_order_1 - processing_order processing_order_2 - processing_order drying_unit_a - drying_unit drying_unit_b - drying_unit drying_unit_c - drying_unit moisture_meter_1 - inspection_device grader_1 - conditioning_equipment desiccant_1 - treatment_material drying_channel_1 - drying_channel time_window_1 - time_window drying_unit_instance_1 - drying_unit_instance grade_a - commodity_grade grade_b - commodity_grade packing_spec_standard - packing_specification packing_spec_premium - packing_specification outbound_channel_wholesale - outbound_channel outbound_channel_retail - outbound_channel distribution_slot_1 - distribution_slot drying_profile_default - drying_profile client_contract_1 - client_contract client_contract_2 - client_contract regulatory_doc_1 - regulatory_document)
  (:init
    (drying_unit_available drying_unit_a)
    (drying_unit_available drying_unit_b)
    (drying_unit_available drying_unit_c)
    (inspection_device_available moisture_meter_1)
    (conditioning_equipment_available grader_1)
    (treatment_material_available desiccant_1)
    (collection_batch_allocated_channel collection_batch_1 drying_channel_1)
    (farm_batch_allocated_time_window farm_batch_1 time_window_1)
    (drying_unit_instance_available drying_unit_instance_1)
    (commodity_grade_available grade_a)
    (commodity_grade_available grade_b)
    (order_includes_collection_batch processing_order_1 collection_batch_1)
    (order_includes_collection_batch processing_order_2 collection_batch_1)
    (order_includes_farm_batch processing_order_1 farm_batch_1)
    (order_includes_farm_batch processing_order_2 farm_batch_1)
    (order_assigned_to_unit_instance processing_order_1 drying_unit_instance_1)
    (order_assigned_to_unit_instance processing_order_2 drying_unit_instance_1)
    (order_specifies_commodity_grade processing_order_1 grade_a)
    (order_specifies_commodity_grade processing_order_2 grade_b)
    (packing_spec_available packing_spec_standard)
    (packing_spec_available packing_spec_premium)
    (outbound_channel_available outbound_channel_wholesale)
    (outbound_channel_available outbound_channel_retail)
    (distribution_slot_available distribution_slot_1)
    (drying_profile_available drying_profile_default)
    (client_contract_available client_contract_1)
    (order_linked_to_client_contract processing_order_1 client_contract_1)
    (order_linked_to_client_contract processing_order_2 client_contract_2)
    (regulatory_document_available regulatory_doc_1)
  )
  (:goal
    (and
      (placed_in_drying_unit collection_batch_1)
      (placed_in_drying_unit farm_batch_1)
      (placed_in_drying_unit processing_order_1)
      (placed_in_drying_unit processing_order_2)
    )
  )
)
