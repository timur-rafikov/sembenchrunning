(define (problem ripeness_dispatch_scenario)
  (:domain ripeness_dispatch_domain)
  (:objects receiving_slot_1 - inbound_handling_unit outbound_lane_1 - outbound_handling_unit workstation_a - workstation workstation_b - workstation dock_slot_1 - resource_slot dock_slot_2 - resource_slot dock_slot_3 - resource_slot inspection_sensor_1 - inspection_sensor conditioning_chamber_1 - conditioning_equipment packaging_crate - packaging_item ripeness_optimal - ripeness_class distribution_retail - distribution_channel shipment_pallet_slot_1 - shipment_pallet staging_label_1 - staging_label staging_label_2 - staging_label flag_precool - special_handling_flag flag_fragile - special_handling_flag label_document_1 - label_document label_document_2 - label_document time_window_1 - shipping_time_window storage_profile_cold_chain - storage_profile priority_token_customer_a - priority_token priority_token_customer_b - priority_token compliance_cert_1 - compliance_certificate)
  (:init
    (slot_available dock_slot_1)
    (slot_available dock_slot_2)
    (slot_available dock_slot_3)
    (sensor_available inspection_sensor_1)
    (conditioning_available conditioning_chamber_1)
    (packaging_available packaging_crate)
    (inbound_assigned_ripeness receiving_slot_1 ripeness_optimal)
    (outbound_unit_channel_assignment outbound_lane_1 distribution_retail)
    (pallet_available shipment_pallet_slot_1)
    (staging_label_available staging_label_1)
    (staging_label_available staging_label_2)
    (workstation_link_inbound_unit workstation_a receiving_slot_1)
    (workstation_link_inbound_unit workstation_b receiving_slot_1)
    (workstation_link_outbound_unit workstation_a outbound_lane_1)
    (workstation_link_outbound_unit workstation_b outbound_lane_1)
    (workstation_link_pallet workstation_a shipment_pallet_slot_1)
    (workstation_link_pallet workstation_b shipment_pallet_slot_1)
    (workstation_has_staging_label workstation_a staging_label_1)
    (workstation_has_staging_label workstation_b staging_label_2)
    (special_handling_flag_available flag_precool)
    (special_handling_flag_available flag_fragile)
    (label_document_available label_document_1)
    (label_document_available label_document_2)
    (shipping_time_window_available time_window_1)
    (storage_profile_available storage_profile_cold_chain)
    (priority_token_available priority_token_customer_a)
    (workstation_has_priority_token workstation_a priority_token_customer_a)
    (workstation_has_priority_token workstation_b priority_token_customer_b)
    (compliance_document_available compliance_cert_1)
  )
  (:goal
    (and
      (dispatch_binding_confirmed_entity receiving_slot_1)
      (dispatch_binding_confirmed_entity outbound_lane_1)
      (dispatch_binding_confirmed_entity workstation_a)
      (dispatch_binding_confirmed_entity workstation_b)
    )
  )
)
