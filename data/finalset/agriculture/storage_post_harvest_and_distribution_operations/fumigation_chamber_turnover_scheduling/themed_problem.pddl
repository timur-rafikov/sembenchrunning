(define (problem fumigation_chamber_turnover_example_problem)
  (:domain fumigation_chamber_turnover_scheduling_domain)
  (:objects inbound_batch_1 - inbound_batch outbound_batch_1 - outbound_batch fumigation_chamber_a - fumigation_chamber fumigation_chamber_b - fumigation_chamber schedule_slot_1 - schedule_slot schedule_slot_2 - schedule_slot schedule_slot_3 - schedule_slot quality_test_device_1 - quality_test technician_1 - technician pallet_1 - pallet treatment_profile_1 - treatment_profile receiving_profile_1 - receiving_profile container_unit_1 - container_unit inspection_record_1 - inspection_record inspection_record_2 - inspection_record compliance_certificate_1 - compliance_certificate compliance_certificate_2 - compliance_certificate carrier_1 - carrier carrier_2 - carrier release_window_1 - release_window fumigant_supply_1 - fumigant_supply safety_protocol_1 - safety_protocol safety_protocol_2 - safety_protocol monitoring_instrument_1 - monitoring_instrument)
  (:init
    (slot_available schedule_slot_1)
    (slot_available schedule_slot_2)
    (slot_available schedule_slot_3)
    (quality_test_available quality_test_device_1)
    (technician_available technician_1)
    (pallet_available pallet_1)
    (assigned_treatment_profile inbound_batch_1 treatment_profile_1)
    (assigned_receiving_profile outbound_batch_1 receiving_profile_1)
    (container_available container_unit_1)
    (inspection_record_available inspection_record_1)
    (inspection_record_available inspection_record_2)
    (chamber_compatible_with_batch fumigation_chamber_a inbound_batch_1)
    (chamber_compatible_with_batch fumigation_chamber_b inbound_batch_1)
    (chamber_compatible_with_outbound_batch fumigation_chamber_a outbound_batch_1)
    (chamber_compatible_with_outbound_batch fumigation_chamber_b outbound_batch_1)
    (chamber_compatible_with_container_unit fumigation_chamber_a container_unit_1)
    (chamber_compatible_with_container_unit fumigation_chamber_b container_unit_1)
    (chamber_has_inspection_record fumigation_chamber_a inspection_record_1)
    (chamber_has_inspection_record fumigation_chamber_b inspection_record_2)
    (compliance_certificate_available compliance_certificate_1)
    (compliance_certificate_available compliance_certificate_2)
    (carrier_available carrier_1)
    (carrier_available carrier_2)
    (release_window_available release_window_1)
    (fumigant_supply_available fumigant_supply_1)
    (safety_protocol_available safety_protocol_1)
    (chamber_has_safety_protocol fumigation_chamber_a safety_protocol_1)
    (chamber_has_safety_protocol fumigation_chamber_b safety_protocol_2)
    (monitoring_instrument_available monitoring_instrument_1)
  )
  (:goal
    (and
      (turnover_complete inbound_batch_1)
      (turnover_complete outbound_batch_1)
      (turnover_complete fumigation_chamber_a)
      (turnover_complete fumigation_chamber_b)
    )
  )
)
