    (case_box_available case_box_1)
    (case_box_available case_box_2)
    (manifest_assigned_cold_slot manifest_1 cold_slot_1)
    (manifest_assigned_cold_slot manifest_2 cold_slot_1)
    (manifest_assigned_ambient_slot manifest_1 ambient_slot_1)
    (manifest_assigned_ambient_slot manifest_2 ambient_slot_1)
    (manifest_assigned_to_shipment manifest_1 outbound_shipment_1)
    (manifest_assigned_to_shipment manifest_2 outbound_shipment_1)
