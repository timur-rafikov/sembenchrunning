(define (problem destination_market_channel_assignment_problem)
  (:domain postharvest_destination_market_channel_assignment)
  (:objects storage_slot_1 - storage_slot staging_slot_1 - staging_slot sku_1 - product_sku sku_2 - product_sku channel_wholesale - market_channel_option channel_retail - market_channel_option channel_export - market_channel_option test_resource_1 - quality_test_resource conditioning_station_1 - conditioning_station packaging_material_1 - packaging_material temperature_zone_cold - temperature_zone transit_route_1 - transit_route consignment_1 - consignment_unit sample_1 - sample_unit sample_2 - sample_unit label_template_1 - label_template label_template_2 - label_template dispatch_template_1 - dispatch_document_template dispatch_template_2 - dispatch_document_template destination_attribute_1 - destination_attribute packaging_spec_1 - packaging_spec buyer_1 - buyer buyer_2 - buyer cert_doc_1 - certification_document)
  (:init
    (market_channel_available channel_wholesale)
    (market_channel_available channel_retail)
    (market_channel_available channel_export)
    (test_resource_available test_resource_1)
    (conditioning_station_available conditioning_station_1)
    (packaging_material_available packaging_material_1)
    (storage_slot_in_temperature_zone storage_slot_1 temperature_zone_cold)
    (staging_slot_transit_assignment staging_slot_1 transit_route_1)
    (consignment_unit_available consignment_1)
    (sample_unit_available sample_1)
    (sample_unit_available sample_2)
    (sku_assigned_storage_slot sku_1 storage_slot_1)
    (sku_assigned_storage_slot sku_2 storage_slot_1)
    (sku_assigned_staging_slot sku_1 staging_slot_1)
    (sku_assigned_staging_slot sku_2 staging_slot_1)
    (sku_assigned_consignment sku_1 consignment_1)
    (sku_assigned_consignment sku_2 consignment_1)
    (sku_sample_association sku_1 sample_1)
    (sku_sample_association sku_2 sample_2)
    (label_template_available label_template_1)
    (label_template_available label_template_2)
    (dispatch_template_available dispatch_template_1)
    (dispatch_template_available dispatch_template_2)
    (destination_attribute_available destination_attribute_1)
    (packaging_spec_available packaging_spec_1)
    (buyer_available buyer_1)
    (sku_buyer_assignment sku_1 buyer_1)
    (sku_buyer_assignment sku_2 buyer_2)
    (certification_document_available cert_doc_1)
  )
  (:goal
    (and
      (released_for_destination storage_slot_1)
      (released_for_destination staging_slot_1)
      (released_for_destination sku_1)
      (released_for_destination sku_2)
    )
  )
)
