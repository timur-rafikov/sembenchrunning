(define (problem end_of_day_unsent_produce_rollover_problem)
  (:domain end_of_day_unsent_produce_rollover_domain)
  (:objects inbound_pallet_1 - consignment_inbound_pallet outbound_pallet_1 - consignment_outbound_pallet handling_unit_case_1 - consignment_case handling_unit_case_2 - consignment_case dispatch_slot_1 - dispatch_channel_slot dispatch_slot_2 - dispatch_channel_slot dispatch_slot_3 - dispatch_channel_slot grader_station_1 - grader_station conditioning_unit_1 - conditioning_unit packing_material_1 - packing_material storage_location_1 - storage_location transport_channel_1 - transport_channel outbound_container_1 - outbound_container storage_bin_1 - storage_bin storage_bin_2 - storage_bin destination_channel_1 - destination_channel destination_channel_2 - destination_channel carrier_manifest_1 - carrier_manifest carrier_manifest_2 - carrier_manifest rollover_window_1 - rollover_window quality_certificate_1 - quality_certificate priority_flag_1 - priority_flag priority_flag_2 - priority_flag traceability_tag_1 - traceability_tag)
  (:init
    (dispatch_slot_available dispatch_slot_1)
    (dispatch_slot_available dispatch_slot_2)
    (dispatch_slot_available dispatch_slot_3)
    (grader_available grader_station_1)
    (conditioning_unit_available conditioning_unit_1)
    (packing_material_available packing_material_1)
    (inbound_pallet_assigned_storage_location inbound_pallet_1 storage_location_1)
    (outbound_pallet_assigned_transport_channel outbound_pallet_1 transport_channel_1)
    (outbound_container_available outbound_container_1)
    (storage_bin_available storage_bin_1)
    (storage_bin_available storage_bin_2)
    (case_loaded_on_inbound_pallet handling_unit_case_1 inbound_pallet_1)
    (case_loaded_on_inbound_pallet handling_unit_case_2 inbound_pallet_1)
    (case_loaded_on_outbound_pallet handling_unit_case_1 outbound_pallet_1)
    (case_loaded_on_outbound_pallet handling_unit_case_2 outbound_pallet_1)
    (case_assigned_to_outbound_container handling_unit_case_1 outbound_container_1)
    (case_assigned_to_outbound_container handling_unit_case_2 outbound_container_1)
    (case_assigned_to_storage_bin handling_unit_case_1 storage_bin_1)
    (case_assigned_to_storage_bin handling_unit_case_2 storage_bin_2)
    (destination_channel_available destination_channel_1)
    (destination_channel_available destination_channel_2)
    (carrier_manifest_available carrier_manifest_1)
    (carrier_manifest_available carrier_manifest_2)
    (rollover_window_available rollover_window_1)
    (quality_certificate_available quality_certificate_1)
    (priority_flag_available priority_flag_1)
    (case_assigned_priority_flag handling_unit_case_1 priority_flag_1)
    (case_assigned_priority_flag handling_unit_case_2 priority_flag_2)
    (traceability_tag_available traceability_tag_1)
  )
  (:goal
    (and
      (consignment_item_marked_for_release inbound_pallet_1)
      (consignment_item_marked_for_release outbound_pallet_1)
      (consignment_item_marked_for_release handling_unit_case_1)
      (consignment_item_marked_for_release handling_unit_case_2)
    )
  )
)
