(define (problem harvest_scheduling_case_01)
  (:domain harvester_capacity_distribution)
  (:objects plot_variant_a_1 - plot_variant_a plot_variant_b_1 - plot_variant_b harvester_asset_alpha - harvester_asset harvester_asset_bravo - harvester_asset harvester_token_1 - harvester_resource_token harvester_token_2 - harvester_resource_token harvester_token_3 - harvester_resource_token time_slot_1 - harvest_time_slot attachment_header_1 - attachment_header consumable_kit_1 - consumable_kit route_a_1 - transfer_route_a route_b_1 - transfer_route_b harvest_job_1 - harvest_job silo_bin_1 - storage_silo_bin silo_bin_2 - storage_silo_bin header_model_a - header_model header_model_b - header_model operator_crew_alpha - operator_crew operator_crew_bravo - operator_crew contingency_unit_1 - contingency_reserve_unit fuel_reserve_1 - fuel_reserve site_permission_1 - site_permission site_permission_2 - site_permission weather_window_1 - weather_window)
  (:init
    (harvester_token_available harvester_token_1)
    (harvester_token_available harvester_token_2)
    (harvester_token_available harvester_token_3)
    (time_slot_available time_slot_1)
    (header_available attachment_header_1)
    (consumable_kit_available consumable_kit_1)
    (plot_variant_a_assigned_route plot_variant_a_1 route_a_1)
    (plot_variant_b_assigned_route plot_variant_b_1 route_b_1)
    (harvest_job_available harvest_job_1)
    (silo_bin_available silo_bin_1)
    (silo_bin_available silo_bin_2)
    (asset_compatible_with_variant_a harvester_asset_alpha plot_variant_a_1)
    (asset_compatible_with_variant_a harvester_asset_bravo plot_variant_a_1)
    (asset_compatible_with_variant_b harvester_asset_alpha plot_variant_b_1)
    (asset_compatible_with_variant_b harvester_asset_bravo plot_variant_b_1)
    (asset_assigned_to_job harvester_asset_alpha harvest_job_1)
    (asset_assigned_to_job harvester_asset_bravo harvest_job_1)
    (asset_assigned_to_silo_bin harvester_asset_alpha silo_bin_1)
    (asset_assigned_to_silo_bin harvester_asset_bravo silo_bin_2)
    (header_model_available header_model_a)
    (header_model_available header_model_b)
    (operator_crew_available operator_crew_alpha)
    (operator_crew_available operator_crew_bravo)
    (contingency_reserve_available contingency_unit_1)
    (fuel_reserve_available fuel_reserve_1)
    (site_permission_available site_permission_1)
    (asset_has_site_permission harvester_asset_alpha site_permission_1)
    (asset_has_site_permission harvester_asset_bravo site_permission_2)
    (weather_window_available weather_window_1)
  )
  (:goal
    (and
      (entity_serviced plot_variant_a_1)
      (entity_serviced plot_variant_b_1)
      (entity_serviced harvester_asset_alpha)
      (entity_serviced harvester_asset_bravo)
    )
  )
)
