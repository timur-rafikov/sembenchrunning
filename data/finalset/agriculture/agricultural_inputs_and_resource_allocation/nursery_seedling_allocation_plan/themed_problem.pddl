(define (problem nursery_seedling_allocation_problem)
  (:domain nursery_seedling_allocation)
  (:objects source_bench_1 - source_bench destination_bench_1 - destination_bench batch_alpha - seedling_batch batch_beta - seedling_batch transport_unit_1 - transport_unit transport_unit_2 - transport_unit transport_unit_3 - transport_unit variety_1 - crop_variety technician_1 - technician seed_stock_1 - input_stock source_zone_1 - source_zone destination_zone_1 - destination_zone crate_1 - transport_crate label_tag_1 - label_tag label_tag_2 - label_tag priority_flag_1 - priority_flag priority_flag_2 - priority_flag treatment_protocol_1 - treatment_protocol treatment_protocol_2 - treatment_protocol contingency_reserve_1 - contingency_reserve input_batch_1 - input_batch approval_doc_1 - approval_document approval_doc_2 - approval_document inspection_certificate_1 - inspection_certificate)
  (:init
    (transport_unit_available transport_unit_1)
    (transport_unit_available transport_unit_2)
    (transport_unit_available transport_unit_3)
    (crop_variety_available variety_1)
    (technician_available technician_1)
    (input_stock_available seed_stock_1)
    (source_bench_has_zone source_bench_1 source_zone_1)
    (destination_bench_has_zone destination_bench_1 destination_zone_1)
    (transport_crate_available crate_1)
    (label_tag_available label_tag_1)
    (label_tag_available label_tag_2)
    (batch_origin_source_bench batch_alpha source_bench_1)
    (batch_origin_source_bench batch_beta source_bench_1)
    (batch_assigned_destination_bench batch_alpha destination_bench_1)
    (batch_assigned_destination_bench batch_beta destination_bench_1)
    (batch_assigned_crate batch_alpha crate_1)
    (batch_assigned_crate batch_beta crate_1)
    (batch_has_label_tag batch_alpha label_tag_1)
    (batch_has_label_tag batch_beta label_tag_2)
    (priority_flag_available priority_flag_1)
    (priority_flag_available priority_flag_2)
    (treatment_protocol_available treatment_protocol_1)
    (treatment_protocol_available treatment_protocol_2)
    (contingency_reserve_available contingency_reserve_1)
    (input_batch_available input_batch_1)
    (approval_document_available approval_doc_1)
    (batch_attached_approval batch_alpha approval_doc_1)
    (batch_attached_approval batch_beta approval_doc_2)
    (inspection_certificate_available inspection_certificate_1)
  )
  (:goal
    (and
      (allocatable_fulfilled source_bench_1)
      (allocatable_fulfilled destination_bench_1)
      (allocatable_fulfilled batch_alpha)
      (allocatable_fulfilled batch_beta)
    )
  )
)
