(define (problem budget_constrained_procurement_case)
  (:domain agriculture_budget_constrained_procurement_selection)
  (:objects crop_parcel_alpha - crop_parcel alternate_parcel_beta - alternate_parcel procurement_agent_alpha - procurement_agent procurement_agent_beta - procurement_agent supplier_option_1 - supplier_option supplier_option_2 - supplier_option supplier_option_3 - supplier_option input_seed_batch_1 - input_product equipment_sprayer_1 - equipment adjuvant_package_1 - accessory_item inbound_slot_1 - inbound_logistics_slot outbound_slot_1 - outbound_logistics_slot purchase_order_1 - purchase_order compliance_doc_cert_a - compliance_document compliance_doc_cert_b - compliance_document promo_offer_a - promotional_offer promo_offer_b - promotional_offer labor_package_day_shift - labor_package labor_package_night_shift - labor_package contingency_reserve_1 - contingency_reserve storage_unit_1 - storage_resource site_constraint_zone_a - site_constraint site_constraint_zone_b - site_constraint insurance_policy_standard - insurance_policy)
  (:init
    (supplier_available supplier_option_1)
    (supplier_available supplier_option_2)
    (supplier_available supplier_option_3)
    (product_available input_seed_batch_1)
    (equipment_available equipment_sprayer_1)
    (accessory_available adjuvant_package_1)
    (inbound_slot_assigned_to_parcel crop_parcel_alpha inbound_slot_1)
    (outbound_slot_assigned_to_alternate_parcel alternate_parcel_beta outbound_slot_1)
    (purchase_order_staged purchase_order_1)
    (compliance_document_available compliance_doc_cert_a)
    (compliance_document_available compliance_doc_cert_b)
    (agent_assigned_to_parcel procurement_agent_alpha crop_parcel_alpha)
    (agent_assigned_to_parcel procurement_agent_beta crop_parcel_alpha)
    (agent_assigned_to_alternate_parcel procurement_agent_alpha alternate_parcel_beta)
    (agent_assigned_to_alternate_parcel procurement_agent_beta alternate_parcel_beta)
    (agent_assigned_to_purchase_order procurement_agent_alpha purchase_order_1)
    (agent_assigned_to_purchase_order procurement_agent_beta purchase_order_1)
    (agent_has_document procurement_agent_alpha compliance_doc_cert_a)
    (agent_has_document procurement_agent_beta compliance_doc_cert_b)
    (promotional_offer_available promo_offer_a)
    (promotional_offer_available promo_offer_b)
    (labor_package_available labor_package_day_shift)
    (labor_package_available labor_package_night_shift)
    (contingency_reserve_available contingency_reserve_1)
    (storage_available storage_unit_1)
    (site_constraint_active site_constraint_zone_a)
    (agent_has_site_constraint procurement_agent_alpha site_constraint_zone_a)
    (agent_has_site_constraint procurement_agent_beta site_constraint_zone_b)
    (insurance_available insurance_policy_standard)
  )
  (:goal
    (and
      (allocation_committed crop_parcel_alpha)
      (allocation_committed alternate_parcel_beta)
      (allocation_committed procurement_agent_alpha)
      (allocation_committed procurement_agent_beta)
    )
  )
)
