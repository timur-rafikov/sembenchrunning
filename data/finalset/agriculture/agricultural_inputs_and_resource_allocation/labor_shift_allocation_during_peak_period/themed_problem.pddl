(define (problem agricultural_labor_shift_allocation_peak_period_problem)
  (:domain agricultural_labor_shift_allocation_peak_period)
  (:objects field_worker_a - field_worker support_worker_a - support_worker field_crew_a - work_crew field_crew_b - work_crew tractor_unit_a - equipment_unit sprayer_unit_a - equipment_unit harvester_unit_a - equipment_unit crop_operations_certification - skill_certification field_supervisor_a - supervisor input_supply_a - consumable_supply field_parcel_a - field_parcel transport_route_a - transport_route peak_shift_slot_a - shift_slot work_package_a - work_package work_package_b - work_package authorization_permit_a - authorization_document authorization_permit_b - authorization_document toolkit_a - toolkit toolkit_b - toolkit contingency_buffer_a - contingency_reserve specialized_harvester_a - specialized_equipment incentive_voucher_a - incentive_voucher incentive_voucher_b - incentive_voucher weather_constraint_a - weather_constraint)
  (:init
    (equipment_available tractor_unit_a)
    (equipment_available sprayer_unit_a)
    (equipment_available harvester_unit_a)
    (skill_cert_available crop_operations_certification)
    (supervisor_available field_supervisor_a)
    (consumable_available input_supply_a)
    (worker_parcel_pair field_worker_a field_parcel_a)
    (support_worker_route_pair support_worker_a transport_route_a)
    (shift_open peak_shift_slot_a)
    (work_package_available work_package_a)
    (work_package_available work_package_b)
    (crew_field_worker_pair field_crew_a field_worker_a)
    (crew_field_worker_pair field_crew_b field_worker_a)
    (crew_support_worker_pair field_crew_a support_worker_a)
    (crew_support_worker_pair field_crew_b support_worker_a)
    (crew_shift_pair field_crew_a peak_shift_slot_a)
    (crew_shift_pair field_crew_b peak_shift_slot_a)
    (crew_work_package_pair field_crew_a work_package_a)
    (crew_work_package_pair field_crew_b work_package_b)
    (authorization_document_available authorization_permit_a)
    (authorization_document_available authorization_permit_b)
    (toolkit_available toolkit_a)
    (toolkit_available toolkit_b)
    (contingency_reserve_available contingency_buffer_a)
    (specialized_equipment_available specialized_harvester_a)
    (incentive_voucher_available incentive_voucher_a)
    (crew_voucher_pair field_crew_a incentive_voucher_a)
    (crew_voucher_pair field_crew_b incentive_voucher_b)
    (weather_constraint_active weather_constraint_a)
  )
  (:goal
    (and
      (labor_returned_to_pool field_worker_a)
      (labor_returned_to_pool support_worker_a)
      (labor_returned_to_pool field_crew_a)
      (labor_returned_to_pool field_crew_b)
    )
  )
)
