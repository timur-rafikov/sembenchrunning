(define (problem irrigation_water_allocation_problem)
  (:domain irrigation_water_allocation)
  (:objects high_priority_field_unit_1 - high_priority_field_unit secondary_field_unit_1 - secondary_priority_field_unit irrigation_planner_1 - irrigation_planner irrigation_planner_2 - irrigation_planner water_source_pump_1 - water_source_unit water_source_pump_2 - water_source_unit water_source_pump_3 - water_source_unit timeslot_1 - irrigation_time_slot distribution_valve_1 - distribution_valve quota_token_1 - water_quota_token delivery_segment_1 - delivery_segment delivery_node_1 - delivery_node allocation_record_1 - allocation_record field_sensor_1 - field_sensor field_sensor_2 - field_sensor regulatory_permit_1 - regulatory_permit regulatory_permit_2 - regulatory_permit irrigation_method_drip - irrigation_method irrigation_method_sprinkler - irrigation_method contingency_reserve_1 - contingency_reserve equipment_unit_pump_1 - equipment_unit emergency_certificate_1 - emergency_priority_certificate emergency_certificate_2 - emergency_priority_certificate quality_approval_1 - quality_approval)
  (:init
    (water_source_available water_source_pump_1)
    (water_source_available water_source_pump_2)
    (water_source_available water_source_pump_3)
    (timeslot_available timeslot_1)
    (valve_available distribution_valve_1)
    (quota_token_available quota_token_1)
    (high_priority_assigned_segment high_priority_field_unit_1 delivery_segment_1)
    (secondary_assigned_node secondary_field_unit_1 delivery_node_1)
    (allocation_record_available allocation_record_1)
    (sensor_available field_sensor_1)
    (sensor_available field_sensor_2)
    (planner_assigned_high_unit irrigation_planner_1 high_priority_field_unit_1)
    (planner_assigned_high_unit irrigation_planner_2 high_priority_field_unit_1)
    (planner_assigned_secondary_unit irrigation_planner_1 secondary_field_unit_1)
    (planner_assigned_secondary_unit irrigation_planner_2 secondary_field_unit_1)
    (planner_linked_record irrigation_planner_1 allocation_record_1)
    (planner_linked_record irrigation_planner_2 allocation_record_1)
    (planner_linked_sensor irrigation_planner_1 field_sensor_1)
    (planner_linked_sensor irrigation_planner_2 field_sensor_2)
    (regulatory_permit_available regulatory_permit_1)
    (regulatory_permit_available regulatory_permit_2)
    (irrigation_method_available irrigation_method_drip)
    (irrigation_method_available irrigation_method_sprinkler)
    (contingency_reserve_available contingency_reserve_1)
    (equipment_available equipment_unit_pump_1)
    (emergency_certificate_available emergency_certificate_1)
    (planner_linked_emergency_certificate irrigation_planner_1 emergency_certificate_1)
    (planner_linked_emergency_certificate irrigation_planner_2 emergency_certificate_2)
    (quality_approval_available quality_approval_1)
  )
  (:goal
    (and
      (entity_allocation_fulfilled high_priority_field_unit_1)
      (entity_allocation_fulfilled secondary_field_unit_1)
      (entity_allocation_fulfilled irrigation_planner_1)
      (entity_allocation_fulfilled irrigation_planner_2)
    )
  )
)
