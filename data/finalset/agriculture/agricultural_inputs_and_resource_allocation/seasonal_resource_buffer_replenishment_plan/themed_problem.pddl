(define (problem seasonal_resource_buffer_replenishment_scenario)
  (:domain seasonal_resource_buffer_replenishment_plan)
  (:objects field_alpha - crop_field livestock_unit_alpha - livestock_unit hub_north - logistics_hub hub_south - logistics_hub supply_lot_a - supply_lot supply_lot_b - supply_lot supply_lot_c - supply_lot inspector_1 - inspector tractor_1 - equipment_unit consumable_seed_pack_1 - consumable_unit field_slot_1 - field_resource_slot livestock_slot_1 - livestock_resource_slot order_001 - replenishment_order container_001 - container container_002 - container label_record_a - label_record label_record_b - label_record packaging_material_wrap_1 - packaging_material packaging_material_wrap_2 - packaging_material contingency_reserve_1 - contingency_reserve material_batch_fertilizer_1 - material_batch delivery_permit_1 - delivery_permit delivery_permit_2 - delivery_permit fuel_batch_1 - fuel_batch)
  (:init
    (supply_lot_available supply_lot_a)
    (supply_lot_available supply_lot_b)
    (supply_lot_available supply_lot_c)
    (inspector_available inspector_1)
    (equipment_available tractor_1)
    (consumable_available consumable_seed_pack_1)
    (field_slot_linked field_alpha field_slot_1)
    (livestock_slot_linked livestock_unit_alpha livestock_slot_1)
    (order_created order_001)
    (container_available container_001)
    (container_available container_002)
    (hub_serves_field hub_north field_alpha)
    (hub_serves_field hub_south field_alpha)
    (hub_serves_livestock hub_north livestock_unit_alpha)
    (hub_serves_livestock hub_south livestock_unit_alpha)
    (hub_has_order hub_north order_001)
    (hub_has_order hub_south order_001)
    (hub_has_container hub_north container_001)
    (hub_has_container hub_south container_002)
    (label_record_available label_record_a)
    (label_record_available label_record_b)
    (packaging_material_available packaging_material_wrap_1)
    (packaging_material_available packaging_material_wrap_2)
    (contingency_reserve_available contingency_reserve_1)
    (material_batch_available material_batch_fertilizer_1)
    (delivery_permit_available delivery_permit_1)
    (hub_has_permit hub_north delivery_permit_1)
    (hub_has_permit hub_south delivery_permit_2)
    (fuel_batch_available fuel_batch_1)
  )
  (:goal
    (and
      (target_replenished field_alpha)
      (target_replenished livestock_unit_alpha)
      (target_replenished hub_north)
      (target_replenished hub_south)
    )
  )
)
