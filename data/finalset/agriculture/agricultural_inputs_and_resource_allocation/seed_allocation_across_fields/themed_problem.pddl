(define (problem seed_allocation_problem)
  (:domain seed_allocation_domain)
  (:objects irrigated_field_unit_1 - irrigated_field_unit rainfed_field_unit_1 - rainfed_field_unit farm_site_1 - farm_site farm_site_2 - farm_site seed_batch_1 - seed_batch seed_batch_2 - seed_batch seed_batch_3 - seed_batch seed_variety_1 - seed_variety planter_unit_1 - machinery_unit fertilizer_batch_1 - fertilizer_batch allocation_window_irrigated_1 - allocation_window_irrigated allocation_window_rainfed_1 - allocation_window_rainfed allocation_package_1 - allocation_package storage_container_1 - storage_container storage_container_2 - storage_container compliance_certificate_1 - compliance_certificate compliance_certificate_2 - compliance_certificate logistics_team_1 - logistics_team logistics_team_2 - logistics_team contingency_reserve_unit_1 - contingency_reserve_unit agronomist_assignment_1 - agronomist_assignment insurance_policy_1 - insurance_policy insurance_policy_2 - insurance_policy contingency_reserve_variant_1 - contingency_reserve_variant)
  (:init
    (seed_batch_available seed_batch_1)
    (seed_batch_available seed_batch_2)
    (seed_batch_available seed_batch_3)
    (seed_variety_available seed_variety_1)
    (machinery_available planter_unit_1)
    (fertilizer_available fertilizer_batch_1)
    (allocation_window_assigned_to_irrigated_unit irrigated_field_unit_1 allocation_window_irrigated_1)
    (allocation_window_assigned_to_rainfed_unit rainfed_field_unit_1 allocation_window_rainfed_1)
    (allocation_package_available allocation_package_1)
    (storage_container_available storage_container_1)
    (storage_container_available storage_container_2)
    (farm_site_manages_irrigated_unit farm_site_1 irrigated_field_unit_1)
    (farm_site_manages_irrigated_unit farm_site_2 irrigated_field_unit_1)
    (farm_site_manages_rainfed_unit farm_site_1 rainfed_field_unit_1)
    (farm_site_manages_rainfed_unit farm_site_2 rainfed_field_unit_1)
    (farm_site_has_package farm_site_1 allocation_package_1)
    (farm_site_has_package farm_site_2 allocation_package_1)
    (farm_site_has_storage_container farm_site_1 storage_container_1)
    (farm_site_has_storage_container farm_site_2 storage_container_2)
    (compliance_certificate_available compliance_certificate_1)
    (compliance_certificate_available compliance_certificate_2)
    (logistics_team_available logistics_team_1)
    (logistics_team_available logistics_team_2)
    (contingency_reserve_available contingency_reserve_unit_1)
    (agronomist_available agronomist_assignment_1)
    (insurance_policy_available insurance_policy_1)
    (farm_site_has_insurance_policy farm_site_1 insurance_policy_1)
    (farm_site_has_insurance_policy farm_site_2 insurance_policy_2)
    (contingency_reserve_variant_available contingency_reserve_variant_1)
  )
  (:goal
    (and
      (unit_allocation_confirmed irrigated_field_unit_1)
      (unit_allocation_confirmed rainfed_field_unit_1)
      (unit_allocation_confirmed farm_site_1)
      (unit_allocation_confirmed farm_site_2)
    )
  )
)
