(define (problem input_delivery_priority_ranking_instance)
  (:domain agriculture_input_delivery_priority_ranking)
  (:objects plot_alpha - crop_plot herd_alpha - livestock_unit depot_north - distribution_node depot_south - distribution_node supplier_vehicle_1 - supplier_asset supplier_vehicle_2 - supplier_asset supplier_vehicle_3 - supplier_asset seed_type_a - input_type tractor_crew_1 - machinery_or_crew fertilizer_batch_1 - supply_batch seasonal_priority_high - priority_axis_seasonal operational_priority_high - priority_axis_operational delivery_order_1 - delivery_order voucher_alpha - allocation_voucher voucher_beta - allocation_voucher permit_alpha - regulatory_permit permit_beta - regulatory_permit timeslot_morning - timeslot timeslot_afternoon - timeslot contingency_reserve_1 - contingency_reserve standard_bundle_a - resource_bundle_standard credential_agronomist - specialist_credential credential_veterinarian - specialist_credential emergency_bundle_1 - emergency_bundle)
  (:init
    (supplier_available supplier_vehicle_1)
    (supplier_available supplier_vehicle_2)
    (supplier_available supplier_vehicle_3)
    (input_available seed_type_a)
    (machinery_available tractor_crew_1)
    (batch_available fertilizer_batch_1)
    (plot_seasonal_priority plot_alpha seasonal_priority_high)
    (livestock_operational_priority herd_alpha operational_priority_high)
    (delivery_order_open delivery_order_1)
    (voucher_available voucher_alpha)
    (voucher_available voucher_beta)
    (node_serves_plot depot_north plot_alpha)
    (node_serves_plot depot_south plot_alpha)
    (node_serves_livestock depot_north herd_alpha)
    (node_serves_livestock depot_south herd_alpha)
    (node_assigned_order depot_north delivery_order_1)
    (node_assigned_order depot_south delivery_order_1)
    (node_has_voucher depot_north voucher_alpha)
    (node_has_voucher depot_south voucher_beta)
    (permit_available permit_alpha)
    (permit_available permit_beta)
    (timeslot_available timeslot_morning)
    (timeslot_available timeslot_afternoon)
    (contingency_reserve_available contingency_reserve_1)
    (standard_bundle_available standard_bundle_a)
    (credential_available credential_agronomist)
    (node_has_credential depot_north credential_agronomist)
    (node_has_credential depot_south credential_veterinarian)
    (emergency_bundle_available emergency_bundle_1)
  )
  (:goal
    (and
      (entity_delivery_committed plot_alpha)
      (entity_delivery_committed herd_alpha)
      (entity_delivery_committed depot_north)
      (entity_delivery_committed depot_south)
    )
  )
)
