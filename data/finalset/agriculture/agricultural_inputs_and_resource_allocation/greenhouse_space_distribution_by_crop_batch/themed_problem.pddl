(define (problem greenhouse_batch_allocation_problem)
  (:domain greenhouse_space_distribution_by_crop_batch)
  (:objects bench_batch_1 - bench_batch rack_batch_1 - rack_batch greenhouse_facility_a - greenhouse_facility greenhouse_facility_b - greenhouse_facility space_slot_1 - space_slot space_slot_2 - space_slot space_slot_3 - space_slot crop_variety_1 - crop_variety equipment_1 - equipment consumable_fertilizer_1 - consumable irrigation_profile_zone_1 - irrigation_profile lighting_profile_zone_1 - lighting_profile production_bay_a - production_bay substrate_mix_a - substrate_mix substrate_mix_b - substrate_mix permit_a - permit permit_b - permit labor_shift_morning - labor_shift labor_shift_evening - labor_shift contingency_reserve_1 - contingency_reserve nutrient_solution_batch_1 - nutrient_solution seasonal_document_1 - seasonal_document seasonal_document_2 - seasonal_document climate_buffer_1 - climate_buffer)
  (:init
    (space_slot_available space_slot_1)
    (space_slot_available space_slot_2)
    (space_slot_available space_slot_3)
    (variety_available crop_variety_1)
    (equipment_available equipment_1)
    (consumable_available consumable_fertilizer_1)
    (bench_irrigation_binding bench_batch_1 irrigation_profile_zone_1)
    (rack_lighting_binding rack_batch_1 lighting_profile_zone_1)
    (production_bay_available production_bay_a)
    (substrate_mix_available substrate_mix_a)
    (substrate_mix_available substrate_mix_b)
    (facility_bench_assignment greenhouse_facility_a bench_batch_1)
    (facility_bench_assignment greenhouse_facility_b bench_batch_1)
    (facility_rack_assignment greenhouse_facility_a rack_batch_1)
    (facility_rack_assignment greenhouse_facility_b rack_batch_1)
    (facility_bay_binding greenhouse_facility_a production_bay_a)
    (facility_bay_binding greenhouse_facility_b production_bay_a)
    (facility_substrate_binding greenhouse_facility_a substrate_mix_a)
    (facility_substrate_binding greenhouse_facility_b substrate_mix_b)
    (permit_available permit_a)
    (permit_available permit_b)
    (labor_shift_available labor_shift_morning)
    (labor_shift_available labor_shift_evening)
    (contingency_reserve_available contingency_reserve_1)
    (nutrient_solution_available nutrient_solution_batch_1)
    (seasonal_document_available seasonal_document_1)
    (facility_document_binding greenhouse_facility_a seasonal_document_1)
    (facility_document_binding greenhouse_facility_b seasonal_document_2)
    (climate_buffer_available climate_buffer_1)
  )
  (:goal
    (and
      (allocation_finalized bench_batch_1)
      (allocation_finalized rack_batch_1)
      (allocation_finalized greenhouse_facility_a)
      (allocation_finalized greenhouse_facility_b)
    )
  )
)
