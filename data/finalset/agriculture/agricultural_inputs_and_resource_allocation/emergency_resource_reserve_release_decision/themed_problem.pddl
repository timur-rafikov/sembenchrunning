(define (problem emergency_release_decision_problem)
  (:domain agri_emergency_reserve_release)
  (:objects primary_beneficiary_unit_1 - primary_beneficiary_unit secondary_beneficiary_unit_1 - secondary_beneficiary_unit distribution_center_a - distribution_center distribution_center_b - distribution_center reserve_stock_item_1 - reserve_stock_item reserve_stock_item_2 - reserve_stock_item reserve_stock_item_3 - reserve_stock_item commodity_seed_variety_a - commodity_type operational_asset_loader_1 - operational_asset supply_package_kit_1 - supply_package primary_transport_vehicle_1 - primary_transport_resource secondary_transport_vehicle_1 - secondary_transport_resource release_order_1 - release_order test_resource_1 - quality_test_resource test_resource_2 - quality_test_resource authorization_token_1 - authorization_token authorization_token_2 - authorization_token technical_specialist_1 - technical_specialist technical_specialist_2 - technical_specialist allocation_voucher_1 - allocation_voucher critical_component_1 - critical_component priority_beneficiary_1 - priority_beneficiary priority_beneficiary_2 - priority_beneficiary regulatory_certificate_1 - regulatory_certificate)
  (:init
    (reserve_stock_available reserve_stock_item_1)
    (reserve_stock_available reserve_stock_item_2)
    (reserve_stock_available reserve_stock_item_3)
    (commodity_available commodity_seed_variety_a)
    (asset_available operational_asset_loader_1)
    (supply_package_available supply_package_kit_1)
    (primary_transport_association primary_beneficiary_unit_1 primary_transport_vehicle_1)
    (secondary_transport_association secondary_beneficiary_unit_1 secondary_transport_vehicle_1)
    (release_order_open release_order_1)
    (test_resource_available test_resource_1)
    (test_resource_available test_resource_2)
    (center_linked_primary_unit distribution_center_a primary_beneficiary_unit_1)
    (center_linked_primary_unit distribution_center_b primary_beneficiary_unit_1)
    (center_linked_secondary_unit distribution_center_a secondary_beneficiary_unit_1)
    (center_linked_secondary_unit distribution_center_b secondary_beneficiary_unit_1)
    (center_has_release_order distribution_center_a release_order_1)
    (center_has_release_order distribution_center_b release_order_1)
    (center_has_test_resource distribution_center_a test_resource_1)
    (center_has_test_resource distribution_center_b test_resource_2)
    (authorization_token_available authorization_token_1)
    (authorization_token_available authorization_token_2)
    (technical_specialist_available technical_specialist_1)
    (technical_specialist_available technical_specialist_2)
    (allocation_voucher_available allocation_voucher_1)
    (critical_component_available critical_component_1)
    (priority_beneficiary_available priority_beneficiary_1)
    (center_assigned_priority_beneficiary distribution_center_a priority_beneficiary_1)
    (center_assigned_priority_beneficiary distribution_center_b priority_beneficiary_2)
    (regulatory_certificate_available regulatory_certificate_1)
  )
  (:goal
    (and
      (requesting_unit_released primary_beneficiary_unit_1)
      (requesting_unit_released secondary_beneficiary_unit_1)
      (requesting_unit_released distribution_center_a)
      (requesting_unit_released distribution_center_b)
    )
  )
)
