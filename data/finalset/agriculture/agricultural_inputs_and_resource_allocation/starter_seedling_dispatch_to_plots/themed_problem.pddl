(define (problem starter_seedling_dispatch_to_plots_problem)
  (:domain starter_seedling_dispatch)
  (:objects plot_1 - plot subplot_1 - subplot batch_1 - seedling_batch batch_2 - seedling_batch transport_1 - transport_unit transport_2 - transport_unit transport_3 - transport_unit variety_alpha - seedling_variety operator_1 - operator consumable_fertilizer_1 - consumable_batch staging_slot_1 - staging_slot transport_slot_1 - transport_slot dispatch_pallet_1 - dispatch_pallet container_1 - container container_2 - container label_1 - label label_2 - label certificate_1 - inspection_certificate certificate_2 - inspection_certificate contingency_reserve_1 - contingency_reserve special_equipment_1 - special_equipment site_permit_1 - site_permit site_permit_2 - site_permit biosecurity_clearance_1 - biosecurity_clearance)
  (:init
    (transport_unit_available transport_1)
    (transport_unit_available transport_2)
    (transport_unit_available transport_3)
    (variety_available variety_alpha)
    (operator_available operator_1)
    (consumable_available consumable_fertilizer_1)
    (plot_allocated_staging_slot plot_1 staging_slot_1)
    (subplot_allocated_transport_slot subplot_1 transport_slot_1)
    (dispatch_pallet_available dispatch_pallet_1)
    (container_available container_1)
    (container_available container_2)
    (batch_assigned_to_plot batch_1 plot_1)
    (batch_assigned_to_plot batch_2 plot_1)
    (batch_assigned_to_subplot batch_1 subplot_1)
    (batch_assigned_to_subplot batch_2 subplot_1)
    (batch_loaded_to_pallet batch_1 dispatch_pallet_1)
    (batch_loaded_to_pallet batch_2 dispatch_pallet_1)
    (batch_assigned_to_container batch_1 container_1)
    (batch_assigned_to_container batch_2 container_2)
    (label_available label_1)
    (label_available label_2)
    (inspection_certificate_available certificate_1)
    (inspection_certificate_available certificate_2)
    (contingency_reserve_available contingency_reserve_1)
    (special_equipment_available special_equipment_1)
    (site_permit_available site_permit_1)
    (batch_has_site_permit batch_1 site_permit_1)
    (batch_has_site_permit batch_2 site_permit_2)
    (biosecurity_clearance_available biosecurity_clearance_1)
  )
  (:goal
    (and
      (deployment_completed plot_1)
      (deployment_completed subplot_1)
      (deployment_completed batch_1)
      (deployment_completed batch_2)
    )
  )
)
