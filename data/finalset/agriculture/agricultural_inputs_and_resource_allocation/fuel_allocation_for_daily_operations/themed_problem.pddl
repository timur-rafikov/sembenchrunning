(define (problem daily_fuel_allocation_problem)
  (:domain fuel_allocation_daily_operations)
  (:objects primary_asset_1 - primary_mobile_asset secondary_asset_1 - secondary_mobile_asset coordinator_1 - fuel_coordinator coordinator_2 - fuel_coordinator fuel_source_1 - fuel_source fuel_source_2 - fuel_source fuel_source_3 - fuel_source vehicle_1 - vehicle operator_crew_1 - operator_crew portable_canister_1 - portable_fuel_canister primary_bay_1 - refuel_bay_primary secondary_bay_1 - refuel_bay_secondary allocation_order_1 - fuel_allocation_order flow_meter_1 - flow_meter flow_meter_2 - flow_meter priority_tag_1 - priority_tag priority_tag_2 - priority_tag fuel_grade_1 - fuel_grade fuel_grade_2 - fuel_grade contingency_reserve_1 - contingency_reserve fuel_batch_1 - fuel_batch permit_1 - regulatory_permit permit_2 - regulatory_permit safety_clearance_1 - safety_clearance)
  (:init
    (fuel_source_available fuel_source_1)
    (fuel_source_available fuel_source_2)
    (fuel_source_available fuel_source_3)
    (vehicle_available vehicle_1)
    (operator_available operator_crew_1)
    (canister_available portable_canister_1)
    (asset_link_primary_bay primary_asset_1 primary_bay_1)
    (asset_link_secondary_bay secondary_asset_1 secondary_bay_1)
    (allocation_order_open allocation_order_1)
    (meter_available flow_meter_1)
    (meter_available flow_meter_2)
    (coordinator_assigned_primary_asset coordinator_1 primary_asset_1)
    (coordinator_assigned_primary_asset coordinator_2 primary_asset_1)
    (coordinator_assigned_secondary_asset coordinator_1 secondary_asset_1)
    (coordinator_assigned_secondary_asset coordinator_2 secondary_asset_1)
    (coordinator_assigned_order coordinator_1 allocation_order_1)
    (coordinator_assigned_order coordinator_2 allocation_order_1)
    (coordinator_assigned_meter coordinator_1 flow_meter_1)
    (coordinator_assigned_meter coordinator_2 flow_meter_2)
    (priority_tag_available priority_tag_1)
    (priority_tag_available priority_tag_2)
    (fuel_grade_available fuel_grade_1)
    (fuel_grade_available fuel_grade_2)
    (contingency_reserve_available contingency_reserve_1)
    (fuel_batch_available fuel_batch_1)
    (permit_available permit_1)
    (coordinator_assigned_permit coordinator_1 permit_1)
    (coordinator_assigned_permit coordinator_2 permit_2)
    (safety_clearance_available safety_clearance_1)
  )
  (:goal
    (and
      (entity_fueling_finalized primary_asset_1)
      (entity_fueling_finalized secondary_asset_1)
      (entity_fueling_finalized coordinator_1)
      (entity_fueling_finalized coordinator_2)
    )
  )
)
