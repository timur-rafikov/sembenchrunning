(define (problem mixed_herd_resource_separation_problem)
  (:domain mixed_herd_resource_separation_domain)
  (:objects source_subgroup_a - source_subgroup target_subgroup_a - target_subgroup separation_plan_1 - separation_plan separation_plan_2 - separation_plan resource_token_1 - resource_token resource_token_2 - resource_token resource_token_3 - resource_token clinical_procedure_1 - clinical_procedure handler_1 - handler consumable_supply_1 - consumable_supply facility_origin_1 - facility_origin facility_destination_1 - facility_destination holding_batch_1 - holding_batch container_label_1 - container_label container_label_2 - container_label authorization_doc_1 - authorization_document authorization_doc_2 - authorization_document service_slot_1 - service_slot service_slot_2 - service_slot schedule_slot_1 - schedule_slot medication_1 - medication consent_form_1 - consent_form consent_form_2 - consent_form vaccine_1 - vaccine)
  (:init
    (resource_available resource_token_1)
    (resource_available resource_token_2)
    (resource_available resource_token_3)
    (procedure_available clinical_procedure_1)
    (handler_available handler_1)
    (supply_available consumable_supply_1)
    (subgroup_assigned_origin source_subgroup_a facility_origin_1)
    (subgroup_assigned_destination target_subgroup_a facility_destination_1)
    (batch_available holding_batch_1)
    (container_label_available container_label_1)
    (container_label_available container_label_2)
    (plan_associated_source_subgroup separation_plan_1 source_subgroup_a)
    (plan_associated_source_subgroup separation_plan_2 source_subgroup_a)
    (plan_associated_target_subgroup separation_plan_1 target_subgroup_a)
    (plan_associated_target_subgroup separation_plan_2 target_subgroup_a)
    (plan_associated_batch separation_plan_1 holding_batch_1)
    (plan_associated_batch separation_plan_2 holding_batch_1)
    (plan_has_container_label separation_plan_1 container_label_1)
    (plan_has_container_label separation_plan_2 container_label_2)
    (authorization_document_available authorization_doc_1)
    (authorization_document_available authorization_doc_2)
    (service_slot_available service_slot_1)
    (service_slot_available service_slot_2)
    (schedule_slot_available schedule_slot_1)
    (medication_available medication_1)
    (consent_form_available consent_form_1)
    (plan_has_consent_form separation_plan_1 consent_form_1)
    (plan_has_consent_form separation_plan_2 consent_form_2)
    (vaccine_available vaccine_1)
  )
  (:goal
    (and
      (separation_completed source_subgroup_a)
      (separation_completed target_subgroup_a)
      (separation_completed separation_plan_1)
      (separation_completed separation_plan_2)
    )
