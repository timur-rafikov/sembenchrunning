(define (problem transport_readiness_check_problem)
  (:domain livestock_transport_readiness)
  (:objects source_group_1 - source_animal_group receiving_group_1 - receiving_animal_group handling_station_1 - handling_station handling_station_2 - handling_station load_slot_1 - load_slot load_slot_2 - load_slot load_slot_3 - load_slot weighing_station_1 - weighing_station stock_handler_1 - stock_handler consumable_feed_1 - consumable_item loading_zone_a_1 - loading_zone_a loading_zone_b_1 - loading_zone_b transport_vehicle_1 - transport_vehicle cargo_container_1 - cargo_container cargo_container_2 - cargo_container movement_permit_1 - movement_permit movement_permit_2 - movement_permit vehicle_operator_1 - vehicle_operator vehicle_operator_2 - vehicle_operator identification_tag_1 - identification_tag veterinary_kit_1 - veterinary_kit inspection_certificate_1 - inspection_certificate inspection_certificate_2 - inspection_certificate biosecurity_kit_1 - biosecurity_kit)
  (:init
    (load_slot_available load_slot_1)
    (load_slot_available load_slot_2)
    (load_slot_available load_slot_3)
    (weighing_station_available weighing_station_1)
    (handler_available stock_handler_1)
    (consumable_available consumable_feed_1)
    (group_assigned_to_zone_a source_group_1 loading_zone_a_1)
    (group_assigned_to_zone_b receiving_group_1 loading_zone_b_1)
    (vehicle_available transport_vehicle_1)
    (container_available cargo_container_1)
    (container_available cargo_container_2)
    (station_assigned_source_group handling_station_1 source_group_1)
    (station_assigned_source_group handling_station_2 source_group_1)
    (station_assigned_receiving_group handling_station_1 receiving_group_1)
    (station_assigned_receiving_group handling_station_2 receiving_group_1)
    (station_linked_to_vehicle handling_station_1 transport_vehicle_1)
    (station_linked_to_vehicle handling_station_2 transport_vehicle_1)
    (station_has_container handling_station_1 cargo_container_1)
    (station_has_container handling_station_2 cargo_container_2)
    (movement_permit_available movement_permit_1)
    (movement_permit_available movement_permit_2)
    (operator_available vehicle_operator_1)
    (operator_available vehicle_operator_2)
    (identification_tag_available identification_tag_1)
    (veterinary_kit_available veterinary_kit_1)
    (inspection_certificate_available inspection_certificate_1)
    (station_has_certificate handling_station_1 inspection_certificate_1)
    (station_has_certificate handling_station_2 inspection_certificate_2)
    (biosecurity_kit_available biosecurity_kit_1)
  )
  (:goal
    (and
      (cleared_for_transport source_group_1)
      (cleared_for_transport receiving_group_1)
      (cleared_for_transport handling_station_1)
      (cleared_for_transport handling_station_2)
    )
  )
)
