    (additive_batch_available additive_batch_b)
    (record_has_adult_rep herd_record_1 adult_rep_1)
    (record_has_adult_rep herd_record_2 adult_rep_1)
    (record_has_juvenile_rep herd_record_1 juvenile_rep_1)
    (record_has_juvenile_rep herd_record_2 juvenile_rep_1)
    (record_has_transport_unit herd_record_1 transport_unit_1)
    (record_has_transport_unit herd_record_2 transport_unit_1)
    (record_has_additive_batch herd_record_1 additive_batch_a)
    (record_has_additive_batch herd_record_2 additive_batch_b)
