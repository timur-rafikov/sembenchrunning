    (maintenance_tool_available maintenance_tool_b)
    (resource_ticket_available resource_ticket_a)
    (resource_ticket_available resource_ticket_b)
    (water_quality_kit_available water_quality_kit_1)
    (medication_pack_available medication_pack_1)
    (authorization_token_available authorization_token_a)
