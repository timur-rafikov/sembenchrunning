(define (problem herd_veterinary_intervention_problem)
  (:domain veterinary_intervention_priority_ordering)
  (:objects adult_animal_1 - adult_animal juvenile_animal_1 - juvenile_animal case_file_1 - case_file case_file_2 - case_file treatment_station_1 - treatment_station treatment_station_2 - treatment_station treatment_station_3 - treatment_station diagnostic_kit_1 - diagnostic_kit procedure_equipment_1 - procedure_equipment medication_batch_1 - medication_batch clinical_signature_1 - clinical_signature triage_category_1 - triage_category intervention_bundle_1 - intervention_bundle sample_record_1 - sample_record sample_record_2 - sample_record regulatory_document_1 - regulatory_document regulatory_document_2 - regulatory_document consumable_unit_1 - consumable_unit consumable_unit_2 - consumable_unit schedule_slot_1 - schedule_slot specialist_resource_1 - specialist_resource owner_authorization_1 - owner_authorization owner_authorization_2 - owner_authorization diagnostic_device_1 - diagnostic_device)
  (:init
    (station_available treatment_station_1)
    (station_available treatment_station_2)
    (station_available treatment_station_3)
    (diagnostic_kit_available diagnostic_kit_1)
    (equipment_available procedure_equipment_1)
    (medication_batch_available medication_batch_1)
    (adult_has_clinical_signature adult_animal_1 clinical_signature_1)
    (juvenile_has_triage_category juvenile_animal_1 triage_category_1)
    (intervention_bundle_available intervention_bundle_1)
    (sample_record_available sample_record_1)
    (sample_record_available sample_record_2)
    (case_linked_to_adult case_file_1 adult_animal_1)
    (case_linked_to_adult case_file_2 adult_animal_1)
    (case_linked_to_juvenile case_file_1 juvenile_animal_1)
    (case_linked_to_juvenile case_file_2 juvenile_animal_1)
    (case_linked_to_bundle case_file_1 intervention_bundle_1)
    (case_linked_to_bundle case_file_2 intervention_bundle_1)
    (case_has_sample case_file_1 sample_record_1)
    (case_has_sample case_file_2 sample_record_2)
    (regulatory_document_available regulatory_document_1)
    (regulatory_document_available regulatory_document_2)
    (consumable_unit_available consumable_unit_1)
    (consumable_unit_available consumable_unit_2)
    (schedule_slot_available schedule_slot_1)
    (specialist_resource_available specialist_resource_1)
    (owner_authorization_available owner_authorization_1)
    (case_has_owner_authorization case_file_1 owner_authorization_1)
    (case_has_owner_authorization case_file_2 owner_authorization_2)
    (diagnostic_device_available diagnostic_device_1)
  )
  (:goal
    (and
      (discharged_entity adult_animal_1)
      (discharged_entity juvenile_animal_1)
      (discharged_entity case_file_1)
      (discharged_entity case_file_2)
    )
  )
)
