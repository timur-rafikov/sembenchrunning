(define (problem animal_group_reassignment_scenario)
  (:domain animal_group_reassignment_domain)
  (:objects source_group_1 - source_group destination_group_1 - destination_group reassignment_task_1 - reassignment_task reassignment_task_2 - reassignment_task pen_1 - pen pen_2 - pen pen_3 - pen handling_station_1 - handling_station handler_1 - handler feed_ration_standard - feed_ration movement_slot_1 - movement_slot reception_slot_1 - reception_slot transport_vehicle_1 - transport_vehicle load_crate_1 - load_crate load_crate_2 - load_crate identification_tag_1 - identification_tag identification_tag_2 - identification_tag vaccination_dose_1 - vaccination_dose vaccination_dose_2 - vaccination_dose movement_document_1 - movement_document sedation_dose_1 - sedation_dose breeding_record_1 - breeding_record breeding_record_2 - breeding_record pregnancy_test_1 - pregnancy_test)
  (:init
    (pen_available pen_1)
    (pen_available pen_2)
    (pen_available pen_3)
    (handling_station_available handling_station_1)
    (handler_available handler_1)
    (feed_ration_available feed_ration_standard)
    (group_movement_slot_assigned source_group_1 movement_slot_1)
    (destgroup_reception_slot_assigned destination_group_1 reception_slot_1)
    (vehicle_available transport_vehicle_1)
    (crate_available load_crate_1)
    (crate_available load_crate_2)
    (task_source_group reassignment_task_1 source_group_1)
    (task_source_group reassignment_task_2 source_group_1)
    (task_destination_group reassignment_task_1 destination_group_1)
    (task_destination_group reassignment_task_2 destination_group_1)
    (task_assigned_vehicle reassignment_task_1 transport_vehicle_1)
    (task_assigned_vehicle reassignment_task_2 transport_vehicle_1)
    (task_has_crate reassignment_task_1 load_crate_1)
    (task_has_crate reassignment_task_2 load_crate_2)
    (identification_tag_available identification_tag_1)
    (identification_tag_available identification_tag_2)
    (vaccination_dose_available vaccination_dose_1)
    (vaccination_dose_available vaccination_dose_2)
    (movement_document_available movement_document_1)
    (sedation_dose_available sedation_dose_1)
    (breeding_record_present breeding_record_1)
    (task_has_breeding_record reassignment_task_1 breeding_record_1)
    (task_has_breeding_record reassignment_task_2 breeding_record_2)
    (pregnancy_test_available pregnancy_test_1)
  )
  (:goal
    (and
      (entity_reassignment_completed source_group_1)
      (entity_reassignment_completed destination_group_1)
      (entity_reassignment_completed reassignment_task_1)
      (entity_reassignment_completed reassignment_task_2)
    )
  )
)
