(define (problem feed_shortage_ration_reallocation_problem)
  (:domain feed_shortage_ration_reallocation_domain)
  (:objects donor_herd_a - donor_herd recipient_herd_a - recipient_herd operational_unit_a - operational_unit operational_unit_b - operational_unit feed_point_a - feed_point feed_point_b - feed_point feed_point_c - feed_point feed_batch_a - feed_batch handler_a - handler supplement_pack_a - supplement_pack ration_request_slot_a - ration_request_slot distribution_slot_a - distribution_slot transfer_container_a - transfer_container quality_sample_a - quality_sample quality_sample_b - quality_sample biosecurity_protocol_a - biosecurity_protocol biosecurity_protocol_b - biosecurity_protocol equipment_item_a - equipment_item equipment_item_b - equipment_item allocation_voucher_a - allocation_voucher treatment_additive_a - treatment_additive regulatory_permit_a - regulatory_permit regulatory_permit_b - regulatory_permit inspection_token_a - inspection_token)
  (:init
    (feed_point_available feed_point_a)
    (feed_point_available feed_point_b)
    (feed_point_available feed_point_c)
    (feed_batch_available feed_batch_a)
    (handler_available handler_a)
    (supplement_pack_available supplement_pack_a)
    (donor_ration_slot_linked donor_herd_a ration_request_slot_a)
    (recipient_distribution_slot_linked recipient_herd_a distribution_slot_a)
    (transfer_container_available transfer_container_a)
    (quality_sample_available quality_sample_a)
    (quality_sample_available quality_sample_b)
    (unit_linked_to_donor_herd operational_unit_a donor_herd_a)
    (unit_linked_to_donor_herd operational_unit_b donor_herd_a)
    (unit_linked_to_recipient_herd operational_unit_a recipient_herd_a)
    (unit_linked_to_recipient_herd operational_unit_b recipient_herd_a)
    (unit_linked_to_transfer_container operational_unit_a transfer_container_a)
    (unit_linked_to_transfer_container operational_unit_b transfer_container_a)
    (sample_assigned_to_unit operational_unit_a quality_sample_a)
    (sample_assigned_to_unit operational_unit_b quality_sample_b)
    (biosecurity_protocol_available biosecurity_protocol_a)
    (biosecurity_protocol_available biosecurity_protocol_b)
    (equipment_item_available equipment_item_a)
    (equipment_item_available equipment_item_b)
    (allocation_voucher_available allocation_voucher_a)
    (treatment_additive_available treatment_additive_a)
    (regulatory_permit_available regulatory_permit_a)
    (permit_assigned operational_unit_a regulatory_permit_a)
    (permit_assigned operational_unit_b regulatory_permit_b)
    (inspection_token_available inspection_token_a)
  )
  (:goal
    (and
      (unit_allocation_finalized donor_herd_a)
      (unit_allocation_finalized recipient_herd_a)
      (unit_allocation_finalized operational_unit_a)
      (unit_allocation_finalized operational_unit_b)
    )
  )
)
