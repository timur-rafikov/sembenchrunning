    (young_group_time_slot young_group_1 young_time_slot_1)
    (visit_resource_available visit_resource_1)
    (vaccine_vial_type_available vaccine_vial_type_a)
    (vaccine_vial_type_available vaccine_vial_type_b)
    (case_bound_to_adult_group follow_up_case_1 adult_group_1)
    (case_bound_to_adult_group follow_up_case_2 adult_group_1)
    (case_bound_to_young_group follow_up_case_1 young_group_1)
    (case_bound_to_young_group follow_up_case_2 young_group_1)
    (case_assigned_visit follow_up_case_1 visit_resource_1)
    (case_assigned_visit follow_up_case_2 visit_resource_1)
    (case_bound_vaccine_vial_type follow_up_case_1 vaccine_vial_type_a)
    (case_bound_vaccine_vial_type follow_up_case_2 vaccine_vial_type_b)
    (consent_form_available consent_form_1)
    (consent_form_available consent_form_2)
    (record_form_available record_form_1)
    (record_form_available record_form_2)
    (follow_up_interval_available follow_up_interval_1)
    (equipment_item_available equipment_item_1)
    (authorization_token_available authorization_token_1)
    (case_bound_to_authorization_token follow_up_case_1 authorization_token_1)
    (case_bound_to_authorization_token follow_up_case_2 authorization_token_2)
    (regulatory_approval_available regulatory_approval_1)
