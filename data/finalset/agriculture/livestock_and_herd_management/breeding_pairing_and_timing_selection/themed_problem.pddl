(define (problem breeding_pairing_timing_problem)
  (:domain livestock_breeding_pairing_domain)
  (:objects female_subject_1 - female_animal male_subject_1 - male_animal pairing_record_1 - pairing_record pairing_record_2 - pairing_record breeding_resource_1 - breeding_resource breeding_resource_2 - breeding_resource breeding_resource_3 - breeding_resource service_time_slot_1 - service_time_slot technician_1 - technician consumable_unit_1 - consumable_unit female_pen_1 - female_pen male_pen_1 - male_pen service_event_1 - service_event biological_sample_1 - biological_sample biological_sample_2 - biological_sample breeding_protocol_1 - breeding_protocol breeding_protocol_2 - breeding_protocol post_service_procedure_1 - post_service_procedure post_service_procedure_2 - post_service_procedure service_certificate_1 - service_certificate genetic_profile_1 - genetic_profile owner_consent_1 - owner_consent owner_consent_2 - owner_consent pregnancy_test_1 - pregnancy_test)
  (:init
    (resource_available breeding_resource_1)
    (resource_available breeding_resource_2)
    (resource_available breeding_resource_3)
    (time_slot_available service_time_slot_1)
    (technician_available technician_1)
    (consumable_available consumable_unit_1)
    (female_assigned_pen female_subject_1 female_pen_1)
    (male_assigned_pen male_subject_1 male_pen_1)
    (service_event_available service_event_1)
    (sample_available biological_sample_1)
    (sample_available biological_sample_2)
    (pairing_has_female pairing_record_1 female_subject_1)
    (pairing_has_female pairing_record_2 female_subject_1)
    (pairing_has_male pairing_record_1 male_subject_1)
    (pairing_has_male pairing_record_2 male_subject_1)
    (pairing_has_service_event pairing_record_1 service_event_1)
    (pairing_has_service_event pairing_record_2 service_event_1)
    (pairing_has_sample pairing_record_1 biological_sample_1)
    (pairing_has_sample pairing_record_2 biological_sample_2)
    (protocol_available breeding_protocol_1)
    (protocol_available breeding_protocol_2)
    (post_service_procedure_available post_service_procedure_1)
    (post_service_procedure_available post_service_procedure_2)
    (service_certificate_available service_certificate_1)
    (genetic_profile_available genetic_profile_1)
    (owner_consent_available owner_consent_1)
    (pairing_has_consent pairing_record_1 owner_consent_1)
    (pairing_has_consent pairing_record_2 owner_consent_2)
    (pregnancy_test_available pregnancy_test_1)
  )
  (:goal
    (and
      (service_certified female_subject_1)
      (service_certified male_subject_1)
      (service_certified pairing_record_1)
      (service_certified pairing_record_2)
    )
  )
)
