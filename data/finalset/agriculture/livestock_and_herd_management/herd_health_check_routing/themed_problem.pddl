(define (problem herd_health_check_routing_problem)
  (:domain herd_health_check_routing)
  (:objects primary_animal_1 - animal_primary secondary_animal_1 - animal_secondary inspection_team_alpha - inspection_team inspection_team_bravo - inspection_team route_slot_1 - route_slot route_slot_2 - route_slot route_slot_3 - route_slot appointment_slot_1 - appointment_slot handling_station_1 - handling_station consumable_supply_1 - consumable_supply checkpoint_1 - checkpoint route_node_1 - route_node inspection_round_1 - inspection_round sample_kit_1 - sample_kit sample_kit_2 - sample_kit certificate_type_movement - certificate_type certificate_type_compliance - certificate_type treatment_protocol_standard - treatment_protocol treatment_protocol_vaccination - treatment_protocol health_record_slot_1 - health_record equipment_portable_reader - equipment authorization_token_authority - authorization_token authorization_token_regulator - authorization_token diagnostic_test_pcr - diagnostic_test)
  (:init
    (route_slot_available route_slot_1)
    (route_slot_available route_slot_2)
    (route_slot_available route_slot_3)
    (appointment_slot_available appointment_slot_1)
    (handling_station_available handling_station_1)
    (consumable_available consumable_supply_1)
    (assigned_to_checkpoint primary_animal_1 checkpoint_1)
    (assigned_to_route_node secondary_animal_1 route_node_1)
    (inspection_round_available inspection_round_1)
    (sample_kit_available sample_kit_1)
    (sample_kit_available sample_kit_2)
    (team_assigned_to_primary inspection_team_alpha primary_animal_1)
    (team_assigned_to_primary inspection_team_bravo primary_animal_1)
    (team_assigned_to_secondary inspection_team_alpha secondary_animal_1)
    (team_assigned_to_secondary inspection_team_bravo secondary_animal_1)
    (team_assigned_to_round inspection_team_alpha inspection_round_1)
    (team_assigned_to_round inspection_team_bravo inspection_round_1)
    (team_has_sample_kit inspection_team_alpha sample_kit_1)
    (team_has_sample_kit inspection_team_bravo sample_kit_2)
    (certificate_type_available certificate_type_movement)
    (certificate_type_available certificate_type_compliance)
    (treatment_protocol_available treatment_protocol_standard)
    (treatment_protocol_available treatment_protocol_vaccination)
    (health_record_available health_record_slot_1)
    (equipment_available equipment_portable_reader)
    (authorization_token_available authorization_token_authority)
    (team_has_authorization_token inspection_team_alpha authorization_token_authority)
    (team_has_authorization_token inspection_team_bravo authorization_token_regulator)
    (diagnostic_test_available diagnostic_test_pcr)
  )
  (:goal
    (and
      (resources_returned primary_animal_1)
      (resources_returned secondary_animal_1)
      (resources_returned inspection_team_alpha)
      (resources_returned inspection_team_bravo)
    )
  )
)
