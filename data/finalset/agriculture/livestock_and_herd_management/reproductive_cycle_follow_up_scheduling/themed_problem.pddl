(define (problem herd_reproductive_followup_problem)
  (:domain reproductive_cycle_follow_up_scheduling)
  (:objects female_cow_1 - female_animal male_bull_1 - male_animal herd_group_a - herd_group herd_group_b - herd_group breeding_slot_1 - breeding_slot breeding_slot_2 - breeding_slot breeding_slot_3 - breeding_slot insemination_kit_1 - insemination_kit handling_station_1 - handling_station treatment_dose_1 - treatment_dose estrus_event_1 - female_estrus_event male_availability_event_1 - male_availability_event service_appointment_1 - service_appointment preg_test_kit_1 - pregnancy_test_kit preg_test_kit_2 - pregnancy_test_kit ultrasound_unit_1 - ultrasound_unit ultrasound_unit_2 - ultrasound_unit vaccine_dose_1 - vaccine_dose vaccine_dose_2 - vaccine_dose observation_form_1 - observation_form handling_equipment_1 - handling_equipment vet_technician_1 - veterinary_technician vet_technician_2 - veterinary_technician hormone_batch_1 - hormone_batch)
  (:init
    (breeding_slot_available breeding_slot_1)
    (breeding_slot_available breeding_slot_2)
    (breeding_slot_available breeding_slot_3)
    (insemination_kit_available insemination_kit_1)
    (handling_station_available handling_station_1)
    (treatment_dose_available treatment_dose_1)
    (female_linked_estrus_event female_cow_1 estrus_event_1)
    (male_linked_availability_event male_bull_1 male_availability_event_1)
    (service_appointment_available service_appointment_1)
    (pregnancy_test_kit_available preg_test_kit_1)
    (pregnancy_test_kit_available preg_test_kit_2)
    (group_contains_female herd_group_a female_cow_1)
    (group_contains_female herd_group_b female_cow_1)
    (group_contains_male herd_group_a male_bull_1)
    (group_contains_male herd_group_b male_bull_1)
    (group_linked_appointment herd_group_a service_appointment_1)
    (group_linked_appointment herd_group_b service_appointment_1)
    (group_has_pregnancy_test_kit herd_group_a preg_test_kit_1)
    (group_has_pregnancy_test_kit herd_group_b preg_test_kit_2)
    (ultrasound_unit_available ultrasound_unit_1)
    (ultrasound_unit_available ultrasound_unit_2)
    (vaccine_dose_available vaccine_dose_1)
    (vaccine_dose_available vaccine_dose_2)
    (observation_form_available observation_form_1)
    (handling_equipment_available handling_equipment_1)
    (technician_available vet_technician_1)
    (group_technician_association_exists herd_group_a vet_technician_1)
    (group_technician_association_exists herd_group_b vet_technician_2)
    (hormone_batch_available hormone_batch_1)
  )
  (:goal
    (and
      (outcome_recorded female_cow_1)
      (outcome_recorded male_bull_1)
      (outcome_recorded herd_group_a)
      (outcome_recorded herd_group_b)
    )
  )
)
