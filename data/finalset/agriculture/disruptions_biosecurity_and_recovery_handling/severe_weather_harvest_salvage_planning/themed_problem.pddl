(define (problem severe_weather_salvage_scenario)
  (:domain severe_weather_harvest_salvage_planning)
  (:objects field_salvage_team_1 - field_salvage_team processing_salvage_team_1 - processing_salvage_team salvage_plan_1 - salvage_plan salvage_plan_2 - salvage_plan loader_1 - logistics_asset truck_1 - logistics_asset forklift_1 - logistics_asset assessor_1 - assessor response_crew_1 - response_crew supply_kit_1 - supply_kit salvage_zone_1 - salvage_zone processing_facility_1 - processing_facility transport_container_1 - transport_container test_sample_1 - test_sample test_sample_2 - test_sample permit_type_standard - regulatory_permit_type permit_type_emergency - regulatory_permit_type quality_cert_standard - quality_certification quality_cert_secondary - quality_certification contingency_reserve_1 - contingency_reserve decon_kit_1 - decontamination_kit regulatory_permit_1 - regulatory_permit regulatory_permit_2 - regulatory_permit lab_capacity_1 - lab_capacity)
  (:init
    (asset_available loader_1)
    (asset_available truck_1)
    (asset_available forklift_1)
    (assessor_available assessor_1)
    (response_crew_available response_crew_1)
    (supply_kit_available supply_kit_1)
    (field_team_assigned_zone field_salvage_team_1 salvage_zone_1)
    (processing_team_assigned_facility processing_salvage_team_1 processing_facility_1)
    (transport_container_available transport_container_1)
    (test_sample_available test_sample_1)
    (test_sample_available test_sample_2)
    (plan_assigned_field_team salvage_plan_1 field_salvage_team_1)
    (plan_assigned_field_team salvage_plan_2 field_salvage_team_1)
    (plan_assigned_processing_team salvage_plan_1 processing_salvage_team_1)
    (plan_assigned_processing_team salvage_plan_2 processing_salvage_team_1)
    (plan_assigned_container salvage_plan_1 transport_container_1)
    (plan_assigned_container salvage_plan_2 transport_container_1)
    (plan_has_test_sample salvage_plan_1 test_sample_1)
    (plan_has_test_sample salvage_plan_2 test_sample_2)
    (regulatory_permit_type_available permit_type_standard)
    (regulatory_permit_type_available permit_type_emergency)
    (quality_certification_available quality_cert_standard)
    (quality_certification_available quality_cert_secondary)
    (contingency_reserve_available contingency_reserve_1)
    (decon_kit_available decon_kit_1)
    (regulatory_permit_available regulatory_permit_1)
    (plan_has_regulatory_permit salvage_plan_1 regulatory_permit_1)
    (plan_has_regulatory_permit salvage_plan_2 regulatory_permit_2)
    (lab_capacity_available lab_capacity_1)
  )
  (:goal
    (and
      (cleared_for_distribution field_salvage_team_1)
      (cleared_for_distribution processing_salvage_team_1)
      (cleared_for_distribution salvage_plan_1)
      (cleared_for_distribution salvage_plan_2)
    )
  )
)
