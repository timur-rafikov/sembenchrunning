(define (problem cold_storage_failure_salvage_problem)
  (:domain cold_storage_failure_salvage_domain)
  (:objects primary_cold_room - primary_cold_storage_unit backup_cold_room - secondary_cold_storage_unit salvage_response_unit_a - response_facility salvage_response_unit_b - response_facility refrigerated_trailer_a - mobile_resource refrigerated_trailer_b - mobile_resource portable_cooler_unit - mobile_resource field_operator - operator biosecurity_inspector - inspector sanitizing_supply - supply cold_hold_profile - conditioning_profile contingency_route_plan - transport_plan salvage_container_a - salvage_shipment quality_sample_a - sample quality_sample_b - sample regulatory_permit_a - permit_document regulatory_permit_b - permit_document thermal_treatment_protocol - processing_protocol sorting_protocol - processing_protocol compressor_repair_ticket - repair_order pathogen_test_kit - testing_kit initial_clearance_token - clearance_token secondary_clearance_token - clearance_token reference_lab_expert - external_expert)
  (:init
    (mobile_resource_available refrigerated_trailer_a)
    (mobile_resource_available refrigerated_trailer_b)
    (mobile_resource_available portable_cooler_unit)
    (operator_available field_operator)
    (inspector_available biosecurity_inspector)
    (supply_available sanitizing_supply)
    (primary_conditioning_linked primary_cold_room cold_hold_profile)
    (secondary_transport_linked backup_cold_room contingency_route_plan)
    (salvage_shipment_available salvage_container_a)
    (sample_available quality_sample_a)
    (sample_available quality_sample_b)
    (facility_has_primary_unit salvage_response_unit_a primary_cold_room)
    (facility_has_primary_unit salvage_response_unit_b primary_cold_room)
    (facility_has_secondary_unit salvage_response_unit_a backup_cold_room)
    (facility_has_secondary_unit salvage_response_unit_b backup_cold_room)
    (facility_has_salvage_shipment salvage_response_unit_a salvage_container_a)
    (facility_has_salvage_shipment salvage_response_unit_b salvage_container_a)
    (sample_checked_in salvage_response_unit_a quality_sample_a)
    (sample_checked_in salvage_response_unit_b quality_sample_b)
    (permit_available regulatory_permit_a)
    (permit_available regulatory_permit_b)
    (processing_protocol_available thermal_treatment_protocol)
    (processing_protocol_available sorting_protocol)
    (repair_order_available compressor_repair_ticket)
    (testing_kit_available pathogen_test_kit)
    (clearance_token_available initial_clearance_token)
    (clearance_token_linked salvage_response_unit_a initial_clearance_token)
    (clearance_token_linked salvage_response_unit_b secondary_clearance_token)
    (external_expert_available reference_lab_expert)
  )
  (:goal
    (and
      (asset_restored_to_service primary_cold_room)
      (asset_restored_to_service backup_cold_room)
      (asset_restored_to_service salvage_response_unit_a)
      (asset_restored_to_service salvage_response_unit_b)
    )
  )
)
