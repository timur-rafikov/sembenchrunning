    (operation_has_deployment_asset recovery_operation_2 deployment_asset_1)
    (operation_has_inspection_report recovery_operation_1 inspection_report_1)
    (operation_has_inspection_report recovery_operation_2 inspection_report_2)
    (regulatory_permit_available regulatory_permit_1)
    (regulatory_permit_available regulatory_permit_2)
    (funding_allocation_available funding_allocation_1)
    (funding_allocation_available funding_allocation_2)
    (salvage_option_available salvage_option_1)
    (decontamination_kit_available decontamination_kit_1)
    (insurance_document_available insurance_document_1)
