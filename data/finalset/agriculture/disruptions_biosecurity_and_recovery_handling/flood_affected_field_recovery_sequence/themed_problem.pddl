    (inspection_report_available inspection_report_1)
    (inspection_report_available inspection_report_2)
    (operation_assigned_primary_response_unit recovery_operation_1 primary_response_unit_1)
    (operation_assigned_primary_response_unit recovery_operation_2 primary_response_unit_1)
    (operation_assigned_secondary_response_unit recovery_operation_1 secondary_response_unit_1)
    (operation_assigned_secondary_response_unit recovery_operation_2 secondary_response_unit_1)
