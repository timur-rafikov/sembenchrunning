(define (problem liquidity_priority_scenario)
  (:domain treasury_liquidity_priority_domain)
  (:objects primary_account_a - entity_account_primary secondary_account_a - entity_account_secondary treasury_agent_1 - treasury_agent treasury_agent_2 - treasury_agent internal_account_source_1 - liquidity_source internal_account_source_2 - liquidity_source external_source_1 - liquidity_source incoming_flow_1 - incoming_cash_flow payment_channel_1 - payment_channel buffer_account_operational - buffer_account primary_source_id_1 - primary_source_id secondary_source_id_1 - secondary_source_id instruction_1 - funding_instruction funding_pool_intraday - funding_pool funding_pool_reserve - funding_pool approval_token_1 - approval_token approval_token_2 - approval_token execution_profile_1 - execution_profile execution_profile_2 - execution_profile priority_profile_default - source_priority_profile transfer_method_internal - transfer_method override_token_1 - override_token override_token_2 - override_token compliance_check_1 - compliance_check)
  (:init
    (source_available internal_account_source_1)
    (source_available internal_account_source_2)
    (source_available external_source_1)
    (incoming_flow_available incoming_flow_1)
    (channel_available payment_channel_1)
    (buffer_available buffer_account_operational)
    (primary_source_assigned primary_account_a primary_source_id_1)
    (secondary_source_assigned secondary_account_a secondary_source_id_1)
    (instruction_created instruction_1)
    (funding_pool_available funding_pool_intraday)
    (funding_pool_available funding_pool_reserve)
    (agent_primary_account_link treasury_agent_1 primary_account_a)
    (agent_primary_account_link treasury_agent_2 primary_account_a)
    (agent_secondary_account_link treasury_agent_1 secondary_account_a)
    (agent_secondary_account_link treasury_agent_2 secondary_account_a)
    (agent_assigned_instruction treasury_agent_1 instruction_1)
    (agent_assigned_instruction treasury_agent_2 instruction_1)
    (agent_assigned_pool treasury_agent_1 funding_pool_intraday)
    (agent_assigned_pool treasury_agent_2 funding_pool_reserve)
    (approval_token_available approval_token_1)
    (approval_token_available approval_token_2)
    (execution_profile_available execution_profile_1)
    (execution_profile_available execution_profile_2)
    (source_priority_profile_available priority_profile_default)
    (transfer_method_available transfer_method_internal)
    (override_token_available override_token_1)
    (agent_override_linked treasury_agent_1 override_token_1)
    (agent_override_linked treasury_agent_2 override_token_2)
    (compliance_check_available compliance_check_1)
  )
  (:goal
    (and
      (funding_settled primary_account_a)
      (funding_settled secondary_account_a)
      (funding_settled treasury_agent_1)
      (funding_settled treasury_agent_2)
    )
  )
)
