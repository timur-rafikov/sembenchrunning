(define (problem treasury_internal_netting_scenario)
  (:domain treasury_internal_transfer_netting_domain)
  (:objects source_subsidiary_a - source_subsidiary destination_subsidiary_b - destination_subsidiary netting_job_alpha - netting_job netting_job_beta - netting_job settlement_channel_rail_1 - settlement_channel settlement_channel_rail_2 - settlement_channel settlement_channel_rail_3 - settlement_channel transfer_request_tx_1 - transfer_request funding_account_operational - funding_account offset_instruction_candidate_1 - offset_instruction cash_account_source_pool_1 - cash_account_source cash_account_destination_pool_1 - cash_account_destination settlement_order_001 - settlement_order liquidity_buffer_pool_a - liquidity_buffer liquidity_buffer_pool_b - liquidity_buffer compliance_approval_exemption_a - compliance_approval compliance_approval_exemption_b - compliance_approval fee_structure_standard - fee_structure fee_structure_premium - fee_structure funding_resource_cash_t0 - funding_resource liquidity_limit_default - liquidity_limit priority_directive_high - priority_directive priority_directive_low - priority_directive regulatory_flag_watchlist - regulatory_flag)
  (:init
    (settlement_channel_available settlement_channel_rail_1)
    (settlement_channel_available settlement_channel_rail_2)
    (settlement_channel_available settlement_channel_rail_3)
    (transfer_request_available transfer_request_tx_1)
    (funding_account_available funding_account_operational)
    (offset_instruction_available offset_instruction_candidate_1)
    (source_entity_assigned_cash_account source_subsidiary_a cash_account_source_pool_1)
    (destination_entity_assigned_cash_account destination_subsidiary_b cash_account_destination_pool_1)
    (settlement_order_available settlement_order_001)
    (liquidity_buffer_available liquidity_buffer_pool_a)
    (liquidity_buffer_available liquidity_buffer_pool_b)
    (netting_job_includes_source_entity netting_job_alpha source_subsidiary_a)
    (netting_job_includes_source_entity netting_job_beta source_subsidiary_a)
    (netting_job_includes_destination_entity netting_job_alpha destination_subsidiary_b)
    (netting_job_includes_destination_entity netting_job_beta destination_subsidiary_b)
    (netting_job_associated_settlement_order netting_job_alpha settlement_order_001)
    (netting_job_associated_settlement_order netting_job_beta settlement_order_001)
    (netting_job_allocated_liquidity_buffer netting_job_alpha liquidity_buffer_pool_a)
    (netting_job_allocated_liquidity_buffer netting_job_beta liquidity_buffer_pool_b)
    (compliance_approval_available compliance_approval_exemption_a)
    (compliance_approval_available compliance_approval_exemption_b)
    (fee_structure_available fee_structure_standard)
    (fee_structure_available fee_structure_premium)
    (funding_resource_available funding_resource_cash_t0)
    (liquidity_limit_available liquidity_limit_default)
    (priority_directive_available priority_directive_high)
    (netting_job_assigned_priority_directive netting_job_alpha priority_directive_high)
    (netting_job_assigned_priority_directive netting_job_beta priority_directive_low)
    (regulatory_flag_available regulatory_flag_watchlist)
  )
  (:goal
    (and
      (entity_settled source_subsidiary_a)
      (entity_settled destination_subsidiary_b)
      (entity_settled netting_job_alpha)
      (entity_settled netting_job_beta)
    )
  )
)
