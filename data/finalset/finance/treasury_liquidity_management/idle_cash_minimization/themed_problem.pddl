(define (problem idle_cash_minimization_problem)
  (:domain treasury_idle_cash_minimization)
  (:objects operating_account_1 - operating_account concentration_account_1 - concentration_account treasury_agent_1 - treasury_agent treasury_agent_2 - treasury_agent bank_relation_1 - bank_account bank_relation_2 - bank_account bank_relation_3 - bank_account placement_option_1 - placement_option authorized_approver_1 - authorized_approver investment_product_mmf - investment_product source_endpoint_operating - source_endpoint destination_endpoint_1 - destination_endpoint transfer_candidate_1 - transfer_candidate liquidity_pool_1 - liquidity_pool liquidity_pool_2 - liquidity_pool approval_mandate_1 - approval_mandate approval_mandate_2 - approval_mandate allocation_profile_primary - allocation_profile allocation_profile_secondary - allocation_profile settlement_instrument_1 - settlement_instrument short_term_instrument_1 - short_term_instrument external_mandate_1 - external_mandate external_mandate_2 - external_mandate credit_approval_1 - credit_approval)
  (:init
    (bank_account_available bank_relation_1)
    (bank_account_available bank_relation_2)
    (bank_account_available bank_relation_3)
    (placement_option_available placement_option_1)
    (approver_available authorized_approver_1)
    (investment_product_available investment_product_mmf)
    (operating_account_source_endpoint operating_account_1 source_endpoint_operating)
    (concentration_account_destination_endpoint concentration_account_1 destination_endpoint_1)
    (transfer_candidate_available transfer_candidate_1)
    (liquidity_pool_available liquidity_pool_1)
    (liquidity_pool_available liquidity_pool_2)
    (agent_operating_account_link treasury_agent_1 operating_account_1)
    (agent_operating_account_link treasury_agent_2 operating_account_1)
    (agent_concentration_account_link treasury_agent_1 concentration_account_1)
    (agent_concentration_account_link treasury_agent_2 concentration_account_1)
    (agent_has_transfer_candidate treasury_agent_1 transfer_candidate_1)
    (agent_has_transfer_candidate treasury_agent_2 transfer_candidate_1)
    (agent_liquidity_pool_link treasury_agent_1 liquidity_pool_1)
    (agent_liquidity_pool_link treasury_agent_2 liquidity_pool_2)
    (approval_mandate_available approval_mandate_1)
    (approval_mandate_available approval_mandate_2)
    (allocation_profile_available allocation_profile_primary)
    (allocation_profile_available allocation_profile_secondary)
    (settlement_instrument_available settlement_instrument_1)
    (short_term_instrument_available short_term_instrument_1)
    (external_mandate_available external_mandate_1)
    (agent_external_mandate_link treasury_agent_1 external_mandate_1)
    (agent_external_mandate_link treasury_agent_2 external_mandate_2)
    (credit_approval_available credit_approval_1)
  )
  (:goal
    (and
      (funding_associated operating_account_1)
      (funding_associated concentration_account_1)
      (funding_associated treasury_agent_1)
      (funding_associated treasury_agent_2)
    )
  )
)
