(define (problem short_term_investment_laddering_problem)
  (:domain short_term_investment_laddering_domain)
  (:objects entity_a_account_1 - entity_a_account entity_b_account_1 - entity_b_account treasury_pool_primary - treasury_pool treasury_pool_secondary - treasury_pool counterparty_bank_1 - counterparty_bank counterparty_bank_2 - counterparty_bank counterparty_bank_3 - counterparty_bank instrument_offer_1 - instrument_offer execution_channel_1 - execution_channel buffer_tranche_1 - buffer_tranche maturity_bucket_short_1 - maturity_bucket_short maturity_bucket_medium_1 - maturity_bucket_medium investment_lot_1 - investment_lot security_id_1 - security_id security_id_2 - security_id approval_token_1 - approval_token approval_token_2 - approval_token allocation_policy_1 - allocation_policy allocation_policy_2 - allocation_policy liquidity_tag_1 - liquidity_tag pricing_eligibility_1 - pricing_eligibility deal_approval_1 - deal_approval deal_approval_2 - deal_approval settlement_option_1 - settlement_option)
  (:init
    (counterparty_available counterparty_bank_1)
    (counterparty_available counterparty_bank_2)
    (counterparty_available counterparty_bank_3)
    (instrument_offer_available instrument_offer_1)
    (execution_channel_available execution_channel_1)
    (buffer_tranche_available buffer_tranche_1)
    (entity_a_to_maturity_bucket_link entity_a_account_1 maturity_bucket_short_1)
    (entity_b_to_maturity_bucket_link entity_b_account_1 maturity_bucket_medium_1)
    (investment_lot_available investment_lot_1)
    (security_id_unbound security_id_1)
    (security_id_unbound security_id_2)
    (pool_to_entity_a_mapping treasury_pool_primary entity_a_account_1)
    (pool_to_entity_a_mapping treasury_pool_secondary entity_a_account_1)
    (pool_to_entity_b_mapping treasury_pool_primary entity_b_account_1)
    (pool_to_entity_b_mapping treasury_pool_secondary entity_b_account_1)
    (pool_to_lot_mapping treasury_pool_primary investment_lot_1)
    (pool_to_lot_mapping treasury_pool_secondary investment_lot_1)
    (pool_to_security_mapping treasury_pool_primary security_id_1)
    (pool_to_security_mapping treasury_pool_secondary security_id_2)
    (approval_token_available approval_token_1)
    (approval_token_available approval_token_2)
    (allocation_policy_available allocation_policy_1)
    (allocation_policy_available allocation_policy_2)
    (liquidity_tag_available liquidity_tag_1)
    (pricing_eligibility_available pricing_eligibility_1)
    (deal_approval_available deal_approval_1)
    (pool_has_deal_approval treasury_pool_primary deal_approval_1)
    (pool_has_deal_approval treasury_pool_secondary deal_approval_2)
    (settlement_option_available settlement_option_1)
  )
  (:goal
    (and
      (invested_status entity_a_account_1)
      (invested_status entity_b_account_1)
      (invested_status treasury_pool_primary)
      (invested_status treasury_pool_secondary)
    )
  )
)
