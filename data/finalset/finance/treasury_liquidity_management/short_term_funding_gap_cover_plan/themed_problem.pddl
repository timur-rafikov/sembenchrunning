(define (problem short_term_funding_gap_cover_plan)
  (:domain treasury_liquidity_management)
  (:objects cash_shortfall_originator - originating_entity funding_counterparty - counterparty_entity treasury_operator_alpha - treasury_operator treasury_operator_beta - treasury_operator internal_liquidity_pool - funding_source_option committed_credit_facility - funding_source_option external_borrowing_line - funding_source_option overnight_tenor_bucket - maturity_bucket treasury_approver - approval_role liquidity_buffer_reserve - liquidity_buffer internal_leg_instance - internal_funding_leg external_leg_instance - external_funding_leg funding_transfer_order - transfer_order settlement_batch_alpha - settlement_batch settlement_batch_beta - settlement_batch execution_parameter_alpha - execution_parameter execution_parameter_beta - execution_parameter execution_profile_alpha - execution_profile execution_profile_beta - execution_profile shortfall_assessment_record - shortfall_assessment_document collateral_profile_standard - collateral_profile external_authority_instruction_alpha - external_authority_instruction external_authority_instruction_beta - external_authority_instruction compliance_check_template - compliance_check)
  (:init
    (funding_option_available internal_liquidity_pool)
    (funding_option_available committed_credit_facility)
    (funding_option_available external_borrowing_line)
    (maturity_bucket_available overnight_tenor_bucket)
    (approval_role_available treasury_approver)
    (liquidity_buffer_available liquidity_buffer_reserve)
    (originator_internal_leg_link cash_shortfall_originator internal_leg_instance)
    (counterparty_external_leg_link funding_counterparty external_leg_instance)
    (transfer_order_draft funding_transfer_order)
    (settlement_batch_available settlement_batch_alpha)
    (settlement_batch_available settlement_batch_beta)
    (operator_originator_link treasury_operator_alpha cash_shortfall_originator)
    (operator_originator_link treasury_operator_beta cash_shortfall_originator)
    (operator_counterparty_link treasury_operator_alpha funding_counterparty)
    (operator_counterparty_link treasury_operator_beta funding_counterparty)
    (operator_order_link treasury_operator_alpha funding_transfer_order)
    (operator_order_link treasury_operator_beta funding_transfer_order)
    (operator_batch_link treasury_operator_alpha settlement_batch_alpha)
    (operator_batch_link treasury_operator_beta settlement_batch_beta)
    (execution_parameter_available execution_parameter_alpha)
    (execution_parameter_available execution_parameter_beta)
    (execution_profile_available execution_profile_alpha)
    (execution_profile_available execution_profile_beta)
    (shortfall_assessment_available shortfall_assessment_record)
    (collateral_profile_available collateral_profile_standard)
    (external_instruction_available external_authority_instruction_alpha)
    (operator_instruction_link treasury_operator_alpha external_authority_instruction_alpha)
    (operator_instruction_link treasury_operator_beta external_authority_instruction_beta)
    (compliance_check_available compliance_check_template)
  )
  (:goal
    (and
      (funding_gap_covered cash_shortfall_originator)
      (funding_gap_covered funding_counterparty)
      (funding_gap_covered treasury_operator_alpha)
      (funding_gap_covered treasury_operator_beta)
    )
  )
)
