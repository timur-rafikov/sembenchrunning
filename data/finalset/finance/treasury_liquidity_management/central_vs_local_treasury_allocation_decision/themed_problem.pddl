(define (problem central_vs_local_treasury_allocation_case)
  (:domain central_vs_local_treasury_allocation_decision)
  (:objects local_treasury_node - local_treasury local_business_unit_instance - local_business_unit central_treasury_primary - central_treasury central_treasury_secondary - central_treasury primary_funding_source - funding_source backup_funding_source - funding_source contingent_funding_source - funding_source cash_forecast_base_case - cash_forecast local_treasury_approver - approver_role intercompany_transfer_order - transfer_order operational_liquidity_bucket - liquidity_bucket short_term_maturity_bucket - maturity_bucket allocation_proposal_record - allocation_record liquidity_coverage_metric - liquidity_metric liquidity_stress_metric - liquidity_metric baseline_rate_scenario - rate_scenario stressed_rate_scenario - rate_scenario central_pooling_strategy - treasury_strategy local_retention_strategy - treasury_strategy issued_funding_request_token - funding_request_token settlement_instruction_packet - settlement_instruction treasury_policy_document - policy_document allocation_policy_document - policy_document executive_approval_token - executive_approval)
  (:init
    (funding_source_available primary_funding_source)
    (funding_source_available backup_funding_source)
    (funding_source_available contingent_funding_source)
    (cash_forecast_available cash_forecast_base_case)
    (approver_role_available local_treasury_approver)
    (transfer_order_available intercompany_transfer_order)
    (local_treasury_links_liquidity_bucket local_treasury_node operational_liquidity_bucket)
    (business_unit_links_maturity_bucket local_business_unit_instance short_term_maturity_bucket)
    (allocation_record_available allocation_proposal_record)
    (liquidity_metric_available liquidity_coverage_metric)
    (liquidity_metric_available liquidity_stress_metric)
    (central_treasury_links_local_treasury central_treasury_primary local_treasury_node)
    (central_treasury_links_local_treasury central_treasury_secondary local_treasury_node)
    (central_treasury_links_business_unit central_treasury_primary local_business_unit_instance)
    (central_treasury_links_business_unit central_treasury_secondary local_business_unit_instance)
    (central_treasury_links_allocation_record central_treasury_primary allocation_proposal_record)
    (central_treasury_links_allocation_record central_treasury_secondary allocation_proposal_record)
    (central_treasury_links_liquidity_metric central_treasury_primary liquidity_coverage_metric)
    (central_treasury_links_liquidity_metric central_treasury_secondary liquidity_stress_metric)
    (rate_scenario_available baseline_rate_scenario)
    (rate_scenario_available stressed_rate_scenario)
    (treasury_strategy_available central_pooling_strategy)
    (treasury_strategy_available local_retention_strategy)
    (funding_request_available issued_funding_request_token)
    (settlement_instruction_available settlement_instruction_packet)
    (policy_document_available treasury_policy_document)
    (central_treasury_links_policy_document central_treasury_primary treasury_policy_document)
    (central_treasury_links_policy_document central_treasury_secondary allocation_policy_document)
    (executive_approval_available executive_approval_token)
  )
  (:goal
    (and
      (allocation_settled local_treasury_node)
      (allocation_settled local_business_unit_instance)
      (allocation_settled central_treasury_primary)
      (allocation_settled central_treasury_secondary)
    )
  )
)
