(define (problem liquidity_stress_response_problem)
  (:domain finance_treasury_liquidity_stress_response)
  (:objects operating_unit_1 - operating_unit trading_unit_1 - trading_unit treasury_desk_main - treasury_desk treasury_desk_secondary - treasury_desk funding_source_internal_pool - funding_source funding_source_bank_a - funding_source funding_source_bank_b - funding_source cash_flow_need_1 - cash_flow_need treasury_controller_1 - treasury_controller liquidity_measure_asset_sale - liquidity_measure internal_funding_channel_intercompany - internal_funding_channel external_funding_channel_repo - external_funding_channel funding_allocation_slot_1 - funding_allocation liquid_asset_gov_bond_1 - liquid_asset liquid_asset_cash_reserve_1 - liquid_asset contingency_credit_line_a - contingency_credit_line contingency_credit_line_b - contingency_credit_line operational_resource_settlement_window_morning - operational_resource operational_resource_settlement_window_evening - operational_resource stress_scenario_1 - stress_scenario funding_strategy_priority_internal_first - funding_strategy delegated_authority_small - delegated_authority delegated_authority_large - delegated_authority regulatory_exception_waiver_1 - regulatory_exception)
  (:init
    (funding_source_available funding_source_internal_pool)
    (funding_source_available funding_source_bank_a)
    (funding_source_available funding_source_bank_b)
    (cash_flow_need_unassigned cash_flow_need_1)
    (treasury_controller_available treasury_controller_1)
    (liquidity_measure_available liquidity_measure_asset_sale)
    (operating_unit_internal_channel operating_unit_1 internal_funding_channel_intercompany)
    (trading_unit_external_channel trading_unit_1 external_funding_channel_repo)
    (funding_allocation_unassigned funding_allocation_slot_1)
    (liquid_asset_available liquid_asset_gov_bond_1)
    (liquid_asset_available liquid_asset_cash_reserve_1)
    (treasury_desk_manages_operating_unit treasury_desk_main operating_unit_1)
    (treasury_desk_manages_operating_unit treasury_desk_secondary operating_unit_1)
    (treasury_desk_manages_trading_unit treasury_desk_main trading_unit_1)
    (treasury_desk_manages_trading_unit treasury_desk_secondary trading_unit_1)
    (treasury_desk_links_funding_allocation treasury_desk_main funding_allocation_slot_1)
    (treasury_desk_links_funding_allocation treasury_desk_secondary funding_allocation_slot_1)
    (treasury_desk_holds_liquid_asset treasury_desk_main liquid_asset_gov_bond_1)
    (treasury_desk_holds_liquid_asset treasury_desk_secondary liquid_asset_cash_reserve_1)
    (contingency_credit_line_available contingency_credit_line_a)
    (contingency_credit_line_available contingency_credit_line_b)
    (operational_resource_available operational_resource_settlement_window_morning)
    (operational_resource_available operational_resource_settlement_window_evening)
    (stress_scenario_available stress_scenario_1)
    (funding_strategy_available funding_strategy_priority_internal_first)
    (delegated_authority_available delegated_authority_small)
    (treasury_desk_has_delegated_authority treasury_desk_main delegated_authority_small)
    (treasury_desk_has_delegated_authority treasury_desk_secondary delegated_authority_large)
    (regulatory_exception_available regulatory_exception_waiver_1)
  )
  (:goal
    (and
      (entity_liquidity_protected operating_unit_1)
      (entity_liquidity_protected trading_unit_1)
      (entity_liquidity_protected treasury_desk_main)
      (entity_liquidity_protected treasury_desk_secondary)
    )
  )
)
