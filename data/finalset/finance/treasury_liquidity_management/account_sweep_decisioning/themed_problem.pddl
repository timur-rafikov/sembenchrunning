(define (problem account_sweep_decision_problem)
  (:domain treasury_account_sweep_decisioning)
  (:objects funding_account_operating - source_account receiving_account_buffer - destination_account sweep_engine_primary - sweep_engine sweep_engine_secondary - sweep_engine destination_profile_high - sweep_destination_profile destination_profile_standard - sweep_destination_profile destination_profile_low - sweep_destination_profile cash_snapshot_funding_1 - cash_position_snapshot auth_profile_standard - authorization_profile sweep_template_standard - sweep_instruction_template sweep_leg_funding_1 - sweep_leg counterparty_leg_buffer_1 - counterparty_leg sweep_order_batch_1 - sweep_order settlement_instruction_ach - settlement_instruction settlement_instruction_swift - settlement_instruction business_constraint_regulatory - business_constraint business_constraint_internal - business_constraint execution_mode_immediate - execution_mode execution_mode_batched - execution_mode timing_profile_eod - timing_profile buffer_policy_standard - buffer_policy escalation_policy_primary - escalation_policy escalation_policy_secondary - escalation_policy compliance_check_limits - compliance_check)
  (:init
    (destination_profile_available destination_profile_high)
    (destination_profile_available destination_profile_standard)
    (destination_profile_available destination_profile_low)
    (cash_snapshot_available cash_snapshot_funding_1)
    (authorization_profile_available auth_profile_standard)
    (sweep_instruction_template_available sweep_template_standard)
    (source_account_sweep_leg_link funding_account_operating sweep_leg_funding_1)
    (destination_account_counterparty_leg_link receiving_account_buffer counterparty_leg_buffer_1)
    (sweep_order_open sweep_order_batch_1)
    (settlement_instruction_available settlement_instruction_ach)
    (settlement_instruction_available settlement_instruction_swift)
    (sweep_engine_bound_to_source_account sweep_engine_primary funding_account_operating)
    (sweep_engine_bound_to_source_account sweep_engine_secondary funding_account_operating)
    (sweep_engine_bound_to_destination_account sweep_engine_primary receiving_account_buffer)
    (sweep_engine_bound_to_destination_account sweep_engine_secondary receiving_account_buffer)
    (sweep_engine_order_link sweep_engine_primary sweep_order_batch_1)
    (sweep_engine_order_link sweep_engine_secondary sweep_order_batch_1)
    (engine_settlement_instruction_link sweep_engine_primary settlement_instruction_ach)
    (engine_settlement_instruction_link sweep_engine_secondary settlement_instruction_swift)
    (business_constraint_available business_constraint_regulatory)
    (business_constraint_available business_constraint_internal)
    (execution_mode_available execution_mode_immediate)
    (execution_mode_available execution_mode_batched)
    (timing_profile_available timing_profile_eod)
    (buffer_policy_available buffer_policy_standard)
    (escalation_policy_available escalation_policy_primary)
    (engine_escalation_policy_link sweep_engine_primary escalation_policy_primary)
    (engine_escalation_policy_link sweep_engine_secondary escalation_policy_secondary)
    (compliance_check_available compliance_check_limits)
  )
  (:goal
    (and
      (relinked_for_next_sweep funding_account_operating)
      (relinked_for_next_sweep receiving_account_buffer)
      (relinked_for_next_sweep sweep_engine_primary)
      (relinked_for_next_sweep sweep_engine_secondary)
    )
  )
)
