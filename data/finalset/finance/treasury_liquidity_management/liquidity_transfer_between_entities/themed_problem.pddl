(define (problem liquidity_transfer_between_entities)
  (:domain finance_treasury_liquidity_transfer)
  (:objects source_account_obj - source_account destination_account_obj - destination_account transfer_instruction_obj_1 - transfer_instruction transfer_instruction_obj_2 - transfer_instruction payment_channel_obj_1 - payment_channel payment_channel_obj_2 - payment_channel payment_channel_obj_3 - payment_channel liquidity_request_obj - liquidity_request treasury_approver_obj - treasury_approver funding_instrument_obj - funding_instrument liquidity_buffer_obj - liquidity_buffer target_buffer_obj - target_buffer settlement_batch_obj - settlement_batch payment_file_obj_1 - payment_file payment_file_obj_2 - payment_file compliance_rule_obj_1 - compliance_rule compliance_rule_obj_2 - compliance_rule execution_window_obj_1 - execution_window execution_window_obj_2 - execution_window transaction_token_obj - transaction_token approval_credential_obj - approval_credential compliance_certificate_obj_1 - compliance_certificate compliance_certificate_obj_2 - compliance_certificate execution_signature_obj - execution_signature)
  (:init
    (payment_channel_available payment_channel_obj_1)
    (payment_channel_available payment_channel_obj_2)
    (payment_channel_available payment_channel_obj_3)
    (liquidity_request_available liquidity_request_obj)
    (treasury_approver_available treasury_approver_obj)
    (funding_instrument_available funding_instrument_obj)
    (source_buffer_linked source_account_obj liquidity_buffer_obj)
    (destination_buffer_linked destination_account_obj target_buffer_obj)
    (settlement_batch_available settlement_batch_obj)
    (payment_file_available payment_file_obj_1)
    (payment_file_available payment_file_obj_2)
    (instruction_source_account_link transfer_instruction_obj_1 source_account_obj)
    (instruction_source_account_link transfer_instruction_obj_2 source_account_obj)
    (instruction_destination_account_link transfer_instruction_obj_1 destination_account_obj)
    (instruction_destination_account_link transfer_instruction_obj_2 destination_account_obj)
    (instruction_in_settlement_batch transfer_instruction_obj_1 settlement_batch_obj)
    (instruction_in_settlement_batch transfer_instruction_obj_2 settlement_batch_obj)
    (instruction_has_payment_file transfer_instruction_obj_1 payment_file_obj_1)
    (instruction_has_payment_file transfer_instruction_obj_2 payment_file_obj_2)
    (compliance_rule_available compliance_rule_obj_1)
    (compliance_rule_available compliance_rule_obj_2)
    (execution_window_available execution_window_obj_1)
    (execution_window_available execution_window_obj_2)
    (transaction_token_available transaction_token_obj)
    (approval_credential_available approval_credential_obj)
    (compliance_certificate_available compliance_certificate_obj_1)
    (instruction_compliance_certificate_link transfer_instruction_obj_1 compliance_certificate_obj_1)
    (instruction_compliance_certificate_link transfer_instruction_obj_2 compliance_certificate_obj_2)
    (execution_signature_available execution_signature_obj)
  )
  (:goal
    (and
      (entity_settlement_marked source_account_obj)
      (entity_settlement_marked destination_account_obj)
      (entity_settlement_marked transfer_instruction_obj_1)
      (entity_settlement_marked transfer_instruction_obj_2)
    )
  )
)
