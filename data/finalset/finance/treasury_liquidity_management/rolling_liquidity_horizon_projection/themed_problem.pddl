(define (problem rolling_liquidity_projection_problem)
  (:domain rolling_liquidity_horizon_projection_domain)
  (:objects legal_entity_1 - legal_entity cash_pool_1 - cash_pool projection_job_1 - projection_job projection_job_2 - projection_job funding_facility_1 - funding_facility funding_facility_2 - funding_facility funding_facility_3 - funding_facility cashflow_forecast_1 - cashflow_forecast approver_1 - approver liquidity_policy_1 - liquidity_policy time_bucket_1 - time_bucket scenario_1 - scenario transfer_instruction_template_1 - transfer_instruction account_1 - account account_2 - account stakeholder_1 - stakeholder stakeholder_2 - stakeholder funding_limit_1 - funding_limit funding_limit_2 - funding_limit buffer_type_1 - buffer_type liquidity_instrument_1 - liquidity_instrument report_template_1 - report_template report_template_2 - report_template approval_rule_1 - approval_rule)
  (:init
    (funding_facility_available funding_facility_1)
    (funding_facility_available funding_facility_2)
    (funding_facility_available funding_facility_3)
    (cashflow_forecast_available cashflow_forecast_1)
    (approver_available approver_1)
    (liquidity_policy_available liquidity_policy_1)
    (legal_entity_eligible_time_bucket legal_entity_1 time_bucket_1)
    (cash_pool_has_scenario cash_pool_1 scenario_1)
    (transfer_instruction_template_available transfer_instruction_template_1)
    (account_available account_1)
    (account_available account_2)
    (projection_job_includes_legal_entity projection_job_1 legal_entity_1)
    (projection_job_includes_legal_entity projection_job_2 legal_entity_1)
    (projection_job_includes_cash_pool projection_job_1 cash_pool_1)
    (projection_job_includes_cash_pool projection_job_2 cash_pool_1)
    (projection_job_linked_transfer_instruction projection_job_1 transfer_instruction_template_1)
    (projection_job_linked_transfer_instruction projection_job_2 transfer_instruction_template_1)
    (projection_job_linked_account projection_job_1 account_1)
    (projection_job_linked_account projection_job_2 account_2)
    (stakeholder_available stakeholder_1)
    (stakeholder_available stakeholder_2)
    (funding_limit_available funding_limit_1)
    (funding_limit_available funding_limit_2)
    (buffer_type_available buffer_type_1)
    (liquidity_instrument_available liquidity_instrument_1)
    (report_template_available report_template_1)
    (projection_job_linked_report_template projection_job_1 report_template_1)
    (projection_job_linked_report_template projection_job_2 report_template_2)
    (approval_rule_available approval_rule_1)
  )
  (:goal
    (and
      (funding_committed legal_entity_1)
      (funding_committed cash_pool_1)
      (funding_committed projection_job_1)
      (funding_committed projection_job_2)
    )
  )
)
