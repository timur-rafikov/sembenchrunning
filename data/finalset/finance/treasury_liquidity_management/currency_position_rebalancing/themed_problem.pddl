(define (problem currency_position_rebalancing_problem)
  (:domain currency_position_rebalancing_domain)
  (:objects operating_account_hq - operating_account subsidiary_account_branch - subsidiary_account treasury_desk_primary - treasury_desk treasury_desk_secondary - treasury_desk funding_source_pool_a - funding_source funding_source_pool_b - funding_source funding_source_pool_c - funding_source fx_quote_usd_eur - fx_quote approver_primary - approver liquidity_instrument_short_term_note - liquidity_instrument currency_usd - local_currency currency_eur - counterparty_currency transfer_order_001 - transfer_order liquidity_buffer_usd - liquidity_buffer liquidity_buffer_eur - liquidity_buffer venue_swift - execution_venue venue_local_rtgs - execution_venue funding_priority_high - funding_priority funding_priority_low - funding_priority execution_window_morning - execution_window settlement_profile_standard - settlement_profile limit_profile_default - limit_profile limit_profile_special - limit_profile regulatory_constraint_standard - regulatory_constraint)
  (:init
    (funding_source_available funding_source_pool_a)
    (funding_source_available funding_source_pool_b)
    (funding_source_available funding_source_pool_c)
    (fx_quote_available fx_quote_usd_eur)
    (approver_available approver_primary)
    (liquidity_instrument_available liquidity_instrument_short_term_note)
    (operating_account_local_currency operating_account_hq currency_usd)
    (subsidiary_counterparty_currency_assigned subsidiary_account_branch currency_eur)
    (transfer_order_draft transfer_order_001)
    (liquidity_buffer_available liquidity_buffer_usd)
    (liquidity_buffer_available liquidity_buffer_eur)
    (desk_manages_operating_account treasury_desk_primary operating_account_hq)
    (desk_manages_operating_account treasury_desk_secondary operating_account_hq)
    (desk_manages_subsidiary_account treasury_desk_primary subsidiary_account_branch)
    (desk_manages_subsidiary_account treasury_desk_secondary subsidiary_account_branch)
    (desk_assigned_transfer_order treasury_desk_primary transfer_order_001)
    (desk_assigned_transfer_order treasury_desk_secondary transfer_order_001)
    (desk_allocated_liquidity_buffer treasury_desk_primary liquidity_buffer_usd)
    (desk_allocated_liquidity_buffer treasury_desk_secondary liquidity_buffer_eur)
    (execution_venue_available venue_swift)
    (execution_venue_available venue_local_rtgs)
    (funding_priority_available funding_priority_high)
    (funding_priority_available funding_priority_low)
    (execution_window_available execution_window_morning)
    (settlement_profile_available settlement_profile_standard)
    (limit_profile_available limit_profile_default)
    (desk_assigned_limit_profile treasury_desk_primary limit_profile_default)
    (desk_assigned_limit_profile treasury_desk_secondary limit_profile_special)
    (regulatory_constraint_available regulatory_constraint_standard)
  )
  (:goal
    (and
      (position_settled operating_account_hq)
      (position_settled subsidiary_account_branch)
      (position_settled treasury_desk_primary)
      (position_settled treasury_desk_secondary)
    )
  )
)
