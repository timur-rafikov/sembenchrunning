(define (problem cash_flow_adjustment_scenario)
  (:domain cash_flow_adjustment)
  (:objects source_account_1 - source_account destination_account_1 - destination_account treasury_operator_1 - treasury_operator treasury_operator_2 - treasury_operator funding_candidate_1 - funding_source_candidate funding_candidate_2 - funding_source_candidate funding_candidate_3 - funding_source_candidate time_bucket_1 - time_period_bucket business_reviewer_1 - business_reviewer adjustment_reason_tag_1 - adjustment_reason_tag liquidity_pool_1 - liquidity_pool counterparty_pool_1 - counterparty_pool transfer_instruction_1 - transfer_instruction settlement_window_1 - settlement_window settlement_window_2 - settlement_window policy_rule_1 - policy_rule policy_rule_2 - policy_rule execution_profile_1 - execution_profile execution_profile_2 - execution_profile supporting_document_1 - supporting_document funding_product_1 - funding_product authority_credential_1 - authority_credential authority_credential_2 - authority_credential settlement_method_1 - settlement_method)
  (:init
    (candidate_available funding_candidate_1)
    (candidate_available funding_candidate_2)
    (candidate_available funding_candidate_3)
    (time_bucket_available time_bucket_1)
    (reviewer_available business_reviewer_1)
    (reason_tag_available adjustment_reason_tag_1)
    (account_liquidity_pool source_account_1 liquidity_pool_1)
    (destination_counterparty_pool destination_account_1 counterparty_pool_1)
    (instruction_pending transfer_instruction_1)
    (settlement_window_available settlement_window_1)
    (settlement_window_available settlement_window_2)
    (operator_source_account_association treasury_operator_1 source_account_1)
    (operator_source_account_association treasury_operator_2 source_account_1)
    (operator_destination_account_association treasury_operator_1 destination_account_1)
    (operator_destination_account_association treasury_operator_2 destination_account_1)
    (operator_instruction_association treasury_operator_1 transfer_instruction_1)
    (operator_instruction_association treasury_operator_2 transfer_instruction_1)
    (operator_settlement_window_association treasury_operator_1 settlement_window_1)
    (operator_settlement_window_association treasury_operator_2 settlement_window_2)
    (policy_rule_available policy_rule_1)
    (policy_rule_available policy_rule_2)
    (execution_profile_available execution_profile_1)
    (execution_profile_available execution_profile_2)
    (supporting_document_available supporting_document_1)
    (funding_product_available funding_product_1)
    (authority_credential_available authority_credential_1)
    (operator_credential_binding treasury_operator_1 authority_credential_1)
    (operator_credential_binding treasury_operator_2 authority_credential_2)
    (settlement_method_available settlement_method_1)
  )
  (:goal
    (and
      (routing_assigned source_account_1)
      (routing_assigned destination_account_1)
      (routing_assigned treasury_operator_1)
      (routing_assigned treasury_operator_2)
    )
  )
)
