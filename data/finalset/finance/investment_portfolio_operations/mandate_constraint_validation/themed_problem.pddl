    (instrument_available instrument_candidate_1)
    (reviewer_token_available reviewer_token_1)
    (constraint_param_available constraint_parameter_1)
    (has_primary_exposure_bucket primary_segment_1 primary_exposure_bucket_1)
    (has_secondary_exposure_bucket secondary_segment_1 secondary_exposure_bucket_1)
    (trade_basket_available trade_basket_1)
    (security_lot_available security_lot_1)
    (security_lot_available security_lot_2)
    (composite_has_primary_segment portfolio_composite_a primary_segment_1)
    (composite_has_primary_segment portfolio_composite_b primary_segment_1)
    (composite_has_secondary_segment portfolio_composite_a secondary_segment_1)
    (composite_has_secondary_segment portfolio_composite_b secondary_segment_1)
    (composite_has_trade_basket portfolio_composite_a trade_basket_1)
    (composite_has_trade_basket portfolio_composite_b trade_basket_1)
    (composite_has_lot_candidate portfolio_composite_a security_lot_1)
    (composite_has_lot_candidate portfolio_composite_b security_lot_2)
    (strategy_tag_available strategy_tag_1)
    (strategy_tag_available strategy_tag_2)
    (instruction_tag_available instruction_tag_1)
    (instruction_tag_available instruction_tag_2)
    (trade_identifier_available trade_identifier_1)
    (execution_venue_available execution_venue_1)
    (approval_credential_available approval_credential_1)
    (composite_has_approval_credential portfolio_composite_a approval_credential_1)
    (composite_has_approval_credential portfolio_composite_b approval_credential_2)
    (compliance_credential_available compliance_credential_1)
  )
  (:goal
    (and
      (entity_finalized primary_segment_1)
      (entity_finalized secondary_segment_1)
      (entity_finalized portfolio_composite_a)
      (entity_finalized portfolio_composite_b)
    )
  )
)
