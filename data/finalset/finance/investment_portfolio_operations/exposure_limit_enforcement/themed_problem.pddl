(define (problem exposure_limit_enforcement_problem)
  (:domain exposure_limit_enforcement_domain)
  (:objects source_portfolio_1 - source_portfolio target_portfolio_1 - target_portfolio execution_plan_1 - execution_plan execution_plan_2 - execution_plan limit_profile_a - limit_profile limit_profile_b - limit_profile limit_profile_c - limit_profile security_candidate_1 - security broker_1 - broker adjustment_instruction_1 - adjustment_instruction source_exposure_bucket_1 - source_exposure_bucket target_exposure_bucket_1 - target_exposure_bucket trade_proposal_1 - trade_proposal allocation_template_a - allocation_template allocation_template_b - allocation_template liquidity_slot_a - liquidity_slot liquidity_slot_b - liquidity_slot settlement_instruction_a - settlement_instruction settlement_instruction_b - settlement_instruction client_account_a - client_account pretrade_approval_a - pretrade_approval strategy_tag_alpha - strategy_tag strategy_tag_beta - strategy_tag execution_authorization_a - execution_authorization)
  (:init
    (limit_profile_available limit_profile_a)
    (limit_profile_available limit_profile_b)
    (limit_profile_available limit_profile_c)
    (security_available security_candidate_1)
    (broker_available broker_1)
