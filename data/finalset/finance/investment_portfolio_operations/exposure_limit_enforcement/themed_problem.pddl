    (allocation_template_available allocation_template_a)
    (allocation_template_available allocation_template_b)
    (plan_linked_to_source_portfolio execution_plan_1 source_portfolio_1)
    (plan_linked_to_source_portfolio execution_plan_2 source_portfolio_1)
    (plan_linked_to_target_portfolio execution_plan_1 target_portfolio_1)
    (plan_linked_to_target_portfolio execution_plan_2 target_portfolio_1)
    (plan_has_trade_proposal execution_plan_1 trade_proposal_1)
    (plan_has_trade_proposal execution_plan_2 trade_proposal_1)
    (plan_bound_allocation_template execution_plan_1 allocation_template_a)
    (plan_bound_allocation_template execution_plan_2 allocation_template_b)
    (liquidity_slot_available liquidity_slot_a)
    (liquidity_slot_available liquidity_slot_b)
    (settlement_instruction_available settlement_instruction_a)
    (settlement_instruction_available settlement_instruction_b)
    (client_account_available client_account_a)
    (pretrade_approval_available pretrade_approval_a)
    (strategy_tag_available strategy_tag_alpha)
    (plan_assigned_strategy_tag execution_plan_1 strategy_tag_alpha)
    (plan_assigned_strategy_tag execution_plan_2 strategy_tag_beta)
    (execution_authorization_available execution_authorization_a)
