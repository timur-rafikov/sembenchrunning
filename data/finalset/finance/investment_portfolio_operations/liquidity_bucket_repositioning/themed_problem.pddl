(define (problem liquidity_repositioning_problem)
  (:domain liquidity_bucket_repositioning_domain)
  (:objects source_bucket_a - source_liquidity_bucket target_bucket_a - target_liquidity_bucket transition_job_alpha - transition_job transition_job_beta - transition_job trade_idea_provider_a - trade_idea_provider trade_idea_provider_b - trade_idea_provider trade_idea_provider_c - trade_idea_provider market_signal_1 - market_signal execution_desk_main - execution_desk security_candidate_x - security_candidate liquidity_profile_a - liquidity_profile execution_profile_a - execution_profile order_instruction_1 - order_instruction settlement_account_a - settlement_account settlement_account_b - settlement_account constraint_template_a - constraint_template constraint_template_b - constraint_template allocation_rule_a - allocation_rule allocation_rule_b - allocation_rule assignment_token_a - post_trade_assignment_token compliance_document_a - compliance_document counterparty_preference_a - counterparty_preference counterparty_preference_b - counterparty_preference approval_ticket_a - approval_ticket)
  (:init
    (trade_idea_provider_available trade_idea_provider_a)
    (trade_idea_provider_available trade_idea_provider_b)
    (trade_idea_provider_available trade_idea_provider_c)
    (market_signal_available market_signal_1)
    (execution_desk_available execution_desk_main)
    (security_candidate_available security_candidate_x)
    (bucket_liquidity_profile_assigned source_bucket_a liquidity_profile_a)
    (target_liquidity_bucket_execution_profile_assigned target_bucket_a execution_profile_a)
    (order_instruction_draft order_instruction_1)
    (settlement_account_available settlement_account_a)
    (settlement_account_available settlement_account_b)
    (job_has_source_liquidity_bucket transition_job_alpha source_bucket_a)
    (job_has_source_liquidity_bucket transition_job_beta source_bucket_a)
    (job_has_target_liquidity_bucket transition_job_alpha target_bucket_a)
    (job_has_target_liquidity_bucket transition_job_beta target_bucket_a)
    (job_has_order_instruction transition_job_alpha order_instruction_1)
    (job_has_order_instruction transition_job_beta order_instruction_1)
    (job_has_settlement_account transition_job_alpha settlement_account_a)
    (job_has_settlement_account transition_job_beta settlement_account_b)
    (constraint_template_available constraint_template_a)
    (constraint_template_available constraint_template_b)
    (allocation_rule_available allocation_rule_a)
    (allocation_rule_available allocation_rule_b)
    (post_trade_assignment_token_available assignment_token_a)
    (compliance_document_available compliance_document_a)
    (counterparty_preference_available counterparty_preference_a)
    (job_has_counterparty_preference transition_job_alpha counterparty_preference_a)
    (job_has_counterparty_preference transition_job_beta counterparty_preference_b)
    (approval_ticket_available approval_ticket_a)
  )
  (:goal
    (and
      (entity_reposition_finalized source_bucket_a)
      (entity_reposition_finalized target_bucket_a)
      (entity_reposition_finalized transition_job_alpha)
      (entity_reposition_finalized transition_job_beta)
    )
  )
)
