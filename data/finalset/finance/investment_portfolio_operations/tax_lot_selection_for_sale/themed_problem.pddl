(define (problem tax_lot_selection_for_sale_problem)
  (:domain investment_portfolio_tax_lot_selection_for_sale)
  (:objects source_lot_1 - source_lot counterparty_lot_1 - counterparty_lot sell_instruction_1 - sell_instruction sell_instruction_2 - sell_instruction selection_profile_1 - selection_profile selection_profile_2 - selection_profile selection_profile_3 - selection_profile security_1 - security execution_venue_1 - execution_venue lot_tag_1 - lot_tag tax_bucket_source_1 - tax_bucket_source tax_bucket_counterpart_1 - tax_bucket_counterpart trade_candidate_1 - trade_candidate lot_record_1 - lot_record lot_record_2 - lot_record execution_strategy_1 - execution_strategy execution_strategy_2 - execution_strategy order_constraint_1 - order_constraint order_constraint_2 - order_constraint tax_profile_1 - tax_profile settlement_window_1 - settlement_window compliance_check_1 - compliance_check compliance_check_2 - compliance_check approval_token_1 - approval_token)
  (:init
    (selection_profile_available selection_profile_1)
    (selection_profile_available selection_profile_2)
    (selection_profile_available selection_profile_3)
    (security_available security_1)
    (execution_venue_available execution_venue_1)
    (lot_tag_available lot_tag_1)
    (source_lot_in_tax_bucket source_lot_1 tax_bucket_source_1)
    (counterparty_lot_in_tax_bucket counterparty_lot_1 tax_bucket_counterpart_1)
    (trade_candidate_available trade_candidate_1)
    (lot_record_available lot_record_1)
    (lot_record_available lot_record_2)
    (instruction_includes_source_lot sell_instruction_1 source_lot_1)
    (instruction_includes_source_lot sell_instruction_2 source_lot_1)
    (instruction_includes_counterparty_lot sell_instruction_1 counterparty_lot_1)
    (instruction_includes_counterparty_lot sell_instruction_2 counterparty_lot_1)
    (instruction_associated_with_trade_candidate sell_instruction_1 trade_candidate_1)
    (instruction_associated_with_trade_candidate sell_instruction_2 trade_candidate_1)
    (instruction_has_lot_record sell_instruction_1 lot_record_1)
    (instruction_has_lot_record sell_instruction_2 lot_record_2)
    (execution_strategy_available execution_strategy_1)
    (execution_strategy_available execution_strategy_2)
    (order_constraint_available order_constraint_1)
    (order_constraint_available order_constraint_2)
    (tax_profile_available tax_profile_1)
    (settlement_window_available settlement_window_1)
    (compliance_check_available compliance_check_1)
    (instruction_compliance_attached sell_instruction_1 compliance_check_1)
    (instruction_compliance_attached sell_instruction_2 compliance_check_2)
    (approval_token_available approval_token_1)
  )
  (:goal
    (and
      (lot_finalized source_lot_1)
      (lot_finalized counterparty_lot_1)
      (lot_finalized sell_instruction_1)
      (lot_finalized sell_instruction_2)
    )
  )
)
