(define (problem target_allocation_construction_problem)
  (:domain target_allocation_construction_domain)
  (:objects model_portfolio_core - model_portfolio portfolio_bucket_equities - portfolio_bucket allocation_job_a - allocation_job allocation_job_b - allocation_job allocation_template_conservative - allocation_template allocation_template_growth - allocation_template allocation_template_income - allocation_template instrument_equity_1 - instrument execution_desk_ny_trading - execution_desk constraint_max_weight - allocation_constraint asset_slot_equity_sleeve - asset_slot execution_slot_primary - execution_slot proposed_trade_ticket_1 - proposed_trade_ticket position_lot_1 - position_lot_record position_lot_2 - position_lot_record benchmark_clause_msci - benchmark_clause benchmark_clause_client_specific - benchmark_clause execution_algorithm_vwap - execution_algorithm execution_algorithm_twap - execution_algorithm allocation_round_token_1 - allocation_round_token broker_instruction_broker_a - broker_routing_instruction approval_token_ops - approval_token approval_token_manager - approval_token venue_preference_primary_exchange - venue_preference)
  (:init
    (allocation_template_available allocation_template_conservative)
    (allocation_template_available allocation_template_growth)
    (allocation_template_available allocation_template_income)
    (instrument_available instrument_equity_1)
    (execution_desk_available execution_desk_ny_trading)
    (allocation_constraint_available constraint_max_weight)
    (model_portfolio_targets_asset_slot model_portfolio_core asset_slot_equity_sleeve)
    (portfolio_bucket_targets_execution_slot portfolio_bucket_equities execution_slot_primary)
    (proposed_trade_ticket_available proposed_trade_ticket_1)
    (position_lot_available position_lot_1)
    (position_lot_available position_lot_2)
    (entity_assigned_to_model_portfolio allocation_job_a model_portfolio_core)
    (entity_assigned_to_model_portfolio allocation_job_b model_portfolio_core)
    (entity_assigned_to_portfolio_bucket allocation_job_a portfolio_bucket_equities)
    (entity_assigned_to_portfolio_bucket allocation_job_b portfolio_bucket_equities)
    (entity_has_proposed_trade_ticket allocation_job_a proposed_trade_ticket_1)
    (entity_has_proposed_trade_ticket allocation_job_b proposed_trade_ticket_1)
    (entity_has_position_lot allocation_job_a position_lot_1)
    (entity_has_position_lot allocation_job_b position_lot_2)
    (benchmark_clause_available benchmark_clause_msci)
    (benchmark_clause_available benchmark_clause_client_specific)
    (execution_algorithm_available execution_algorithm_vwap)
    (execution_algorithm_available execution_algorithm_twap)
    (allocation_round_token_available allocation_round_token_1)
    (broker_routing_instruction_available broker_instruction_broker_a)
    (approval_token_available approval_token_ops)
    (allocation_job_has_approval_token allocation_job_a approval_token_ops)
    (allocation_job_has_approval_token allocation_job_b approval_token_manager)
    (venue_preference_available venue_preference_primary_exchange)
  )
  (:goal
    (and
      (entity_assigned model_portfolio_core)
      (entity_assigned portfolio_bucket_equities)
      (entity_assigned allocation_job_a)
      (entity_assigned allocation_job_b)
    )
  )
)
