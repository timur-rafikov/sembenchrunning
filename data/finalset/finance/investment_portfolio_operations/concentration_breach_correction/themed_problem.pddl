(define (problem concentration_breach_correction_problem)
  (:domain concentration_breach_correction_domain)
  (:objects primary_account_1 - primary_account secondary_account_1 - secondary_account execution_order_1 - execution_order execution_order_2 - execution_order remediation_instrument_1 - remediation_instrument remediation_instrument_2 - remediation_instrument remediation_instrument_3 - remediation_instrument security_candidate_1 - security_candidate execution_agent_1 - execution_agent allocation_lot_1 - allocation_lot sell_leg_slot_1 - sell_leg_slot buy_leg_slot_1 - buy_leg_slot trade_ticket_1 - trade_ticket settlement_instruction_1 - settlement_instruction settlement_instruction_2 - settlement_instruction execution_strategy_1 - execution_strategy execution_strategy_2 - execution_strategy allocation_model_1 - allocation_model allocation_model_2 - allocation_model trade_reference_1 - trade_reference compliance_approver_1 - compliance_approver portfolio_approver_1 - portfolio_approver portfolio_approver_2 - portfolio_approver risk_approver_1 - risk_approver)
  (:init
    (remediation_instrument_available remediation_instrument_1)
    (remediation_instrument_available remediation_instrument_2)
    (remediation_instrument_available remediation_instrument_3)
    (security_candidate_available security_candidate_1)
    (execution_agent_available execution_agent_1)
    (allocation_lot_available allocation_lot_1)
    (account_has_sell_leg_slot primary_account_1 sell_leg_slot_1)
    (account_has_buy_leg_slot secondary_account_1 buy_leg_slot_1)
    (trade_ticket_available trade_ticket_1)
    (settlement_instruction_available settlement_instruction_1)
    (settlement_instruction_available settlement_instruction_2)
    (execution_order_has_primary_account execution_order_1 primary_account_1)
    (execution_order_has_primary_account execution_order_2 primary_account_1)
    (execution_order_has_secondary_account execution_order_1 secondary_account_1)
    (execution_order_has_secondary_account execution_order_2 secondary_account_1)
    (execution_order_has_trade_ticket execution_order_1 trade_ticket_1)
    (execution_order_has_trade_ticket execution_order_2 trade_ticket_1)
    (execution_order_has_settlement_instruction execution_order_1 settlement_instruction_1)
    (execution_order_has_settlement_instruction execution_order_2 settlement_instruction_2)
    (execution_strategy_available execution_strategy_1)
    (execution_strategy_available execution_strategy_2)
    (allocation_model_available allocation_model_1)
    (allocation_model_available allocation_model_2)
    (trade_reference_available trade_reference_1)
    (compliance_approver_available compliance_approver_1)
    (portfolio_approver_available portfolio_approver_1)
    (execution_order_has_portfolio_approver execution_order_1 portfolio_approver_1)
    (execution_order_has_portfolio_approver execution_order_2 portfolio_approver_2)
    (risk_approver_available risk_approver_1)
  )
  (:goal
    (and
      (remediation_assigned primary_account_1)
      (remediation_assigned secondary_account_1)
      (remediation_assigned execution_order_1)
      (remediation_assigned execution_order_2)
    )
  )
)
