(define (problem outflow_funding_from_positions_problem)
  (:domain outflow_funding_from_positions)
  (:objects liquidation_candidate_1 - liquidation_candidate replacement_candidate_1 - replacement_candidate trade_order_1 - trade_order trade_order_2 - trade_order funding_bucket_a - funding_bucket funding_bucket_b - funding_bucket funding_bucket_c - funding_bucket outflow_request_1 - outflow_request trading_desk_1 - trading_desk available_lot_1 - available_lot from_instrument_1 - from_instrument to_instrument_1 - to_instrument trade_plan_1 - trade_plan allocation_ticket_1 - allocation_ticket allocation_ticket_2 - allocation_ticket approval_token_1 - approval_token approval_token_2 - approval_token execution_method_1 - execution_method execution_method_2 - execution_method cash_account_1 - cash_account execution_algorithm_1 - execution_algorithm client_directive_1 - client_directive client_directive_2 - client_directive settlement_instruction_1 - settlement_instruction)
  (:init
    (funding_bucket_available funding_bucket_a)
    (funding_bucket_available funding_bucket_b)
    (funding_bucket_available funding_bucket_c)
    (outflow_request_unassigned outflow_request_1)
    (trading_desk_available trading_desk_1)
    (available_lot_available available_lot_1)
    (liquidation_candidate_from_instrument liquidation_candidate_1 from_instrument_1)
    (replacement_candidate_to_instrument replacement_candidate_1 to_instrument_1)
    (trade_plan_available trade_plan_1)
    (allocation_ticket_available allocation_ticket_1)
    (allocation_ticket_available allocation_ticket_2)
    (order_sources_liquidation_candidate trade_order_1 liquidation_candidate_1)
    (order_sources_liquidation_candidate trade_order_2 liquidation_candidate_1)
    (order_sources_replacement_candidate trade_order_1 replacement_candidate_1)
    (order_sources_replacement_candidate trade_order_2 replacement_candidate_1)
    (order_bound_to_trade_plan trade_order_1 trade_plan_1)
    (order_bound_to_trade_plan trade_order_2 trade_plan_1)
    (order_bound_to_allocation_ticket trade_order_1 allocation_ticket_1)
    (order_bound_to_allocation_ticket trade_order_2 allocation_ticket_2)
    (approval_token_available approval_token_1)
    (approval_token_available approval_token_2)
    (execution_method_available execution_method_1)
    (execution_method_available execution_method_2)
    (cash_account_available cash_account_1)
    (execution_algorithm_available execution_algorithm_1)
    (client_directive_pending client_directive_1)
    (order_bound_to_client_directive trade_order_1 client_directive_1)
    (order_bound_to_client_directive trade_order_2 client_directive_2)
    (settlement_instruction_available settlement_instruction_1)
  )
  (:goal
    (and
      (order_funded liquidation_candidate_1)
      (order_funded replacement_candidate_1)
      (order_funded trade_order_1)
      (order_funded trade_order_2)
    )
  )
)
