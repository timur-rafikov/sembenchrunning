(define (problem finance_investment_portfolio_cash_drag_reduction_trade_selection_problem)
  (:domain finance_investment_portfolio_cash_drag_reduction_trade_selection_domain)
  (:objects source_liquidity_tranche - source_tranche destination_liquidity_tranche - destination_tranche cash_drag_portfolio_alpha - portfolio cash_drag_portfolio_beta - portfolio cash_drag_minimization_strategy - selection_strategy liquidity_screening_strategy - selection_strategy rebalancing_strategy - selection_strategy target_security - instrument equities_trading_desk - trading_desk standard_liquidity_profile_template - liquidity_profile_template source_liquidity_snapshot - source_liquidity_profile destination_liquidity_snapshot - destination_liquidity_profile candidate_trade_proposal - trade_proposal holding_lot_alpha - holding_lot holding_lot_beta - holding_lot minimum_fill_constraint - order_constraint maximum_slippage_constraint - order_constraint source_allocation_preference - allocation_preference destination_allocation_preference - allocation_preference available_cash_lot - cash_lot execution_instruction_template_alpha - execution_instruction_template mandate_compliance_rule - compliance_rule portfolio_guardrail_rule - compliance_rule settlement_parameter_alpha - settlement_parameter)
  (:init
    (selection_strategy_available cash_drag_minimization_strategy)
    (selection_strategy_available liquidity_screening_strategy)
    (selection_strategy_available rebalancing_strategy)
    (instrument_available target_security)
    (trading_desk_available equities_trading_desk)
    (liquidity_template_available standard_liquidity_profile_template)
    (source_liquidity_profile_linked source_liquidity_tranche source_liquidity_snapshot)
    (destination_liquidity_profile_linked destination_liquidity_tranche destination_liquidity_snapshot)
    (trade_proposal_available candidate_trade_proposal)
    (holding_lot_available holding_lot_alpha)
    (holding_lot_available holding_lot_beta)
    (portfolio_source_tranche_linked cash_drag_portfolio_alpha source_liquidity_tranche)
    (portfolio_source_tranche_linked cash_drag_portfolio_beta source_liquidity_tranche)
    (portfolio_destination_tranche_linked cash_drag_portfolio_alpha destination_liquidity_tranche)
    (portfolio_destination_tranche_linked cash_drag_portfolio_beta destination_liquidity_tranche)
    (portfolio_trade_proposal_linked cash_drag_portfolio_alpha candidate_trade_proposal)
    (portfolio_trade_proposal_linked cash_drag_portfolio_beta candidate_trade_proposal)
    (portfolio_holding_lot_linked cash_drag_portfolio_alpha holding_lot_alpha)
    (portfolio_holding_lot_linked cash_drag_portfolio_beta holding_lot_beta)
    (order_constraint_available minimum_fill_constraint)
    (order_constraint_available maximum_slippage_constraint)
    (allocation_preference_available source_allocation_preference)
    (allocation_preference_available destination_allocation_preference)
    (cash_lot_available available_cash_lot)
    (execution_template_available execution_instruction_template_alpha)
    (compliance_rule_available mandate_compliance_rule)
    (portfolio_compliance_rule_linked cash_drag_portfolio_alpha mandate_compliance_rule)
    (portfolio_compliance_rule_linked cash_drag_portfolio_beta portfolio_guardrail_rule)
    (settlement_parameter_available settlement_parameter_alpha)
  )
  (:goal
    (and
      (post_trade_settled source_liquidity_tranche)
      (post_trade_settled destination_liquidity_tranche)
      (post_trade_settled cash_drag_portfolio_alpha)
      (post_trade_settled cash_drag_portfolio_beta)
    )
  )
)
