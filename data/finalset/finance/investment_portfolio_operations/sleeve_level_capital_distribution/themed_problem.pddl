(define (problem sleeve_level_capital_distribution_problem)
  (:domain finance_sleeve_capital_distribution)
  (:objects source_sleeve_1 - source_sleeve destination_sleeve_1 - destination_sleeve execution_portfolio_alpha - execution_portfolio execution_portfolio_beta - execution_portfolio execution_account_1 - execution_account execution_account_2 - execution_account execution_account_3 - execution_account candidate_security_1 - security_candidate execution_desk_primary - execution_desk adjustment_instrument_cash - adjustment_instrument source_exec_leg_1 - source_exec_leg target_exec_leg_1 - target_exec_leg trade_order_placeholder_1 - trade_order trade_batch_1 - trade_batch trade_batch_2 - trade_batch execution_strategy_algo1 - execution_strategy execution_strategy_algo2 - execution_strategy routing_rule_compliance1 - routing_rule routing_rule_liquidity1 - routing_rule capital_instruction_funding1 - capital_instruction broker_primary - broker security_reference_issuer1 - security_reference security_reference_issuer2 - security_reference settlement_instruction_usd - settlement_instruction)
  (:init
    (execution_account_available execution_account_1)
    (execution_account_available execution_account_2)
    (execution_account_available execution_account_3)
    (security_candidate_available candidate_security_1)
    (execution_desk_available execution_desk_primary)
    (adjustment_instrument_available adjustment_instrument_cash)
    (source_sleeve_assigned_source_leg source_sleeve_1 source_exec_leg_1)
    (destination_sleeve_assigned_target_leg destination_sleeve_1 target_exec_leg_1)
    (trade_order_placeholder_available trade_order_placeholder_1)
    (trade_batch_available trade_batch_1)
    (trade_batch_available trade_batch_2)
    (portfolio_assigned_source_sleeve execution_portfolio_alpha source_sleeve_1)
    (portfolio_assigned_source_sleeve execution_portfolio_beta source_sleeve_1)
    (portfolio_assigned_destination_sleeve execution_portfolio_alpha destination_sleeve_1)
    (portfolio_assigned_destination_sleeve execution_portfolio_beta destination_sleeve_1)
    (portfolio_assigned_order execution_portfolio_alpha trade_order_placeholder_1)
    (portfolio_assigned_order execution_portfolio_beta trade_order_placeholder_1)
    (portfolio_assigned_batch execution_portfolio_alpha trade_batch_1)
    (portfolio_assigned_batch execution_portfolio_beta trade_batch_2)
    (execution_strategy_available execution_strategy_algo1)
    (execution_strategy_available execution_strategy_algo2)
    (routing_rule_available routing_rule_compliance1)
    (routing_rule_available routing_rule_liquidity1)
    (capital_instruction_available capital_instruction_funding1)
    (broker_available broker_primary)
    (security_reference_available security_reference_issuer1)
    (portfolio_assigned_security_reference execution_portfolio_alpha security_reference_issuer1)
    (portfolio_assigned_security_reference execution_portfolio_beta security_reference_issuer2)
    (settlement_instruction_available settlement_instruction_usd)
  )
  (:goal
    (and
      (distribution_finalized source_sleeve_1)
      (distribution_finalized destination_sleeve_1)
      (distribution_finalized execution_portfolio_alpha)
      (distribution_finalized execution_portfolio_beta)
    )
  )
)
