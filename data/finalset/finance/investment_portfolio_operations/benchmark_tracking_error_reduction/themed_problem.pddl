(define (problem portfolio_transition_problem_benchmark_tracking)
  (:domain benchmark_tracking_error_domain)
  (:objects source_bucket_1 - source_bucket target_bucket_1 - target_bucket transition_plan_1 - transition_plan transition_plan_2 - transition_plan execution_algo_a - execution_algorithm execution_algo_b - execution_algorithm execution_algo_c - execution_algorithm signal_tracking_error_reduction - trade_signal trader_execution_1 - trader security_abc - security venue_1 - execution_venue tactic_1 - execution_tactic order_1 - order settlement_instr_1 - settlement_instruction settlement_instr_2 - settlement_instruction liquidity_constraint_1 - liquidity_constraint liquidity_constraint_2 - liquidity_constraint pricing_model_1 - pricing_model pricing_model_2 - pricing_model rebalancing_reason_tracking_error - rebalancing_reason risk_parameter_1 - risk_parameter compliance_check_1 - compliance_check compliance_check_2 - compliance_check post_trade_pool_entry_1 - post_trade_pool_entry)
  (:init
    (execution_algorithm_available execution_algo_a)
    (execution_algorithm_available execution_algo_b)
    (execution_algorithm_available execution_algo_c)
    (trade_signal_available signal_tracking_error_reduction)
    (trader_available trader_execution_1)
    (security_available security_abc)
    (source_bucket_venue_candidate source_bucket_1 venue_1)
    (target_bucket_tactic_candidate target_bucket_1 tactic_1)
    (order_pending_construction order_1)
    (settlement_instruction_available settlement_instr_1)
    (settlement_instruction_available settlement_instr_2)
    (transition_includes_source_bucket transition_plan_1 source_bucket_1)
    (transition_includes_source_bucket transition_plan_2 source_bucket_1)
    (transition_includes_target_bucket transition_plan_1 target_bucket_1)
    (transition_includes_target_bucket transition_plan_2 target_bucket_1)
    (transition_includes_order transition_plan_1 order_1)
    (transition_includes_order transition_plan_2 order_1)
    (transition_has_settlement_instruction transition_plan_1 settlement_instr_1)
    (transition_has_settlement_instruction transition_plan_2 settlement_instr_2)
    (liquidity_constraint_available liquidity_constraint_1)
    (liquidity_constraint_available liquidity_constraint_2)
    (pricing_model_available pricing_model_1)
    (pricing_model_available pricing_model_2)
    (rebalancing_reason_available rebalancing_reason_tracking_error)
    (risk_parameter_available risk_parameter_1)
    (compliance_check_available compliance_check_1)
    (plan_attached_compliance_check transition_plan_1 compliance_check_1)
    (plan_attached_compliance_check transition_plan_2 compliance_check_2)
    (post_trade_pool_entry_available post_trade_pool_entry_1)
  )
  (:goal
    (and
      (finalized source_bucket_1)
      (finalized target_bucket_1)
      (finalized transition_plan_1)
      (finalized transition_plan_2)
    )
  )
)
