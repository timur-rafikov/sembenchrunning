(define (problem portfolio_transition_plan_generation_problem)
  (:domain portfolio_transition_plan_domain)
  (:objects source_account_1 - source_account target_account_1 - target_account transition_plan_alpha - transition_plan transition_plan_beta - transition_plan transition_request_a - transition_request transition_request_b - transition_request transition_request_c - transition_request target_model_1 - target_model operator_1 - operator candidate_security_1 - candidate_security source_bucket_1 - source_asset_bucket target_bucket_1 - target_asset_bucket trade_ticket_1 - trade_ticket holding_lot_1 - holding_lot holding_lot_2 - holding_lot execution_venue_1 - execution_venue execution_venue_2 - execution_venue execution_strategy_vwap - execution_strategy execution_strategy_limit - execution_strategy transition_window_1 - transition_window settlement_instruction_primary - settlement_instruction compliance_rule_1 - compliance_rule compliance_rule_2 - compliance_rule approval_document_1 - approval_document)
  (:init
    (request_available transition_request_a)
    (request_available transition_request_b)
    (request_available transition_request_c)
    (target_model_available target_model_1)
    (operator_available operator_1)
    (candidate_security_available candidate_security_1)
    (account_source_bucket_match source_account_1 source_bucket_1)
    (target_account_bucket_match target_account_1 target_bucket_1)
    (trade_ticket_unassigned trade_ticket_1)
    (holding_lot_available holding_lot_1)
    (holding_lot_available holding_lot_2)
    (plan_includes_source_account transition_plan_alpha source_account_1)
    (plan_includes_source_account transition_plan_beta source_account_1)
    (plan_includes_target_account transition_plan_alpha target_account_1)
    (plan_includes_target_account transition_plan_beta target_account_1)
    (plan_includes_trade_ticket transition_plan_alpha trade_ticket_1)
    (plan_includes_trade_ticket transition_plan_beta trade_ticket_1)
    (plan_has_holding_lot transition_plan_alpha holding_lot_1)
    (plan_has_holding_lot transition_plan_beta holding_lot_2)
    (execution_venue_available execution_venue_1)
    (execution_venue_available execution_venue_2)
    (execution_strategy_available execution_strategy_vwap)
    (execution_strategy_available execution_strategy_limit)
    (transition_window_available transition_window_1)
    (settlement_instruction_available settlement_instruction_primary)
    (compliance_rule_available compliance_rule_1)
    (plan_has_compliance_rule transition_plan_alpha compliance_rule_1)
    (plan_has_compliance_rule transition_plan_beta compliance_rule_2)
    (approval_document_available approval_document_1)
  )
  (:goal
    (and
      (assigned_for_transition source_account_1)
      (assigned_for_transition target_account_1)
      (assigned_for_transition transition_plan_alpha)
      (assigned_for_transition transition_plan_beta)
    )
  )
)
