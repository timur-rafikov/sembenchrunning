(define (problem duration_target_realignment_problem)
  (:domain duration_target_realignment)
  (:objects source_portfolio_1 - source_portfolio target_portfolio_1 - target_portfolio rebalancing_plan_a - rebalancing_plan rebalancing_plan_b - rebalancing_plan execution_desk_1 - execution_desk execution_desk_2 - execution_desk execution_desk_3 - execution_desk analytics_signal_1 - analytics_signal approval_unit_1 - approval_unit instrument_candidate_1 - instrument_candidate sell_leg_1 - sell_leg buy_leg_1 - buy_leg order_ticket_1 - order_ticket settlement_account_1 - settlement_account settlement_account_2 - settlement_account broker_lp_1 - broker_lp broker_lp_2 - broker_lp allocation_template_1 - allocation_template allocation_template_2 - allocation_template post_trade_assignment_record_1 - post_trade_assignment_record execution_parameter_vwap - execution_parameter compliance_rule_1 - compliance_rule compliance_rule_2 - compliance_rule counterparty_constraint_1 - counterparty_constraint)
  (:init
    (execution_desk_available execution_desk_1)
    (execution_desk_available execution_desk_2)
    (execution_desk_available execution_desk_3)
    (analytics_signal_available analytics_signal_1)
    (approval_unit_available approval_unit_1)
    (instrument_candidate_available instrument_candidate_1)
    (source_portfolio_has_sell_leg source_portfolio_1 sell_leg_1)
    (target_portfolio_has_buy_leg target_portfolio_1 buy_leg_1)
    (order_ticket_available order_ticket_1)
    (settlement_account_available settlement_account_1)
    (settlement_account_available settlement_account_2)
    (plan_links_to_source_portfolio rebalancing_plan_a source_portfolio_1)
    (plan_links_to_source_portfolio rebalancing_plan_b source_portfolio_1)
    (plan_links_to_target_portfolio rebalancing_plan_a target_portfolio_1)
    (plan_links_to_target_portfolio rebalancing_plan_b target_portfolio_1)
    (plan_links_to_order_ticket rebalancing_plan_a order_ticket_1)
    (plan_links_to_order_ticket rebalancing_plan_b order_ticket_1)
    (plan_links_to_settlement_account rebalancing_plan_a settlement_account_1)
    (plan_links_to_settlement_account rebalancing_plan_b settlement_account_2)
    (broker_available broker_lp_1)
    (broker_available broker_lp_2)
    (allocation_template_available allocation_template_1)
    (allocation_template_available allocation_template_2)
    (post_trade_assignment_record_available post_trade_assignment_record_1)
    (execution_parameter_available execution_parameter_vwap)
    (compliance_rule_available compliance_rule_1)
    (plan_linked_to_compliance_rule rebalancing_plan_a compliance_rule_1)
    (plan_linked_to_compliance_rule rebalancing_plan_b compliance_rule_2)
    (counterparty_constraint_available counterparty_constraint_1)
  )
  (:goal
    (and
      (completed_for_entity source_portfolio_1)
      (completed_for_entity target_portfolio_1)
      (completed_for_entity rebalancing_plan_a)
      (completed_for_entity rebalancing_plan_b)
    )
  )
)
