    (allocation_lot_available allocation_lot_1)
    (allocation_lot_available allocation_lot_2)
    (plan_targets_portfolio rebalance_plan_1 portfolio_1)
    (plan_targets_portfolio rebalance_plan_2 portfolio_1)
    (plan_targets_sleeve rebalance_plan_1 sleeve_1)
    (plan_targets_sleeve rebalance_plan_2 sleeve_1)
    (plan_has_order rebalance_plan_1 order_1)
    (plan_has_order rebalance_plan_2 order_1)
    (plan_has_allocation_lot rebalance_plan_1 allocation_lot_1)
    (plan_has_allocation_lot rebalance_plan_2 allocation_lot_2)
    (execution_venue_available execution_venue_a)
    (execution_venue_available execution_venue_b)
    (settlement_instruction_available settlement_instruction_a)
    (settlement_instruction_available settlement_instruction_b)
    (risk_budget_request_available risk_budget_request_1)
    (execution_parameter_available execution_parameter_a)
