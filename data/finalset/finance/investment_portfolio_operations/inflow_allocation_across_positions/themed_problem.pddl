(define (problem inflow_allocation_case)
  (:domain finance_inflow_allocation_domain)
  (:objects position_a_1 - position_a position_b_1 - position_b portfolio_account_1 - portfolio_account portfolio_account_2 - portfolio_account funding_source_1 - funding_source funding_source_2 - funding_source funding_source_3 - funding_source security_candidate_1 - security trader_desk_1 - trader_desk allocation_preference_1 - allocation_preference execution_leg_a_1 - execution_leg_type_a execution_leg_b_1 - execution_leg_type_b order_instruction_1 - order_instruction settlement_account_1 - settlement_account settlement_account_2 - settlement_account preferred_broker_1 - preferred_broker preferred_broker_2 - preferred_broker execution_variant_1 - execution_variant execution_variant_2 - execution_variant post_trade_batch_1 - post_trade_batch compliance_check_1 - compliance_check client_constraint_1 - client_constraint client_constraint_2 - client_constraint execution_policy_1 - execution_policy)
  (:init
    (funding_source_available funding_source_1)
    (funding_source_available funding_source_2)
    (funding_source_available funding_source_3)
    (security_available security_candidate_1)
    (trader_desk_available trader_desk_1)
    (allocation_preference_available allocation_preference_1)
    (position_a_leg_a_applicable position_a_1 execution_leg_a_1)
    (position_b_leg_b_applicable position_b_1 execution_leg_b_1)
    (order_instruction_available order_instruction_1)
    (settlement_account_available settlement_account_1)
    (settlement_account_available settlement_account_2)
    (portfolio_account_has_position_a portfolio_account_1 position_a_1)
    (portfolio_account_has_position_a portfolio_account_2 position_a_1)
    (portfolio_account_has_position_b portfolio_account_1 position_b_1)
    (portfolio_account_has_position_b portfolio_account_2 position_b_1)
    (portfolio_account_has_order_instruction portfolio_account_1 order_instruction_1)
    (portfolio_account_has_order_instruction portfolio_account_2 order_instruction_1)
    (portfolio_account_has_settlement_account portfolio_account_1 settlement_account_1)
    (portfolio_account_has_settlement_account portfolio_account_2 settlement_account_2)
    (preferred_broker_available preferred_broker_1)
    (preferred_broker_available preferred_broker_2)
    (execution_variant_available execution_variant_1)
    (execution_variant_available execution_variant_2)
    (post_trade_batch_available post_trade_batch_1)
    (compliance_check_available compliance_check_1)
    (client_constraint_available client_constraint_1)
    (portfolio_account_has_client_constraint portfolio_account_1 client_constraint_1)
    (portfolio_account_has_client_constraint portfolio_account_2 client_constraint_2)
    (execution_policy_available execution_policy_1)
  )
  (:goal
    (and
      (assignment_finalized position_a_1)
      (assignment_finalized position_b_1)
      (assignment_finalized portfolio_account_1)
      (assignment_finalized portfolio_account_2)
    )
  )
)
