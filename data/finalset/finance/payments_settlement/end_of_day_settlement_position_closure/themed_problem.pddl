(define (problem end_of_day_settlement_closure_problem)
  (:domain end_of_day_settlement_position_closure)
  (:objects debit_position_1 - debit_position credit_position_1 - credit_position processing_agent_alpha - processing_agent processing_agent_beta - processing_agent channel_endpoint_a - settlement_channel_endpoint channel_endpoint_b - settlement_channel_endpoint channel_endpoint_c - settlement_channel_endpoint validation_service_core - validation_service authorizing_service_ops - authorizing_service exception_record_1 - exception_record debit_channel_instance_1 - debit_channel_instance credit_channel_instance_1 - credit_channel_instance closure_slot_1 - closure_slot control_record_1 - control_record control_record_2 - control_record compliance_credential_primary - compliance_credential compliance_credential_secondary - compliance_credential approval_token_1 - approval_token approval_token_2 - approval_token reconciliation_record_1 - reconciliation_record settlement_funding_resource_1 - settlement_funding_resource regulatory_approval_authority_1 - regulatory_approval regulatory_approval_authority_2 - regulatory_approval escalation_ticket_1 - escalation_ticket)
  (:init
    (settlement_channel_endpoint_available channel_endpoint_a)
    (settlement_channel_endpoint_available channel_endpoint_b)
    (settlement_channel_endpoint_available channel_endpoint_c)
    (validation_service_available validation_service_core)
    (authorizing_service_available authorizing_service_ops)
    (exception_record_available exception_record_1)
    (debit_position_assigned_debit_channel_instance debit_position_1 debit_channel_instance_1)
    (credit_position_assigned_credit_channel_instance credit_position_1 credit_channel_instance_1)
    (closure_slot_available closure_slot_1)
    (control_record_available control_record_1)
    (control_record_available control_record_2)
    (settlement_entity_assigned_debit_position processing_agent_alpha debit_position_1)
    (settlement_entity_assigned_debit_position processing_agent_beta debit_position_1)
    (settlement_entity_assigned_credit_position processing_agent_alpha credit_position_1)
    (settlement_entity_assigned_credit_position processing_agent_beta credit_position_1)
    (settlement_entity_assigned_closure_slot processing_agent_alpha closure_slot_1)
    (settlement_entity_assigned_closure_slot processing_agent_beta closure_slot_1)
    (processing_agent_attached_control_record processing_agent_alpha control_record_1)
    (processing_agent_attached_control_record processing_agent_beta control_record_2)
    (compliance_credential_available compliance_credential_primary)
    (compliance_credential_available compliance_credential_secondary)
    (approval_token_available approval_token_1)
    (approval_token_available approval_token_2)
    (reconciliation_record_available reconciliation_record_1)
    (settlement_funding_resource_available settlement_funding_resource_1)
    (regulatory_approval_available regulatory_approval_authority_1)
    (processing_agent_has_regulatory_approval processing_agent_alpha regulatory_approval_authority_1)
    (processing_agent_has_regulatory_approval processing_agent_beta regulatory_approval_authority_2)
    (escalation_ticket_available escalation_ticket_1)
  )
  (:goal
    (and
      (settlement_entity_closed debit_position_1)
      (settlement_entity_closed credit_position_1)
      (settlement_entity_closed processing_agent_alpha)
      (settlement_entity_closed processing_agent_beta)
    )
  )
)
