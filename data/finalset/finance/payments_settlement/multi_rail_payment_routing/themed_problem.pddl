(define (problem multi_rail_payment_settlement_scenario)
  (:domain multi_rail_payment_routing)
  (:objects origin_leg_1 - originating_ledger_entry beneficiary_leg_1 - beneficiary_ledger_entry routing_engine_1 - routing_engine routing_engine_2 - routing_engine rail_ach - payment_rail rail_rtp - payment_rail rail_correspondent - payment_rail worker_validation - processing_worker auth_gateway_primary - authorization_gateway standard_fee_profile - fee_profile origin_channel_option_domestic - origin_channel_option beneficiary_channel_option_standard - beneficiary_channel_option settlement_message_1 - settlement_message settlement_credential_a - settlement_credential settlement_credential_b - settlement_credential compliance_document_aml - compliance_document compliance_document_sanctions - compliance_document confirmation_provider_1 - confirmation_provider confirmation_provider_2 - confirmation_provider settlement_ticket_1 - settlement_ticket liquidity_source_primary - liquidity_source regulatory_token_jurisdiction_a - regulatory_approval_token regulatory_token_jurisdiction_b - regulatory_approval_token counterparty_confirmation_1 - counterparty_confirmation)
  (:init
    (rail_available rail_ach)
    (rail_available rail_rtp)
    (rail_available rail_correspondent)
    (worker_available worker_validation)
    (gateway_available auth_gateway_primary)
    (fee_profile_available standard_fee_profile)
    (origin_channel_option_applicable origin_leg_1 origin_channel_option_domestic)
    (beneficiary_channel_option_applicable beneficiary_leg_1 beneficiary_channel_option_standard)
    (settlement_message_draft settlement_message_1)
    (settlement_credential_available settlement_credential_a)
    (settlement_credential_available settlement_credential_b)
    (engine_linked_origin_leg routing_engine_1 origin_leg_1)
    (engine_linked_origin_leg routing_engine_2 origin_leg_1)
    (engine_linked_beneficiary_leg routing_engine_1 beneficiary_leg_1)
    (engine_linked_beneficiary_leg routing_engine_2 beneficiary_leg_1)
    (engine_bound_settlement_message routing_engine_1 settlement_message_1)
    (engine_bound_settlement_message routing_engine_2 settlement_message_1)
    (engine_has_credential routing_engine_1 settlement_credential_a)
    (engine_has_credential routing_engine_2 settlement_credential_b)
    (compliance_document_available compliance_document_aml)
    (compliance_document_available compliance_document_sanctions)
    (confirmation_provider_available confirmation_provider_1)
    (confirmation_provider_available confirmation_provider_2)
    (settlement_ticket_available settlement_ticket_1)
    (liquidity_source_available liquidity_source_primary)
    (regulatory_token_available regulatory_token_jurisdiction_a)
    (engine_has_regulatory_token routing_engine_1 regulatory_token_jurisdiction_a)
    (engine_has_regulatory_token routing_engine_2 regulatory_token_jurisdiction_b)
    (counterparty_confirmation_available counterparty_confirmation_1)
  )
  (:goal
    (and
      (settlement_completed origin_leg_1)
      (settlement_completed beneficiary_leg_1)
      (settlement_completed routing_engine_1)
      (settlement_completed routing_engine_2)
    )
  )
)
