(define (problem payment_scheduling_case)
  (:domain cut_off_time_aware_payment_scheduling)
  (:objects originating_bank_a - originating_participant receiving_bank_b - receiving_participant payment_message_container_1 - payment_message_container payment_message_container_2 - payment_message_container cutoff_slot_1 - cutoff_slot cutoff_slot_2 - cutoff_slot cutoff_slot_3 - cutoff_slot settlement_leg_detail_1 - settlement_leg_detail processing_agent_1 - processing_agent compliance_payload_1 - compliance_payload origin_channel_1 - origin_channel destination_channel_1 - destination_channel outbound_message_1 - outbound_settlement_message message_template_1 - message_template message_template_2 - message_template routing_preference_1 - routing_preference_flag routing_preference_2 - routing_preference_flag execution_profile_1 - execution_profile execution_profile_2 - execution_profile scheduling_window_token_1 - scheduling_window_token authorization_credential_1 - authorization_credential exception_token_1 - exception_waiver_token exception_token_2 - exception_waiver_token settlement_instrument_ref_1 - settlement_instrument_reference)
  (:init
    (cutoff_slot_available cutoff_slot_1)
    (cutoff_slot_available cutoff_slot_2)
    (cutoff_slot_available cutoff_slot_3)
    (settlement_leg_available settlement_leg_detail_1)
    (processing_agent_available processing_agent_1)
    (compliance_payload_available compliance_payload_1)
    (participant_bound_to_origin_channel originating_bank_a origin_channel_1)
    (participant_bound_to_destination_channel receiving_bank_b destination_channel_1)
    (outbound_message_pending_assembly outbound_message_1)
    (message_template_available message_template_1)
    (message_template_available message_template_2)
    (container_bound_to_origin_participant payment_message_container_1 originating_bank_a)
    (container_bound_to_origin_participant payment_message_container_2 originating_bank_a)
    (container_bound_to_receiving_participant payment_message_container_1 receiving_bank_b)
    (container_bound_to_receiving_participant payment_message_container_2 receiving_bank_b)
    (container_contains_outbound_message payment_message_container_1 outbound_message_1)
    (container_contains_outbound_message payment_message_container_2 outbound_message_1)
    (container_bound_to_message_template payment_message_container_1 message_template_1)
    (container_bound_to_message_template payment_message_container_2 message_template_2)
    (routing_preference_flag_available routing_preference_1)
    (routing_preference_flag_available routing_preference_2)
    (execution_profile_available execution_profile_1)
    (execution_profile_available execution_profile_2)
    (scheduling_window_token_available scheduling_window_token_1)
    (authorization_credential_available authorization_credential_1)
    (exception_token_available exception_token_1)
    (container_bound_to_exception_token payment_message_container_1 exception_token_1)
    (container_bound_to_exception_token payment_message_container_2 exception_token_2)
    (settlement_instrument_reference_available settlement_instrument_ref_1)
  )
  (:goal
    (and
      (released_to_settlement originating_bank_a)
      (released_to_settlement receiving_bank_b)
      (released_to_settlement payment_message_container_1)
      (released_to_settlement payment_message_container_2)
    )
  )
)
