(define (problem payment_release_queue_prioritization_problem)
  (:domain payment_release_queue_prioritization)
  (:objects main_debit_leg - debit_leg main_credit_leg - credit_leg release_workflow_a - release_workflow release_workflow_b - release_workflow processing_slot_a - processing_slot processing_slot_b - processing_slot processing_slot_c - processing_slot validation_agent_a - validation_agent operator_agent_a - operator_agent supporting_document_a - supporting_document debit_route_target_a - debit_route_target credit_route_target_a - credit_route_target settlement_message_a - settlement_message document_bundle_a - document_bundle document_bundle_b - document_bundle priority_profile_a - priority_profile priority_profile_b - priority_profile exception_profile_a - exception_profile exception_profile_b - exception_profile release_context_a - release_context signature_token_a - signature_token external_approval_a - external_approval external_approval_b - external_approval compliance_verification_a - compliance_verification)
  (:init
    (processing_slot_available processing_slot_a)
    (processing_slot_available processing_slot_b)
    (processing_slot_available processing_slot_c)
    (validation_agent_available validation_agent_a)
    (operator_agent_available operator_agent_a)
    (supporting_document_available supporting_document_a)
    (debit_route_assignment main_debit_leg debit_route_target_a)
    (credit_route_assignment main_credit_leg credit_route_target_a)
    (settlement_message_available settlement_message_a)
    (document_bundle_available document_bundle_a)
    (document_bundle_available document_bundle_b)
    (workflow_debit_leg_link release_workflow_a main_debit_leg)
    (workflow_debit_leg_link release_workflow_b main_debit_leg)
    (workflow_credit_leg_link release_workflow_a main_credit_leg)
    (workflow_credit_leg_link release_workflow_b main_credit_leg)
    (workflow_settlement_message_link release_workflow_a settlement_message_a)
    (workflow_settlement_message_link release_workflow_b settlement_message_a)
    (workflow_document_bundle_link release_workflow_a document_bundle_a)
    (workflow_document_bundle_link release_workflow_b document_bundle_b)
    (priority_profile_available priority_profile_a)
    (priority_profile_available priority_profile_b)
    (exception_profile_available exception_profile_a)
    (exception_profile_available exception_profile_b)
    (release_context_available release_context_a)
    (signature_token_available signature_token_a)
    (external_approval_available external_approval_a)
    (workflow_external_approval_link release_workflow_a external_approval_a)
    (workflow_external_approval_link release_workflow_b external_approval_b)
    (compliance_verification_available compliance_verification_a)
  )
  (:goal
    (and
      (settlement_completed main_debit_leg)
      (settlement_completed main_credit_leg)
      (settlement_completed release_workflow_a)
      (settlement_completed release_workflow_b)
    )
  )
)
