    (destination_channel_assigned beneficiary_agent_instance destination_channel_instance)
    (settlement_message_available settlement_message_instance)
    (settlement_file_available settlement_file_primary_instance)
    (settlement_file_available settlement_file_secondary_instance)
    (processor_bound_to_origin_agent settlement_processor_primary_instance originating_agent_instance)
    (processor_bound_to_origin_agent settlement_processor_secondary_instance originating_agent_instance)
    (processor_bound_to_beneficiary_agent settlement_processor_primary_instance beneficiary_agent_instance)
    (processor_bound_to_beneficiary_agent settlement_processor_secondary_instance beneficiary_agent_instance)
    (processor_bound_to_settlement_message settlement_processor_primary_instance settlement_message_instance)
    (processor_bound_to_settlement_message settlement_processor_secondary_instance settlement_message_instance)
    (processor_bound_to_settlement_file settlement_processor_primary_instance settlement_file_primary_instance)
    (processor_bound_to_settlement_file settlement_processor_secondary_instance settlement_file_secondary_instance)
    (service_parameter_available service_parameter_primary_instance)
    (service_parameter_available service_parameter_secondary_instance)
    (authorization_token_available authorization_token_primary_instance)
    (authorization_token_available authorization_token_secondary_instance)
    (duplicate_check_record_available duplicate_check_record_instance)
    (configuration_parameter_available configuration_parameter_instance)
    (external_reference_available external_reference_primary_instance)
    (processor_bound_to_external_reference settlement_processor_primary_instance external_reference_primary_instance)
    (processor_bound_to_external_reference settlement_processor_secondary_instance external_reference_secondary_instance)
    (escalation_policy_available escalation_policy_instance)
  )
  (:goal
    (and
      (settlement_completed originating_agent_instance)
      (settlement_completed beneficiary_agent_instance)
      (settlement_completed settlement_processor_primary_instance)
      (settlement_completed settlement_processor_secondary_instance)
    )
  )
)
