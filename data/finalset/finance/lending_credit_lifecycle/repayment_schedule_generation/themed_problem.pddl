(define (problem generate_repayment_schedule_problem)
  (:domain repayment_schedule_generation_domain)
  (:objects primary_loan_account_1 - primary_loan_account secondary_loan_account_1 - secondary_loan_account schedule_generation_job_1 - schedule_generation_job schedule_generation_job_2 - schedule_generation_job rate_template_standard - rate_template rate_template_indexed - rate_template rate_template_promotional - rate_template pricing_model_standard - pricing_model servicing_policy_standard - servicing_policy adjustment_profile_standard - adjustment_profile principal_leg_profile_standard - principal_leg_profile interest_leg_profile_standard - interest_leg_profile repayment_schedule_template_candidate - repayment_schedule_template amendment_record_1 - amendment_record amendment_record_2 - amendment_record document_template_disclosure - document_template document_template_terms - document_template presentation_profile_default - presentation_profile presentation_profile_detailed - presentation_profile execution_context_run_1 - execution_context collateral_profile_primary - collateral_profile manual_override_token_1 - manual_override_token manual_override_token_2 - manual_override_token regulatory_flag_jurisdictional - regulatory_flag)
  (:init
    (rate_template_available rate_template_standard)
    (rate_template_available rate_template_indexed)
    (rate_template_available rate_template_promotional)
    (pricing_model_available pricing_model_standard)
    (servicing_policy_available servicing_policy_standard)
    (adjustment_profile_available adjustment_profile_standard)
    (loan_has_principal_leg_profile primary_loan_account_1 principal_leg_profile_standard)
    (loan_has_interest_leg_profile secondary_loan_account_1 interest_leg_profile_standard)
    (schedule_template_available repayment_schedule_template_candidate)
    (amendment_record_available amendment_record_1)
    (amendment_record_available amendment_record_2)
    (job_includes_primary_loan schedule_generation_job_1 primary_loan_account_1)
    (job_includes_primary_loan schedule_generation_job_2 primary_loan_account_1)
    (job_includes_secondary_loan schedule_generation_job_1 secondary_loan_account_1)
    (job_includes_secondary_loan schedule_generation_job_2 secondary_loan_account_1)
    (job_bound_template schedule_generation_job_1 repayment_schedule_template_candidate)
    (job_bound_template schedule_generation_job_2 repayment_schedule_template_candidate)
    (job_bound_amendment schedule_generation_job_1 amendment_record_1)
    (job_bound_amendment schedule_generation_job_2 amendment_record_2)
    (document_template_available document_template_disclosure)
    (document_template_available document_template_terms)
    (presentation_profile_available presentation_profile_default)
    (presentation_profile_available presentation_profile_detailed)
    (execution_context_available execution_context_run_1)
    (collateral_profile_available collateral_profile_primary)
    (manual_override_token_available manual_override_token_1)
    (job_bound_manual_override schedule_generation_job_1 manual_override_token_1)
    (job_bound_manual_override schedule_generation_job_2 manual_override_token_2)
    (regulatory_flag_available regulatory_flag_jurisdictional)
  )
  (:goal
    (and
      (schedule_published primary_loan_account_1)
      (schedule_published secondary_loan_account_1)
      (schedule_published schedule_generation_job_1)
      (schedule_published schedule_generation_job_2)
    )
  )
)
