(define (problem drawdown_condition_check_problem)
  (:domain finance_drawdown_condition_check_domain)
  (:objects lender_party_a - lender_party borrower_party_a - borrower_party processing_case_1 - processing_case processing_case_2 - processing_case commitment_unit_a - commitment_unit commitment_unit_b - commitment_unit commitment_unit_c - commitment_unit drawdown_request_1 - drawdown_request authorised_approver_1 - authorised_approver supporting_document_1 - supporting_document covenant_rule_1 - covenant_rule financial_condition_1 - financial_condition drawdown_package_1 - drawdown_package collateral_item_1 - collateral_item collateral_item_2 - collateral_item legal_provision_1 - legal_provision legal_provision_2 - legal_provision pricing_profile_1 - pricing_profile pricing_profile_2 - pricing_profile condition_evidence_1 - condition_evidence pricing_component_1 - pricing_component exceptional_approval_1 - exceptional_approval exceptional_approval_2 - exceptional_approval regulatory_confirmation_1 - regulatory_confirmation)
  (:init
    (commitment_unit_available commitment_unit_a)
    (commitment_unit_available commitment_unit_b)
    (commitment_unit_available commitment_unit_c)
    (drawdown_request_unallocated drawdown_request_1)
    (approver_available authorised_approver_1)
    (supporting_document_available supporting_document_1)
    (lender_covenant_link lender_party_a covenant_rule_1)
    (borrower_financial_condition_link borrower_party_a financial_condition_1)
    (drawdown_package_available drawdown_package_1)
    (collateral_item_available collateral_item_1)
    (collateral_item_available collateral_item_2)
    (case_associated_with_lender processing_case_1 lender_party_a)
    (case_associated_with_lender processing_case_2 lender_party_a)
    (case_associated_with_borrower processing_case_1 borrower_party_a)
    (case_associated_with_borrower processing_case_2 borrower_party_a)
    (case_has_drawdown_package processing_case_1 drawdown_package_1)
    (case_has_drawdown_package processing_case_2 drawdown_package_1)
    (case_has_collateral_item processing_case_1 collateral_item_1)
    (case_has_collateral_item processing_case_2 collateral_item_2)
    (legal_provision_available legal_provision_1)
    (legal_provision_available legal_provision_2)
    (pricing_profile_available pricing_profile_1)
    (pricing_profile_available pricing_profile_2)
    (condition_evidence_available condition_evidence_1)
    (pricing_component_available pricing_component_1)
    (exceptional_approval_available exceptional_approval_1)
    (case_exceptional_approval_link processing_case_1 exceptional_approval_1)
    (case_exceptional_approval_link processing_case_2 exceptional_approval_2)
    (regulatory_confirmation_available regulatory_confirmation_1)
  )
  (:goal
    (and
      (conditions_precedent_satisfied lender_party_a)
      (conditions_precedent_satisfied borrower_party_a)
      (conditions_precedent_satisfied processing_case_1)
      (conditions_precedent_satisfied processing_case_2)
    )
  )
)
