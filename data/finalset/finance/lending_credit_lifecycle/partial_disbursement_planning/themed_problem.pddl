(define (problem partial_disbursement_planning_problem)
  (:domain partial_disbursement_planning)
  (:objects primary_tranche_1 - primary_tranche secondary_tranche_1 - secondary_tranche loan_account_1 - loan_account loan_account_2 - loan_account allocation_slot_1 - allocation_slot allocation_slot_2 - allocation_slot allocation_slot_3 - allocation_slot drawdown_request_1 - drawdown_request approver_1 - authorized_approver supporting_document_1 - supporting_document disbursement_channel_1 - disbursement_channel payee_account_1 - payee_account disbursement_instruction_1 - disbursement_instruction collateral_unit_1 - collateral_unit collateral_unit_2 - collateral_unit pricing_option_standard - pricing_option pricing_option_premium - pricing_option fee_schedule_standard - fee_schedule fee_schedule_extra - fee_schedule funding_source_treasury_pool - funding_source funding_account_operative - funding_account product_offer_basic - product_offer product_offer_premium - product_offer customer_consent_signed - customer_consent)
  (:init
    (allocation_slot_available allocation_slot_1)
    (allocation_slot_available allocation_slot_2)
    (allocation_slot_available allocation_slot_3)
    (drawdown_request_pending drawdown_request_1)
    (approver_available approver_1)
    (supporting_document_available supporting_document_1)
    (tranche_channel_eligible primary_tranche_1 disbursement_channel_1)
    (secondary_tranche_payee_assigned secondary_tranche_1 payee_account_1)
    (instruction_template_available disbursement_instruction_1)
    (collateral_unit_available collateral_unit_1)
    (collateral_unit_available collateral_unit_2)
    (loan_account_primary_tranche_association loan_account_1 primary_tranche_1)
    (loan_account_primary_tranche_association loan_account_2 primary_tranche_1)
    (loan_account_secondary_tranche_association loan_account_1 secondary_tranche_1)
    (loan_account_secondary_tranche_association loan_account_2 secondary_tranche_1)
    (loan_account_instruction_link loan_account_1 disbursement_instruction_1)
    (loan_account_instruction_link loan_account_2 disbursement_instruction_1)
    (loan_account_has_collateral_unit loan_account_1 collateral_unit_1)
    (loan_account_has_collateral_unit loan_account_2 collateral_unit_2)
    (pricing_option_available pricing_option_standard)
    (pricing_option_available pricing_option_premium)
    (fee_schedule_available fee_schedule_standard)
    (fee_schedule_available fee_schedule_extra)
    (funding_source_available funding_source_treasury_pool)
    (funding_account_available funding_account_operative)
    (product_offer_available product_offer_basic)
    (loan_account_product_assigned loan_account_1 product_offer_basic)
    (loan_account_product_assigned loan_account_2 product_offer_premium)
    (customer_consent_available customer_consent_signed)
  )
  (:goal
    (and
      (disbursed primary_tranche_1)
      (disbursed secondary_tranche_1)
      (disbursed loan_account_1)
      (disbursed loan_account_2)
    )
  )
)
