(define (problem early_repayment_recalculation_problem)
  (:domain lending_early_repayment_recalculation_domain)
  (:objects primary_loan_record_1 - primary_loan_record secondary_loan_record_1 - secondary_loan_record recalc_case_1 - recalculation_case recalc_case_2 - recalculation_case pricing_scheme_a - pricing_scheme pricing_scheme_b - pricing_scheme pricing_scheme_c - pricing_scheme notice_1 - early_repayment_notice servicing_agent_1 - servicing_agent business_document_1 - business_document exposure_component_1 - exposure_component pricing_component_1 - pricing_component recalculation_result_1 - recalculation_result collateral_item_1 - collateral_item collateral_item_2 - collateral_item approval_doc_1 - approval_document approval_doc_2 - approval_document adjustment_rule_1 - adjustment_rule adjustment_rule_2 - adjustment_rule charge_item_1 - charge_schedule_item interest_override_1 - interest_override policy_attachment_1 - policy_attachment policy_attachment_2 - policy_attachment regulatory_parameter_1 - regulatory_parameter)
  (:init
    (pricing_scheme_available pricing_scheme_a)
    (pricing_scheme_available pricing_scheme_b)
    (pricing_scheme_available pricing_scheme_c)
    (notice_available notice_1)
    (servicing_agent_available servicing_agent_1)
    (business_document_available business_document_1)
    (primary_record_exposure_link primary_loan_record_1 exposure_component_1)
    (secondary_record_pricing_link secondary_loan_record_1 pricing_component_1)
    (result_slot_available recalculation_result_1)
    (collateral_available collateral_item_1)
    (collateral_available collateral_item_2)
    (case_primary_record_link recalc_case_1 primary_loan_record_1)
    (case_primary_record_link recalc_case_2 primary_loan_record_1)
    (case_secondary_record_link recalc_case_1 secondary_loan_record_1)
    (case_secondary_record_link recalc_case_2 secondary_loan_record_1)
    (case_result_link recalc_case_1 recalculation_result_1)
    (case_result_link recalc_case_2 recalculation_result_1)
    (case_collateral_link recalc_case_1 collateral_item_1)
    (case_collateral_link recalc_case_2 collateral_item_2)
    (approval_document_available approval_doc_1)
    (approval_document_available approval_doc_2)
    (adjustment_rule_available adjustment_rule_1)
    (adjustment_rule_available adjustment_rule_2)
    (charge_schedule_item_available charge_item_1)
    (interest_override_available interest_override_1)
    (policy_attachment_available policy_attachment_1)
    (case_policy_attachment recalc_case_1 policy_attachment_1)
    (case_policy_attachment recalc_case_2 policy_attachment_2)
    (regulatory_parameter_available regulatory_parameter_1)
  )
  (:goal
    (and
      (finalized primary_loan_record_1)
      (finalized secondary_loan_record_1)
      (finalized recalc_case_1)
      (finalized recalc_case_2)
    )
  )
)
