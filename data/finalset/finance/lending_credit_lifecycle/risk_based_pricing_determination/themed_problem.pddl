(define (problem risk_based_pricing_scenario)
  (:domain risk_based_pricing_determination)
  (:objects primary_facility_1 - primary_facility secondary_facility_1 - secondary_facility pricing_job_1 - pricing_job pricing_job_2 - pricing_job rate_source_1 - rate_source rate_source_2 - rate_source rate_source_3 - rate_source score_model_v1 - score_model underwriter_1 - underwriter collateral_option_standard - collateral_option risk_adjustment_bucket_a - risk_adjustment product_adjustment_tier_a - product_adjustment pricing_proposal_candidate_1 - pricing_proposal collateral_asset_1 - collateral_asset collateral_asset_2 - collateral_asset channel_online - distribution_channel channel_branch - distribution_channel compliance_check_aml - compliance_check compliance_check_kyc - compliance_check regulatory_rule_default - regulatory_rule rate_parameter_base - rate_parameter discount_condition_volume_discount - discount_condition discount_condition_promotional - discount_condition manager_override_standard - manager_override)
  (:init
    (rate_source_available rate_source_1)
    (rate_source_available rate_source_2)
    (rate_source_available rate_source_3)
    (score_model_available score_model_v1)
    (underwriter_available underwriter_1)
    (collateral_option_available collateral_option_standard)
    (primary_facility_selected_risk_adjustment primary_facility_1 risk_adjustment_bucket_a)
    (secondary_facility_selected_product_adjustment secondary_facility_1 product_adjustment_tier_a)
    (pricing_proposal_available pricing_proposal_candidate_1)
    (collateral_asset_available collateral_asset_1)
    (collateral_asset_available collateral_asset_2)
    (job_attached_primary_facility pricing_job_1 primary_facility_1)
    (job_attached_primary_facility pricing_job_2 primary_facility_1)
    (job_attached_secondary_facility pricing_job_1 secondary_facility_1)
    (job_attached_secondary_facility pricing_job_2 secondary_facility_1)
    (job_attached_proposal pricing_job_1 pricing_proposal_candidate_1)
    (job_attached_proposal pricing_job_2 pricing_proposal_candidate_1)
    (job_assigned_collateral_asset pricing_job_1 collateral_asset_1)
    (job_assigned_collateral_asset pricing_job_2 collateral_asset_2)
    (distribution_channel_available channel_online)
    (distribution_channel_available channel_branch)
    (compliance_check_available compliance_check_aml)
    (compliance_check_available compliance_check_kyc)
    (regulatory_rule_available regulatory_rule_default)
    (rate_parameter_available rate_parameter_base)
    (discount_condition_available discount_condition_volume_discount)
    (job_assigned_discount_condition pricing_job_1 discount_condition_volume_discount)
    (job_assigned_discount_condition pricing_job_2 discount_condition_promotional)
    (manager_override_available manager_override_standard)
  )
  (:goal
    (and
      (pricing_committed primary_facility_1)
      (pricing_committed secondary_facility_1)
      (pricing_committed pricing_job_1)
      (pricing_committed pricing_job_2)
    )
  )
)
