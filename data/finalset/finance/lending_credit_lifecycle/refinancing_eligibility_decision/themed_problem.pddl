(define (problem refinancing_eligibility_decision_problem)
  (:domain refinancing_eligibility_decision_domain)
  (:objects primary_applicant_1 - primary_applicant_record co_applicant_1 - co_applicant_record underwriting_case_1 - underwriting_case underwriting_case_2 - underwriting_case decision_engine_a - decision_engine decision_engine_b - decision_engine decision_engine_c - decision_engine document_income_statement_1 - document assessor_1 - third_party_assessor policy_rule_set_1 - rule_set residential_property_type - collateral_type collateral_asset_1 - collateral_asset refinance_offer_1 - refinance_offer collateral_item_1 - collateral_item collateral_item_2 - collateral_item guarantor_profile_1 - guarantor_profile guarantor_profile_2 - guarantor_profile override_token_1 - override_token override_token_2 - override_token risk_threshold_1 - risk_threshold valuation_report_1 - valuation_report external_indicator_credit_bureau_1 - external_indicator external_indicator_public_records_1 - external_indicator compliance_flag_1 - compliance_flag)
  (:init
    (engine_available decision_engine_a)
    (engine_available decision_engine_b)
    (engine_available decision_engine_c)
    (document_available document_income_statement_1)
    (assessor_available assessor_1)
    (rule_set_available policy_rule_set_1)
    (primary_applicant_linked_collateral_type primary_applicant_1 residential_property_type)
    (co_applicant_linked_collateral_asset co_applicant_1 collateral_asset_1)
    (offer_slot_available refinance_offer_1)
    (collateral_item_available collateral_item_1)
    (collateral_item_available collateral_item_2)
    (case_primary_applicant_link underwriting_case_1 primary_applicant_1)
    (case_primary_applicant_link underwriting_case_2 primary_applicant_1)
    (case_co_applicant_link underwriting_case_1 co_applicant_1)
    (case_co_applicant_link underwriting_case_2 co_applicant_1)
    (case_offer_link underwriting_case_1 refinance_offer_1)
    (case_offer_link underwriting_case_2 refinance_offer_1)
    (case_has_collateral_item underwriting_case_1 collateral_item_1)
    (case_has_collateral_item underwriting_case_2 collateral_item_2)
    (guarantor_profile_available guarantor_profile_1)
    (guarantor_profile_available guarantor_profile_2)
    (override_token_available override_token_1)
    (override_token_available override_token_2)
    (risk_threshold_available risk_threshold_1)
    (valuation_report_available valuation_report_1)
    (external_indicator_available external_indicator_credit_bureau_1)
    (case_linked_external_indicator underwriting_case_1 external_indicator_credit_bureau_1)
    (case_linked_external_indicator underwriting_case_2 external_indicator_public_records_1)
    (compliance_flag_available compliance_flag_1)
  )
  (:goal
    (and
      (decision_finalized primary_applicant_1)
      (decision_finalized co_applicant_1)
      (decision_finalized underwriting_case_1)
      (decision_finalized underwriting_case_2)
    )
  )
)
