(define (problem ledger_cutoff_exception_resolution_problem)
  (:domain ledger_cutoff_exception_resolution)
  (:objects gl_segment_1 - general_ledger_segment subledger_segment_1 - subledger_segment finance_processor_1 - finance_processor finance_processor_2 - finance_processor approver_role_1 - approver_role approver_role_2 - approver_role approver_role_3 - approver_role investigator_1 - investigator sme_reviewer_1 - sme_reviewer supporting_document_1 - supporting_document ledger_discrepancy_1 - ledger_discrepancy_record counterparty_discrepancy_1 - counterparty_discrepancy_record resolution_packet_1 - resolution_packet workpaper_1 - workpaper workpaper_2 - workpaper control_checklist_1 - control_checklist control_checklist_2 - control_checklist signoff_1 - signoff signoff_2 - signoff audit_reference_1 - audit_reference adjustment_code_1 - adjustment_code policy_reference_1 - policy_reference policy_reference_2 - policy_reference escalation_reason_1 - escalation_reason)
  (:init
    (approver_available approver_role_1)
    (approver_available approver_role_2)
    (approver_available approver_role_3)
    (investigator_available investigator_1)
    (sme_available sme_reviewer_1)
    (supporting_document_available supporting_document_1)
    (gl_has_discrepancy_record gl_segment_1 ledger_discrepancy_1)
    (subledger_has_discrepancy_record subledger_segment_1 counterparty_discrepancy_1)
    (resolution_packet_available resolution_packet_1)
    (workpaper_available workpaper_1)
    (workpaper_available workpaper_2)
    (processor_responsible_for_gl_segment finance_processor_1 gl_segment_1)
    (processor_responsible_for_gl_segment finance_processor_2 gl_segment_1)
    (processor_responsible_for_subledger_segment finance_processor_1 subledger_segment_1)
    (processor_responsible_for_subledger_segment finance_processor_2 subledger_segment_1)
    (processor_has_resolution_packet finance_processor_1 resolution_packet_1)
    (processor_has_resolution_packet finance_processor_2 resolution_packet_1)
    (processor_has_workpaper finance_processor_1 workpaper_1)
    (processor_has_workpaper finance_processor_2 workpaper_2)
    (control_checklist_available control_checklist_1)
    (control_checklist_available control_checklist_2)
    (signoff_available signoff_1)
    (signoff_available signoff_2)
    (audit_reference_available audit_reference_1)
    (adjustment_code_available adjustment_code_1)
    (policy_reference_available policy_reference_1)
    (processor_attached_policy_reference finance_processor_1 policy_reference_1)
    (processor_attached_policy_reference finance_processor_2 policy_reference_2)
    (escalation_reason_available escalation_reason_1)
  )
  (:goal
    (and
      (entity_closed_for_cutoff gl_segment_1)
      (entity_closed_for_cutoff subledger_segment_1)
      (entity_closed_for_cutoff finance_processor_1)
      (entity_closed_for_cutoff finance_processor_2)
    )
  )
)
