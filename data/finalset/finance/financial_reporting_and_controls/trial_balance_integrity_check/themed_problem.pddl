  (:objects ledger_recon_1 - ledger_reconciliation interco_recon_1 - intercompany_reconciliation tb_case_1 - trial_balance_check_case tb_case_2 - trial_balance_check_case reviewer_1 - reviewer reviewer_2 - reviewer reviewer_3 - reviewer supporting_document_1 - supporting_document_role approver_1 - approver adjustment_proposal_1 - adjustment_proposal checkpoint_1 - reconciliation_checkpoint variance_issue_1 - variance_issue reconciliation_package_1 - reconciliation_package supporting_schedule_1 - supporting_schedule supporting_schedule_2 - supporting_schedule compliance_attachment_1 - compliance_attachment_role compliance_attachment_2 - compliance_attachment_role quality_stamp_1 - quality_review_stamp_role quality_stamp_2 - quality_review_stamp_role exception_tag_1 - exception_tag_role policy_ref_1 - accounting_policy_reference_role control_rationale_doc_1 - control_rationale_document control_rationale_doc_2 - control_rationale_document audit_evidence_ref_1 - audit_evidence_reference_role)
  (:init
