    (interco_recon_variance_linked interco_recon_1 variance_issue_1)
    (reconciliation_package_open reconciliation_package_1)
    (supporting_schedule_available supporting_schedule_1)
    (supporting_schedule_available supporting_schedule_2)
    (case_has_ledger_recon tb_case_1 ledger_recon_1)
    (case_has_ledger_recon tb_case_2 ledger_recon_1)
    (case_has_interco_recon tb_case_1 interco_recon_1)
    (case_has_interco_recon tb_case_2 interco_recon_1)
    (case_includes_reconciliation_package tb_case_1 reconciliation_package_1)
    (case_includes_reconciliation_package tb_case_2 reconciliation_package_1)
    (case_has_supporting_schedule tb_case_1 supporting_schedule_1)
    (case_has_supporting_schedule tb_case_2 supporting_schedule_2)
    (compliance_attachment_role_available compliance_attachment_1)
    (compliance_attachment_role_available compliance_attachment_2)
    (quality_review_stamp_role_available quality_stamp_1)
    (quality_review_stamp_role_available quality_stamp_2)
    (exception_tag_role_available exception_tag_1)
    (accounting_policy_reference_role_available policy_ref_1)
    (control_rationale_available control_rationale_doc_1)
    (case_has_control_rationale tb_case_1 control_rationale_doc_1)
    (case_has_control_rationale tb_case_2 control_rationale_doc_2)
    (audit_evidence_reference_role_available audit_evidence_ref_1)
  )
  (:goal
    (and
      (tb_item_finalized ledger_recon_1)
      (tb_item_finalized interco_recon_1)
      (tb_item_finalized tb_case_1)
      (tb_item_finalized tb_case_2)
    )
  )
)
