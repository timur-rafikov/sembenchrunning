    (customs_broker_token_available customs_broker_token_secondary)
    (customs_broker_token_available customs_broker_token_backup)
    (classification_reference_available classification_reference_primary)
    (permit_document_available permit_document_primary)
    (supporting_document_available supporting_document_primary)
    (consignment_issue_link import_consignment_primary consignment_issue_primary)
    (line_item_issue_link import_line_item_primary line_item_issue_primary)
    (submission_packet_available submission_packet_primary)
    (attachment_available attachment_primary)
    (attachment_available attachment_secondary)
    (case_consignment_link processing_case_primary import_consignment_primary)
    (case_consignment_link processing_case_secondary import_consignment_primary)
    (case_line_item_link processing_case_primary import_line_item_primary)
    (case_line_item_link processing_case_secondary import_line_item_primary)
    (case_submission_packet_link processing_case_primary submission_packet_primary)
    (case_submission_packet_link processing_case_secondary submission_packet_primary)
    (case_attachment_link processing_case_primary attachment_primary)
    (case_attachment_link processing_case_secondary attachment_secondary)
    (condition_code_available condition_code_primary)
    (condition_code_available condition_code_secondary)
    (payment_receipt_available payment_receipt_primary)
    (payment_receipt_available payment_receipt_secondary)
    (valuation_basis_record_available valuation_basis_record_primary)
    (evidence_document_available evidence_document_primary)
    (registry_flag_available registry_flag_primary)
    (case_registry_flag_link processing_case_primary registry_flag_primary)
    (case_registry_flag_link processing_case_secondary registry_flag_secondary)
    (authority_verification_token_available authority_verification_token_primary)
  )
  (:goal
    (and
      (customs_clearance_completed import_consignment_primary)
      (customs_clearance_completed import_line_item_primary)
      (customs_clearance_completed processing_case_primary)
      (customs_clearance_completed processing_case_secondary)
    )
  )
)
