  (:objects import_consignment_primary - consignment import_line_item_primary - line_item processing_case_primary - processing_case processing_case_secondary - processing_case customs_broker_token_primary - customs_broker_token customs_broker_token_secondary - customs_broker_token customs_broker_token_backup - customs_broker_token classification_reference_primary - classification_reference permit_document_primary - permit_document supporting_document_primary - supporting_document consignment_issue_primary - consignment_valuation_issue line_item_issue_primary - line_item_valuation_issue submission_packet_primary - submission_packet attachment_primary - attachment attachment_secondary - attachment condition_code_primary - condition_code condition_code_secondary - condition_code payment_receipt_primary - payment_receipt payment_receipt_secondary - payment_receipt valuation_basis_record_primary - valuation_basis_record evidence_document_primary - evidence_document registry_flag_primary - registry_flag registry_flag_secondary - registry_flag authority_verification_token_primary - authority_verification_token)
