(define (problem customs_hold_response_problem)
  (:domain customs_hold_response_document_completion)
  (:objects origin_shipment_1 - origin_shipment destination_shipment_1 - destination_shipment declaration_record_1 - declaration_record declaration_record_2 - declaration_record broker_contact_1 - broker_contact broker_contact_2 - broker_contact broker_contact_3 - broker_contact document_template_packing_list - document_template regulatory_reviewer_1 - regulatory_reviewer supporting_evidence_invoice - supporting_evidence commodity_classification_hs_1001 - commodity_classification customs_jurisdiction_port_of_entry - customs_jurisdiction response_packet_draft_1 - response_packet attachment_descriptor_commercial_invoice - attachment_descriptor attachment_descriptor_certificate_of_origin - attachment_descriptor permit_type_general_import - permit_type permit_type_special_import - permit_type payment_authorisation_fee - payment_authorisation payment_authorisation_duty - payment_authorisation regulatory_reference_section_12 - regulatory_reference certification_of_origin - certification external_approval_chamber_of_commerce - external_approval external_approval_third_party - external_approval authority_clearance_local_authority - authority_clearance)
  (:init
    (broker_available broker_contact_1)
    (broker_available broker_contact_2)
    (broker_available broker_contact_3)
    (document_template_available document_template_packing_list)
    (regulatory_reviewer_available regulatory_reviewer_1)
    (supporting_evidence_available supporting_evidence_invoice)
    (origin_has_commodity_classification origin_shipment_1 commodity_classification_hs_1001)
    (destination_has_customs_jurisdiction destination_shipment_1 customs_jurisdiction_port_of_entry)
    (response_packet_draft response_packet_draft_1)
    (attachment_descriptor_available attachment_descriptor_commercial_invoice)
    (attachment_descriptor_available attachment_descriptor_certificate_of_origin)
    (declaration_links_origin declaration_record_1 origin_shipment_1)
    (declaration_links_origin declaration_record_2 origin_shipment_1)
    (declaration_links_destination declaration_record_1 destination_shipment_1)
    (declaration_links_destination declaration_record_2 destination_shipment_1)
    (declaration_in_response_packet declaration_record_1 response_packet_draft_1)
    (declaration_in_response_packet declaration_record_2 response_packet_draft_1)
    (declaration_requires_attachment_descriptor declaration_record_1 attachment_descriptor_commercial_invoice)
    (declaration_requires_attachment_descriptor declaration_record_2 attachment_descriptor_certificate_of_origin)
    (permit_type_available permit_type_general_import)
    (permit_type_available permit_type_special_import)
    (payment_authorisation_available payment_authorisation_fee)
    (payment_authorisation_available payment_authorisation_duty)
    (regulatory_reference_available regulatory_reference_section_12)
    (certification_available certification_of_origin)
    (external_approval_available external_approval_chamber_of_commerce)
    (declaration_has_external_approval declaration_record_1 external_approval_chamber_of_commerce)
    (declaration_has_external_approval declaration_record_2 external_approval_third_party)
    (authority_clearance_available authority_clearance_local_authority)
  )
  (:goal
    (and
      (cleared_for_release origin_shipment_1)
      (cleared_for_release destination_shipment_1)
      (cleared_for_release declaration_record_1)
      (cleared_for_release declaration_record_2)
    )
  )
)
