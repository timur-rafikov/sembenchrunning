(define (problem commercial_invoice_validation_problem)
  (:domain commercial_invoice_data_validation)
  (:objects export_case_1 - export_shipment_case import_case_1 - import_shipment_case entry_draft_1 - customs_entry_draft entry_draft_2 - customs_entry_draft broker_1 - broker broker_2 - broker broker_3 - broker classifier_service_1 - automated_classifier_service compliance_reviewer_1 - compliance_reviewer supporting_document_1 - supporting_document line_item_1 - line_item tariff_decision_1 - tariff_decision_record submission_package_1 - submission_package regulatory_certificate_1 - regulatory_certificate regulatory_certificate_2 - regulatory_certificate regulation_reference_1 - regulation_reference regulation_reference_2 - regulation_reference submission_channel_1 - submission_channel submission_channel_2 - submission_channel permit_1 - permit license_record_1 - license_record trade_agreement_reference_1 - trade_agreement_reference trade_agreement_reference_2 - trade_agreement_reference risk_rule_1 - risk_rule)
  (:init
    (broker_available broker_1)
    (broker_available broker_2)
    (broker_available broker_3)
    (classifier_available classifier_service_1)
    (reviewer_available compliance_reviewer_1)
    (supporting_document_available supporting_document_1)
    (export_case_has_line_item export_case_1 line_item_1)
    (import_case_has_tariff_decision import_case_1 tariff_decision_1)
    (submission_package_available submission_package_1)
    (regulatory_certificate_available regulatory_certificate_1)
    (regulatory_certificate_available regulatory_certificate_2)
    (entry_draft_for_export_case entry_draft_1 export_case_1)
    (entry_draft_for_export_case entry_draft_2 export_case_1)
    (entry_draft_for_import_case entry_draft_1 import_case_1)
    (entry_draft_for_import_case entry_draft_2 import_case_1)
    (entry_draft_linked_submission_package entry_draft_1 submission_package_1)
    (entry_draft_linked_submission_package entry_draft_2 submission_package_1)
    (entry_draft_has_certificate entry_draft_1 regulatory_certificate_1)
    (entry_draft_has_certificate entry_draft_2 regulatory_certificate_2)
    (regulation_reference_available regulation_reference_1)
    (regulation_reference_available regulation_reference_2)
    (submission_channel_available submission_channel_1)
    (submission_channel_available submission_channel_2)
    (permit_available permit_1)
    (license_record_available license_record_1)
    (trade_agreement_reference_available trade_agreement_reference_1)
    (entry_draft_has_trade_agreement_reference entry_draft_1 trade_agreement_reference_1)
    (entry_draft_has_trade_agreement_reference entry_draft_2 trade_agreement_reference_2)
    (risk_rule_available risk_rule_1)
  )
  (:goal
    (and
      (case_finalized export_case_1)
      (case_finalized import_case_1)
      (case_finalized entry_draft_1)
      (case_finalized entry_draft_2)
    )
  )
)
