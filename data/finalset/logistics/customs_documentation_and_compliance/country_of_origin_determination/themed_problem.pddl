(define (problem origin_determination_scenario)
  (:domain country_of_origin_determination_domain)
  (:objects producer_entity_1 - producer_entity assembler_entity_1 - assembler_or_importer_entity origin_case_1 - origin_assessment_case origin_case_2 - origin_assessment_case broker_service_1 - broker_service broker_service_2 - broker_service broker_service_3 - broker_service classification_ref_1 - classification_reference reviewer_1 - technical_reviewer evidence_doc_1 - evidence_document evidence_bundle_a_1 - supplier_evidence_bundle_a evidence_bundle_b_1 - supplier_evidence_bundle_b submission_package_1 - submission_package lineitem_spec_1 - product_line_item lineitem_spec_2 - product_line_item legal_ref_1 - legal_rule_reference legal_ref_2 - legal_rule_reference regulatory_permit_1 - regulatory_permit regulatory_permit_2 - regulatory_permit country_ref_1 - country_reference commercial_record_1 - commercial_record preference_program_1 - preference_program preference_program_2 - preference_program supplier_declaration_1 - supplier_declaration)
  (:init
    (broker_available broker_service_1)
    (broker_available broker_service_2)
    (broker_available broker_service_3)
    (classification_reference_available classification_ref_1)
    (reviewer_available reviewer_1)
    (evidence_document_available evidence_doc_1)
    (party_linked_evidence_bundle producer_entity_1 evidence_bundle_a_1)
    (party_linked_evidence_bundle_b assembler_entity_1 evidence_bundle_b_1)
    (submission_package_available submission_package_1)
    (product_lineitem_spec_available lineitem_spec_1)
    (product_lineitem_spec_available lineitem_spec_2)
    (case_linked_producer origin_case_1 producer_entity_1)
    (case_linked_producer origin_case_2 producer_entity_1)
    (case_linked_assembler origin_case_1 assembler_entity_1)
    (case_linked_assembler origin_case_2 assembler_entity_1)
    (case_associated_submission_package origin_case_1 submission_package_1)
    (case_associated_submission_package origin_case_2 submission_package_1)
    (case_attached_lineitem_spec origin_case_1 lineitem_spec_1)
    (case_attached_lineitem_spec origin_case_2 lineitem_spec_2)
    (legal_reference_available legal_ref_1)
    (legal_reference_available legal_ref_2)
    (regulatory_permit_available regulatory_permit_1)
    (regulatory_permit_available regulatory_permit_2)
    (country_reference_available country_ref_1)
    (commercial_record_available commercial_record_1)
    (preference_program_available preference_program_1)
    (case_attached_preference_program origin_case_1 preference_program_1)
    (case_attached_preference_program origin_case_2 preference_program_2)
    (supplier_declaration_available supplier_declaration_1)
  )
  (:goal
    (and
      (entity_origin_determination_finalized producer_entity_1)
      (entity_origin_determination_finalized assembler_entity_1)
      (entity_origin_determination_finalized origin_case_1)
      (entity_origin_determination_finalized origin_case_2)
    )
  )
)
