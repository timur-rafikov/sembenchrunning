(define (problem import_permit_validation_problem)
  (:domain import_permit_dependency_validation_domain)
  (:objects segment_a_1 - consignment_segment_a segment_b_1 - consignment_segment_b clearance_record_1 - clearance_record clearance_record_2 - clearance_record permit_slot_1 - permit_type permit_slot_2 - permit_type permit_slot_3 - permit_type tariff_classifier_system - tariff_classifier_role compliance_officer_1 - compliance_officer_role supporting_document_1 - supporting_document_artifact regulation_clause_a_1 - regulation_clause_a regulation_clause_b_1 - regulation_clause_b broker_package_1 - broker_submission_package certificate_1 - third_party_certificate_document certificate_2 - third_party_certificate_document policy_ref_1 - policy_reference policy_ref_2 - policy_reference supplementary_evidence_1 - supplementary_evidence supplementary_evidence_2 - supplementary_evidence dependency_token_1 - permit_dependency_token special_certificate_1 - special_certificate endorsement_1 - endorsement_document endorsement_2 - endorsement_document agency_authorization_1 - agency_authorization)
  (:init
    (permit_resource_available permit_slot_1)
    (permit_resource_available permit_slot_2)
    (permit_resource_available permit_slot_3)
    (classifier_available tariff_classifier_system)
    (officer_available compliance_officer_1)
    (document_available supporting_document_1)
    (segment_a_clause_link segment_a_1 regulation_clause_a_1)
    (segment_b_clause_link segment_b_1 regulation_clause_b_1)
    (broker_package_ready broker_package_1)
    (certificate_available certificate_1)
    (certificate_available certificate_2)
    (clearance_record_includes_segment_a clearance_record_1 segment_a_1)
    (clearance_record_includes_segment_a clearance_record_2 segment_a_1)
    (clearance_record_includes_segment_b clearance_record_1 segment_b_1)
    (clearance_record_includes_segment_b clearance_record_2 segment_b_1)
    (clearance_record_includes_submission clearance_record_1 broker_package_1)
    (clearance_record_includes_submission clearance_record_2 broker_package_1)
    (clearance_record_certificate_link clearance_record_1 certificate_1)
    (clearance_record_certificate_link clearance_record_2 certificate_2)
    (policy_reference_available policy_ref_1)
    (policy_reference_available policy_ref_2)
    (supplementary_evidence_available supplementary_evidence_1)
    (supplementary_evidence_available supplementary_evidence_2)
    (permit_dependency_token_available dependency_token_1)
    (special_certificate_available special_certificate_1)
    (endorsement_available endorsement_1)
    (clearance_record_endorsement_link clearance_record_1 endorsement_1)
    (clearance_record_endorsement_link clearance_record_2 endorsement_2)
    (agency_authorization_available agency_authorization_1)
  )
  (:goal
    (and
      (clearance_granted segment_a_1)
      (clearance_granted segment_b_1)
      (clearance_granted clearance_record_1)
      (clearance_granted clearance_record_2)
    )
  )
)
