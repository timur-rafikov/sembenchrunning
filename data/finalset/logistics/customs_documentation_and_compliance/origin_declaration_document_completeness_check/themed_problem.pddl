    (regulatory_reference_available regulatory_reference_1)
    (regulatory_reference_available regulatory_reference_2)
    (inspector_credential_available inspector_credential_1)
    (inspector_credential_available inspector_credential_2)
    (customs_office_available customs_office_1)
    (commercial_credential_available commercial_credential_1)
