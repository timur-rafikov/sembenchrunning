    (case_includes_import_leg compliance_case_1 import_leg_1)
    (case_includes_import_leg compliance_case_2 import_leg_1)
    (case_linked_to_submission compliance_case_1 declaration_submission_1)
    (case_linked_to_submission compliance_case_2 declaration_submission_1)
