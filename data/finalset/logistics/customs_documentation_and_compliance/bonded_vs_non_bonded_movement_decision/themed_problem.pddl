(define (problem bonded_vs_non_bonded_movement_case_problem)
  (:domain customs_bonded_vs_non_bonded_decision_domain)
  (:objects export_segment_1 - export_movement_segment import_segment_1 - import_movement_segment declarant_profile_alpha - declarant_profile declarant_profile_beta - declarant_profile representative_broker_a - representative_profile representative_broker_b - representative_profile representative_broker_c - representative_profile commercial_invoice_doc - trade_document regulatory_officer_1 - regulatory_officer supporting_evidence_cert_1 - supporting_evidence bond_profile_standard - bond_profile license_profile_special - license_profile clearance_submission_template - clearance_submission attachment_package_1 - attachment_package attachment_package_2 - attachment_package commodity_classification_hs1 - commodity_classification commodity_classification_hs2 - commodity_classification inspection_profile_standard - inspection_profile inspection_profile_additional - inspection_profile customs_office_port_a - customs_office financial_guarantee_1 - financial_guarantee power_of_attorney_doc_1 - power_of_attorney power_of_attorney_doc_2 - power_of_attorney special_clearance_permit_1 - special_clearance_permit)
  (:init
    (representative_available representative_broker_a)
    (representative_available representative_broker_b)
    (representative_available representative_broker_c)
    (trade_document_available commercial_invoice_doc)
    (regulatory_officer_available regulatory_officer_1)
    (supporting_evidence_available supporting_evidence_cert_1)
    (segment_bond_profile_link export_segment_1 bond_profile_standard)
    (segment_license_profile_link import_segment_1 license_profile_special)
    (clearance_submission_draft_available clearance_submission_template)
    (attachment_package_available attachment_package_1)
    (attachment_package_available attachment_package_2)
    (declarant_linked_export_segment declarant_profile_alpha export_segment_1)
    (declarant_linked_export_segment declarant_profile_beta export_segment_1)
    (declarant_linked_import_segment declarant_profile_alpha import_segment_1)
    (declarant_linked_import_segment declarant_profile_beta import_segment_1)
    (declarant_assigned_submission declarant_profile_alpha clearance_submission_template)
    (declarant_assigned_submission declarant_profile_beta clearance_submission_template)
    (declarant_has_attachment_package declarant_profile_alpha attachment_package_1)
    (declarant_has_attachment_package declarant_profile_beta attachment_package_2)
    (commodity_classification_available commodity_classification_hs1)
    (commodity_classification_available commodity_classification_hs2)
    (inspection_profile_available inspection_profile_standard)
    (inspection_profile_available inspection_profile_additional)
    (customs_office_available customs_office_port_a)
    (financial_guarantee_available financial_guarantee_1)
    (power_of_attorney_available power_of_attorney_doc_1)
    (declarant_has_power_of_attorney declarant_profile_alpha power_of_attorney_doc_1)
    (declarant_has_power_of_attorney declarant_profile_beta power_of_attorney_doc_2)
    (special_clearance_permit_available special_clearance_permit_1)
  )
  (:goal
    (and
      (entity_ready_for_clearance export_segment_1)
      (entity_ready_for_clearance import_segment_1)
      (entity_ready_for_clearance declarant_profile_alpha)
      (entity_ready_for_clearance declarant_profile_beta)
    )
  )
)
