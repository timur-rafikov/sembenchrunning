(define (problem customs_document_pack_preparation_problem)
  (:domain customs_document_pack_preparation_domain)
  (:objects exporter_1 - exporter importer_1 - export_segment_importer pack_candidate_a - document_pack pack_candidate_b - document_pack broker_alpha - customs_broker broker_beta - customs_broker broker_gamma - customs_broker tariff_rule_1 - regulatory_source compliance_reviewer_1 - compliance_reviewer supporting_doc_invoice - supporting_document hs_class_0101 - classification_record permit_type_1 - permit_record submission_slot_1 - submission_record attachment_invoice_copy - attachment_artifact attachment_certificate_copy - attachment_artifact insurance_policy_1 - insurance_policy insurance_policy_2 - insurance_policy payment_evidence_1 - payment_evidence payment_evidence_2 - payment_evidence permit_application_1 - permit_application certificate_of_origin_1 - certificate_document special_authorization_1 - special_authorization special_authorization_2 - special_authorization regulatory_approval_1 - regulatory_approval)
  (:init
    (broker_available broker_alpha)
    (broker_available broker_beta)
    (broker_available broker_gamma)
    (regulatory_source_available tariff_rule_1)
    (reviewer_available compliance_reviewer_1)
    (supporting_document_available supporting_doc_invoice)
    (exporter_classification_assigned exporter_1 hs_class_0101)
    (importer_permit_requirement importer_1 permit_type_1)
    (submission_slot_available submission_slot_1)
    (attachment_available attachment_invoice_copy)
    (attachment_available attachment_certificate_copy)
    (pack_linked_exporter pack_candidate_a exporter_1)
    (pack_linked_exporter pack_candidate_b exporter_1)
    (pack_linked_importer pack_candidate_a importer_1)
    (pack_linked_importer pack_candidate_b importer_1)
    (pack_linked_submission pack_candidate_a submission_slot_1)
    (pack_linked_submission pack_candidate_b submission_slot_1)
    (pack_has_attachment pack_candidate_a attachment_invoice_copy)
    (pack_has_attachment pack_candidate_b attachment_certificate_copy)
    (insurance_policy_available insurance_policy_1)
    (insurance_policy_available insurance_policy_2)
    (payment_evidence_available payment_evidence_1)
    (payment_evidence_available payment_evidence_2)
    (permit_application_available permit_application_1)
    (certificate_available certificate_of_origin_1)
    (special_authorization_available special_authorization_1)
    (pack_has_special_authorization pack_candidate_a special_authorization_1)
    (pack_has_special_authorization pack_candidate_b special_authorization_2)
    (regulatory_approval_available regulatory_approval_1)
  )
  (:goal
    (and
      (ready_for_clearance exporter_1)
      (ready_for_clearance importer_1)
      (ready_for_clearance pack_candidate_a)
      (ready_for_clearance pack_candidate_b)
    )
  )
)
