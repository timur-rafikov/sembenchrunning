    (pallet_id_available pallet_id_101)
    (storage_unit_in_source_zone storage_unit_1 source_zone_1)
    (storage_unit_in_source_zone storage_unit_2 source_zone_1)
    (storage_unit_in_destination_zone storage_unit_1 destination_zone_1)
    (storage_unit_in_destination_zone storage_unit_2 destination_zone_1)
    (storage_unit_linked_to_carrier storage_unit_1 carrier_pallet_1)
    (storage_unit_linked_to_carrier storage_unit_2 carrier_pallet_1)
    (storage_unit_has_pallet_id storage_unit_1 pallet_id_100)
    (storage_unit_has_pallet_id storage_unit_2 pallet_id_101)
    (storage_policy_available storage_policy_cold)
    (storage_policy_available storage_policy_bulk)
    (load_profile_available load_profile_standard)
    (load_profile_available load_profile_fragile)
    (rebalance_batch_available rebalance_batch_1)
    (handling_constraint_available handling_constraint_1)
    (audit_token_available audit_token_1)
    (audit_token_associated_with_storage_unit storage_unit_1 audit_token_1)
    (audit_token_associated_with_storage_unit storage_unit_2 audit_token_2)
    (maintenance_tag_available maintenance_tag_quarantine)
