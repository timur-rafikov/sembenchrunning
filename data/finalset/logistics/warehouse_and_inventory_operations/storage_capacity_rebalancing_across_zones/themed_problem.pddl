(define (problem storage_capacity_rebalancing_problem)
  (:domain warehouse_storage_rebalancing)
  (:objects source_zone_1 - source_zone destination_zone_1 - destination_zone storage_unit_1 - storage_unit storage_unit_2 - storage_unit move_request_1 - move_request move_request_2 - move_request move_request_3 - move_request sku_001 - sku operator_1 - operator inventory_unit_pallet_a - inventory_unit source_slot_a - source_slot destination_slot_a - destination_slot carrier_pallet_1 - carrier pallet_id_100 - pallet_identifier pallet_id_101 - pallet_identifier storage_policy_cold - storage_policy storage_policy_bulk - storage_policy load_profile_standard - load_profile load_profile_fragile - load_profile rebalance_batch_1 - rebalance_batch handling_constraint_1 - handling_constraint audit_token_1 - audit_token audit_token_2 - audit_token maintenance_tag_quarantine - maintenance_tag)
  (:init
    (move_request_available move_request_1)
