(define (problem slotting_reconfiguration_velocity_case)
  (:domain warehouse_slotting_reconfiguration)
  (:objects donor_slot_1 - donor_slot recipient_slot_1 - recipient_slot storage_slot_001 - slot_record storage_slot_002 - slot_record handling_resource_1 - handling_resource handling_resource_2 - handling_resource handling_resource_3 - handling_resource classification_station_1 - classification_station operator_1 - operator transfer_tote_1 - transfer_tote source_velocity_band_fast - source_velocity_band target_velocity_band_fast - target_velocity_band move_order_1 - move_order staging_tote_1 - staging_tote staging_tote_2 - staging_tote slot_attribute_fixture_a - slot_attribute slot_attribute_fixture_b - slot_attribute label_tag_1 - label_tag label_tag_2 - label_tag wms_record_1 - wms_record slot_capacity_profile_1 - slot_capacity_profile operational_constraint_1 - operational_constraint operational_constraint_2 - operational_constraint approval_token_1 - approval_token)
  (:init
