    (handling_resource_available handling_resource_2)
    (handling_resource_available handling_resource_3)
    (classification_station_available classification_station_1)
    (operator_available operator_1)
    (transfer_tote_available transfer_tote_1)
    (slot_current_velocity_band donor_slot_1 source_velocity_band_fast)
    (slot_target_velocity_band recipient_slot_1 target_velocity_band_fast)
    (move_order_pending move_order_1)
    (staging_tote_available staging_tote_1)
    (staging_tote_available staging_tote_2)
    (slot_record_associated_with_donor_slot storage_slot_001 donor_slot_1)
    (slot_record_associated_with_donor_slot storage_slot_002 donor_slot_1)
    (slot_record_associated_with_recipient_slot storage_slot_001 recipient_slot_1)
    (slot_record_associated_with_recipient_slot storage_slot_002 recipient_slot_1)
    (slot_record_linked_move_order storage_slot_001 move_order_1)
    (slot_record_linked_move_order storage_slot_002 move_order_1)
    (slot_record_has_staging_tote storage_slot_001 staging_tote_1)
    (slot_record_has_staging_tote storage_slot_002 staging_tote_2)
    (slot_attribute_available slot_attribute_fixture_a)
    (slot_attribute_available slot_attribute_fixture_b)
    (label_tag_available label_tag_1)
    (label_tag_available label_tag_2)
    (wms_record_available wms_record_1)
    (slot_capacity_profile_available slot_capacity_profile_1)
    (operational_constraint_present operational_constraint_1)
    (slot_has_constraint storage_slot_001 operational_constraint_1)
    (slot_has_constraint storage_slot_002 operational_constraint_2)
    (approval_token_available approval_token_1)
  )
  (:goal
    (and
      (reconfiguration_committed donor_slot_1)
      (reconfiguration_committed recipient_slot_1)
      (reconfiguration_committed storage_slot_001)
      (reconfiguration_committed storage_slot_002)
    )
  )
