    (lot_available inventory_lot_2)
    (reconciliation_record_assigned_source_location reconciliation_operator_1 source_location_1)
    (reconciliation_record_assigned_source_location reconciliation_operator_2 source_location_1)
    (reconciliation_record_assigned_target_location reconciliation_operator_1 target_location_1)
    (reconciliation_record_assigned_target_location reconciliation_operator_2 target_location_1)
    (reconciliation_record_assigned_tote reconciliation_operator_1 transfer_tote_1)
    (reconciliation_record_assigned_tote reconciliation_operator_2 transfer_tote_1)
    (reconciliation_record_has_lot reconciliation_operator_1 inventory_lot_1)
    (reconciliation_record_has_lot reconciliation_operator_2 inventory_lot_2)
    (label_type_available label_type_a)
    (label_type_available label_type_b)
    (checklist_available inspection_checklist_a)
    (checklist_available inspection_checklist_b)
    (adjustment_reason_available adjustment_reason_1)
    (inspection_device_available inspection_device_1)
    (approver_available approver_1)
    (reconciliation_record_assigned_approver reconciliation_operator_1 approver_1)
    (reconciliation_record_assigned_approver reconciliation_operator_2 approver_2)
    (authorization_token_available authorization_token_1)
