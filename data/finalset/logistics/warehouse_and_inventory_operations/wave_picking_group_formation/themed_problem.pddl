(define (problem wave_picking_group_formation_problem)
  (:domain wave_picking_group_formation_domain)
  (:objects picker_role_a_1 - picker_role_a picker_role_b_1 - picker_role_b wave_group_unit_1 - wave_group_unit wave_group_unit_2 - wave_group_unit picker_resource_1 - picker_resource picker_resource_2 - picker_resource picker_resource_3 - picker_resource order_1 - order workstation_1 - workstation tote_1 - tote_container pick_zone_1 - pick_zone pack_zone_1 - pack_zone picking_cart_1 - picking_cart pick_batch_1 - pick_batch pick_batch_2 - pick_batch equipment_profile_1 - equipment_profile equipment_profile_2 - equipment_profile station_token_1 - station_token station_token_2 - station_token priority_token_1 - priority_token configuration_profile_1 - configuration_profile supervisor_token_1 - supervisor_token supervisor_token_2 - supervisor_token shift_slot_1 - shift_slot)
  (:init
    (picker_available picker_resource_1)
    (picker_available picker_resource_2)
    (picker_available picker_resource_3)
    (order_available order_1)
    (workstation_available workstation_1)
    (tote_available tote_1)
    (picker_a_assigned_pick_zone picker_role_a_1 pick_zone_1)
    (picker_b_assigned_pack_zone picker_role_b_1 pack_zone_1)
    (cart_available picking_cart_1)
    (pick_batch_available pick_batch_1)
    (pick_batch_available pick_batch_2)
    (group_has_picker_a wave_group_unit_1 picker_role_a_1)
    (group_has_picker_a wave_group_unit_2 picker_role_a_1)
    (group_has_picker_b wave_group_unit_1 picker_role_b_1)
    (group_has_picker_b wave_group_unit_2 picker_role_b_1)
    (group_assigned_cart wave_group_unit_1 picking_cart_1)
    (group_assigned_cart wave_group_unit_2 picking_cart_1)
    (group_has_pick_batch wave_group_unit_1 pick_batch_1)
    (group_has_pick_batch wave_group_unit_2 pick_batch_2)
    (equipment_profile_available equipment_profile_1)
    (equipment_profile_available equipment_profile_2)
    (station_token_available station_token_1)
    (station_token_available station_token_2)
    (priority_token_available priority_token_1)
    (configuration_profile_available configuration_profile_1)
    (supervisor_token_available supervisor_token_1)
    (group_bound_supervisor wave_group_unit_1 supervisor_token_1)
    (group_bound_supervisor wave_group_unit_2 supervisor_token_2)
    (shift_slot_available shift_slot_1)
  )
  (:goal
    (and
      (released_for_execution picker_role_a_1)
      (released_for_execution picker_role_b_1)
      (released_for_execution wave_group_unit_1)
      (released_for_execution wave_group_unit_2)
    )
  )
)
