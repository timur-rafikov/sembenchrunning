(define (problem inventory_allocation_case)
  (:domain inventory_allocation_by_storage_condition_domain)
  (:objects bulk_location_1 - bulk_storage_location pick_face_location_1 - pick_face_location storage_slot_1 - storage_slot_record storage_slot_2 - storage_slot_record forklift_1 - handling_equipment forklift_2 - handling_equipment pallet_jack_1 - handling_equipment putaway_task_1 - putaway_task operator_1 - operator sku_1 - product_sku bulk_profile_cold - bulk_condition_profile pickface_profile_ambient - pick_face_condition_profile pallet_1 - pallet_container shelf_template_1 - shelf_bin_template shelf_template_2 - shelf_bin_template storage_constraint_stackable - storage_constraint storage_constraint_segregation - storage_constraint access_constraint_forklift_required - access_constraint access_constraint_restricted - access_constraint condition_requirement_refrigerated - condition_requirement inspection_resource_qc - inspection_resource special_handling_label_fragile - special_handling_label special_handling_label_hazardous - special_handling_label regulatory_document_sds - regulatory_document)
  (:init
    (equipment_available forklift_1)
    (equipment_available forklift_2)
    (equipment_available pallet_jack_1)
    (putaway_task_available putaway_task_1)
    (operator_available operator_1)
    (sku_available sku_1)
    (bulk_location_condition_profile bulk_location_1 bulk_profile_cold)
    (pick_face_location_condition_profile pick_face_location_1 pickface_profile_ambient)
    (container_available pallet_1)
    (shelf_template_available shelf_template_1)
    (shelf_template_available shelf_template_2)
    (slot_in_bulk_location storage_slot_1 bulk_location_1)
    (slot_in_bulk_location storage_slot_2 bulk_location_1)
    (slot_in_pickface_location storage_slot_1 pick_face_location_1)
    (slot_in_pickface_location storage_slot_2 pick_face_location_1)
    (slot_contains_container storage_slot_1 pallet_1)
    (slot_contains_container storage_slot_2 pallet_1)
    (slot_assigned_template storage_slot_1 shelf_template_1)
    (slot_assigned_template storage_slot_2 shelf_template_2)
    (storage_constraint_available storage_constraint_stackable)
    (storage_constraint_available storage_constraint_segregation)
    (access_constraint_available access_constraint_forklift_required)
    (access_constraint_available access_constraint_restricted)
    (condition_requirement_available condition_requirement_refrigerated)
    (inspection_resource_available inspection_resource_qc)
    (label_available special_handling_label_fragile)
    (slot_assigned_label storage_slot_1 special_handling_label_fragile)
    (slot_assigned_label storage_slot_2 special_handling_label_hazardous)
    (regulatory_document_available regulatory_document_sds)
  )
  (:goal
    (and
      (allocated bulk_location_1)
      (allocated pick_face_location_1)
      (allocated storage_slot_1)
      (allocated storage_slot_2)
    )
  )
)
