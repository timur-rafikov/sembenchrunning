(define (problem pick_face_replenishment_problem)
  (:domain warehouse_pick_face_replenishment)
  (:objects bulk_slot_1 - bulk_slot pick_slot_1 - pick_slot pick_face_1 - pick_face pick_face_2 - pick_face replenishment_source_1 - replenishment_source replenishment_source_2 - replenishment_source replenishment_source_3 - replenishment_source sku_1 - sku operator_1 - operator replenish_tote_1 - replenish_tote bulk_staging_point_1 - bulk_staging_point pick_staging_point_1 - pick_staging_point replenishment_task_template_1 - replenishment_task inventory_unit_1 - inventory_unit inventory_unit_2 - inventory_unit label_template_1 - location_label_template label_template_2 - location_label_template replenishment_cart_1 - replenishment_cart replenishment_cart_2 - replenishment_cart inventory_record_1 - inventory_record consumable_kit_1 - consumable_kit inspection_tool_1 - inspection_tool inspection_tool_2 - inspection_tool approval_tag_1 - supervisor_approval_tag)
  (:init
    (replenishment_source_available replenishment_source_1)
    (replenishment_source_available replenishment_source_2)
    (replenishment_source_available replenishment_source_3)
    (sku_available sku_1)
    (operator_available operator_1)
    (replenish_tote_available replenish_tote_1)
    (bulk_slot_assigned_staging_point bulk_slot_1 bulk_staging_point_1)
    (pick_slot_assigned_staging_point pick_slot_1 pick_staging_point_1)
    (task_available replenishment_task_template_1)
    (inventory_unit_available inventory_unit_1)
    (inventory_unit_available inventory_unit_2)
    (pick_face_supplied_by_bulk_slot pick_face_1 bulk_slot_1)
    (pick_face_supplied_by_bulk_slot pick_face_2 bulk_slot_1)
    (pick_face_contains_pick_slot pick_face_1 pick_slot_1)
    (pick_face_contains_pick_slot pick_face_2 pick_slot_1)
    (pick_face_assigned_to_task pick_face_1 replenishment_task_template_1)
    (pick_face_assigned_to_task pick_face_2 replenishment_task_template_1)
    (pick_face_assigned_inventory_unit pick_face_1 inventory_unit_1)
    (pick_face_assigned_inventory_unit pick_face_2 inventory_unit_2)
    (label_template_available label_template_1)
    (label_template_available label_template_2)
    (replenishment_cart_available replenishment_cart_1)
    (replenishment_cart_available replenishment_cart_2)
    (inventory_record_available inventory_record_1)
    (consumable_kit_available consumable_kit_1)
    (inspection_tool_available inspection_tool_1)
    (pick_face_assigned_inspection_tool pick_face_1 inspection_tool_1)
    (pick_face_assigned_inspection_tool pick_face_2 inspection_tool_2)
    (approval_tag_available approval_tag_1)
  )
  (:goal
    (and
      (replenishment_completed bulk_slot_1)
      (replenishment_completed pick_slot_1)
      (replenishment_completed pick_face_1)
      (replenishment_completed pick_face_2)
    )
  )
)
