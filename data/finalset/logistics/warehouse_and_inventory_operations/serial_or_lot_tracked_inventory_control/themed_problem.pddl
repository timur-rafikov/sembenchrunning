(define (problem serial_lot_inventory_case)
  (:domain warehouse_serial_lot_inventory_control)
  (:objects reserve_location_obj - reserve_location pick_location_obj - pick_location work_task_obj_1 - work_task work_task_obj_2 - work_task inbound_shipment_unit_obj_1 - inbound_shipment_unit inbound_shipment_unit_obj_2 - inbound_shipment_unit inbound_shipment_unit_obj_3 - inbound_shipment_unit product_sku_obj - product_sku equipment_unit_obj - equipment_unit consumable_packaging_obj - consumable_or_packaging location_equipment_binding_obj - location_equipment_binding location_picker_binding_obj - location_picker_binding handling_unit_obj - handling_unit container_slot_obj_1 - container_slot container_slot_obj_2 - container_slot label_template_obj_1 - label_template label_template_obj_2 - label_template work_batch_obj_1 - work_batch work_batch_obj_2 - work_batch lot_or_serial_id_obj - lot_or_serial_id special_instruction_tag_obj - special_instruction_tag document_certificate_obj_1 - document_certificate document_certificate_obj_2 - document_certificate traceability_token_obj - traceability_token)
  (:init
    (inbound_shipment_unit_available inbound_shipment_unit_obj_1)
    (inbound_shipment_unit_available inbound_shipment_unit_obj_2)
    (inbound_shipment_unit_available inbound_shipment_unit_obj_3)
    (sku_available product_sku_obj)
    (equipment_available equipment_unit_obj)
    (consumable_available consumable_packaging_obj)
    (location_has_equipment_binding reserve_location_obj location_equipment_binding_obj)
    (pick_location_picker_binding pick_location_obj location_picker_binding_obj)
    (handling_unit_available_for_assembly handling_unit_obj)
    (container_slot_available container_slot_obj_1)
    (container_slot_available container_slot_obj_2)
    (task_source_location work_task_obj_1 reserve_location_obj)
    (task_source_location work_task_obj_2 reserve_location_obj)
    (task_destination_location work_task_obj_1 pick_location_obj)
    (task_destination_location work_task_obj_2 pick_location_obj)
    (task_assigned_handling_unit work_task_obj_1 handling_unit_obj)
    (task_assigned_handling_unit work_task_obj_2 handling_unit_obj)
    (task_assigned_container_slot work_task_obj_1 container_slot_obj_1)
    (task_assigned_container_slot work_task_obj_2 container_slot_obj_2)
    (label_template_available label_template_obj_1)
    (label_template_available label_template_obj_2)
    (work_batch_available work_batch_obj_1)
    (work_batch_available work_batch_obj_2)
    (lot_or_serial_id_available lot_or_serial_id_obj)
    (special_instruction_tag_available special_instruction_tag_obj)
    (document_available document_certificate_obj_1)
    (task_document_assigned work_task_obj_1 document_certificate_obj_1)
    (task_document_assigned work_task_obj_2 document_certificate_obj_2)
    (traceability_token_available traceability_token_obj)
  )
  (:goal
    (and
      (finalized reserve_location_obj)
      (finalized pick_location_obj)
      (finalized work_task_obj_1)
      (finalized work_task_obj_2)
    )
  )
)
