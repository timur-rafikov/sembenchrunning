(define (problem inbound_receipt_slot_assignment_problem)
  (:domain warehouse_inbound_receipt_slot_assignment)
  (:objects forklift_team_alpha - forklift_team pallet_jack_team_alpha - pallet_jack_team putaway_job_alpha - putaway_job putaway_job_beta - putaway_job dock_1 - dock_door dock_2 - dock_door dock_3 - dock_door staging_pallet_1 - staging_pallet operator_1 - operator tote_1 - tote_or_cart forklift_path_1 - forklift_path jack_path_1 - jack_path storage_location_1 - storage_location pallet_tag_1 - pallet_id_tag pallet_tag_2 - pallet_id_tag label_batch_1 - label_batch label_batch_2 - label_batch pack_material_1 - pack_material pack_material_2 - pack_material inventory_record_1 - inventory_record inspection_tool_1 - inspection_tool authorization_badge_1 - authorization_badge authorization_badge_2 - authorization_badge qc_station_1 - qc_station)
  (:init
    (dock_available dock_1)
    (dock_available dock_2)
    (dock_available dock_3)
    (staging_pallet_available staging_pallet_1)
    (operator_available operator_1)
    (tote_available tote_1)
    (forklift_team_assigned_path forklift_team_alpha forklift_path_1)
    (jack_team_assigned_path pallet_jack_team_alpha jack_path_1)
    (storage_location_available storage_location_1)
    (pallet_tag_available pallet_tag_1)
    (pallet_tag_available pallet_tag_2)
    (putaway_job_assigned_forklift_team putaway_job_alpha forklift_team_alpha)
    (putaway_job_assigned_forklift_team putaway_job_beta forklift_team_alpha)
    (putaway_job_assigned_jack_team putaway_job_alpha pallet_jack_team_alpha)
    (putaway_job_assigned_jack_team putaway_job_beta pallet_jack_team_alpha)
    (putaway_job_target_location putaway_job_alpha storage_location_1)
    (putaway_job_target_location putaway_job_beta storage_location_1)
    (putaway_job_assigned_pallet_tag putaway_job_alpha pallet_tag_1)
    (putaway_job_assigned_pallet_tag putaway_job_beta pallet_tag_2)
    (label_batch_available label_batch_1)
    (label_batch_available label_batch_2)
    (pack_material_available pack_material_1)
    (pack_material_available pack_material_2)
    (inventory_record_available inventory_record_1)
    (inspection_tool_available inspection_tool_1)
    (auth_badge_available authorization_badge_1)
    (authorization_badge_assigned_to_job putaway_job_alpha authorization_badge_1)
    (authorization_badge_assigned_to_job putaway_job_beta authorization_badge_2)
    (qc_station_available qc_station_1)
  )
  (:goal
    (and
      (work_completed forklift_team_alpha)
      (work_completed pallet_jack_team_alpha)
      (work_completed putaway_job_alpha)
      (work_completed putaway_job_beta)
    )
  )
)
