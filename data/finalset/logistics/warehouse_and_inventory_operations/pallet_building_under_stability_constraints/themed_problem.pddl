(define (problem pallet_building_scenario)
  (:domain pallet_assembly)
  (:objects picker_work_unit_1 - picker_work_unit stager_work_unit_1 - stager_work_unit assembly_station_a - assembly_station assembly_station_b - assembly_station shrink_wrap_roll_1 - packaging_resource shrink_wrap_roll_2 - packaging_resource corner_protector_1 - packaging_resource sku_1 - sku operator_1 - operator case_unit_1 - case_unit layer_profile_a - layer_stability_profile pallet_profile_a - pallet_stability_profile pallet_unit_1 - pallet_unit layer_template_a - layer_template layer_template_b - layer_template packaging_config_a - packaging_configuration packaging_config_b - packaging_configuration forklift_1 - handling_equipment pallet_jack_1 - handling_equipment identity_tag_1 - identity_tag stabilizer_strap_roll_1 - stabilizer_material inspection_tool_1 - inspection_tool inspection_tool_2 - inspection_tool inspection_stamp_1 - inspection_stamp)
  (:init
    (packaging_resource_available shrink_wrap_roll_1)
    (packaging_resource_available shrink_wrap_roll_2)
    (packaging_resource_available corner_protector_1)
    (sku_available sku_1)
    (operator_available operator_1)
    (case_unit_available case_unit_1)
    (work_unit_assigned_layer_profile picker_work_unit_1 layer_profile_a)
    (stager_assigned_pallet_profile stager_work_unit_1 pallet_profile_a)
    (pallet_unit_available pallet_unit_1)
    (layer_template_available layer_template_a)
    (layer_template_available layer_template_b)
    (assembly_station_assigned_picker_work_unit assembly_station_a picker_work_unit_1)
    (assembly_station_assigned_picker_work_unit assembly_station_b picker_work_unit_1)
    (assembly_station_assigned_stager_work_unit assembly_station_a stager_work_unit_1)
    (assembly_station_assigned_stager_work_unit assembly_station_b stager_work_unit_1)
    (assembly_station_assigned_pallet_unit assembly_station_a pallet_unit_1)
    (assembly_station_assigned_pallet_unit assembly_station_b pallet_unit_1)
    (assembly_station_has_layer_template assembly_station_a layer_template_a)
    (assembly_station_has_layer_template assembly_station_b layer_template_b)
    (packaging_configuration_available packaging_config_a)
    (packaging_configuration_available packaging_config_b)
    (handling_equipment_available forklift_1)
    (handling_equipment_available pallet_jack_1)
    (identity_tag_available identity_tag_1)
    (stabilizer_material_available stabilizer_strap_roll_1)
    (inspection_tool_available inspection_tool_1)
    (assembly_station_assigned_inspection_tool assembly_station_a inspection_tool_1)
    (assembly_station_assigned_inspection_tool assembly_station_b inspection_tool_2)
    (inspection_stamp_available inspection_stamp_1)
  )
  (:goal
    (and
      (handover_complete picker_work_unit_1)
      (handover_complete stager_work_unit_1)
      (handover_complete assembly_station_a)
      (handover_complete assembly_station_b)
    )
  )
)
