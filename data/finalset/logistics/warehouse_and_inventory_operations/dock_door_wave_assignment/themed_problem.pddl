(define (problem dock_door_wave_assignment_instance)
  (:domain dock_door_wave_assignment)
  (:objects receiving_area_1 - receiving_area picking_area_1 - picking_area load_task_1 - load_task load_task_2 - load_task dock_door_1 - dock_door dock_door_2 - dock_door dock_door_3 - dock_door inbound_load_1 - inbound_load handler_1 - handler pick_unit_1 - pick_unit inbound_staging_1 - inbound_staging_area outbound_staging_1 - outbound_staging_area load_container_1 - load_container inventory_slot_a - inventory_slot inventory_slot_b - inventory_slot equipment_unit_1 - equipment_unit equipment_unit_2 - equipment_unit packaging_spec_1 - packaging_spec packaging_spec_2 - packaging_spec pick_face_1 - pick_face storage_profile_1 - storage_profile routing_instruction_1 - routing_instruction routing_instruction_2 - routing_instruction inventory_tag_1 - inventory_tag)
  (:init
    (dock_door_available dock_door_1)
    (dock_door_available dock_door_2)
    (dock_door_available dock_door_3)
    (inbound_load_available inbound_load_1)
    (handler_available handler_1)
    (pick_unit_available pick_unit_1)
    (receiving_area_linked_inbound_staging receiving_area_1 inbound_staging_1)
    (picking_area_linked_outbound_staging picking_area_1 outbound_staging_1)
    (load_container_available load_container_1)
    (inventory_slot_available inventory_slot_a)
    (inventory_slot_available inventory_slot_b)
    (load_task_assigned_receiving_area load_task_1 receiving_area_1)
    (load_task_assigned_receiving_area load_task_2 receiving_area_1)
    (load_task_assigned_picking_area load_task_1 picking_area_1)
    (load_task_assigned_picking_area load_task_2 picking_area_1)
    (load_task_assigned_container load_task_1 load_container_1)
    (load_task_assigned_container load_task_2 load_container_1)
    (load_task_assigned_inventory_slot load_task_1 inventory_slot_a)
    (load_task_assigned_inventory_slot load_task_2 inventory_slot_b)
    (equipment_unit_available equipment_unit_1)
    (equipment_unit_available equipment_unit_2)
    (packaging_spec_available packaging_spec_1)
    (packaging_spec_available packaging_spec_2)
    (pick_face_available pick_face_1)
    (storage_profile_available storage_profile_1)
    (routing_instruction_available routing_instruction_1)
    (load_task_assigned_routing_instruction load_task_1 routing_instruction_1)
    (load_task_assigned_routing_instruction load_task_2 routing_instruction_2)
    (inventory_tag_available inventory_tag_1)
  )
  (:goal
    (and
      (assignment_finalized receiving_area_1)
      (assignment_finalized picking_area_1)
      (assignment_finalized load_task_1)
      (assignment_finalized load_task_2)
    )
  )
)
