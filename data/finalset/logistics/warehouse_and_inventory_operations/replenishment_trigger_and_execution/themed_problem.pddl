(define (problem replenishment_trigger_execution_problem)
  (:domain warehouse_replenishment_domain)
  (:objects storage_bin_a1 - storage_location pick_face_1 - pick_location job_rj1 - replenishment_job job_rj2 - replenishment_job staging_slot_left - staging_slot staging_slot_center - staging_slot staging_slot_right - staging_slot sku_acme_100 - sku operator_alice - operator case_box_100 - case_unit source_slot_s1 - source_slot destination_slot_d1 - destination_slot tote_t1 - transfer_tote case_label_100 - case_label case_label_101 - case_label storage_profile_fast_moving - storage_profile storage_profile_bulk - storage_profile amr_1 - material_handling_vehicle amr_2 - material_handling_vehicle inventory_doc_manifest_1 - inventory_document lift_truck_1 - lift_equipment order_batch_1 - order_batch order_batch_2 - order_batch quality_check_q1 - quality_check)
  (:init
    (staging_slot_available staging_slot_left)
    (staging_slot_available staging_slot_center)
    (staging_slot_available staging_slot_right)
    (sku_available sku_acme_100)
    (operator_available operator_alice)
    (case_available case_box_100)
    (storage_has_source_slot storage_bin_a1 source_slot_s1)
    (pick_location_destination_link pick_face_1 destination_slot_d1)
    (tote_available tote_t1)
    (label_available case_label_100)
    (label_available case_label_101)
    (job_source_location job_rj1 storage_bin_a1)
    (job_source_location job_rj2 storage_bin_a1)
    (job_pick_location job_rj1 pick_face_1)
    (job_pick_location job_rj2 pick_face_1)
    (job_tote job_rj1 tote_t1)
    (job_tote job_rj2 tote_t1)
    (job_label_assigned job_rj1 case_label_100)
    (job_label_assigned job_rj2 case_label_101)
    (storage_profile_available storage_profile_fast_moving)
    (storage_profile_available storage_profile_bulk)
    (vehicle_available amr_1)
    (vehicle_available amr_2)
    (inventory_document_available inventory_doc_manifest_1)
    (lift_equipment_available lift_truck_1)
    (order_batch_available order_batch_1)
    (job_order_link job_rj1 order_batch_1)
    (job_order_link job_rj2 order_batch_2)
    (quality_check_available quality_check_q1)
  )
  (:goal
    (and
      (reconciled storage_bin_a1)
      (reconciled pick_face_1)
      (reconciled job_rj1)
      (reconciled job_rj2)
    )
  )
)
