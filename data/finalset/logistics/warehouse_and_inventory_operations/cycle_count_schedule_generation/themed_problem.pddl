(define (problem warehouse_cycle_count_instance)
  (:domain cycle_count_schedule_generation)
  (:objects count_loc_1 - count_location alt_count_loc_1 - alternate_count_location schedule_entry_1 - schedule_entry schedule_entry_2 - schedule_entry operator_1 - operator operator_2 - operator operator_3 - operator time_slot_1 - operator_shift verifier_1 - verifier scanner_1 - count_device zone_a - zone subzone_a1 - subzone count_batch_1 - count_batch sku_1001 - inventory_item sku_1002 - inventory_item location_label_a - location_label location_label_b - location_label protocol_blind - count_protocol protocol_spot_check - count_protocol audit_token_1 - audit_token quality_check_visual - quality_check_type approver_role_lead - approver_role approver_role_supervisor - approver_role approval_token_1 - approval_token)
  (:init
    (operator_available operator_1)
    (operator_available operator_2)
    (operator_available operator_3)
    (operator_shift_available time_slot_1)
    (verifier_available verifier_1)
    (device_available scanner_1)
    (located_in_zone count_loc_1 zone_a)
    (alt_location_assigned_subzone alt_count_loc_1 subzone_a1)
    (count_batch_open count_batch_1)
    (inventory_item_available sku_1001)
    (inventory_item_available sku_1002)
    (entry_includes_location schedule_entry_1 count_loc_1)
    (entry_includes_location schedule_entry_2 count_loc_1)
    (entry_includes_alt_location schedule_entry_1 alt_count_loc_1)
    (entry_includes_alt_location schedule_entry_2 alt_count_loc_1)
    (entry_includes_batch schedule_entry_1 count_batch_1)
    (entry_includes_batch schedule_entry_2 count_batch_1)
    (entry_includes_item schedule_entry_1 sku_1001)
    (entry_includes_item schedule_entry_2 sku_1002)
    (location_label_available location_label_a)
    (location_label_available location_label_b)
    (protocol_available protocol_blind)
    (protocol_available protocol_spot_check)
    (audit_token_available audit_token_1)
    (quality_check_available quality_check_visual)
    (approver_available approver_role_lead)
    (entry_assigned_approver schedule_entry_1 approver_role_lead)
    (entry_assigned_approver schedule_entry_2 approver_role_supervisor)
    (approval_token_available approval_token_1)
  )
  (:goal
    (and
      (count_finalized count_loc_1)
      (count_finalized alt_count_loc_1)
      (count_finalized schedule_entry_1)
      (count_finalized schedule_entry_2)
    )
  )
)
