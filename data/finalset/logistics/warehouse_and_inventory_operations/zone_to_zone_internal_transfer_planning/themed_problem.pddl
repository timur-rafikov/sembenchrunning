(define (problem zone_to_zone_transfer_planning_instance)
  (:domain zone_to_zone_internal_transfer_planning)
  (:objects source_zone_1 - source_zone destination_zone_1 - destination_zone transfer_job_1 - transfer_job transfer_job_2 - transfer_job mhu_1 - material_handling_unit mhu_2 - material_handling_unit mhu_3 - material_handling_unit sku_1 - sku workstation_1 - workstation inventory_unit_1 - inventory_unit source_bin_1 - source_bin destination_bin_1 - destination_bin transport_unit_1 - transport_unit storage_slot_1 - storage_slot storage_slot_2 - storage_slot special_handling_code_1 - special_handling_code special_handling_code_2 - special_handling_code packing_instruction_1 - packing_instruction packing_instruction_2 - packing_instruction time_slot_1 - time_slot equipment_tag_1 - equipment_tag operator_certification_1 - operator_certification operator_certification_2 - operator_certification shift_assignment_1 - shift_assignment)
  (:init
    (mhu_available mhu_1)
    (mhu_available mhu_2)
    (mhu_available mhu_3)
    (sku_available sku_1)
    (workstation_available workstation_1)
    (inventory_unit_available inventory_unit_1)
    (source_zone_assigned_bin source_zone_1 source_bin_1)
    (destination_zone_assigned_bin destination_zone_1 destination_bin_1)
    (transport_unit_available transport_unit_1)
    (storage_slot_available storage_slot_1)
    (storage_slot_available storage_slot_2)
    (transfer_job_assigned_source_zone transfer_job_1 source_zone_1)
    (transfer_job_assigned_source_zone transfer_job_2 source_zone_1)
    (transfer_job_assigned_destination_zone transfer_job_1 destination_zone_1)
    (transfer_job_assigned_destination_zone transfer_job_2 destination_zone_1)
    (transfer_job_assigned_transport_unit transfer_job_1 transport_unit_1)
    (transfer_job_assigned_transport_unit transfer_job_2 transport_unit_1)
    (transfer_job_assigned_storage_slot transfer_job_1 storage_slot_1)
    (transfer_job_assigned_storage_slot transfer_job_2 storage_slot_2)
    (special_handling_code_available special_handling_code_1)
    (special_handling_code_available special_handling_code_2)
    (packing_instruction_available packing_instruction_1)
    (packing_instruction_available packing_instruction_2)
    (time_slot_available time_slot_1)
    (equipment_tag_available equipment_tag_1)
    (operator_certification_available operator_certification_1)
    (transfer_job_assigned_operator_certification transfer_job_1 operator_certification_1)
    (transfer_job_assigned_operator_certification transfer_job_2 operator_certification_2)
    (shift_assignment_available shift_assignment_1)
  )
  (:goal
    (and
      (commitment_for_transfer source_zone_1)
      (commitment_for_transfer destination_zone_1)
      (commitment_for_transfer transfer_job_1)
      (commitment_for_transfer transfer_job_2)
    )
  )
)
