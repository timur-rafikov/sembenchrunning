    (putaway_task_slot_available putaway_task_1)
    (pallet_type_available pallet_type_standard)
    (pallet_type_available pallet_type_large)
    (storage_location_assigned_source_area storage_location_a1 receiving_dock_1)
    (storage_location_assigned_source_area storage_location_a2 receiving_dock_1)
    (storage_location_assigned_alternate_area storage_location_a1 alternate_receiving_zone_1)
    (storage_location_assigned_alternate_area storage_location_a2 alternate_receiving_zone_1)
    (storage_location_linked_to_task storage_location_a1 putaway_task_1)
    (storage_location_linked_to_task storage_location_a2 putaway_task_1)
    (storage_location_supports_pallet_type storage_location_a1 pallet_type_standard)
    (storage_location_supports_pallet_type storage_location_a2 pallet_type_large)
    (handling_code_available handling_code_priority)
    (handling_code_available handling_code_fragile)
    (storage_profile_available storage_profile_standard)
    (storage_profile_available storage_profile_cold_chain)
    (inventory_tag_available inventory_tag_1001)
    (equipment_unit_available forklift_01)
    (asset_owner_available owner_acme)
    (storage_location_restricted_to_owner storage_location_a1 owner_acme)
    (storage_location_restricted_to_owner storage_location_a2 owner_global)
    (inspection_requirement_available inspection_qc_1)
  )
  (:goal
    (and
      (putaway_entity_putaway_completed receiving_dock_1)
      (putaway_entity_putaway_completed alternate_receiving_zone_1)
      (putaway_entity_putaway_completed storage_location_a1)
      (putaway_entity_putaway_completed storage_location_a2)
    )
  )
)
