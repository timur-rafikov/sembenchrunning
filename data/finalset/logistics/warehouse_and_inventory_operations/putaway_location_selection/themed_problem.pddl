(define (problem putaway_location_selection_problem)
  (:domain warehouse_putaway_location_selection_domain)
  (:objects receiving_dock_1 - inbound_source_area alternate_receiving_zone_1 - alternate_source_area storage_location_a1 - storage_location storage_location_a2 - storage_location reservation_token_1 - location_reservation_token reservation_token_2 - location_reservation_token reservation_token_3 - location_reservation_token sku_1001 - product_sku handler_operator_1 - handler_resource attribute_temperature_controlled - slot_attribute storage_zone_a - storage_zone bay_1 - subzone_or_bay putaway_task_1 - putaway_task pallet_type_standard - pallet_type pallet_type_large - pallet_type handling_code_priority - special_handling_code handling_code_fragile - special_handling_code storage_profile_standard - storage_profile storage_profile_cold_chain - storage_profile inventory_tag_1001 - inventory_tag forklift_01 - equipment_unit owner_acme - asset_owner owner_global - asset_owner inspection_qc_1 - inspection_requirement)
  (:init
