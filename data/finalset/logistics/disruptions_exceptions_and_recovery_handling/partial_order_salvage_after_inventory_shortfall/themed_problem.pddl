(define (problem partial_order_salvage_problem)
  (:domain logistics_partial_order_salvage)
  (:objects pfu_1 - primary_fulfillment_unit sfu_1 - secondary_fulfillment_unit recovery_case_1 - recovery_case recovery_case_2 - recovery_case carrier_slot_1 - carrier_slot carrier_slot_2 - carrier_slot carrier_slot_3 - carrier_slot routing_option_1 - routing_option service_partner_1 - service_partner substitute_item_1 - substitute_item origin_leg_1 - origin_leg destination_leg_1 - destination_leg salvage_shipment_draft_1 - salvage_shipment package_batch_a - package_batch package_batch_b - package_batch compliance_doc_a - compliance_document compliance_doc_b - compliance_document authorization_token_a - authorization_token authorization_token_b - authorization_token compensation_option_credit - compensation_option repair_center_alpha - repair_service_center claim_file_1 - claim_file claim_file_2 - claim_file payment_reference_1 - payment_reference)
  (:init
    (carrier_slot_available carrier_slot_1)
    (carrier_slot_available carrier_slot_2)
    (carrier_slot_available carrier_slot_3)
    (routing_option_available routing_option_1)
    (service_partner_available service_partner_1)
    (substitute_item_available substitute_item_1)
    (pfu_origin_leg_assigned pfu_1 origin_leg_1)
    (sfu_destination_leg_assigned sfu_1 destination_leg_1)
    (salvage_shipment_draft salvage_shipment_draft_1)
    (package_batch_available package_batch_a)
    (package_batch_available package_batch_b)
    (case_primary_fulfillment_unit recovery_case_1 pfu_1)
    (case_primary_fulfillment_unit recovery_case_2 pfu_1)
    (case_secondary_fulfillment_unit recovery_case_1 sfu_1)
    (case_secondary_fulfillment_unit recovery_case_2 sfu_1)
    (case_salvage_shipment recovery_case_1 salvage_shipment_draft_1)
    (case_salvage_shipment recovery_case_2 salvage_shipment_draft_1)
    (case_package_batch recovery_case_1 package_batch_a)
    (case_package_batch recovery_case_2 package_batch_b)
    (compliance_document_available compliance_doc_a)
    (compliance_document_available compliance_doc_b)
    (authorization_token_available authorization_token_a)
    (authorization_token_available authorization_token_b)
    (compensation_option_available compensation_option_credit)
    (repair_center_available repair_center_alpha)
    (claim_file_available claim_file_1)
    (case_claim_file_linked recovery_case_1 claim_file_1)
    (case_claim_file_linked recovery_case_2 claim_file_2)
    (payment_reference_available payment_reference_1)
  )
  (:goal
    (and
      (salvage_subject_salvaged pfu_1)
      (salvage_subject_salvaged sfu_1)
      (salvage_subject_salvaged recovery_case_1)
      (salvage_subject_salvaged recovery_case_2)
    )
  )
)
