(define (problem failed_delivery_attempt_resolution_problem)
  (:domain failed_delivery_attempt_resolution_domain)
  (:objects local_recovery_task_primary - local_recovery_task partner_recovery_task_primary - partner_recovery_task failed_delivery_case_primary - failed_delivery_case failed_delivery_case_secondary - failed_delivery_case primary_delivery_resource - delivery_resource backup_delivery_resource - delivery_resource standby_delivery_resource - delivery_resource contact_attempt_slot_primary - contact_attempt_slot primary_field_service_partner - field_service_partner redelivery_resolution_option - resolution_option primary_local_route_segment - local_route_segment primary_partner_route_segment - partner_route_segment contingency_reroute_plan_primary - contingency_reroute_plan primary_package_item - package_item secondary_package_item - package_item goodwill_compensation_option - compensation_option alternate_compensation_option - compensation_option escalation_token_primary - escalation_token escalation_token_secondary - escalation_token standard_case_priority - case_priority remediation_action_template_primary - remediation_action_template customer_response_template_primary - customer_response_template customer_response_template_secondary - customer_response_template claim_template_primary - claim_template)
  (:init
    (resource_available primary_delivery_resource)
    (resource_available backup_delivery_resource)
    (resource_available standby_delivery_resource)
    (contact_slot_available contact_attempt_slot_primary)
    (field_partner_available primary_field_service_partner)
    (resolution_option_available redelivery_resolution_option)
    (local_task_route_linked local_recovery_task_primary primary_local_route_segment)
    (partner_task_route_linked partner_recovery_task_primary primary_partner_route_segment)
    (contingency_reroute_plan_draft contingency_reroute_plan_primary)
    (package_available primary_package_item)
    (package_available secondary_package_item)
    (case_local_task_linked failed_delivery_case_primary local_recovery_task_primary)
    (case_local_task_linked failed_delivery_case_secondary local_recovery_task_primary)
    (case_partner_task_linked failed_delivery_case_primary partner_recovery_task_primary)
    (case_partner_task_linked failed_delivery_case_secondary partner_recovery_task_primary)
    (case_reroute_plan_linked failed_delivery_case_primary contingency_reroute_plan_primary)
    (case_reroute_plan_linked failed_delivery_case_secondary contingency_reroute_plan_primary)
    (case_package_linked failed_delivery_case_primary primary_package_item)
    (case_package_linked failed_delivery_case_secondary secondary_package_item)
    (compensation_option_available goodwill_compensation_option)
    (compensation_option_available alternate_compensation_option)
    (escalation_token_available escalation_token_primary)
    (escalation_token_available escalation_token_secondary)
    (case_priority_available standard_case_priority)
    (remediation_template_available remediation_action_template_primary)
    (customer_response_template_available customer_response_template_primary)
    (case_customer_response_template_linked failed_delivery_case_primary customer_response_template_primary)
    (case_customer_response_template_linked failed_delivery_case_secondary customer_response_template_secondary)
    (claim_template_available claim_template_primary)
  )
  (:goal
    (and
      (case_closed local_recovery_task_primary)
      (case_closed partner_recovery_task_primary)
      (case_closed failed_delivery_case_primary)
      (case_closed failed_delivery_case_secondary)
    )
  )
)
