(define (problem customs_clearance_delay_case_problem)
  (:domain logistics_customs_clearance_delay_contingency_domain)
  (:objects origin_leg_1 - origin_leg destination_leg_1 - destination_leg contingency_plan_1 - contingency_plan_instance contingency_plan_2 - contingency_plan_instance alternate_route_a - alternate_route alternate_route_b - alternate_route alternate_route_c - alternate_route customs_task_1 - customs_task local_agent_1 - local_customs_agent supporting_document_1 - supporting_document origin_facility_1 - origin_facility destination_facility_1 - destination_facility transport_unit_container_1 - transport_unit inspection_report_1 - inspection_report inspection_report_2 - inspection_report special_clearance_certificate_1 - special_clearance_certificate special_clearance_certificate_2 - special_clearance_certificate claim_account_1 - claim_account claim_account_2 - claim_account evidence_package_1 - evidence_package inspection_team_1 - inspection_team customs_authority_contact_1 - customs_authority_contact customs_authority_contact_2 - customs_authority_contact legal_advisor_1 - legal_advisor)
  (:init
    (alternate_route_available alternate_route_a)
    (alternate_route_available alternate_route_b)
    (alternate_route_available alternate_route_c)
    (customs_task_available customs_task_1)
    (local_customs_agent_available local_agent_1)
    (supporting_document_available supporting_document_1)
    (origin_leg_linked_to_facility origin_leg_1 origin_facility_1)
    (destination_leg_linked_to_facility destination_leg_1 destination_facility_1)
    (transport_unit_available transport_unit_container_1)
    (inspection_report_available inspection_report_1)
    (inspection_report_available inspection_report_2)
    (plan_includes_origin_leg contingency_plan_1 origin_leg_1)
    (plan_includes_origin_leg contingency_plan_2 origin_leg_1)
    (plan_includes_destination_leg contingency_plan_1 destination_leg_1)
    (plan_includes_destination_leg contingency_plan_2 destination_leg_1)
    (plan_includes_transport_unit contingency_plan_1 transport_unit_container_1)
    (plan_includes_transport_unit contingency_plan_2 transport_unit_container_1)
    (plan_has_inspection_report contingency_plan_1 inspection_report_1)
    (plan_has_inspection_report contingency_plan_2 inspection_report_2)
    (special_clearance_certificate_available special_clearance_certificate_1)
    (special_clearance_certificate_available special_clearance_certificate_2)
    (claim_account_available claim_account_1)
    (claim_account_available claim_account_2)
    (evidence_package_available evidence_package_1)
    (inspection_team_available inspection_team_1)
    (customs_authority_contact_available customs_authority_contact_1)
    (authority_contact_assigned_to_plan contingency_plan_1 customs_authority_contact_1)
    (authority_contact_assigned_to_plan contingency_plan_2 customs_authority_contact_2)
    (legal_advisor_available legal_advisor_1)
  )
  (:goal
    (and
      (service_restored origin_leg_1)
      (service_restored destination_leg_1)
      (service_restored contingency_plan_1)
      (service_restored contingency_plan_2)
    )
  )
)
