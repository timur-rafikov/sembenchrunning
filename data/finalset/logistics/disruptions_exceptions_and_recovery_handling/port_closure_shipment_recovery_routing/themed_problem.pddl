(define (problem port_closure_shipment_recovery_problem)
  (:domain port_closure_shipment_recovery_domain)
  (:objects origin_segment_1 - shipment_segment_origin destination_segment_1 - shipment_segment_destination recovery_case_1 - recovery_case recovery_case_2 - recovery_case carrier_resource_slot_1 - carrier_resource carrier_resource_slot_2 - carrier_resource carrier_resource_slot_3 - carrier_resource feeder_service_option_1 - transport_mode_option carrier_stakeholder_contact_1 - stakeholder_contact bill_of_lading_1 - logistics_document alternate_port_1 - alternate_port alternate_route_1 - alternate_route routing_solution_1 - routing_solution container_unit_1 - container_unit container_unit_2 - container_unit permit_1 - permit permit_2 - permit resource_bundle_1 - resource_bundle resource_bundle_2 - resource_bundle claim_file_1 - claim_file equipment_asset_1 - equipment_asset incident_report_1 - incident_report incident_report_2 - incident_report external_approval_1 - external_approval)
  (:init
    (carrier_resource_available carrier_resource_slot_1)
    (carrier_resource_available carrier_resource_slot_2)
    (carrier_resource_available carrier_resource_slot_3)
    (mode_option_available feeder_service_option_1)
    (stakeholder_contact_available carrier_stakeholder_contact_1)
    (logistics_document_available bill_of_lading_1)
    (segment_candidate_alternate_port origin_segment_1 alternate_port_1)
    (segment_candidate_alternate_route destination_segment_1 alternate_route_1)
    (routing_solution_available routing_solution_1)
    (container_unit_available container_unit_1)
    (container_unit_available container_unit_2)
    (case_includes_origin_segment recovery_case_1 origin_segment_1)
    (case_includes_origin_segment recovery_case_2 origin_segment_1)
    (case_includes_destination_segment recovery_case_1 destination_segment_1)
    (case_includes_destination_segment recovery_case_2 destination_segment_1)
    (case_includes_routing_solution recovery_case_1 routing_solution_1)
    (case_includes_routing_solution recovery_case_2 routing_solution_1)
    (case_has_container_unit recovery_case_1 container_unit_1)
    (case_has_container_unit recovery_case_2 container_unit_2)
    (permit_available permit_1)
    (permit_available permit_2)
    (resource_bundle_available resource_bundle_1)
    (resource_bundle_available resource_bundle_2)
    (claim_file_available claim_file_1)
    (equipment_asset_available equipment_asset_1)
    (incident_report_available incident_report_1)
    (case_has_incident_report recovery_case_1 incident_report_1)
    (case_has_incident_report recovery_case_2 incident_report_2)
    (external_approval_available external_approval_1)
  )
  (:goal
    (and
      (recovery_routing_applied origin_segment_1)
      (recovery_routing_applied destination_segment_1)
      (recovery_routing_applied recovery_case_1)
      (recovery_routing_applied recovery_case_2)
    )
  )
)
