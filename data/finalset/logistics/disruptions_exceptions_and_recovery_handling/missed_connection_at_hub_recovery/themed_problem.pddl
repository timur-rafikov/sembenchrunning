(define (problem missed_connection_at_hub_recovery_problem)
  (:domain logistics_missed_connection_recovery)
  (:objects inbound_leg_1 - inbound_transport_leg outbound_leg_1 - outbound_transport_leg recovery_case_1 - recovery_case recovery_case_2 - recovery_case operator_resource_1 - operator_resource operator_resource_2 - operator_resource operator_resource_3 - operator_resource schedule_slot_1 - schedule_slot ground_handling_unit_1 - ground_handling_unit container_1 - handling_container inbound_service_1 - inbound_service_instance outbound_service_1 - outbound_service_instance contingency_plan_1 - contingency_plan shipping_document_1 - shipping_document shipping_document_2 - shipping_document approval_credential_1 - approval_credential approval_credential_2 - approval_credential stakeholder_contact_1 - stakeholder_contact stakeholder_contact_2 - stakeholder_contact customer_contact_1 - customer_contact alternate_carrier_1 - alternate_carrier claims_agent_1 - claims_agent claims_agent_2 - claims_agent escalation_contact_1 - escalation_contact)
  (:init
    (operator_resource_available operator_resource_1)
    (operator_resource_available operator_resource_2)
    (operator_resource_available operator_resource_3)
    (schedule_slot_available schedule_slot_1)
    (handling_unit_available ground_handling_unit_1)
    (container_available container_1)
    (inbound_leg_linked_service inbound_leg_1 inbound_service_1)
    (outbound_leg_linked_service outbound_leg_1 outbound_service_1)
    (contingency_plan_available contingency_plan_1)
    (shipping_document_available shipping_document_1)
    (shipping_document_available shipping_document_2)
    (case_has_inbound_leg recovery_case_1 inbound_leg_1)
    (case_has_inbound_leg recovery_case_2 inbound_leg_1)
    (case_has_outbound_leg recovery_case_1 outbound_leg_1)
    (case_has_outbound_leg recovery_case_2 outbound_leg_1)
    (case_assigned_contingency_plan recovery_case_1 contingency_plan_1)
    (case_assigned_contingency_plan recovery_case_2 contingency_plan_1)
    (case_has_document recovery_case_1 shipping_document_1)
    (case_has_document recovery_case_2 shipping_document_2)
    (approval_credential_available approval_credential_1)
    (approval_credential_available approval_credential_2)
    (stakeholder_contact_available stakeholder_contact_1)
    (stakeholder_contact_available stakeholder_contact_2)
    (customer_contact_available customer_contact_1)
    (alternate_carrier_available alternate_carrier_1)
    (claims_agent_available claims_agent_1)
    (case_assigned_claims_agent recovery_case_1 claims_agent_1)
    (case_assigned_claims_agent recovery_case_2 claims_agent_2)
    (escalation_contact_available escalation_contact_1)
  )
  (:goal
    (and
      (service_restored_flag inbound_leg_1)
      (service_restored_flag outbound_leg_1)
      (service_restored_flag recovery_case_1)
      (service_restored_flag recovery_case_2)
    )
  )
)
