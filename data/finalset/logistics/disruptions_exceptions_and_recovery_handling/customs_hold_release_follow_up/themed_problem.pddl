(define (problem customs_hold_release_follow_up_problem)
  (:domain customs_hold_release_follow_up_domain)
  (:objects primary_leg_1 - primary_transport_leg secondary_leg_1 - secondary_transport_leg recovery_job_1 - recovery_job recovery_job_2 - recovery_job release_channel_1 - release_channel release_channel_2 - release_channel release_channel_3 - release_channel supporting_document_1 - supporting_document customs_broker_1 - customs_broker alt_routing_option_1 - alternate_routing_option origin_checkpoint_1 - origin_checkpoint destination_checkpoint_1 - destination_checkpoint contingency_shipment_1 - contingency_shipment cargo_unit_1 - cargo_unit cargo_unit_2 - cargo_unit special_authorization_1 - special_authorization special_authorization_2 - special_authorization remediation_plan_1 - remediation_plan remediation_plan_2 - remediation_plan release_certificate_1 - release_certificate external_service_1 - external_service regulatory_contact_1 - regulatory_contact regulatory_contact_2 - regulatory_contact legal_clearance_1 - legal_clearance)
  (:init
    (release_channel_available release_channel_1)
    (release_channel_available release_channel_2)
    (release_channel_available release_channel_3)
    (supporting_document_available supporting_document_1)
    (broker_available customs_broker_1)
    (alternate_routing_option_available alt_routing_option_1)
    (leg_origin_checkpoint_link primary_leg_1 origin_checkpoint_1)
    (leg_destination_checkpoint_link secondary_leg_1 destination_checkpoint_1)
    (contingency_shipment_available contingency_shipment_1)
    (cargo_unit_available cargo_unit_1)
    (cargo_unit_available cargo_unit_2)
    (recovery_job_assigned_primary_leg recovery_job_1 primary_leg_1)
    (recovery_job_assigned_primary_leg recovery_job_2 primary_leg_1)
    (recovery_job_assigned_secondary_leg recovery_job_1 secondary_leg_1)
    (recovery_job_assigned_secondary_leg recovery_job_2 secondary_leg_1)
    (recovery_job_assigned_contingency_shipment recovery_job_1 contingency_shipment_1)
    (recovery_job_assigned_contingency_shipment recovery_job_2 contingency_shipment_1)
    (recovery_job_assigned_cargo_unit recovery_job_1 cargo_unit_1)
    (recovery_job_assigned_cargo_unit recovery_job_2 cargo_unit_2)
    (special_authorization_available special_authorization_1)
    (special_authorization_available special_authorization_2)
    (remediation_plan_available remediation_plan_1)
    (remediation_plan_available remediation_plan_2)
    (release_certificate_available release_certificate_1)
    (external_service_available external_service_1)
    (regulatory_contact_available regulatory_contact_1)
    (recovery_job_assigned_regulatory_contact recovery_job_1 regulatory_contact_1)
    (recovery_job_assigned_regulatory_contact recovery_job_2 regulatory_contact_2)
    (legal_clearance_available legal_clearance_1)
  )
  (:goal
    (and
      (subject_closed_or_released primary_leg_1)
      (subject_closed_or_released secondary_leg_1)
      (subject_closed_or_released recovery_job_1)
      (subject_closed_or_released recovery_job_2)
    )
  )
)
