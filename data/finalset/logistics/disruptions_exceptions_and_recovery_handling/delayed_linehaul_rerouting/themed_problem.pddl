(define (problem delayed_linehaul_case_instance)
  (:domain delayed_linehaul_rerouting)
  (:objects origin_leg_1 - origin_leg destination_leg_1 - destination_leg reroute_case_1 - reroute_case reroute_case_2 - reroute_case carrier_unit_1 - carrier_unit carrier_unit_2 - carrier_unit carrier_unit_3 - carrier_unit schedule_option_1 - schedule_option operator_resource_1 - operator_resource alternative_service_1 - alternative_service upstream_route_option_1 - upstream_route_option downstream_route_option_1 - downstream_route_option contingency_itinerary_1 - contingency_itinerary freight_unit_1 - freight_unit freight_unit_2 - freight_unit authorization_document_1 - authorization_document authorization_document_2 - authorization_document operational_permit_1 - operational_permit operational_permit_2 - operational_permit claim_document_1 - claim_document service_provider_1 - service_provider escalation_contact_1 - escalation_contact escalation_contact_2 - escalation_contact external_approval_1 - external_approval)
  (:init
    (carrier_available carrier_unit_1)
    (carrier_available carrier_unit_2)
    (carrier_available carrier_unit_3)
    (schedule_option_available schedule_option_1)
    (operator_resource_available operator_resource_1)
    (alternative_service_available alternative_service_1)
    (origin_leg_upstream_option_link origin_leg_1 upstream_route_option_1)
    (destination_leg_downstream_option_link destination_leg_1 downstream_route_option_1)
    (contingency_itinerary_unallocated contingency_itinerary_1)
    (freight_unit_available freight_unit_1)
    (freight_unit_available freight_unit_2)
    (case_origin_leg_link reroute_case_1 origin_leg_1)
    (case_origin_leg_link reroute_case_2 origin_leg_1)
    (case_destination_leg_link reroute_case_1 destination_leg_1)
    (case_destination_leg_link reroute_case_2 destination_leg_1)
    (case_linked_itinerary reroute_case_1 contingency_itinerary_1)
    (case_linked_itinerary reroute_case_2 contingency_itinerary_1)
    (case_has_freight_unit reroute_case_1 freight_unit_1)
    (case_has_freight_unit reroute_case_2 freight_unit_2)
    (authorization_document_available authorization_document_1)
    (authorization_document_available authorization_document_2)
    (operational_permit_available operational_permit_1)
    (operational_permit_available operational_permit_2)
    (claim_document_available claim_document_1)
    (service_provider_available service_provider_1)
    (escalation_contact_available escalation_contact_1)
    (case_has_escalation_contact reroute_case_1 escalation_contact_1)
    (case_has_escalation_contact reroute_case_2 escalation_contact_2)
    (external_approval_available external_approval_1)
  )
  (:goal
    (and
      (restoration_confirmed_for_subject origin_leg_1)
      (restoration_confirmed_for_subject destination_leg_1)
      (restoration_confirmed_for_subject reroute_case_1)
      (restoration_confirmed_for_subject reroute_case_2)
    )
  )
)
