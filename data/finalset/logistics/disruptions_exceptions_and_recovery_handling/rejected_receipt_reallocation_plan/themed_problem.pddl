(define (problem rejected_receipt_reallocation_problem)
  (:domain rejected_receipt_reallocation_domain)
  (:objects order_line_1 - order_line shipment_unit_1 - shipment_unit reallocation_plan_a - reallocation_plan reallocation_plan_b - reallocation_plan carrier_alpha - carrier carrier_beta - carrier carrier_gamma - carrier inspection_team_alpha - inspection_team receiving_facility_1 - facility inventory_unit_replacement_1 - inventory_unit candidate_source_loc_1 - candidate_source candidate_destination_loc_1 - candidate_destination reallocation_shipment_1 - reallocation_shipment staging_slot_1 - staging_slot staging_slot_2 - staging_slot compliance_doc_permit_a - compliance_document compliance_doc_permit_b - compliance_document service_profile_standard - service_profile service_profile_expedited - service_profile claim_document_1 - claim_document operational_certificate_1 - operational_certificate vendor_authorization_1 - vendor_authorization vendor_authorization_2 - vendor_authorization incident_report_1 - incident_report)
  (:init
    (carrier_available carrier_alpha)
    (carrier_available carrier_beta)
    (carrier_available carrier_gamma)
    (inspection_team_available inspection_team_alpha)
    (facility_available receiving_facility_1)
    (inventory_unit_available inventory_unit_replacement_1)
    (order_line_candidate_source order_line_1 candidate_source_loc_1)
    (shipment_unit_candidate_destination shipment_unit_1 candidate_destination_loc_1)
    (reallocation_shipment_draft reallocation_shipment_1)
    (staging_slot_available staging_slot_1)
    (staging_slot_available staging_slot_2)
    (plan_has_order_line reallocation_plan_a order_line_1)
    (plan_has_order_line reallocation_plan_b order_line_1)
    (plan_has_shipment_unit reallocation_plan_a shipment_unit_1)
    (plan_has_shipment_unit reallocation_plan_b shipment_unit_1)
    (plan_bound_shipment reallocation_plan_a reallocation_shipment_1)
    (plan_bound_shipment reallocation_plan_b reallocation_shipment_1)
    (plan_staging_slot_assigned reallocation_plan_a staging_slot_1)
    (plan_staging_slot_assigned reallocation_plan_b staging_slot_2)
    (compliance_document_available compliance_doc_permit_a)
    (compliance_document_available compliance_doc_permit_b)
    (service_profile_available service_profile_standard)
    (service_profile_available service_profile_expedited)
    (claim_document_available claim_document_1)
    (operational_certificate_available operational_certificate_1)
    (vendor_authorization_available vendor_authorization_1)
    (plan_vendor_authorization_attached reallocation_plan_a vendor_authorization_1)
    (plan_vendor_authorization_attached reallocation_plan_b vendor_authorization_2)
    (incident_report_available incident_report_1)
  )
  (:goal
    (and
      (entity_reallocation_finalized order_line_1)
      (entity_reallocation_finalized shipment_unit_1)
      (entity_reallocation_finalized reallocation_plan_a)
      (entity_reallocation_finalized reallocation_plan_b)
    )
  )
)
