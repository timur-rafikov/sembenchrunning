(define (problem partial_fulfillment_split_decision_scenario)
  (:domain logistics_partial_fulfillment_split_decision)
  (:objects source_allocation_1 - source_allocation consolidation_group_1 - consolidation_group shipment_plan_a - shipment_plan shipment_plan_b - shipment_plan fulfillment_center_north - fulfillment_center fulfillment_center_south - fulfillment_center fulfillment_center_central - fulfillment_center service_level_standard - service_level_profile packing_station_1 - packing_resource inventory_unit_pallet_1 - inventory_unit origin_node_dock_1 - origin_node destination_node_zone_1 - destination_node transport_unit_container_1 - transport_unit hu_type_box - handling_unit_type hu_type_pallet - handling_unit_type equipment_type_forklift - equipment_type equipment_type_trailer - equipment_type transport_requirement_capacity_small - transport_requirement transport_requirement_capacity_large - transport_requirement split_token_1 - split_decision_token special_handling_temperature_control - special_handling_requirement customer_slot_morning - customer_delivery_slot customer_slot_evening - customer_delivery_slot carrier_option_standard - carrier_option)
  (:init
    (fulfillment_center_available fulfillment_center_north)
    (fulfillment_center_available fulfillment_center_south)
    (fulfillment_center_available fulfillment_center_central)
    (service_level_available service_level_standard)
    (packing_resource_available packing_station_1)
    (inventory_unit_available inventory_unit_pallet_1)
    (allocation_origin_node source_allocation_1 origin_node_dock_1)
    (consolidation_destination_node consolidation_group_1 destination_node_zone_1)
    (transport_unit_available transport_unit_container_1)
    (handling_unit_type_available hu_type_box)
    (handling_unit_type_available hu_type_pallet)
    (shipment_includes_allocation shipment_plan_a source_allocation_1)
    (shipment_includes_allocation shipment_plan_b source_allocation_1)
    (shipment_includes_consolidation shipment_plan_a consolidation_group_1)
    (shipment_includes_consolidation shipment_plan_b consolidation_group_1)
    (shipment_assigned_transport_unit shipment_plan_a transport_unit_container_1)
    (shipment_assigned_transport_unit shipment_plan_b transport_unit_container_1)
    (shipment_requested_handling_unit_type shipment_plan_a hu_type_box)
    (shipment_requested_handling_unit_type shipment_plan_b hu_type_pallet)
    (equipment_type_available equipment_type_forklift)
    (equipment_type_available equipment_type_trailer)
    (transport_requirement_available transport_requirement_capacity_small)
    (transport_requirement_available transport_requirement_capacity_large)
    (split_token_available split_token_1)
    (special_handling_available special_handling_temperature_control)
    (customer_delivery_slot_available customer_slot_morning)
    (shipment_assigned_customer_slot shipment_plan_a customer_slot_morning)
    (shipment_assigned_customer_slot shipment_plan_b customer_slot_evening)
    (carrier_option_available carrier_option_standard)
  )
  (:goal
    (and
      (fulfilled source_allocation_1)
      (fulfilled consolidation_group_1)
      (fulfilled shipment_plan_a)
      (fulfilled shipment_plan_b)
    )
  )
)
