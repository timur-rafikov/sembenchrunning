(define (problem customer_delivery_window_alignment_problem)
  (:domain logistics_customer_delivery_window_alignment)
  (:objects fulfillment_unit_1 - fulfillment_unit order_segment_1 - order_segment shipment_plan_1 - shipment_plan shipment_plan_2 - shipment_plan transport_resource_1 - transport_resource transport_resource_2 - transport_resource transport_resource_3 - transport_resource customer_time_window_1 - customer_time_window loading_dock_1 - loading_dock order_line_1 - order_line route_slot_1 - route_slot shipment_option_1 - shipment_option shipment_unit_1 - shipment_unit pallet_1 - pallet pallet_2 - pallet vehicle_type_1 - vehicle_type vehicle_type_2 - vehicle_type service_profile_standard - service_level_profile service_profile_expedited - service_level_profile delivery_time_slot_1 - delivery_time_slot handling_requirement_refrigeration - handling_requirement regulatory_clearance_1 - regulatory_clearance regulatory_clearance_2 - regulatory_clearance carrier_shift_1 - carrier_shift)
  (:init
    (transport_resource_available transport_resource_1)
    (transport_resource_available transport_resource_2)
    (transport_resource_available transport_resource_3)
    (customer_time_window_available customer_time_window_1)
    (dock_available loading_dock_1)
    (order_line_available order_line_1)
    (fulfillment_unit_route_slot_candidate fulfillment_unit_1 route_slot_1)
    (segment_option_candidate order_segment_1 shipment_option_1)
    (shipment_unit_available shipment_unit_1)
    (pallet_available pallet_1)
    (pallet_available pallet_2)
    (shipment_plan_includes_fulfillment_unit shipment_plan_1 fulfillment_unit_1)
    (shipment_plan_includes_fulfillment_unit shipment_plan_2 fulfillment_unit_1)
    (shipment_plan_includes_order_segment shipment_plan_1 order_segment_1)
    (shipment_plan_includes_order_segment shipment_plan_2 order_segment_1)
    (shipment_plan_assigned_to_shipment_unit shipment_plan_1 shipment_unit_1)
    (shipment_plan_assigned_to_shipment_unit shipment_plan_2 shipment_unit_1)
    (assigned_pallet_to_shipment_plan shipment_plan_1 pallet_1)
    (assigned_pallet_to_shipment_plan shipment_plan_2 pallet_2)
    (vehicle_type_available vehicle_type_1)
    (vehicle_type_available vehicle_type_2)
    (service_level_profile_available service_profile_standard)
    (service_level_profile_available service_profile_expedited)
    (delivery_time_slot_available delivery_time_slot_1)
    (handling_requirement_available handling_requirement_refrigeration)
    (regulatory_clearance_available regulatory_clearance_1)
    (assigned_regulatory_clearance_to_plan shipment_plan_1 regulatory_clearance_1)
    (assigned_regulatory_clearance_to_plan shipment_plan_2 regulatory_clearance_2)
    (carrier_shift_available carrier_shift_1)
  )
  (:goal
    (and
      (ready_for_dispatch_entity fulfillment_unit_1)
      (ready_for_dispatch_entity order_segment_1)
      (ready_for_dispatch_entity shipment_plan_1)
      (ready_for_dispatch_entity shipment_plan_2)
    )
  )
)
