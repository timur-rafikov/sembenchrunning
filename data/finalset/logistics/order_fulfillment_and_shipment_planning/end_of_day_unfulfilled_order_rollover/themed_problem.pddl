(define (problem eod_unfulfilled_order_rollover_problem)
  (:domain logistics_end_of_day_unfulfilled_order_rollover)
  (:objects source_unit_1 - source_unit destination_unit_1 - destination_unit outbound_shipment_1 - outbound_shipment outbound_shipment_2 - outbound_shipment release_slot_batch_a - release_slot release_slot_batch_b - release_slot release_slot_batch_c - release_slot order_line_item_1 - order_line_item workstation_1 - workstation package_unit_1 - package_unit source_load_1 - source_load_id destination_load_1 - destination_load_id transport_unit_1 - transport_unit container_asset_pallet_1 - container_asset container_asset_pallet_2 - container_asset load_profile_small - load_profile load_profile_large - load_profile manifest_label_1 - manifest_label manifest_label_2 - manifest_label service_level_profile_standard - service_level_profile equipment_resource_1 - equipment_resource handling_instruction_fragile - handling_instruction handling_instruction_temperature_controlled - handling_instruction carrier_option_standard - carrier_option)
  (:init
    (release_slot_available release_slot_batch_a)
    (release_slot_available release_slot_batch_b)
    (release_slot_available release_slot_batch_c)
    (unallocated_order_line order_line_item_1)
    (workstation_available workstation_1)
    (available_package_unit package_unit_1)
    (source_assigned_load source_unit_1 source_load_1)
    (destination_assigned_load destination_unit_1 destination_load_1)
    (transport_unit_available transport_unit_1)
    (container_available container_asset_pallet_1)
    (container_available container_asset_pallet_2)
    (shipment_assigned_source_unit outbound_shipment_1 source_unit_1)
    (shipment_assigned_source_unit outbound_shipment_2 source_unit_1)
    (shipment_assigned_destination_unit outbound_shipment_1 destination_unit_1)
    (shipment_assigned_destination_unit outbound_shipment_2 destination_unit_1)
    (shipment_assigned_transport_unit outbound_shipment_1 transport_unit_1)
    (shipment_assigned_transport_unit outbound_shipment_2 transport_unit_1)
    (shipment_has_container outbound_shipment_1 container_asset_pallet_1)
    (shipment_has_container outbound_shipment_2 container_asset_pallet_2)
    (load_profile_available load_profile_small)
    (load_profile_available load_profile_large)
    (manifest_label_available manifest_label_1)
    (manifest_label_available manifest_label_2)
    (service_level_profile_available service_level_profile_standard)
    (equipment_resource_available equipment_resource_1)
    (handling_instruction_available handling_instruction_fragile)
    (shipment_has_handling_instruction outbound_shipment_1 handling_instruction_fragile)
    (shipment_has_handling_instruction outbound_shipment_2 handling_instruction_temperature_controlled)
    (carrier_option_available carrier_option_standard)
  )
  (:goal
    (and
      (marked_for_rollover source_unit_1)
      (marked_for_rollover destination_unit_1)
      (marked_for_rollover outbound_shipment_1)
      (marked_for_rollover outbound_shipment_2)
    )
  )
)
