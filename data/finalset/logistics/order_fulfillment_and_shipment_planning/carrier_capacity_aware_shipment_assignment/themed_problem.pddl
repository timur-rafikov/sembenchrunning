(define (problem carrier_capacity_shipment_assignment_problem)
  (:domain carrier_capacity_shipment_assignment_domain)
  (:objects origin_unit_1 - origin_fulfillment_unit destination_unit_1 - destination_fulfillment_unit consolidation_candidate_a - consolidation_shipment consolidation_candidate_b - consolidation_shipment carrier_alpha - carrier_resource carrier_beta - carrier_resource carrier_gamma - carrier_resource order_line_item_1 - order_line_item warehouse_terminal_1 - warehouse_terminal packaging_unit_1 - packaging_unit origin_slot_1 - origin_time_slot destination_slot_1 - destination_time_slot formed_shipment_1 - formed_shipment package_1 - piece_package package_2 - piece_package routing_attribute_primary - routing_attribute routing_attribute_secondary - routing_attribute special_handling_fragile - special_handling_requirement special_handling_hazardous - special_handling_requirement service_option_standard - service_option equipment_type_reefer - equipment_type contract_offer_a - contract_offer contract_offer_b - contract_offer operational_attribute_1 - operational_attribute)
  (:init
    (carrier_available carrier_alpha)
    (carrier_available carrier_beta)
    (carrier_available carrier_gamma)
    (item_available order_line_item_1)
    (terminal_available warehouse_terminal_1)
    (packaging_available packaging_unit_1)
    (compatible_with_origin_slot origin_unit_1 origin_slot_1)
    (compatible_with_destination_slot destination_unit_1 destination_slot_1)
    (formed_shipment_available formed_shipment_1)
    (package_available package_1)
    (package_available package_2)
    (consolidation_contains_origin consolidation_candidate_a origin_unit_1)
    (consolidation_contains_origin consolidation_candidate_b origin_unit_1)
    (consolidation_contains_destination consolidation_candidate_a destination_unit_1)
    (consolidation_contains_destination consolidation_candidate_b destination_unit_1)
    (consolidation_linked_to_formed_shipment consolidation_candidate_a formed_shipment_1)
    (consolidation_linked_to_formed_shipment consolidation_candidate_b formed_shipment_1)
    (consolidation_has_package consolidation_candidate_a package_1)
    (consolidation_has_package consolidation_candidate_b package_2)
    (routing_attribute_available routing_attribute_primary)
    (routing_attribute_available routing_attribute_secondary)
    (special_handling_available special_handling_fragile)
    (special_handling_available special_handling_hazardous)
    (service_option_available service_option_standard)
    (equipment_type_available equipment_type_reefer)
    (contract_offer_available contract_offer_a)
    (consolidation_has_contract_offer consolidation_candidate_a contract_offer_a)
    (consolidation_has_contract_offer consolidation_candidate_b contract_offer_b)
    (operational_attribute_available operational_attribute_1)
  )
  (:goal
    (and
      (assignment_finalized origin_unit_1)
      (assignment_finalized destination_unit_1)
      (assignment_finalized consolidation_candidate_a)
      (assignment_finalized consolidation_candidate_b)
    )
  )
)
