(define (problem service_level_shipment_selection_problem)
  (:domain service_level_shipment_planning)
  (:objects origin_line_1 - order_line_origin destination_line_1 - order_line_destination aggregate_order_1 - customer_order_aggregate aggregate_order_2 - customer_order_aggregate warehouse_a - inventory_source warehouse_b - inventory_source warehouse_c - inventory_source sku_1001 - product_sku pack_station_1 - pack_station box_type_a - packing_material origin_dock_1 - origin_loading_dock destination_dock_1 - destination_loading_dock shipment_unit_1 - shipment_unit pallet_a - pallet_or_container pallet_b - pallet_or_container transport_mode_truck - transport_mode transport_mode_air - transport_mode shipping_label_a - shipping_label shipping_label_b - shipping_label service_level_express - service_level carrier_option_standard - carrier_option routing_preference_cost - routing_preference routing_preference_speed - routing_preference delivery_window_morning - delivery_time_window)
  (:init
    (inventory_source_available warehouse_a)
    (inventory_source_available warehouse_b)
    (inventory_source_available warehouse_c)
    (sku_available sku_1001)
    (pack_station_available pack_station_1)
    (packing_material_available box_type_a)
    (order_line_origin_assigned_to_dock origin_line_1 origin_dock_1)
    (order_line_destination_assigned_to_dock destination_line_1 destination_dock_1)
    (shipment_open shipment_unit_1)
    (container_available pallet_a)
    (container_available pallet_b)
    (aggregate_contains_origin_line aggregate_order_1 origin_line_1)
    (aggregate_contains_origin_line aggregate_order_2 origin_line_1)
    (aggregate_contains_destination_line aggregate_order_1 destination_line_1)
    (aggregate_contains_destination_line aggregate_order_2 destination_line_1)
    (aggregate_assigned_to_shipment aggregate_order_1 shipment_unit_1)
    (aggregate_assigned_to_shipment aggregate_order_2 shipment_unit_1)
    (aggregate_assigned_container aggregate_order_1 pallet_a)
    (aggregate_assigned_container aggregate_order_2 pallet_b)
    (transport_mode_available transport_mode_truck)
    (transport_mode_available transport_mode_air)
    (shipping_label_available shipping_label_a)
    (shipping_label_available shipping_label_b)
    (service_level_available service_level_express)
    (carrier_option_available carrier_option_standard)
    (routing_preference_available routing_preference_cost)
    (aggregate_assigned_routing_preference aggregate_order_1 routing_preference_cost)
    (aggregate_assigned_routing_preference aggregate_order_2 routing_preference_speed)
    (delivery_time_window_available delivery_window_morning)
  )
  (:goal
    (and
      (finalized origin_line_1)
      (finalized destination_line_1)
      (finalized aggregate_order_1)
      (finalized aggregate_order_2)
    )
  )
)
