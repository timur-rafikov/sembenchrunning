(define (problem order_mix_instance)
  (:domain packaging_type_selection_for_order_mix)
  (:objects pick_unit_1 - pick_unit consolidation_unit_1 - consolidation_unit package_config_1 - package_configuration package_config_2 - package_configuration carton_small - packaging_type box_medium - packaging_type polybag_small - packaging_type sku_1001 - item_sku packing_station_a - packing_station bubble_wrap - package_component template_slot_a - pack_template variant_a - template_variant handling_unit_slot_1 - handling_unit container_size_small - container_size container_size_medium - container_size shipping_label - label_type compliance_label - label_type carrier_fedex - carrier_option carrier_dhl - carrier_option service_standard - service_level_option attribute_fragile - handling_attribute pref_no_signature - customer_preference pref_leave_at_door - customer_preference regulatory_code_1 - regulatory_code)
  (:init
    (packaging_type_available carton_small)
    (packaging_type_available box_medium)
    (packaging_type_available polybag_small)
    (sku_available sku_1001)
    (packing_station_available packing_station_a)
    (component_available bubble_wrap)
    (pick_unit_assigned_template pick_unit_1 template_slot_a)
    (consolidation_unit_assigned_variant consolidation_unit_1 variant_a)
    (handling_unit_available handling_unit_slot_1)
    (container_size_available container_size_small)
    (container_size_available container_size_medium)
    (config_assigned_to_pick_unit package_config_1 pick_unit_1)
    (config_assigned_to_pick_unit package_config_2 pick_unit_1)
    (config_assigned_to_consolidation_unit package_config_1 consolidation_unit_1)
    (config_assigned_to_consolidation_unit package_config_2 consolidation_unit_1)
    (config_assigned_to_handling_unit package_config_1 handling_unit_slot_1)
    (config_assigned_to_handling_unit package_config_2 handling_unit_slot_1)
    (config_supports_container_size package_config_1 container_size_small)
    (config_supports_container_size package_config_2 container_size_medium)
    (label_type_available shipping_label)
    (label_type_available compliance_label)
    (carrier_option_available carrier_fedex)
    (carrier_option_available carrier_dhl)
    (service_level_option_available service_standard)
    (handling_attribute_available attribute_fragile)
    (customer_preference_available pref_no_signature)
    (config_associated_with_customer_preference package_config_1 pref_no_signature)
    (config_associated_with_customer_preference package_config_2 pref_leave_at_door)
    (regulatory_code_available regulatory_code_1)
  )
  (:goal
    (and
      (packaging_finalized pick_unit_1)
      (packaging_finalized consolidation_unit_1)
      (packaging_finalized package_config_1)
      (packaging_finalized package_config_2)
    )
  )
)
