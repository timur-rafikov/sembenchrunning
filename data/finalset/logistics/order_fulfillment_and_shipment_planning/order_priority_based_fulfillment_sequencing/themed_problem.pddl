(define (problem order_priority_fulfillment_problem)
  (:domain order_priority_fulfillment_domain)
  (:objects pick_zone_1 - pick_zone_instance pack_zone_1 - pack_zone_instance fulfillment_job_1 - fulfillment_job fulfillment_job_2 - fulfillment_job supply_source_1 - supply_source supply_source_2 - supply_source supply_source_3 - supply_source pick_task_1 - pick_task operator_1 - operator sku_unit_1 - sku_unit pick_wave_1 - pick_wave pack_batch_1 - pack_batch shipment_1 - shipment item_unit_1 - item_unit item_unit_2 - item_unit priority_expedited - priority_tag priority_standard - priority_tag carrier_express - carrier_option carrier_standard - carrier_option delivery_window_1 - delivery_window handling_resource_dock_1 - handling_resource service_constraint_cold_chain - service_constraint service_constraint_signature - service_constraint routing_constraint_lane_1 - routing_constraint)
  (:init
    (supply_source_available supply_source_1)
    (supply_source_available supply_source_2)
    (supply_source_available supply_source_3)
    (pick_task_available pick_task_1)
    (operator_available operator_1)
    (sku_unit_available sku_unit_1)
    (pick_zone_assigned_to_wave pick_zone_1 pick_wave_1)
    (pack_zone_assigned_to_batch pack_zone_1 pack_batch_1)
    (shipment_slot_available shipment_1)
    (item_unit_available item_unit_1)
    (item_unit_available item_unit_2)
    (fulfillment_entity_assigned_pick_zone fulfillment_job_1 pick_zone_1)
    (fulfillment_entity_assigned_pick_zone fulfillment_job_2 pick_zone_1)
    (fulfillment_entity_assigned_pack_zone fulfillment_job_1 pack_zone_1)
    (fulfillment_entity_assigned_pack_zone fulfillment_job_2 pack_zone_1)
    (fulfillment_entity_assigned_shipment fulfillment_job_1 shipment_1)
    (fulfillment_entity_assigned_shipment fulfillment_job_2 shipment_1)
    (job_contains_item_unit fulfillment_job_1 item_unit_1)
    (job_contains_item_unit fulfillment_job_2 item_unit_2)
    (priority_tag_available priority_expedited)
    (priority_tag_available priority_standard)
    (carrier_option_available carrier_express)
    (carrier_option_available carrier_standard)
    (delivery_window_available delivery_window_1)
    (handling_resource_available handling_resource_dock_1)
    (service_constraint_available service_constraint_cold_chain)
    (fulfillment_entity_assigned_service_constraint fulfillment_job_1 service_constraint_cold_chain)
    (fulfillment_entity_assigned_service_constraint fulfillment_job_2 service_constraint_signature)
    (routing_constraint_available routing_constraint_lane_1)
  )
  (:goal
    (and
      (sourcing_allocation_finalized pick_zone_1)
      (sourcing_allocation_finalized pack_zone_1)
      (sourcing_allocation_finalized fulfillment_job_1)
      (sourcing_allocation_finalized fulfillment_job_2)
    )
  )
)
