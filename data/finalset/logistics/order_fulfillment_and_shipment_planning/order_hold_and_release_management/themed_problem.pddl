(define (problem order_hold_release_scenario)
  (:domain order_hold_and_release_management)
  (:objects customer_order_1 - order order_line_1 - order_line shipment_1 - shipment shipment_2 - shipment sourcing_warehouse_a - sourcing_option sourcing_warehouse_b - sourcing_option sourcing_supplier_c - sourcing_option inventory_item_sku_1 - inventory_item picker_1 - fulfillment_resource package_tote_1 - package source_location_warehouse_1 - source_location delivery_route_1 - delivery_route transport_unit_1 - transport_unit stock_item_batch_1 - stock_item stock_item_batch_2 - stock_item shipping_mode_standard - shipping_mode shipping_mode_express - shipping_mode service_level_standard - service_level service_level_premium - service_level release_auth_token_1 - release_authorization packing_station_1 - packing_resource routing_constraint_domestic - routing_constraint routing_constraint_restricted - routing_constraint regulatory_clearance_customs - regulatory_clearance)
  (:init
    (sourcing_option_available sourcing_warehouse_a)
    (sourcing_option_available sourcing_warehouse_b)
    (sourcing_option_available sourcing_supplier_c)
    (inventory_available inventory_item_sku_1)
    (resource_available picker_1)
    (package_available package_tote_1)
    (assigned_source customer_order_1 source_location_warehouse_1)
    (line_assigned_route order_line_1 delivery_route_1)
    (transport_unit_available transport_unit_1)
    (stock_item_available stock_item_batch_1)
    (stock_item_available stock_item_batch_2)
    (shipment_includes_order shipment_1 customer_order_1)
    (shipment_includes_order shipment_2 customer_order_1)
    (shipment_includes_line shipment_1 order_line_1)
    (shipment_includes_line shipment_2 order_line_1)
    (shipment_assigned_transport_unit shipment_1 transport_unit_1)
    (shipment_assigned_transport_unit shipment_2 transport_unit_1)
    (shipment_has_stock_item shipment_1 stock_item_batch_1)
    (shipment_has_stock_item shipment_2 stock_item_batch_2)
    (shipping_mode_available shipping_mode_standard)
    (shipping_mode_available shipping_mode_express)
    (service_level_available service_level_standard)
    (service_level_available service_level_premium)
    (release_authorization_available release_auth_token_1)
    (packing_resource_available packing_station_1)
    (routing_constraint_available routing_constraint_domestic)
    (shipment_routing_constraint shipment_1 routing_constraint_domestic)
    (shipment_routing_constraint shipment_2 routing_constraint_restricted)
    (regulatory_clearance_available regulatory_clearance_customs)
  )
  (:goal
    (and
      (released customer_order_1)
      (released order_line_1)
      (released shipment_1)
      (released shipment_2)
    )
  )
)
