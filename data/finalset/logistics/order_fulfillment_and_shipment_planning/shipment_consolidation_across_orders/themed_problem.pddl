(define (problem consolidate_orders_scenario)
  (:domain shipment_consolidation_domain)
  (:objects src_unit_1 - source_fulfillment_unit dst_unit_1 - destination_fulfillment_unit outbound_shipment_1 - outbound_shipment outbound_shipment_2 - outbound_shipment warehouse_a - source_warehouse warehouse_b - source_warehouse warehouse_c - source_warehouse sku_1 - product_sku handler_1 - handling_resource package_type_box - package_type origin_zone_a - origin_zone destination_zone_a - destination_zone container_1 - consolidation_container package_instance_1 - package_instance package_instance_2 - package_instance routing_profile_fast - routing_profile routing_profile_economy - routing_profile carrier_acme - carrier carrier_globex - carrier service_level_express - service_level special_service_cold_chain - special_service_option reg_doc_1 - regulatory_document reg_doc_2 - regulatory_document compliance_doc_1 - compliance_document)
  (:init
    (warehouse_available warehouse_a)
    (warehouse_available warehouse_b)
    (warehouse_available warehouse_c)
    (sku_available sku_1)
    (handling_resource_available handler_1)
    (package_type_available package_type_box)
    (source_unit_in_origin_zone src_unit_1 origin_zone_a)
    (destination_unit_in_destination_zone dst_unit_1 destination_zone_a)
    (container_available container_1)
    (package_instance_available package_instance_1)
    (package_instance_available package_instance_2)
    (shipment_contains_source_unit outbound_shipment_1 src_unit_1)
    (shipment_contains_source_unit outbound_shipment_2 src_unit_1)
    (shipment_contains_destination_unit outbound_shipment_1 dst_unit_1)
    (shipment_contains_destination_unit outbound_shipment_2 dst_unit_1)
    (shipment_assigned_container outbound_shipment_1 container_1)
    (shipment_assigned_container outbound_shipment_2 container_1)
    (shipment_has_package_instance outbound_shipment_1 package_instance_1)
    (shipment_has_package_instance outbound_shipment_2 package_instance_2)
    (routing_profile_available routing_profile_fast)
    (routing_profile_available routing_profile_economy)
    (carrier_available carrier_acme)
    (carrier_available carrier_globex)
    (service_level_available service_level_express)
    (special_service_option_available special_service_cold_chain)
    (regulatory_document_available reg_doc_1)
    (shipment_has_regulatory_document outbound_shipment_1 reg_doc_1)
    (shipment_has_regulatory_document outbound_shipment_2 reg_doc_2)
    (compliance_document_available compliance_doc_1)
  )
  (:goal
    (and
      (assigned_into_shipment src_unit_1)
      (assigned_into_shipment dst_unit_1)
      (assigned_into_shipment outbound_shipment_1)
      (assigned_into_shipment outbound_shipment_2)
    )
  )
)
