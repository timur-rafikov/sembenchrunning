(define (problem inventory_commitment_scenario)
  (:domain order_fulfillment_inventory_commitment)
  (:objects order_line_primary_1 - order_line_primary order_line_competing_1 - order_line_competing fulfillment_request_1 - fulfillment_request fulfillment_request_2 - fulfillment_request fulfillment_center_1 - fulfillment_center fulfillment_center_2 - fulfillment_center fulfillment_center_3 - fulfillment_center product_sku_1 - product_sku warehouse_zone_a - warehouse_zone inventory_lot_1 - inventory_lot pick_slot_1 - pick_slot consolidation_slot_1 - consolidation_slot shipment_1 - shipment package_1 - package package_2 - package routing_profile_express - routing_profile routing_profile_standard - routing_profile transport_equipment_1 - transport_equipment transport_equipment_2 - transport_equipment delivery_time_window_1 - delivery_time_window special_handling_resource_1 - special_handling_resource service_option_express - service_option service_option_standard - service_option carrier_1 - carrier)
  (:init
    (fulfillment_center_available fulfillment_center_1)
    (fulfillment_center_available fulfillment_center_2)
    (fulfillment_center_available fulfillment_center_3)
    (sku_available product_sku_1)
    (warehouse_zone_available warehouse_zone_a)
    (inventory_lot_available inventory_lot_1)
    (order_line_candidate_pick_slot order_line_primary_1 pick_slot_1)
    (competing_line_candidate_consolidation_slot order_line_competing_1 consolidation_slot_1)
    (shipment_available_for_consolidation shipment_1)
    (package_available package_1)
    (package_available package_2)
    (fulfillment_request_assigned_primary_line fulfillment_request_1 order_line_primary_1)
    (fulfillment_request_assigned_primary_line fulfillment_request_2 order_line_primary_1)
    (fulfillment_request_assigned_competing_line fulfillment_request_1 order_line_competing_1)
    (fulfillment_request_assigned_competing_line fulfillment_request_2 order_line_competing_1)
    (fulfillment_request_assigned_shipment fulfillment_request_1 shipment_1)
    (fulfillment_request_assigned_shipment fulfillment_request_2 shipment_1)
    (fulfillment_request_assigned_package fulfillment_request_1 package_1)
    (fulfillment_request_assigned_package fulfillment_request_2 package_2)
    (routing_profile_available routing_profile_express)
    (routing_profile_available routing_profile_standard)
    (transport_equipment_available transport_equipment_1)
    (transport_equipment_available transport_equipment_2)
    (delivery_time_window_available delivery_time_window_1)
    (special_handling_resource_available special_handling_resource_1)
    (service_option_available service_option_express)
    (fulfillment_request_assigned_service_option fulfillment_request_1 service_option_express)
    (fulfillment_request_assigned_service_option fulfillment_request_2 service_option_standard)
    (carrier_available carrier_1)
  )
  (:goal
    (and
      (allocation_committed order_line_primary_1)
      (allocation_committed order_line_competing_1)
      (allocation_committed fulfillment_request_1)
      (allocation_committed fulfillment_request_2)
    )
  )
)
