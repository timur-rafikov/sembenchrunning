(define (problem bundled_order_fulfillment_scenario)
  (:domain logistics_bundled_order_component_coordination)
  (:objects pick_task_1 - pick_task pack_task_1 - pack_task customer_order_1 - customer_order customer_order_2 - customer_order inventory_source_north - inventory_source inventory_source_south - inventory_source inventory_source_central - inventory_source sku_item_001 - sku_item picker_1 - fulfillment_resource inventory_unit_lot_1 - inventory_unit consolidation_slot_a - consolidation_slot route_segment_01 - transport_route_segment shipment_slot_1 - shipment package_box_standard - package_type package_pallet_standard - package_type packing_profile_standard - packing_profile packing_profile_fragile - packing_profile service_level_standard - service_level_option service_level_expedited - service_level_option delivery_window_morning - delivery_time_window handling_requirement_temperature_control - handling_requirement customer_instruction_doc_1 - customer_instruction customer_instruction_note_1 - customer_instruction carrier_preference_default - carrier_preference)
  (:init
    (inventory_source_available inventory_source_north)
    (inventory_source_available inventory_source_south)
    (inventory_source_available inventory_source_central)
    (sku_available sku_item_001)
    (fulfillment_resource_available picker_1)
    (inventory_unit_available inventory_unit_lot_1)
    (pick_task_assigned_slot pick_task_1 consolidation_slot_a)
    (pack_task_assigned_route_segment pack_task_1 route_segment_01)
    (shipment_placeholder_available shipment_slot_1)
    (package_type_available package_box_standard)
    (package_type_available package_pallet_standard)
    (customer_order_includes_pick_task customer_order_1 pick_task_1)
    (customer_order_includes_pick_task customer_order_2 pick_task_1)
    (customer_order_includes_pack_task customer_order_1 pack_task_1)
    (customer_order_includes_pack_task customer_order_2 pack_task_1)
    (customer_order_assigned_shipment customer_order_1 shipment_slot_1)
    (customer_order_assigned_shipment customer_order_2 shipment_slot_1)
    (order_assigned_package_type customer_order_1 package_box_standard)
    (order_assigned_package_type customer_order_2 package_pallet_standard)
    (packing_profile_available packing_profile_standard)
    (packing_profile_available packing_profile_fragile)
    (service_level_option_available service_level_standard)
    (service_level_option_available service_level_expedited)
    (delivery_time_window_available delivery_window_morning)
    (handling_requirement_available handling_requirement_temperature_control)
    (customer_instruction_available customer_instruction_doc_1)
    (order_assigned_customer_instruction customer_order_1 customer_instruction_doc_1)
    (order_assigned_customer_instruction customer_order_2 customer_instruction_note_1)
    (carrier_preference_available carrier_preference_default)
  )
  (:goal
    (and
      (ready_for_outbound pick_task_1)
      (ready_for_outbound pack_task_1)
      (ready_for_outbound customer_order_1)
      (ready_for_outbound customer_order_2)
    )
  )
)
