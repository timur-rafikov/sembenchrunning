(define (problem cut_off_sensitive_order_release_problem)
  (:domain cut_off_sensitive_order_release_domain)
  (:objects source_fulfillment_unit_a - source_fulfillment_unit destination_fulfillment_unit_a - destination_fulfillment_unit shipment_a - shipment shipment_b - shipment warehouse_a - source_location warehouse_b - source_location warehouse_c - source_location cutoff_window_a - release_window pack_station_a - handling_resource fulfillment_item_a - fulfillment_item source_shipment_segment_a - source_shipment_segment destination_shipment_segment_a - destination_shipment_segment transport_unit_a - transport_unit pack_unit_a - pack_unit pack_unit_b - pack_unit routing_option_a - routing_option routing_option_b - routing_option stowage_profile_a - stowage_profile stowage_profile_b - stowage_profile express_service_level - service_level_profile refrigerated_equipment_requirement - equipment_requirement carrier_preference_a - carrier_preference carrier_preference_b - carrier_preference cold_chain_profile - temperature_profile)
  (:init
    (source_location_available warehouse_a)
    (source_location_available warehouse_b)
    (source_location_available warehouse_c)
    (release_window_available cutoff_window_a)
    (handling_resource_available pack_station_a)
    (fulfillment_item_available fulfillment_item_a)
    (source_segment_linked source_fulfillment_unit_a source_shipment_segment_a)
    (destination_segment_linked destination_fulfillment_unit_a destination_shipment_segment_a)
    (transport_unit_available transport_unit_a)
    (pack_unit_available pack_unit_a)
    (pack_unit_available pack_unit_b)
    (shipment_source_linked shipment_a source_fulfillment_unit_a)
    (shipment_source_linked shipment_b source_fulfillment_unit_a)
    (shipment_destination_linked shipment_a destination_fulfillment_unit_a)
    (shipment_destination_linked shipment_b destination_fulfillment_unit_a)
    (shipment_transport_unit_linked shipment_a transport_unit_a)
    (shipment_transport_unit_linked shipment_b transport_unit_a)
    (shipment_pack_unit_linked shipment_a pack_unit_a)
    (shipment_pack_unit_linked shipment_b pack_unit_b)
    (routing_option_available routing_option_a)
    (routing_option_available routing_option_b)
    (stowage_profile_available stowage_profile_a)
    (stowage_profile_available stowage_profile_b)
    (service_level_profile_available express_service_level)
    (equipment_requirement_available refrigerated_equipment_requirement)
    (carrier_preference_available carrier_preference_a)
    (carrier_preference_linked shipment_a carrier_preference_a)
    (carrier_preference_linked shipment_b carrier_preference_b)
    (temperature_profile_available cold_chain_profile)
  )
  (:goal
    (and
      (outbound_closed source_fulfillment_unit_a)
      (outbound_closed destination_fulfillment_unit_a)
      (outbound_closed shipment_a)
      (outbound_closed shipment_b)
    )
  )
)
