(define (problem return_replacement_scenario)
  (:domain return_replacement_outbound_planning)
  (:objects return_line_1 - return_line replacement_line_1 - replacement_line shipment_plan_1 - shipment_plan shipment_plan_2 - shipment_plan fulfillment_source_1 - fulfillment_source fulfillment_source_2 - fulfillment_source fulfillment_source_3 - fulfillment_source handling_profile_1 - handling_profile warehouse_resource_1 - warehouse_resource inventory_unit_1 - inventory_unit return_node_1 - return_node replacement_node_1 - replacement_node transport_unit_1 - transport_unit packaging_unit_1 - packaging_unit packaging_unit_2 - packaging_unit label_profile_1 - label_profile label_profile_2 - label_profile service_level_standard - service_level service_level_expedited - service_level route_slot_1 - route_slot handling_equipment_1 - handling_equipment return_authorization_1 - return_authorization return_authorization_2 - return_authorization time_window_1 - time_window)
  (:init
    (fulfillment_source_available fulfillment_source_1)
    (fulfillment_source_available fulfillment_source_2)
    (fulfillment_source_available fulfillment_source_3)
    (handling_profile_available handling_profile_1)
    (warehouse_resource_available warehouse_resource_1)
    (inventory_unit_available inventory_unit_1)
    (return_line_eligible_for_return_node return_line_1 return_node_1)
    (replacement_line_eligible_for_replacement_node replacement_line_1 replacement_node_1)
    (transport_unit_available transport_unit_1)
    (packaging_unit_available packaging_unit_1)
    (packaging_unit_available packaging_unit_2)
    (shipment_plan_links_return_line shipment_plan_1 return_line_1)
    (shipment_plan_links_return_line shipment_plan_2 return_line_1)
    (shipment_plan_links_replacement_line shipment_plan_1 replacement_line_1)
    (shipment_plan_links_replacement_line shipment_plan_2 replacement_line_1)
    (shipment_plan_linked_transport_unit shipment_plan_1 transport_unit_1)
    (shipment_plan_linked_transport_unit shipment_plan_2 transport_unit_1)
    (shipment_plan_requires_packaging_unit shipment_plan_1 packaging_unit_1)
    (shipment_plan_requires_packaging_unit shipment_plan_2 packaging_unit_2)
    (label_profile_available label_profile_1)
    (label_profile_available label_profile_2)
    (service_level_resource_available service_level_standard)
    (service_level_resource_available service_level_expedited)
    (route_slot_available route_slot_1)
    (handling_equipment_available handling_equipment_1)
    (return_authorization_available return_authorization_1)
    (shipment_plan_linked_return_authorization shipment_plan_1 return_authorization_1)
    (shipment_plan_linked_return_authorization shipment_plan_2 return_authorization_2)
    (time_window_available time_window_1)
  )
  (:goal
    (and
      (fulfillment_item_ready_for_shipment return_line_1)
      (fulfillment_item_ready_for_shipment replacement_line_1)
      (fulfillment_item_ready_for_shipment shipment_plan_1)
      (fulfillment_item_ready_for_shipment shipment_plan_2)
    )
  )
)
