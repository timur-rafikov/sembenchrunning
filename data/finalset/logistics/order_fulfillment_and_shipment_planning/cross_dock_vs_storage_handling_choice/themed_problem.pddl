(define (problem cross_dock_handling_scenario)
  (:domain cross_dock_vs_storage_domain)
  (:objects inbound_shipment_1 - inbound_shipment outbound_shipment_1 - outbound_shipment transfer_job_1 - transfer_job transfer_job_2 - transfer_job supply_location_a - supply_location supply_location_b - supply_location supply_location_c - supply_location inventory_item_1 - inventory_item handling_resource_forklift_1 - handling_resource package_unit_1 - package_unit inbound_dock_1 - inbound_dock outbound_dock_1 - outbound_dock load_unit_1 - load_unit staging_slot_a - staging_slot staging_slot_b - staging_slot routing_profile_1 - routing_profile routing_profile_2 - routing_profile carrier_service_express - carrier_service carrier_service_standard - carrier_service delivery_slot_1 - delivery_slot equipment_capability_forklift - equipment_capability appointment_1 - appointment appointment_2 - appointment time_window_1 - time_window)
  (:init
    (supply_location_available supply_location_a)
    (supply_location_available supply_location_b)
    (supply_location_available supply_location_c)
    (inventory_available inventory_item_1)
    (handling_resource_available handling_resource_forklift_1)
    (package_unit_available package_unit_1)
    (assigned_inbound_dock inbound_shipment_1 inbound_dock_1)
    (assigned_outbound_dock outbound_shipment_1 outbound_dock_1)
    (load_unit_available load_unit_1)
    (staging_slot_available staging_slot_a)
    (staging_slot_available staging_slot_b)
    (transfer_job_has_inbound transfer_job_1 inbound_shipment_1)
    (transfer_job_has_inbound transfer_job_2 inbound_shipment_1)
    (transfer_job_has_outbound transfer_job_1 outbound_shipment_1)
    (transfer_job_has_outbound transfer_job_2 outbound_shipment_1)
    (transfer_job_assigned_to_load_unit transfer_job_1 load_unit_1)
    (transfer_job_assigned_to_load_unit transfer_job_2 load_unit_1)
    (transfer_job_assigned_staging_slot transfer_job_1 staging_slot_a)
    (transfer_job_assigned_staging_slot transfer_job_2 staging_slot_b)
    (routing_profile_available routing_profile_1)
    (routing_profile_available routing_profile_2)
    (carrier_service_available carrier_service_express)
    (carrier_service_available carrier_service_standard)
    (delivery_slot_available delivery_slot_1)
    (equipment_capability_available equipment_capability_forklift)
    (appointment_available appointment_1)
    (transfer_job_has_appointment transfer_job_1 appointment_1)
    (transfer_job_has_appointment transfer_job_2 appointment_2)
    (time_window_available time_window_1)
  )
  (:goal
    (and
      (released_for_transport inbound_shipment_1)
      (released_for_transport outbound_shipment_1)
      (released_for_transport transfer_job_1)
      (released_for_transport transfer_job_2)
    )
  )
)
