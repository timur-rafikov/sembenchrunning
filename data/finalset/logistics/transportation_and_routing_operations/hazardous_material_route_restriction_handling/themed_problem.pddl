(define (problem hazmat_route_restriction_scenario)
  (:domain hazmat_route_restriction_handling_domain)
  (:objects pickup_leg_1 - pickup_leg delivery_leg_1 - delivery_leg dispatch_operator_1 - dispatch_operator dispatch_operator_2 - dispatch_operator transport_unit_1 - transport_unit transport_unit_2 - transport_unit transport_unit_3 - transport_unit hazard_profile_1 - hazard_profile escort_team_1 - escort_team cargo_item_1 - cargo_item origin_node_1 - origin_node destination_node_1 - destination_node manifest_1 - manifest container_1 - container container_2 - container regulatory_document_1 - regulatory_document regulatory_document_2 - regulatory_document crew_credential_1 - crew_credential crew_credential_2 - crew_credential route_restriction_1 - route_restriction special_equipment_1 - special_equipment operator_license_1 - operator_license operator_license_2 - operator_license authority_clearance_1 - authority_clearance)
  (:init
    (transport_unit_available transport_unit_1)
    (transport_unit_available transport_unit_2)
    (transport_unit_available transport_unit_3)
    (hazard_profile_available hazard_profile_1)
    (escort_team_available escort_team_1)
    (cargo_item_available cargo_item_1)
    (pickup_leg_origin_assigned pickup_leg_1 origin_node_1)
    (delivery_leg_destination_assigned delivery_leg_1 destination_node_1)
    (manifest_available manifest_1)
    (container_available container_1)
    (container_available container_2)
    (operator_assigned_to_pickup_leg dispatch_operator_1 pickup_leg_1)
    (operator_assigned_to_pickup_leg dispatch_operator_2 pickup_leg_1)
    (operator_assigned_to_delivery_leg dispatch_operator_1 delivery_leg_1)
    (operator_assigned_to_delivery_leg dispatch_operator_2 delivery_leg_1)
    (operator_assigned_to_manifest dispatch_operator_1 manifest_1)
    (operator_assigned_to_manifest dispatch_operator_2 manifest_1)
    (operator_has_container dispatch_operator_1 container_1)
    (operator_has_container dispatch_operator_2 container_2)
    (regulatory_document_available regulatory_document_1)
    (regulatory_document_available regulatory_document_2)
    (crew_credential_available crew_credential_1)
    (crew_credential_available crew_credential_2)
    (route_restriction_available route_restriction_1)
    (special_equipment_available special_equipment_1)
    (operator_license_available operator_license_1)
    (operator_has_license dispatch_operator_1 operator_license_1)
    (operator_has_license dispatch_operator_2 operator_license_2)
    (authority_clearance_available authority_clearance_1)
  )
  (:goal
    (and
      (route_restriction_applied_entity pickup_leg_1)
      (route_restriction_applied_entity delivery_leg_1)
      (route_restriction_applied_entity dispatch_operator_1)
      (route_restriction_applied_entity dispatch_operator_2)
    )
  )
)
