(define (problem ev_charging_stop_insertion_problem)
  (:domain electric_vehicle_charging_stop_insertion)
  (:objects departure_leg_1 - departure_leg arrival_leg_1 - arrival_leg vehicle_route_1 - vehicle_route vehicle_route_2 - vehicle_route charger_station_1 - charger_station charger_station_2 - charger_station charger_station_3 - charger_station connector_requirement_1 - connector_requirement charger_connector_1 - charger_connector adapter_unit_1 - adapter_unit candidate_departure_charger_1 - candidate_charger_departure candidate_arrival_charger_1 - candidate_charger_arrival charging_stop_candidate_1 - charging_stop_candidate access_permit_1 - access_permit access_permit_2 - access_permit time_window_profile_1 - time_window_profile time_window_profile_2 - time_window_profile charging_profile_1 - charging_profile charging_profile_2 - charging_profile time_slot_1 - time_slot charger_model_1 - charger_model driver_preference_1 - driver_preference driver_preference_2 - driver_preference session_token_1 - session_token)
  (:init
    (charger_station_available charger_station_1)
    (charger_station_available charger_station_2)
    (charger_station_available charger_station_3)
    (connector_requirement_available connector_requirement_1)
    (charger_connector_available charger_connector_1)
    (adapter_unit_available adapter_unit_1)
    (leg_mapped_to_candidate_departure_charger departure_leg_1 candidate_departure_charger_1)
    (leg_mapped_to_candidate_arrival_charger arrival_leg_1 candidate_arrival_charger_1)
    (charging_stop_candidate_available charging_stop_candidate_1)
    (access_permit_available access_permit_1)
    (access_permit_available access_permit_2)
    (vehicle_route_has_departure_leg vehicle_route_1 departure_leg_1)
    (vehicle_route_has_departure_leg vehicle_route_2 departure_leg_1)
    (vehicle_route_has_arrival_leg vehicle_route_1 arrival_leg_1)
    (vehicle_route_has_arrival_leg vehicle_route_2 arrival_leg_1)
    (vehicle_route_assigned_stop_candidate vehicle_route_1 charging_stop_candidate_1)
    (vehicle_route_assigned_stop_candidate vehicle_route_2 charging_stop_candidate_1)
    (vehicle_route_holds_access_permit vehicle_route_1 access_permit_1)
    (vehicle_route_holds_access_permit vehicle_route_2 access_permit_2)
    (time_window_profile_available time_window_profile_1)
    (time_window_profile_available time_window_profile_2)
    (charging_profile_available charging_profile_1)
    (charging_profile_available charging_profile_2)
    (time_slot_available time_slot_1)
    (charger_model_available charger_model_1)
    (driver_preference_available driver_preference_1)
    (vehicle_route_has_driver_preference_binding vehicle_route_1 driver_preference_1)
    (vehicle_route_has_driver_preference_binding vehicle_route_2 driver_preference_2)
    (session_token_available session_token_1)
  )
  (:goal
    (and
      (route_element_inserted departure_leg_1)
      (route_element_inserted arrival_leg_1)
      (route_element_inserted vehicle_route_1)
      (route_element_inserted vehicle_route_2)
    )
  )
)
