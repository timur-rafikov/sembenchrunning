(define (problem route_profile_matching_scenario)
  (:domain fleet_type_matching_domain)
  (:objects origin_leg_profile_1 - origin_leg_profile destination_leg_profile_1 - destination_leg_profile vehicle_unit_1 - vehicle_unit vehicle_unit_2 - vehicle_unit fleet_type_light_van - fleet_type fleet_type_heavy_truck - fleet_type fleet_type_intermodal - fleet_type time_window_slot_1 - time_window depot_main - depot cargo_unit_pallet_1 - cargo_unit origin_node_a - origin_node destination_node_b - destination_node transport_leg_1 - transport_leg container_unit_1 - container_unit container_unit_2 - container_unit vehicle_model_a - vehicle_model vehicle_model_b - vehicle_model service_option_refrigeration - service_option service_option_liftgate - service_option route_requirement_hazardous - route_requirement_tag vehicle_equipment_refrigeration_unit - vehicle_equipment operator_qualification_cert_a - operator_qualification operator_qualification_cert_b - operator_qualification vehicle_availability_constraint_weekend_restriction - vehicle_availability_constraint)
  (:init
    (fleet_type_available fleet_type_light_van)
    (fleet_type_available fleet_type_heavy_truck)
    (fleet_type_available fleet_type_intermodal)
    (time_window_available time_window_slot_1)
    (depot_available depot_main)
    (cargo_unit_available cargo_unit_pallet_1)
    (origin_leg_profile_at_origin_node origin_leg_profile_1 origin_node_a)
    (destination_leg_profile_at_node destination_leg_profile_1 destination_node_b)
    (transport_leg_unassigned transport_leg_1)
    (container_available container_unit_1)
    (container_available container_unit_2)
    (vehicle_origin_leg_compatibility vehicle_unit_1 origin_leg_profile_1)
    (vehicle_origin_leg_compatibility vehicle_unit_2 origin_leg_profile_1)
    (vehicle_destination_leg_compatibility vehicle_unit_1 destination_leg_profile_1)
    (vehicle_destination_leg_compatibility vehicle_unit_2 destination_leg_profile_1)
    (vehicle_assigned_to_transport_leg vehicle_unit_1 transport_leg_1)
    (vehicle_assigned_to_transport_leg vehicle_unit_2 transport_leg_1)
    (vehicle_container_compatible vehicle_unit_1 container_unit_1)
    (vehicle_container_compatible vehicle_unit_2 container_unit_2)
    (vehicle_model_available vehicle_model_a)
    (vehicle_model_available vehicle_model_b)
    (service_option_available service_option_refrigeration)
    (service_option_available service_option_liftgate)
    (route_requirement_tag_available route_requirement_hazardous)
    (vehicle_equipment_available vehicle_equipment_refrigeration_unit)
    (operator_qualification_available operator_qualification_cert_a)
    (vehicle_has_operator_qualification vehicle_unit_1 operator_qualification_cert_a)
    (vehicle_has_operator_qualification vehicle_unit_2 operator_qualification_cert_b)
    (vehicle_availability_constraint_available vehicle_availability_constraint_weekend_restriction)
  )
  (:goal
    (and
      (resource_bound origin_leg_profile_1)
      (resource_bound destination_leg_profile_1)
      (resource_bound vehicle_unit_1)
      (resource_bound vehicle_unit_2)
    )
  )
)
