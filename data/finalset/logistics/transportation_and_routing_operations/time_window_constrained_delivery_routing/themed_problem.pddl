(define (problem time_window_constrained_delivery_problem)
  (:domain time_window_constrained_delivery_routing)
  (:objects pickup_stop_1 - pickup_stop delivery_stop_1 - delivery_stop route_plan_alpha - route_plan route_plan_beta - route_plan vehicle_asset_1 - vehicle_asset vehicle_asset_2 - vehicle_asset vehicle_asset_3 - vehicle_asset time_window_slot_1 - time_window_slot driver_1 - driver package_unit_1 - package_unit origin_hub_primary - origin_hub destination_hub_primary - destination_hub transfer_leg_1 - transfer_leg container_1 - container container_2 - container priority_marker_high - priority_marker priority_marker_low - priority_marker assignment_profile_standard - assignment_profile assignment_profile_express - assignment_profile shipment_batch_1 - shipment_batch equipment_item_forklift - equipment_item authorization_token_1 - authorization_token authorization_token_2 - authorization_token special_constraint_1 - special_constraint)
  (:init
    (vehicle_available vehicle_asset_1)
    (vehicle_available vehicle_asset_2)
    (vehicle_available vehicle_asset_3)
    (time_slot_available time_window_slot_1)
    (driver_available driver_1)
    (package_available package_unit_1)
    (pickup_at_origin_hub pickup_stop_1 origin_hub_primary)
    (delivery_at_destination_hub delivery_stop_1 destination_hub_primary)
    (transfer_leg_pending transfer_leg_1)
    (container_available container_1)
    (container_available container_2)
    (route_plan_includes_pickup route_plan_alpha pickup_stop_1)
    (route_plan_includes_pickup route_plan_beta pickup_stop_1)
    (route_plan_includes_delivery route_plan_alpha delivery_stop_1)
    (route_plan_includes_delivery route_plan_beta delivery_stop_1)
    (route_plan_includes_transfer_leg route_plan_alpha transfer_leg_1)
    (route_plan_includes_transfer_leg route_plan_beta transfer_leg_1)
    (route_plan_includes_container route_plan_alpha container_1)
    (route_plan_includes_container route_plan_beta container_2)
    (priority_marker_available priority_marker_high)
    (priority_marker_available priority_marker_low)
    (assignment_profile_available assignment_profile_standard)
    (assignment_profile_available assignment_profile_express)
    (shipment_batch_available shipment_batch_1)
    (equipment_available equipment_item_forklift)
    (authorization_token_available authorization_token_1)
    (route_plan_has_authorization route_plan_alpha authorization_token_1)
    (route_plan_has_authorization route_plan_beta authorization_token_2)
    (special_constraint_available special_constraint_1)
  )
  (:goal
    (and
      (finalized pickup_stop_1)
      (finalized delivery_stop_1)
      (finalized route_plan_alpha)
      (finalized route_plan_beta)
    )
  )
)
