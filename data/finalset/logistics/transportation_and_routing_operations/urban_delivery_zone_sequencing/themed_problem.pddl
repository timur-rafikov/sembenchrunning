(define (problem urban_delivery_zone_sequencing_problem)
  (:domain urban_delivery_zone_sequencing_domain)
  (:objects vehicle_1 - vehicle_unit driver_1 - driver_operator route_plan_1 - route_plan route_plan_2 - route_plan mode_van - transport_mode mode_bike - transport_mode mode_e_cargo - transport_mode dispatch_window_1 - dispatch_window handling_agent_1 - handling_agent cargo_unit_1 - cargo_unit origin_zone_1 - origin_zone destination_zone_1 - destination_zone transport_leg_1 - transport_leg container_1 - container_unit container_2 - container_unit access_permit_1 - access_permit access_permit_2 - access_permit service_requirement_1 - service_requirement service_requirement_2 - service_requirement delivery_slot_1 - delivery_slot equipment_1 - vehicle_equipment priority_tag_1 - priority_tag priority_tag_2 - priority_tag clearance_1 - regulatory_clearance)
  (:init
    (mode_available mode_van)
    (mode_available mode_bike)
    (mode_available mode_e_cargo)
    (time_window_available dispatch_window_1)
    (handling_agent_available handling_agent_1)
    (cargo_unit_available cargo_unit_1)
    (vehicle_zone_assignment vehicle_1 origin_zone_1)
    (driver_zone_assignment driver_1 destination_zone_1)
    (transport_leg_available transport_leg_1)
    (container_available container_1)
    (container_available container_2)
    (route_vehicle_relation route_plan_1 vehicle_1)
    (route_vehicle_relation route_plan_2 vehicle_1)
    (route_driver_relation route_plan_1 driver_1)
    (route_driver_relation route_plan_2 driver_1)
    (route_leg_relation route_plan_1 transport_leg_1)
    (route_leg_relation route_plan_2 transport_leg_1)
    (route_container_relation route_plan_1 container_1)
    (route_container_relation route_plan_2 container_2)
    (access_permit_available access_permit_1)
    (access_permit_available access_permit_2)
    (service_requirement_available service_requirement_1)
    (service_requirement_available service_requirement_2)
    (delivery_slot_available delivery_slot_1)
    (equipment_available equipment_1)
    (priority_tag_available priority_tag_1)
    (route_priority_binding route_plan_1 priority_tag_1)
    (route_priority_binding route_plan_2 priority_tag_2)
    (clearance_available clearance_1)
  )
  (:goal
    (and
      (deployed_integrated vehicle_1)
      (deployed_integrated driver_1)
      (deployed_integrated route_plan_1)
      (deployed_integrated route_plan_2)
    )
  )
)
