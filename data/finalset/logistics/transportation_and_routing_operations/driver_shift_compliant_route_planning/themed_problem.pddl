(define (problem driver_shift_compliant_route_planning_problem)
  (:domain driver_shift_compliant_route_planning)
  (:objects origin_availability_alpha - origin_candidate_availability destination_availability_alpha - destination_candidate_availability shift_candidate_alpha - schedule_candidate shift_candidate_beta - schedule_candidate vehicle_unit_alpha - vehicle_unit vehicle_unit_beta - vehicle_unit vehicle_unit_gamma - vehicle_unit route_task_profile_alpha - route_task_profile driver_operator_alpha - operator_resource cargo_payload_alpha - cargo_payload origin_node_alpha - origin_node destination_node_alpha - destination_node transport_leg_alpha - transport_leg loading_container_alpha - loading_container loading_container_beta - loading_container equipment_resource_alpha - equipment_resource equipment_resource_beta - equipment_resource service_window_alpha - service_window service_window_beta - service_window dispatch_slot_alpha - dispatch_slot skill_certificate_alpha - skill_certificate operational_constraint_alpha - operational_constraint operational_constraint_beta - operational_constraint compliance_certificate_alpha - compliance_certificate)
  (:init
    (vehicle_available vehicle_unit_alpha)
    (vehicle_available vehicle_unit_beta)
    (vehicle_available vehicle_unit_gamma)
    (route_task_profile_available route_task_profile_alpha)
    (operator_available driver_operator_alpha)
    (cargo_available cargo_payload_alpha)
    (origin_availability_node_linked origin_availability_alpha origin_node_alpha)
    (destination_availability_node_linked destination_availability_alpha destination_node_alpha)
    (transport_leg_available transport_leg_alpha)
    (loading_container_available loading_container_alpha)
    (loading_container_available loading_container_beta)
    (candidate_origin_availability_linked shift_candidate_alpha origin_availability_alpha)
    (candidate_origin_availability_linked shift_candidate_beta origin_availability_alpha)
    (candidate_destination_availability_linked shift_candidate_alpha destination_availability_alpha)
    (candidate_destination_availability_linked shift_candidate_beta destination_availability_alpha)
    (candidate_transport_leg_linked shift_candidate_alpha transport_leg_alpha)
    (candidate_transport_leg_linked shift_candidate_beta transport_leg_alpha)
    (candidate_loading_container_linked shift_candidate_alpha loading_container_alpha)
    (candidate_loading_container_linked shift_candidate_beta loading_container_beta)
    (equipment_available equipment_resource_alpha)
    (equipment_available equipment_resource_beta)
    (service_window_available service_window_alpha)
    (service_window_available service_window_beta)
    (dispatch_slot_available dispatch_slot_alpha)
    (skill_certificate_available skill_certificate_alpha)
    (operational_constraint_available operational_constraint_alpha)
    (candidate_operational_constraint_linked shift_candidate_alpha operational_constraint_alpha)
    (candidate_operational_constraint_linked shift_candidate_beta operational_constraint_beta)
    (compliance_certificate_available compliance_certificate_alpha)
  )
  (:goal
    (and
      (dispatched origin_availability_alpha)
      (dispatched destination_availability_alpha)
      (dispatched shift_candidate_alpha)
      (dispatched shift_candidate_beta)
    )
  )
)
