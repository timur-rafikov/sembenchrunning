(define (problem dock_appointment_dispatch_scenario)
  (:domain dock_appointment_aligned_dispatch_planning)
  (:objects inbound_stop_a - inbound_stop outbound_stop_a - outbound_stop dispatch_job_alpha - dispatch_job dispatch_job_bravo - dispatch_job vehicle_truck_1 - vehicle_unit vehicle_truck_2 - vehicle_unit vehicle_truck_3 - vehicle_unit appointment_slot_1 - appointment_slot dock_door_1 - dock_door pallet_1 - load_unit inbound_leg_1 - inbound_leg outbound_leg_1 - outbound_leg trailer_1 - trailer_unit forklift_1 - handling_equipment forklift_2 - handling_equipment special_service_refrigeration - special_service special_service_crossdock - special_service driver_1 - driver_resource driver_2 - driver_resource bol_1 - shipping_document container_1 - container_equipment consignee_auth_1 - consignee_authorization consignee_auth_2 - consignee_authorization regulatory_permit_1 - regulatory_permit)
  (:init
    (vehicle_available vehicle_truck_1)
    (vehicle_available vehicle_truck_2)
    (vehicle_available vehicle_truck_3)
    (appointment_available appointment_slot_1)
    (door_available dock_door_1)
    (load_unit_available pallet_1)
    (inbound_leg_for_stop inbound_stop_a inbound_leg_1)
    (outbound_leg_for_stop outbound_stop_a outbound_leg_1)
    (trailer_available trailer_1)
    (equipment_available forklift_1)
    (equipment_available forklift_2)
    (dispatch_job_includes_inbound_stop dispatch_job_alpha inbound_stop_a)
    (dispatch_job_includes_inbound_stop dispatch_job_bravo inbound_stop_a)
    (dispatch_job_includes_outbound_stop dispatch_job_alpha outbound_stop_a)
    (dispatch_job_includes_outbound_stop dispatch_job_bravo outbound_stop_a)
    (dispatch_job_assigned_trailer dispatch_job_alpha trailer_1)
    (dispatch_job_assigned_trailer dispatch_job_bravo trailer_1)
    (equipment_assigned_to_dispatch_job dispatch_job_alpha forklift_1)
    (equipment_assigned_to_dispatch_job dispatch_job_bravo forklift_2)
    (special_service_available special_service_refrigeration)
    (special_service_available special_service_crossdock)
    (driver_available driver_1)
    (driver_available driver_2)
    (shipping_document_available bol_1)
    (container_equipment_available container_1)
    (authorization_available consignee_auth_1)
    (job_has_consignee_authorization dispatch_job_alpha consignee_auth_1)
    (job_has_consignee_authorization dispatch_job_bravo consignee_auth_2)
    (regulatory_permit_available regulatory_permit_1)
  )
  (:goal
    (and
      (dispatch_entity_released_for_execution inbound_stop_a)
      (dispatch_entity_released_for_execution outbound_stop_a)
      (dispatch_entity_released_for_execution dispatch_job_alpha)
      (dispatch_entity_released_for_execution dispatch_job_bravo)
    )
  )
)
