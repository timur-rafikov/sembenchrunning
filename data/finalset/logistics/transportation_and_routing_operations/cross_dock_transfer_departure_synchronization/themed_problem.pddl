(define (problem cross_dock_transfer_departure_case)
  (:domain cross_dock_transfer_departure_synchronization)
  (:objects inbound_movement_1 - inbound_movement outbound_movement_1 - outbound_movement transfer_job_1 - transfer_job transfer_job_2 - transfer_job transport_asset_1 - transport_asset transport_asset_2 - transport_asset transport_asset_3 - transport_asset time_slot_1 - time_slot dock_bay_1 - dock_bay unit_load_1 - unit_load inbound_slot_1 - inbound_slot outbound_slot_1 - outbound_slot departure_batch_1 - departure_batch handling_equipment_1 - handling_equipment handling_equipment_2 - handling_equipment clearance_1 - clearance clearance_2 - clearance cargo_profile_1 - cargo_profile cargo_profile_2 - cargo_profile routing_document_1 - routing_document equipment_team_1 - equipment_team carrier_authorization_1 - carrier_authorization carrier_authorization_2 - carrier_authorization security_pass_1 - security_pass)
  (:init
    (asset_available transport_asset_1)
    (asset_available transport_asset_2)
    (asset_available transport_asset_3)
    (time_slot_available time_slot_1)
    (dock_available dock_bay_1)
    (unit_load_available unit_load_1)
    (inbound_movement_assigned_inbound_slot inbound_movement_1 inbound_slot_1)
    (outbound_movement_assigned_outbound_slot outbound_movement_1 outbound_slot_1)
    (departure_batch_available departure_batch_1)
    (equipment_available handling_equipment_1)
    (equipment_available handling_equipment_2)
    (transfer_job_assigned_inbound_movement transfer_job_1 inbound_movement_1)
    (transfer_job_assigned_inbound_movement transfer_job_2 inbound_movement_1)
    (transfer_job_assigned_outbound_movement transfer_job_1 outbound_movement_1)
    (transfer_job_assigned_outbound_movement transfer_job_2 outbound_movement_1)
    (transfer_job_part_of_departure_batch transfer_job_1 departure_batch_1)
    (transfer_job_part_of_departure_batch transfer_job_2 departure_batch_1)
    (transfer_job_assigned_equipment transfer_job_1 handling_equipment_1)
    (transfer_job_assigned_equipment transfer_job_2 handling_equipment_2)
    (clearance_available clearance_1)
    (clearance_available clearance_2)
    (cargo_profile_available cargo_profile_1)
    (cargo_profile_available cargo_profile_2)
    (routing_document_available routing_document_1)
    (equipment_team_available equipment_team_1)
    (carrier_authorization_available carrier_authorization_1)
    (transfer_job_has_carrier_authorization transfer_job_1 carrier_authorization_1)
    (transfer_job_has_carrier_authorization transfer_job_2 carrier_authorization_2)
    (security_pass_available security_pass_1)
  )
  (:goal
    (and
      (dispatch_assigned inbound_movement_1)
      (dispatch_assigned outbound_movement_1)
      (dispatch_assigned transfer_job_1)
      (dispatch_assigned transfer_job_2)
    )
  )
)
