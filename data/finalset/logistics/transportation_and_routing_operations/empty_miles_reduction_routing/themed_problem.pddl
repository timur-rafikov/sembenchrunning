(define (problem empty_miles_reduction_scenario)
  (:domain empty_miles_reduction_routing)
  (:objects origin_hub_1 - origin_hub destination_hub_1 - destination_hub vehicle_unit_1 - vehicle_unit vehicle_unit_2 - vehicle_unit pooled_asset_1 - tractor_or_trailer_asset pooled_asset_2 - tractor_or_trailer_asset pooled_asset_3 - tractor_or_trailer_asset pickup_window_1 - time_window yard_equipment_1 - yard_handling_equipment cargo_item_1 - cargo_item pickup_node_1 - pickup_transfer_node delivery_node_1 - delivery_transfer_node trip_segment_1 - trip_segment container_bay_1 - container_bay container_bay_2 - container_bay route_permit_1 - route_permit route_permit_2 - route_permit operator_credential_1 - operator_credential operator_credential_2 - operator_credential destination_record_1 - consignment_destination_record special_equipment_1 - special_equipment service_stop_instruction_1 - service_stop_instruction service_stop_instruction_2 - service_stop_instruction regulatory_document_1 - regulatory_document)
  (:init
    (asset_available pooled_asset_1)
    (asset_available pooled_asset_2)
    (asset_available pooled_asset_3)
    (time_window_available pickup_window_1)
    (yard_equipment_available yard_equipment_1)
    (cargo_item_available cargo_item_1)
    (origin_connected_to_pickup_node origin_hub_1 pickup_node_1)
    (destination_connected_to_delivery_node destination_hub_1 delivery_node_1)
    (trip_available trip_segment_1)
    (container_bay_available container_bay_1)
    (container_bay_available container_bay_2)
    (vehicle_at_origin vehicle_unit_1 origin_hub_1)
    (vehicle_at_origin vehicle_unit_2 origin_hub_1)
    (vehicle_at_destination vehicle_unit_1 destination_hub_1)
    (vehicle_at_destination vehicle_unit_2 destination_hub_1)
    (vehicle_assigned_to_trip vehicle_unit_1 trip_segment_1)
    (vehicle_assigned_to_trip vehicle_unit_2 trip_segment_1)
    (vehicle_has_container_bay vehicle_unit_1 container_bay_1)
    (vehicle_has_container_bay vehicle_unit_2 container_bay_2)
    (route_permit_available route_permit_1)
    (route_permit_available route_permit_2)
    (operator_credential_available operator_credential_1)
    (operator_credential_available operator_credential_2)
    (destination_record_available destination_record_1)
    (special_equipment_available special_equipment_1)
    (service_stop_instruction_available service_stop_instruction_1)
    (vehicle_has_service_stop_instruction vehicle_unit_1 service_stop_instruction_1)
    (vehicle_has_service_stop_instruction vehicle_unit_2 service_stop_instruction_2)
    (regulatory_document_available regulatory_document_1)
  )
  (:goal
    (and
      (dispatch_finalized origin_hub_1)
      (dispatch_finalized destination_hub_1)
      (dispatch_finalized vehicle_unit_1)
      (dispatch_finalized vehicle_unit_2)
    )
  )
)
