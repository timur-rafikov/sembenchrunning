(define (problem return_trip_backhaul_scenario)
  (:domain return_trip_backhaul_assignment_domain)
  (:objects outbound_vehicle_1 - outbound_vehicle return_vehicle_1 - return_vehicle assignment_task_1 - assignment_task assignment_task_2 - assignment_task carrier_1 - carrier_unit carrier_2 - carrier_unit carrier_3 - carrier_unit time_window_1 - time_window transfer_facility_a - transfer_facility cargo_unit_1 - cargo_unit outbound_leg_1 - outbound_leg return_leg_1 - return_leg container_1 - container_unit cargo_batch_1 - cargo_batch cargo_batch_2 - cargo_batch equipment_liftgate - equipment_type equipment_refrigeration - equipment_type service_expedited - service_option service_fragile_handling - service_option constraint_weight_limit - return_constraint special_equipment_forklift - special_equipment auth_token_1 - authorization_token auth_token_2 - authorization_token priority_marker_urgent - priority_marker)
  (:init
    (carrier_available carrier_1)
    (carrier_available carrier_2)
    (carrier_available carrier_3)
    (time_window_available time_window_1)
    (facility_available transfer_facility_a)
    (cargo_unit_unassigned cargo_unit_1)
    (vehicle_assigned_outbound_leg outbound_vehicle_1 outbound_leg_1)
    (return_vehicle_assigned_return_leg return_vehicle_1 return_leg_1)
    (container_available container_1)
    (cargo_batch_available cargo_batch_1)
    (cargo_batch_available cargo_batch_2)
    (task_assigned_outbound_vehicle assignment_task_1 outbound_vehicle_1)
    (task_assigned_outbound_vehicle assignment_task_2 outbound_vehicle_1)
    (task_assigned_return_vehicle assignment_task_1 return_vehicle_1)
    (task_assigned_return_vehicle assignment_task_2 return_vehicle_1)
    (task_assigned_container assignment_task_1 container_1)
    (task_assigned_container assignment_task_2 container_1)
    (task_has_cargo_batch assignment_task_1 cargo_batch_1)
    (task_has_cargo_batch assignment_task_2 cargo_batch_2)
    (equipment_available equipment_liftgate)
    (equipment_available equipment_refrigeration)
    (service_option_available service_expedited)
    (service_option_available service_fragile_handling)
    (return_constraint_available constraint_weight_limit)
    (special_equipment_available special_equipment_forklift)
    (authorization_token_available auth_token_1)
    (task_associated_authorization assignment_task_1 auth_token_1)
    (task_associated_authorization assignment_task_2 auth_token_2)
    (priority_marker_available priority_marker_urgent)
  )
  (:goal
    (and
      (return_assignment_applied outbound_vehicle_1)
      (return_assignment_applied return_vehicle_1)
      (return_assignment_applied assignment_task_1)
      (return_assignment_applied assignment_task_2)
    )
  )
)
