(define (problem bridge_height_restricted_route_adjustment_problem)
  (:domain bridge_height_restricted_route_adjustment_domain)
  (:objects origin_terminal_1 - origin destination_terminal_1 - destination carrier_unit_alpha - carrier_unit carrier_unit_bravo - carrier_unit asset_truck_1 - asset asset_truck_2 - asset asset_truck_3 - asset schedule_slot_1 - schedule_slot operator_team_a - operator cargo_unit_a - cargo_unit segment_bridge_low_1 - height_restricted_segment transfer_node_main - transfer_node transport_leg_placeholder_1 - transport_leg container_1 - container container_2 - container operational_permit_1 - operational_permit operational_permit_2 - operational_permit shipment_order_1 - shipment_order shipment_order_2 - shipment_order clearance_profile_standard - clearance_profile handling_crane_1 - handling_equipment route_constraint_doc_low_bridge_1 - route_constraint_document route_constraint_doc_low_bridge_2 - route_constraint_document regulatory_authorization_1 - regulatory_authorization)
  (:init
    (asset_available asset_truck_1)
    (asset_available asset_truck_2)
    (asset_available asset_truck_3)
    (schedule_slot_available schedule_slot_1)
    (operator_available operator_team_a)
    (cargo_unit_available cargo_unit_a)
    (origin_has_segment origin_terminal_1 segment_bridge_low_1)
    (destination_has_transfer_node destination_terminal_1 transfer_node_main)
    (transport_leg_provisioned transport_leg_placeholder_1)
    (container_available container_1)
    (container_available container_2)
    (carrier_has_origin carrier_unit_alpha origin_terminal_1)
    (carrier_has_origin carrier_unit_bravo origin_terminal_1)
    (carrier_has_destination carrier_unit_alpha destination_terminal_1)
    (carrier_has_destination carrier_unit_bravo destination_terminal_1)
    (carrier_attached_to_leg carrier_unit_alpha transport_leg_placeholder_1)
    (carrier_attached_to_leg carrier_unit_bravo transport_leg_placeholder_1)
    (carrier_has_container carrier_unit_alpha container_1)
    (carrier_has_container carrier_unit_bravo container_2)
    (operational_permit_available operational_permit_1)
    (operational_permit_available operational_permit_2)
    (shipment_order_available shipment_order_1)
    (shipment_order_available shipment_order_2)
    (clearance_profile_available clearance_profile_standard)
    (handling_equipment_available handling_crane_1)
    (route_constraint_document_available route_constraint_doc_low_bridge_1)
    (carrier_has_route_constraint_document carrier_unit_alpha route_constraint_doc_low_bridge_1)
    (carrier_has_route_constraint_document carrier_unit_bravo route_constraint_doc_low_bridge_2)
    (regulatory_authorization_available regulatory_authorization_1)
  )
  (:goal
    (and
      (dispatch_confirmed origin_terminal_1)
      (dispatch_confirmed destination_terminal_1)
      (dispatch_confirmed carrier_unit_alpha)
      (dispatch_confirmed carrier_unit_bravo)
    )
  )
)
