(define (problem toll_vs_distance_scenario)
  (:domain toll_vs_distance_routing)
  (:objects pickup_node_1 - pickup_node delivery_node_1 - delivery_node route_plan_1 - route_plan route_plan_2 - route_plan toll_option_1 - toll_option toll_option_2 - toll_option toll_option_3 - toll_option route_segment_1 - route_segment carrier_unit_1 - carrier_unit cargo_unit_1 - cargo_unit origin_node_1 - origin_node destination_node_1 - destination_node transfer_bundle_1 - transfer_bundle container_1 - container container_2 - container special_service_1 - special_service special_service_2 - special_service priority_class_high - priority_class priority_class_standard - priority_class toll_zone_1 - toll_zone vehicle_capability_1 - vehicle_capability contract_clause_1 - contract_clause contract_clause_2 - contract_clause access_permit_1 - access_permit)
  (:init
    (toll_option_available toll_option_1)
    (toll_option_available toll_option_2)
    (toll_option_available toll_option_3)
    (route_segment_available route_segment_1)
    (carrier_available carrier_unit_1)
    (cargo_available cargo_unit_1)
    (pickup_at_origin pickup_node_1 origin_node_1)
    (delivery_at_destination delivery_node_1 destination_node_1)
    (transfer_bundle_ready transfer_bundle_1)
    (container_available container_1)
    (container_available container_2)
    (route_plan_has_pickup route_plan_1 pickup_node_1)
    (route_plan_has_pickup route_plan_2 pickup_node_1)
    (route_plan_has_delivery route_plan_1 delivery_node_1)
    (route_plan_has_delivery route_plan_2 delivery_node_1)
    (route_plan_has_bundle route_plan_1 transfer_bundle_1)
    (route_plan_has_bundle route_plan_2 transfer_bundle_1)
    (route_plan_has_container route_plan_1 container_1)
    (route_plan_has_container route_plan_2 container_2)
    (special_service_available special_service_1)
    (special_service_available special_service_2)
    (priority_class_available priority_class_high)
    (priority_class_available priority_class_standard)
    (toll_zone_available toll_zone_1)
    (vehicle_capability_available vehicle_capability_1)
    (contract_clause_available contract_clause_1)
    (route_plan_has_contract_clause route_plan_1 contract_clause_1)
    (route_plan_has_contract_clause route_plan_2 contract_clause_2)
    (access_permit_available access_permit_1)
  )
  (:goal
    (and
      (delivered pickup_node_1)
      (delivered delivery_node_1)
      (delivered route_plan_1)
      (delivered route_plan_2)
    )
  )
)
