(define (problem multi_stop_route_sequence_optimization_instance)
  (:domain multi_stop_route_sequence_optimization)
  (:objects origin_stop_1 - origin_stop destination_stop_1 - destination_stop route_plan_1 - route_plan route_plan_2 - route_plan transport_asset_1 - transport_asset transport_asset_2 - transport_asset transport_asset_3 - transport_asset time_window_1 - time_window terminal_1 - terminal_dock cargo_unit_1 - cargo_unit transfer_node_1 - transfer_node destination_node_1 - destination_node transfer_container_1 - transfer_container cargo_batch_1 - cargo_batch cargo_batch_2 - cargo_batch special_equipment_1 - special_equipment special_equipment_2 - special_equipment operator_qualification_1 - operator_qualification operator_qualification_2 - operator_qualification dispatch_token_1 - dispatch_token vehicle_type_1 - vehicle_type route_constraint_1 - route_constraint route_constraint_2 - route_constraint hazard_clearance_certificate_1 - hazard_clearance_certificate)
  (:init
    (transport_asset_available transport_asset_1)
    (transport_asset_available transport_asset_2)
    (transport_asset_available transport_asset_3)
    (timewindow_available time_window_1)
    (terminal_available terminal_1)
    (cargo_unit_available cargo_unit_1)
    (stop_to_node_mapping origin_stop_1 transfer_node_1)
    (destination_stop_to_node_mapping destination_stop_1 destination_node_1)
    (container_unassigned transfer_container_1)
    (cargo_batch_available cargo_batch_1)
    (cargo_batch_available cargo_batch_2)
    (route_has_origin_entity route_plan_1 origin_stop_1)
    (route_has_origin_entity route_plan_2 origin_stop_1)
    (route_has_destination_entity route_plan_1 destination_stop_1)
    (route_has_destination_entity route_plan_2 destination_stop_1)
    (route_assigned_to_container route_plan_1 transfer_container_1)
    (route_assigned_to_container route_plan_2 transfer_container_1)
    (route_has_cargo_batch route_plan_1 cargo_batch_1)
    (route_has_cargo_batch route_plan_2 cargo_batch_2)
    (special_equipment_available special_equipment_1)
    (special_equipment_available special_equipment_2)
    (operator_qualification_available operator_qualification_1)
    (operator_qualification_available operator_qualification_2)
    (dispatch_token_available dispatch_token_1)
    (vehicle_type_available vehicle_type_1)
    (route_constraint_available route_constraint_1)
    (route_has_constraint route_plan_1 route_constraint_1)
    (route_has_constraint route_plan_2 route_constraint_2)
    (hazard_clearance_certificate_available hazard_clearance_certificate_1)
  )
  (:goal
    (and
      (entity_marked_dispatched origin_stop_1)
      (entity_marked_dispatched destination_stop_1)
      (entity_marked_dispatched route_plan_1)
      (entity_marked_dispatched route_plan_2)
    )
  )
)
