(define (problem same_day_delivery_dispatch_instance)
  (:domain same_day_delivery_dispatch)
  (:objects pickup_leg_1 - pickup_leg delivery_leg_1 - delivery_leg route_plan_alpha - route_plan route_plan_beta - route_plan mode_van_1 - transport_mode mode_bike_1 - transport_mode mode_courier_1 - transport_mode time_window_morning - time_window crew_member_1 - crew_member parcel_1 - parcel origin_node_warehouse - origin_node destination_node_customer_1 - destination_node vehicle_veh_1 - vehicle_asset stop_customer_a - stop stop_customer_b - stop attr_refrigerated - vehicle_attribute attr_liftgate - vehicle_attribute manifest_1 - cargo_manifest manifest_2 - cargo_manifest handover_token_1 - handover_token equipment_liftgate - equipment credential_customer_a - customer_credential credential_customer_b - customer_credential instruction_fragile - handling_instruction)
  (:init
    (transport_mode_available mode_van_1)
    (transport_mode_available mode_bike_1)
    (transport_mode_available mode_courier_1)
    (time_window_available time_window_morning)
    (crew_available crew_member_1)
    (parcel_available parcel_1)
    (pickup_leg_origin_node pickup_leg_1 origin_node_warehouse)
    (delivery_leg_destination_node delivery_leg_1 destination_node_customer_1)
    (vehicle_available vehicle_veh_1)
    (stop_available stop_customer_a)
    (stop_available stop_customer_b)
    (plan_includes_pickup_leg route_plan_alpha pickup_leg_1)
    (plan_includes_pickup_leg route_plan_beta pickup_leg_1)
    (plan_includes_delivery_leg route_plan_alpha delivery_leg_1)
    (plan_includes_delivery_leg route_plan_beta delivery_leg_1)
    (plan_assigned_vehicle route_plan_alpha vehicle_veh_1)
    (plan_assigned_vehicle route_plan_beta vehicle_veh_1)
    (plan_includes_stop route_plan_alpha stop_customer_a)
    (plan_includes_stop route_plan_beta stop_customer_b)
    (vehicle_attribute_available attr_refrigerated)
    (vehicle_attribute_available attr_liftgate)
    (cargo_manifest_available manifest_1)
    (cargo_manifest_available manifest_2)
    (handover_token_available handover_token_1)
    (equipment_available equipment_liftgate)
    (customer_credential_available credential_customer_a)
    (plan_bound_customer_credential route_plan_alpha credential_customer_a)
    (plan_bound_customer_credential route_plan_beta credential_customer_b)
    (handling_instruction_available instruction_fragile)
  )
  (:goal
    (and
      (dispatch_completed pickup_leg_1)
      (dispatch_completed delivery_leg_1)
      (dispatch_completed route_plan_alpha)
      (dispatch_completed route_plan_beta)
    )
  )
)
