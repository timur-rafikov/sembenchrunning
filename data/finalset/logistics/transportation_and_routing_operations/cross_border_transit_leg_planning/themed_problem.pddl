(define (problem cross_border_transit_leg_planning_problem)
  (:domain cross_border_transit_leg_planning_domain)
  (:objects origin_leg_hub_a - origin_leg destination_leg_hub_b - destination_leg shipment_order_1 - shipment_order shipment_order_2 - shipment_order transport_asset_truck_1 - transport_asset transport_asset_truck_2 - transport_asset transport_asset_trailer_1 - transport_asset time_slot_morning_1 - time_slot terminal_gate_alpha - terminal_gate cargo_unit_pallet_1 - cargo_unit origin_transfer_point_yard_1 - origin_transfer_point destination_transfer_point_yard_1 - destination_transfer_point transit_leg_plan_1 - transit_leg_plan container_asset_20ft_1 - container_asset container_asset_40ft_1 - container_asset routing_option_fastest - routing_option routing_option_cost_efficient - routing_option handling_profile_hazardous - handling_profile handling_profile_standard - handling_profile border_document_declaration_1 - border_document regulatory_certificate_insurance_1 - regulatory_certificate transport_permit_export_1 - transport_permit transport_permit_import_1 - transport_permit inspection_manifest_1 - inspection_manifest)
  (:init
    (transport_asset_available transport_asset_truck_1)
    (transport_asset_available transport_asset_truck_2)
    (transport_asset_available transport_asset_trailer_1)
    (time_slot_available time_slot_morning_1)
    (terminal_gate_available terminal_gate_alpha)
    (cargo_unit_available cargo_unit_pallet_1)
    (origin_leg_at_transfer_point origin_leg_hub_a origin_transfer_point_yard_1)
    (destination_leg_at_transfer_point destination_leg_hub_b destination_transfer_point_yard_1)
    (transit_leg_plan_available transit_leg_plan_1)
    (container_available container_asset_20ft_1)
    (container_available container_asset_40ft_1)
    (order_origin_leg shipment_order_1 origin_leg_hub_a)
    (order_origin_leg shipment_order_2 origin_leg_hub_a)
    (order_destination_leg shipment_order_1 destination_leg_hub_b)
    (order_destination_leg shipment_order_2 destination_leg_hub_b)
    (order_assigned_to_transit_leg shipment_order_1 transit_leg_plan_1)
    (order_assigned_to_transit_leg shipment_order_2 transit_leg_plan_1)
    (order_has_container shipment_order_1 container_asset_20ft_1)
    (order_has_container shipment_order_2 container_asset_40ft_1)
    (routing_option_available routing_option_fastest)
    (routing_option_available routing_option_cost_efficient)
    (handling_profile_available handling_profile_hazardous)
    (handling_profile_available handling_profile_standard)
    (border_document_available border_document_declaration_1)
    (regulatory_certificate_available regulatory_certificate_insurance_1)
    (transport_permit_available transport_permit_export_1)
    (order_assigned_permit shipment_order_1 transport_permit_export_1)
    (order_assigned_permit shipment_order_2 transport_permit_import_1)
    (inspection_manifest_available inspection_manifest_1)
  )
  (:goal
    (and
      (planning_entity_dispatched origin_leg_hub_a)
      (planning_entity_dispatched destination_leg_hub_b)
      (planning_entity_dispatched shipment_order_1)
      (planning_entity_dispatched shipment_order_2)
    )
  )
)
