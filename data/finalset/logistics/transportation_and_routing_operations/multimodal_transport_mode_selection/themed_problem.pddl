(define (problem shipment_plan_scenario_1)
  (:domain multimodal_transport_mode_selection)
  (:objects origin_leg_1 - origin_leg feeder_leg_1 - feeder_or_destination_leg itinerary_1 - itinerary_unit itinerary_2 - itinerary_unit mode_slot_1 - mode_slot mode_slot_2 - mode_slot mode_slot_3 - mode_slot route_option_1 - route_option terminal_a - facility_terminal cargo_item_1 - cargo_item transfer_node_a_1 - transfer_node_a transfer_node_b_1 - transfer_node_b intermodal_unit_1 - intermodal_unit package_batch_1 - package_batch package_batch_2 - package_batch handling_code_1 - handling_code handling_code_2 - handling_code equipment_type_1 - equipment_type equipment_type_2 - equipment_type time_window_1 - time_window crew_1 - crew_or_driver consignor_clearance_1 - consignor_clearance consignor_clearance_2 - consignor_clearance insurance_document_1 - insurance_document)
  (:init
    (mode_slot_available mode_slot_1)
    (mode_slot_available mode_slot_2)
    (mode_slot_available mode_slot_3)
    (route_option_available route_option_1)
    (terminal_slot_available terminal_a)
    (cargo_item_available cargo_item_1)
    (origin_leg_assigned_node_a origin_leg_1 transfer_node_a_1)
    (feeder_leg_assigned_node_b feeder_leg_1 transfer_node_b_1)
    (intermodal_unit_available intermodal_unit_1)
    (package_batch_available package_batch_1)
    (package_batch_available package_batch_2)
    (itinerary_has_origin_leg itinerary_1 origin_leg_1)
    (itinerary_has_origin_leg itinerary_2 origin_leg_1)
    (itinerary_has_feeder_leg itinerary_1 feeder_leg_1)
    (itinerary_has_feeder_leg itinerary_2 feeder_leg_1)
    (itinerary_assigned_intermodal_unit itinerary_1 intermodal_unit_1)
    (itinerary_assigned_intermodal_unit itinerary_2 intermodal_unit_1)
    (itinerary_assigned_package_batch itinerary_1 package_batch_1)
    (itinerary_assigned_package_batch itinerary_2 package_batch_2)
    (handling_code_available handling_code_1)
    (handling_code_available handling_code_2)
    (equipment_type_available equipment_type_1)
    (equipment_type_available equipment_type_2)
    (time_window_available time_window_1)
    (crew_available crew_1)
    (consignor_clearance_available consignor_clearance_1)
    (itinerary_has_consignor_clearance itinerary_1 consignor_clearance_1)
    (itinerary_has_consignor_clearance itinerary_2 consignor_clearance_2)
    (insurance_document_available insurance_document_1)
  )
  (:goal
    (and
      (completed origin_leg_1)
      (completed feeder_leg_1)
      (completed itinerary_1)
      (completed itinerary_2)
    )
  )
)
