(define (problem loot_pressure_loadout_preparation)
  (:domain inventory_space_prioritization_under_loot_pressure)
  (:objects player_main - player companion_ally - companion loadout_alpha - loadout_profile loadout_beta - loadout_profile loot_crate_a - loot_unit loot_crate_b - loot_unit loot_crate_c - loot_unit material_scrap - material_type repair_tool - tool_type resource_stack_bandages - resource_stack primary_tag_blue - primary_priority_tag secondary_tag_green - secondary_priority_tag supply_pack_1 - container_item frame_plate - assembly_component latch_mechanism - assembly_component scope_attachment - special_attachment silencer_attachment - special_attachment med_pack_small - consumable_pack med_pack_large - consumable_pack preservation_chip - preservation_token reinforcement_brace - upgrade_component config_token_alpha - configuration_token config_token_beta - configuration_token mod_module_stabilizer - modification_module)
  (:init
    (loot_available loot_crate_a)
    (loot_available loot_crate_b)
    (loot_available loot_crate_c)
    (material_available material_scrap)
    (tool_available repair_tool)
    (resource_stack_available resource_stack_bandages)
    (primary_tag_assigned player_main primary_tag_blue)
    (secondary_tag_assigned companion_ally secondary_tag_green)
    (container_available supply_pack_1)
    (component_available frame_plate)
    (component_available latch_mechanism)
    (loadout_assigned_to_player loadout_alpha player_main)
    (loadout_assigned_to_player loadout_beta player_main)
    (loadout_assigned_to_companion loadout_alpha companion_ally)
    (loadout_assigned_to_companion loadout_beta companion_ally)
    (loadout_requires_container loadout_alpha supply_pack_1)
    (loadout_requires_container loadout_beta supply_pack_1)
    (loadout_has_component loadout_alpha frame_plate)
    (loadout_has_component loadout_beta latch_mechanism)
    (special_attachment_available scope_attachment)
    (special_attachment_available silencer_attachment)
    (consumable_pack_available med_pack_small)
    (consumable_pack_available med_pack_large)
    (preservation_token_available preservation_chip)
    (upgrade_component_available reinforcement_brace)
    (configuration_token_available config_token_alpha)
    (loadout_has_configuration_token loadout_alpha config_token_alpha)
    (loadout_has_configuration_token loadout_beta config_token_beta)
    (modification_module_available mod_module_stabilizer)
  )
  (:goal
    (and
      (is_secured player_main)
      (is_secured companion_ally)
      (is_secured loadout_alpha)
      (is_secured loadout_beta)
    )
  )
)
