(define (problem healing_reservation_scenario)
  (:domain healing_supply_reservation)
  (:objects frontline_unit_1 - frontline_unit support_unit_1 - support_unit field_facility_alpha - facility field_facility_beta - facility supply_template_alpha - supply_template supply_template_beta - supply_template supply_template_gamma - supply_template healing_method_bandage - healing_method medical_tool_basic - tool raw_material_herb - raw_material component_a_alpha - component_type_a component_b_alpha - component_type_b bundle_slot_primary - prepared_bundle consumable_pack_small - consumable_pack consumable_pack_large - consumable_pack attachment_a_standard - attachment_type_a attachment_a_advanced - attachment_type_a attachment_b_standard - attachment_type_b attachment_b_reinforced - attachment_type_b consumable_small_potion - consumable equipment_module_healer - equipment_module upgrade_token_alpha - special_resource upgrade_token_beta - special_resource catalyst_alpha - catalyst)
  (:init
    (template_available supply_template_alpha)
    (template_available supply_template_beta)
    (template_available supply_template_gamma)
    (method_available healing_method_bandage)
    (tool_available medical_tool_basic)
    (material_available raw_material_herb)
    (unit_component_a_compat frontline_unit_1 component_a_alpha)
    (unit_component_b_compat support_unit_1 component_b_alpha)
    (bundle_slot_available bundle_slot_primary)
    (consumable_pack_available consumable_pack_small)
    (consumable_pack_available consumable_pack_large)
    (facility_supports_frontline_unit field_facility_alpha frontline_unit_1)
    (facility_supports_frontline_unit field_facility_beta frontline_unit_1)
    (facility_supports_support_unit field_facility_alpha support_unit_1)
    (facility_supports_support_unit field_facility_beta support_unit_1)
    (facility_has_bundle field_facility_alpha bundle_slot_primary)
    (facility_has_bundle field_facility_beta bundle_slot_primary)
    (facility_has_consumable_pack field_facility_alpha consumable_pack_small)
    (facility_has_consumable_pack field_facility_beta consumable_pack_large)
    (attachment_type_a_available attachment_a_standard)
    (attachment_type_a_available attachment_a_advanced)
    (attachment_type_b_available attachment_b_standard)
    (attachment_type_b_available attachment_b_reinforced)
    (consumable_available consumable_small_potion)
    (equipment_module_available equipment_module_healer)
    (special_resource_available upgrade_token_alpha)
    (facility_has_special_resource field_facility_alpha upgrade_token_alpha)
    (facility_has_special_resource field_facility_beta upgrade_token_beta)
    (catalyst_available catalyst_alpha)
  )
  (:goal
    (and
      (reservation_finalized frontline_unit_1)
      (reservation_finalized support_unit_1)
      (reservation_finalized field_facility_alpha)
      (reservation_finalized field_facility_beta)
    )
  )
)
