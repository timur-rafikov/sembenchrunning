(define (problem reserve_catalysts_for_rare_recipes)
  (:domain crafting_catalyst_reservation)
  (:objects primary_prep_slot_1 - primary_preparation_slot secondary_prep_slot_1 - secondary_preparation_slot rare_recipe_instance_1 - rare_recipe_instance rare_recipe_instance_2 - rare_recipe_instance catalyst_unit_1 - catalyst_unit catalyst_unit_2 - catalyst_unit catalyst_unit_3 - catalyst_unit consumable_unit_1 - consumable_unit maintenance_tool_1 - maintenance_tool material_token_1 - material_token material_variant_a_1 - material_variant_a material_variant_b_1 - material_variant_b intermediate_slot_1 - intermediate_component_slot material_batch_1 - material_batch material_batch_2 - material_batch optional_modifier_slot_1 - optional_modifier_slot optional_modifier_slot_2 - optional_modifier_slot consumable_modifier_1 - consumable_modifier consumable_modifier_2 - consumable_modifier preserved_reserve_1 - preserved_reserve equipment_upgrade_1 - equipment_upgrade special_attachment_1 - special_attachment special_attachment_2 - special_attachment advanced_upgrade_1 - advanced_upgrade)
  (:init
    (catalyst_available catalyst_unit_1)
    (catalyst_available catalyst_unit_2)
    (catalyst_available catalyst_unit_3)
    (consumable_available consumable_unit_1)
    (tool_available maintenance_tool_1)
    (material_token_available material_token_1)
    (preparation_slot_variant_a primary_prep_slot_1 material_variant_a_1)
    (preparation_slot_variant_b secondary_prep_slot_1 material_variant_b_1)
    (intermediate_slot_available intermediate_slot_1)
    (material_batch_available material_batch_1)
    (material_batch_available material_batch_2)
    (recipe_primary_slot_link rare_recipe_instance_1 primary_prep_slot_1)
    (recipe_primary_slot_link rare_recipe_instance_2 primary_prep_slot_1)
    (recipe_secondary_slot_link rare_recipe_instance_1 secondary_prep_slot_1)
    (recipe_secondary_slot_link rare_recipe_instance_2 secondary_prep_slot_1)
    (recipe_intermediate_slot_link rare_recipe_instance_1 intermediate_slot_1)
    (recipe_intermediate_slot_link rare_recipe_instance_2 intermediate_slot_1)
    (material_batch_assigned rare_recipe_instance_1 material_batch_1)
    (material_batch_assigned rare_recipe_instance_2 material_batch_2)
    (optional_modifier_slot_available optional_modifier_slot_1)
    (optional_modifier_slot_available optional_modifier_slot_2)
    (consumable_modifier_available consumable_modifier_1)
    (consumable_modifier_available consumable_modifier_2)
    (preserved_reserve_available preserved_reserve_1)
    (equipment_upgrade_available equipment_upgrade_1)
    (attachment_available special_attachment_1)
    (attachment_assigned rare_recipe_instance_1 special_attachment_1)
    (attachment_assigned rare_recipe_instance_2 special_attachment_2)
    (advanced_upgrade_available advanced_upgrade_1)
  )
  (:goal
    (and
      (completion_locked primary_prep_slot_1)
      (completion_locked secondary_prep_slot_1)
      (completion_locked rare_recipe_instance_1)
      (completion_locked rare_recipe_instance_2)
    )
  )
)
