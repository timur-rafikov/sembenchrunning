(define (problem repair_kit_stock_recovery_problem)
  (:domain repair_kit_stock_recovery_domain)
  (:objects central_depot - depot field_team_alpha - field_team workshop_a - workshop workshop_b - workshop supplier_unit_1 - supplier_unit supplier_unit_2 - supplier_unit supplier_unit_3 - supplier_unit part_type_seal - part_type technician_lead - technician consumable_patch_kit - consumable_part depot_bay_1 - depot_bay field_bay_1 - field_bay repair_kit_unit_1 - repair_kit_unit batch_a - component_batch batch_b - component_batch label_alpha - label_token label_beta - label_token priority_tag_high - priority_tag priority_tag_medium - priority_tag preservative_cell_1 - preservative_cell calibration_module_1 - calibration_module access_code_alpha - access_code access_code_beta - access_code inspection_doc_1 - inspection_document)
  (:init
    (supplier_available supplier_unit_1)
    (supplier_available supplier_unit_2)
    (supplier_available supplier_unit_3)
    (part_available part_type_seal)
    (technician_available technician_lead)
    (consumable_available consumable_patch_kit)
    (depot_has_bay central_depot depot_bay_1)
    (field_has_bay field_team_alpha field_bay_1)
    (kit_unconfigured repair_kit_unit_1)
    (batch_available batch_a)
    (batch_available batch_b)
    (workshop_depot_link workshop_a central_depot)
    (workshop_depot_link workshop_b central_depot)
    (workshop_field_link workshop_a field_team_alpha)
    (workshop_field_link workshop_b field_team_alpha)
    (workshop_can_assemble_kit workshop_a repair_kit_unit_1)
    (workshop_can_assemble_kit workshop_b repair_kit_unit_1)
    (workshop_has_batch workshop_a batch_a)
    (workshop_has_batch workshop_b batch_b)
    (label_available label_alpha)
    (label_available label_beta)
    (priority_tag_available priority_tag_high)
    (priority_tag_available priority_tag_medium)
    (preservative_available preservative_cell_1)
    (calibration_module_available calibration_module_1)
    (access_code_available access_code_alpha)
    (workshop_has_access_code workshop_a access_code_alpha)
    (workshop_has_access_code workshop_b access_code_beta)
    (inspection_document_available inspection_doc_1)
  )
  (:goal
    (and
      (asset_restocked central_depot)
      (asset_restocked field_team_alpha)
      (asset_restocked workshop_a)
      (asset_restocked workshop_b)
    )
  )
)
