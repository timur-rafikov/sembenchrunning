(define (problem pre_boss_supply_preparation_problem)
  (:domain pre_boss_supply_preparation)
  (:objects vanguard_unit - primary_unit support_unit - secondary_unit assault_loadout - loadout_profile support_loadout - loadout_profile resource_token_ore - resource_token resource_token_herb - resource_token resource_token_oil - resource_token healing_potion_class - consumable_class tinker_kit - tool_class minor_healing_potion - consumable_instance main_weapon_mount - attachment_point upgrade_socket_1 - upgrade_node gear_frame_alpha - gear_piece iron_ingot - material_unit leather_strip - material_unit ornament_emblem_a - optional_modifier ornament_emblem_b - optional_modifier performance_chip_alpha - performance_chip performance_chip_beta - performance_chip small_charge_pack - consumable_container weapon_scope_mk1 - weapon_attachment amulet_of_valor - unique_token sigil_of_protection - unique_token augment_core_alpha - augment_module)
  (:init
    (resource_token_available resource_token_ore)
    (resource_token_available resource_token_herb)
    (resource_token_available resource_token_oil)
    (consumable_available healing_potion_class)
    (tool_available tinker_kit)
    (consumable_instance_available minor_healing_potion)
    (primary_has_attachment_point vanguard_unit main_weapon_mount)
    (secondary_has_upgrade_node support_unit upgrade_socket_1)
    (gear_pending_assembly gear_frame_alpha)
    (material_available iron_ingot)
    (material_available leather_strip)
    (profile_links_primary_unit assault_loadout vanguard_unit)
    (profile_links_primary_unit support_loadout vanguard_unit)
    (profile_links_secondary_unit assault_loadout support_unit)
    (profile_links_secondary_unit support_loadout support_unit)
    (profile_contains_gear assault_loadout gear_frame_alpha)
    (profile_contains_gear support_loadout gear_frame_alpha)
    (profile_has_material assault_loadout iron_ingot)
    (profile_has_material support_loadout leather_strip)
    (optional_modifier_available ornament_emblem_a)
    (optional_modifier_available ornament_emblem_b)
    (performance_chip_available performance_chip_alpha)
    (performance_chip_available performance_chip_beta)
    (consumable_container_available small_charge_pack)
    (weapon_attachment_available weapon_scope_mk1)
    (unique_token_available amulet_of_valor)
    (profile_linked_unique_token assault_loadout amulet_of_valor)
    (profile_linked_unique_token support_loadout sigil_of_protection)
    (augment_module_available augment_core_alpha)
  )
  (:goal
    (and
      (prepared_for_battle vanguard_unit)
      (prepared_for_battle support_unit)
      (prepared_for_battle assault_loadout)
      (prepared_for_battle support_loadout)
    )
  )
)
