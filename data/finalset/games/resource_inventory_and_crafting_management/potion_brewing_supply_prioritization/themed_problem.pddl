(define (problem potion_supply_prioritization_problem)
  (:domain potion_brewing_supply_prioritization)
  (:objects primary_herb_station - primary_station secondary_essence_station - secondary_station brewer_cauldron_a - brewer brewer_cauldron_b - brewer herb_batch_alpha - supply_batch herb_batch_beta - supply_batch herb_batch_gamma - supply_batch ingredient_ginseng - ingredient_item mortar_pestle - tool supplement_stabilizer - supplement_item infusion_slot_alpha - infusion_slot focus_slot_alpha - focus_slot vial_alpha - vial_container label_template_a - label_template label_template_b - label_template finishing_additive_a - finishing_additive finishing_additive_b - finishing_additive packaging_wrap_a - packaging_material packaging_wrap_b - packaging_material preservative_solution_a - preservative catalyst_powder_a - catalyst attachment_component_gem - attachment_component attachment_component_ornament - attachment_component enchantment_reagent_a - enchantment_reagent)
  (:init
    (supply_batch_available herb_batch_alpha)
    (supply_batch_available herb_batch_beta)
    (supply_batch_available herb_batch_gamma)
    (ingredient_available ingredient_ginseng)
    (tool_available mortar_pestle)
    (supplement_available supplement_stabilizer)
    (primary_station_has_infusion_slot primary_herb_station infusion_slot_alpha)
    (secondary_station_has_focus_slot secondary_essence_station focus_slot_alpha)
    (vial_available vial_alpha)
    (label_template_available label_template_a)
    (label_template_available label_template_b)
    (brewer_primary_link brewer_cauldron_a primary_herb_station)
    (brewer_primary_link brewer_cauldron_b primary_herb_station)
    (brewer_secondary_link brewer_cauldron_a secondary_essence_station)
    (brewer_secondary_link brewer_cauldron_b secondary_essence_station)
    (brewer_vial_link brewer_cauldron_a vial_alpha)
    (brewer_vial_link brewer_cauldron_b vial_alpha)
    (brewer_has_label_template brewer_cauldron_a label_template_a)
    (brewer_has_label_template brewer_cauldron_b label_template_b)
    (finishing_additive_available finishing_additive_a)
    (finishing_additive_available finishing_additive_b)
    (packaging_material_available packaging_wrap_a)
    (packaging_material_available packaging_wrap_b)
    (preservative_available preservative_solution_a)
    (catalyst_available catalyst_powder_a)
    (attachment_component_available attachment_component_gem)
    (brewer_has_attachment_component brewer_cauldron_a attachment_component_gem)
    (brewer_has_attachment_component brewer_cauldron_b attachment_component_ornament)
    (enchantment_reagent_available enchantment_reagent_a)
  )
  (:goal
    (and
      (entity_resources_committed primary_herb_station)
      (entity_resources_committed secondary_essence_station)
      (entity_resources_committed brewer_cauldron_a)
      (entity_resources_committed brewer_cauldron_b)
    )
  )
)
