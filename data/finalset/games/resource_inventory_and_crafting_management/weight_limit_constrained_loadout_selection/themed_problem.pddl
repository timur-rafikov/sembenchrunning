(define (problem weight_limited_loadout_problem)
  (:domain weight_limited_loadout_domain)
  (:objects primary_slot_1 - primary_slot secondary_slot_1 - secondary_slot profile_alpha - loadout_profile profile_beta - loadout_profile supply_stack_1 - supply_stack supply_stack_2 - supply_stack supply_stack_3 - supply_stack recipe_basic_1 - crafting_recipe maintenance_kit_1 - maintenance_kit consumable_1 - consumable attachment_a_variant_1 - attachment_variant_a attachment_b_variant_1 - attachment_variant_b gear_template_1 - gear_item component_module_1 - component_module component_module_2 - component_module accessory_1 - accessory accessory_2 - accessory utility_mod_1 - utility_mod utility_mod_2 - utility_mod stowage_tag_1 - stowage_tag power_upgrade_1 - power_upgrade mission_modifier_1 - mission_modifier mission_modifier_2 - mission_modifier calibration_unit_1 - calibration_unit)
  (:init
    (supply_available supply_stack_1)
    (supply_available supply_stack_2)
    (supply_available supply_stack_3)
    (recipe_available recipe_basic_1)
    (maintenance_kit_available maintenance_kit_1)
    (consumable_available consumable_1)
    (primary_slot_compatible_with_attachment_a primary_slot_1 attachment_a_variant_1)
    (secondary_slot_compatible_with_attachment_b secondary_slot_1 attachment_b_variant_1)
    (gear_template_available gear_template_1)
    (module_available component_module_1)
    (module_available component_module_2)
    (profile_has_primary_slot profile_alpha primary_slot_1)
    (profile_has_primary_slot profile_beta primary_slot_1)
    (profile_has_secondary_slot profile_alpha secondary_slot_1)
    (profile_has_secondary_slot profile_beta secondary_slot_1)
    (profile_has_gear_template profile_alpha gear_template_1)
    (profile_has_gear_template profile_beta gear_template_1)
    (profile_has_module_slot profile_alpha component_module_1)
    (profile_has_module_slot profile_beta component_module_2)
    (accessory_available accessory_1)
    (accessory_available accessory_2)
    (utility_mod_available utility_mod_1)
    (utility_mod_available utility_mod_2)
    (stowage_tag_available stowage_tag_1)
    (power_upgrade_available power_upgrade_1)
    (mission_modifier_available mission_modifier_1)
    (profile_has_mission_modifier profile_alpha mission_modifier_1)
    (profile_has_mission_modifier profile_beta mission_modifier_2)
    (calibration_unit_available calibration_unit_1)
  )
  (:goal
    (and
      (entity_stowed primary_slot_1)
      (entity_stowed secondary_slot_1)
      (entity_stowed profile_alpha)
      (entity_stowed profile_beta)
    )
  )
)
