(define (problem tool_upgrade_downselection_problem)
  (:domain tool_upgrade_material_downselection)
  (:objects primary_tool_alpha - primary_tool secondary_tool_alpha - secondary_tool auxiliary_tool_frame_a - auxiliary_tool auxiliary_tool_frame_b - auxiliary_tool raw_material_iron_ore - raw_material raw_material_copper_ore - raw_material raw_material_titanium_ore - raw_material subcomponent_core_plate - subcomponent attachment_plate_standard - attachment_piece consumable_bundle_small_pack - consumable_bundle material_category_metal - material_category material_variant_high_grade - material_variant upgrade_module_prototype - upgrade_module upgrade_blueprint_alpha - upgrade_blueprint upgrade_blueprint_beta - upgrade_blueprint optional_modifier_precision - optional_modifier optional_modifier_durability - optional_modifier slot_modifier_alpha - slot_modifier slot_modifier_beta - slot_modifier preservative_pack_basic - preservative_item attachment_type_a_standard - attachment_type_a attachment_type_b_variant_1 - attachment_type_b attachment_type_b_variant_2 - attachment_type_b attachment_type_c_rare - attachment_type_c)
  (:init
    (raw_material_available raw_material_iron_ore)
    (raw_material_available raw_material_copper_ore)
    (raw_material_available raw_material_titanium_ore)
    (subcomponent_available subcomponent_core_plate)
    (attachment_piece_available attachment_plate_standard)
    (consumable_bundle_available consumable_bundle_small_pack)
    (primary_tool_material_category primary_tool_alpha material_category_metal)
    (secondary_tool_material_variant secondary_tool_alpha material_variant_high_grade)
    (upgrade_module_unprepared upgrade_module_prototype)
    (upgrade_blueprint_available upgrade_blueprint_alpha)
    (upgrade_blueprint_available upgrade_blueprint_beta)
    (aux_tool_compatible_with_primary_tool auxiliary_tool_frame_a primary_tool_alpha)
    (aux_tool_compatible_with_primary_tool auxiliary_tool_frame_b primary_tool_alpha)
    (aux_tool_compatible_with_secondary_tool auxiliary_tool_frame_a secondary_tool_alpha)
    (aux_tool_compatible_with_secondary_tool auxiliary_tool_frame_b secondary_tool_alpha)
    (aux_tool_compatible_with_module auxiliary_tool_frame_a upgrade_module_prototype)
    (aux_tool_compatible_with_module auxiliary_tool_frame_b upgrade_module_prototype)
    (aux_tool_bound_to_blueprint auxiliary_tool_frame_a upgrade_blueprint_alpha)
    (aux_tool_bound_to_blueprint auxiliary_tool_frame_b upgrade_blueprint_beta)
    (optional_modifier_available optional_modifier_precision)
    (optional_modifier_available optional_modifier_durability)
    (slot_modifier_available slot_modifier_alpha)
    (slot_modifier_available slot_modifier_beta)
    (preservative_item_available preservative_pack_basic)
    (attachment_type_a_available attachment_type_a_standard)
    (attachment_type_b_available attachment_type_b_variant_1)
    (auxiliary_tool_attachment_type_b_reserved_for auxiliary_tool_frame_a attachment_type_b_variant_1)
    (auxiliary_tool_attachment_type_b_reserved_for auxiliary_tool_frame_b attachment_type_b_variant_2)
    (attachment_type_c_available attachment_type_c_rare)
  )
  (:goal
    (and
      (equipment_upgrade_applied primary_tool_alpha)
      (equipment_upgrade_applied secondary_tool_alpha)
      (equipment_upgrade_applied auxiliary_tool_frame_a)
      (equipment_upgrade_applied auxiliary_tool_frame_b)
    )
  )
)
