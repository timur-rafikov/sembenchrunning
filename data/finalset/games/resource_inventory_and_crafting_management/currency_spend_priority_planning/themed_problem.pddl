(define (problem currency_spend_priority_problem)
  (:domain currency_spend_priority_planning)
  (:objects primary_loadout_1 - primary_loadout secondary_loadout_1 - secondary_loadout build_profile_1 - build_profile build_profile_2 - build_profile currency_gold - currency_option currency_voucher - currency_option currency_premium - currency_option cost_component_1 - cost_component equipment_service_1 - equipment_token consumable_booster_1 - consumable primary_slot_marker_1 - primary_slot_marker secondary_slot_marker_1 - secondary_slot_marker shop_offer_1 - shop_offer module_component_1 - module_component module_component_2 - module_component optional_bonus_1 - optional_bonus optional_bonus_2 - optional_bonus special_resource_1 - special_resource special_resource_2 - special_resource priority_token_1 - priority_token modifier_a_1 - modifier_a modifier_b_1 - modifier_b modifier_b_2 - modifier_b modifier_c_1 - modifier_c)
  (:init
    (currency_available currency_gold)
    (currency_available currency_voucher)
    (currency_available currency_premium)
    (cost_component_available cost_component_1)
    (equipment_available equipment_service_1)
    (consumable_available consumable_booster_1)
    (primary_slot_compatible primary_loadout_1 primary_slot_marker_1)
    (secondary_slot_compatible secondary_loadout_1 secondary_slot_marker_1)
    (offer_available shop_offer_1)
    (module_available module_component_1)
    (module_available module_component_2)
    (profile_primary_link build_profile_1 primary_loadout_1)
    (profile_primary_link build_profile_2 primary_loadout_1)
    (profile_secondary_link build_profile_1 secondary_loadout_1)
    (profile_secondary_link build_profile_2 secondary_loadout_1)
    (profile_offer_bound build_profile_1 shop_offer_1)
    (profile_offer_bound build_profile_2 shop_offer_1)
    (profile_module_bound build_profile_1 module_component_1)
    (profile_module_bound build_profile_2 module_component_2)
    (optional_bonus_available optional_bonus_1)
    (optional_bonus_available optional_bonus_2)
    (special_resource_available special_resource_1)
    (special_resource_available special_resource_2)
    (priority_token_available priority_token_1)
    (modifier_a_available modifier_a_1)
    (modifier_b_available modifier_b_1)
    (profile_modifier_b_bound build_profile_1 modifier_b_1)
    (profile_modifier_b_bound build_profile_2 modifier_b_2)
    (modifier_c_available modifier_c_1)
  )
  (:goal
    (and
      (spend_completed primary_loadout_1)
      (spend_completed secondary_loadout_1)
      (spend_completed build_profile_1)
      (spend_completed build_profile_2)
    )
  )
)
