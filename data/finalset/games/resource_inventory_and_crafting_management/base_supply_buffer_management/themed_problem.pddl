(define (problem base_supply_buffer_instance)
  (:domain base_supply_buffer_management)
  (:objects intake_slot_1 - intake_slot staging_slot_1 - staging_slot production_hub_alpha - production_hub production_hub_beta - production_hub raw_ore_iron - material_resource raw_ore_copper - material_resource raw_polymer - material_resource lubricant_charge - processing_consumable maintenance_tool_kit - maintenance_tool intermediate_frame - intermediate_component material_variant_a_standard - supply_variant_a material_variant_b_standard - supply_variant_b supply_package_empty - supply_package attachment_module_shield - attachment_module attachment_module_scope - attachment_module upgrade_module_speed - upgrade_module upgrade_module_durability - upgrade_module consumable_pack_small - consumable_pack consumable_pack_large - consumable_pack priority_marker_high - priority_marker power_cell_alpha - power_cell special_part_alpha - special_part special_part_beta - special_part exotic_part_x - exotic_part)
  (:init
    (material_resource_available raw_ore_iron)
    (material_resource_available raw_ore_copper)
    (material_resource_available raw_polymer)
    (consumable_available lubricant_charge)
    (tool_available maintenance_tool_kit)
    (component_available intermediate_frame)
    (intake_variant_a_reserved intake_slot_1 material_variant_a_standard)
    (staging_variant_b_reserved staging_slot_1 material_variant_b_standard)
    (package_available supply_package_empty)
    (attachment_module_available attachment_module_shield)
    (attachment_module_available attachment_module_scope)
    (hub_controls_intake_slot production_hub_alpha intake_slot_1)
    (hub_controls_intake_slot production_hub_beta intake_slot_1)
    (hub_controls_staging_slot production_hub_alpha staging_slot_1)
    (hub_controls_staging_slot production_hub_beta staging_slot_1)
    (hub_assigned_supply_package production_hub_alpha supply_package_empty)
    (hub_assigned_supply_package production_hub_beta supply_package_empty)
    (hub_has_attachment_module production_hub_alpha attachment_module_shield)
    (hub_has_attachment_module production_hub_beta attachment_module_scope)
    (upgrade_module_available upgrade_module_speed)
    (upgrade_module_available upgrade_module_durability)
    (consumable_pack_available consumable_pack_small)
    (consumable_pack_available consumable_pack_large)
    (priority_marker_available priority_marker_high)
    (power_cell_available power_cell_alpha)
    (special_part_available special_part_alpha)
    (hub_has_special_part production_hub_alpha special_part_alpha)
    (hub_has_special_part production_hub_beta special_part_beta)
    (exotic_part_available exotic_part_x)
  )
  (:goal
    (and
      (ready_for_dispatch intake_slot_1)
      (ready_for_dispatch staging_slot_1)
      (ready_for_dispatch production_hub_alpha)
      (ready_for_dispatch production_hub_beta)
    )
  )
)
