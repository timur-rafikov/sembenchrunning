(define (problem event_spend_instance)
  (:domain event_limited_currency_spending)
  (:objects slot_a_1 - slot_a slot_b_1 - slot_b loadout_1 - loadout loadout_2 - loadout currency_option_1 - currency_option currency_option_2 - currency_option currency_option_3 - currency_option material_1 - material tool_1 - tool consumable_1 - consumable resource_source_a_1 - resource_source_a resource_source_b_1 - resource_source_b bundle_1 - bundle component_1 - component component_2 - component cosmetic_upgrade_token_1 - cosmetic_upgrade_token cosmetic_upgrade_token_2 - cosmetic_upgrade_token special_material_1 - special_material special_material_2 - special_material voucher_1 - voucher optional_augment_1 - optional_augment cosmetic_token_1 - cosmetic_token cosmetic_token_2 - cosmetic_token unique_catalyst_1 - unique_catalyst)
  (:init
    (currency_available currency_option_1)
    (currency_available currency_option_2)
    (currency_available currency_option_3)
    (material_available material_1)
    (tool_available tool_1)
    (consumable_available consumable_1)
    (slot_a_resource_source slot_a_1 resource_source_a_1)
    (slot_b_resource_source slot_b_1 resource_source_b_1)
    (bundle_available bundle_1)
    (component_available component_1)
    (component_available component_2)
    (loadout_has_slot_a loadout_1 slot_a_1)
    (loadout_has_slot_a loadout_2 slot_a_1)
    (loadout_has_slot_b loadout_1 slot_b_1)
    (loadout_has_slot_b loadout_2 slot_b_1)
    (loadout_linked_bundle loadout_1 bundle_1)
    (loadout_linked_bundle loadout_2 bundle_1)
    (loadout_has_component loadout_1 component_1)
    (loadout_has_component loadout_2 component_2)
    (cosmetic_upgrade_token_available cosmetic_upgrade_token_1)
    (cosmetic_upgrade_token_available cosmetic_upgrade_token_2)
    (special_material_available special_material_1)
    (special_material_available special_material_2)
    (voucher_available voucher_1)
    (optional_augment_available optional_augment_1)
    (cosmetic_token_available cosmetic_token_1)
    (loadout_cosmetic_assigned loadout_1 cosmetic_token_1)
    (loadout_cosmetic_assigned loadout_2 cosmetic_token_2)
    (unique_catalyst_available unique_catalyst_1)
  )
  (:goal
    (and
      (purchase_target_acquired slot_a_1)
      (purchase_target_acquired slot_b_1)
      (purchase_target_acquired loadout_1)
      (purchase_target_acquired loadout_2)
    )
  )
)
