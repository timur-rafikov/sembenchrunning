(define (problem stash_rotation_scenario)
  (:domain stash_to_active_inventory_rotation)
  (:objects primary_slot_main - primary_slot secondary_slot_offhand - secondary_slot loadout_alpha - loadout loadout_beta - loadout stash_iron_ingot - stash_item stash_wood_plank - stash_item stash_leather_strip - stash_item item_type_standard - item_type assembly_tool - tool consumable_bonding_agent - consumable_resource primary_material_metal_core - primary_material secondary_material_buckle - secondary_material prepared_item_alpha - prepared_item upgrade_module_alpha - upgrade_module upgrade_module_beta - upgrade_module cosmetic_skin_red - cosmetic_modifier cosmetic_skin_blue - cosmetic_modifier special_component_gem - special_component special_component_chip - special_component preservation_kit_standard - preservation_kit repair_kit_standard - repair_kit objective_tag_stealth - objective_tag objective_tag_assault - objective_tag power_core_mk1 - power_core)
  (:init
    (in_stash stash_iron_ingot)
    (in_stash stash_wood_plank)
    (in_stash stash_leather_strip)
    (item_type_available item_type_standard)
    (tool_available assembly_tool)
    (consumable_available consumable_bonding_agent)
    (primary_slot_material_reserved primary_slot_main primary_material_metal_core)
    (secondary_slot_material_reserved secondary_slot_offhand secondary_material_buckle)
    (prepared_item_available prepared_item_alpha)
    (upgrade_module_available upgrade_module_alpha)
    (upgrade_module_available upgrade_module_beta)
    (loadout_has_primary_slot loadout_alpha primary_slot_main)
    (loadout_has_primary_slot loadout_beta primary_slot_main)
    (loadout_has_secondary_slot loadout_alpha secondary_slot_offhand)
    (loadout_has_secondary_slot loadout_beta secondary_slot_offhand)
    (loadout_has_prepared_item loadout_alpha prepared_item_alpha)
    (loadout_has_prepared_item loadout_beta prepared_item_alpha)
    (loadout_has_upgrade_module loadout_alpha upgrade_module_alpha)
    (loadout_has_upgrade_module loadout_beta upgrade_module_beta)
    (cosmetic_available cosmetic_skin_red)
    (cosmetic_available cosmetic_skin_blue)
    (special_component_available special_component_gem)
    (special_component_available special_component_chip)
    (preservation_kit_available preservation_kit_standard)
    (repair_kit_available repair_kit_standard)
    (objective_tag_available objective_tag_stealth)
    (loadout_has_objective_tag loadout_alpha objective_tag_stealth)
    (loadout_has_objective_tag loadout_beta objective_tag_assault)
    (power_core_available power_core_mk1)
  )
  (:goal
    (and
      (activated primary_slot_main)
      (activated secondary_slot_offhand)
      (activated loadout_alpha)
      (activated loadout_beta)
    )
  )
)
