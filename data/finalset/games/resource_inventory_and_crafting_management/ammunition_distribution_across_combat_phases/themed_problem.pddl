(define (problem ammunition_distribution_scenario)
  (:domain ammunition_distribution)
  (:objects unit_phase_a_1 - phase_a_unit unit_phase_b_1 - phase_b_unit weapon_unit_alpha - weapon_unit weapon_unit_bravo - weapon_unit supply_crate_1 - supply_crate supply_crate_2 - supply_crate supply_crate_3 - supply_crate ammo_profile_standard - ammo_profile maintenance_tool_1 - maintenance_tool ammo_stabilizer_1 - ammo_stabilizer primary_variant_1 - primary_ammo_variant secondary_variant_1 - secondary_ammo_variant ammo_package_slot_1 - ammo_package_slot assembly_component_a - assembly_component assembly_component_b - assembly_component upgrade_module_1 - upgrade_module upgrade_module_2 - upgrade_module tactical_module_1 - tactical_module tactical_module_2 - tactical_module mission_token_alpha - mission_token maintenance_part_1 - maintenance_part tactical_marker_1 - tactical_marker tactical_marker_2 - tactical_marker calibration_kit_1 - calibration_kit)
  (:init
    (supply_crate_available supply_crate_1)
    (supply_crate_available supply_crate_2)
    (supply_crate_available supply_crate_3)
    (ammo_profile_available ammo_profile_standard)
    (maintenance_tool_available maintenance_tool_1)
    (stabilizer_available ammo_stabilizer_1)
    (primary_variant_compatible_with_unit unit_phase_a_1 primary_variant_1)
    (secondary_variant_compatible_with_unit unit_phase_b_1 secondary_variant_1)
    (package_slot_available ammo_package_slot_1)
    (assembly_component_available assembly_component_a)
    (assembly_component_available assembly_component_b)
    (weapon_assigned_to_phase_a_unit weapon_unit_alpha unit_phase_a_1)
    (weapon_assigned_to_phase_a_unit weapon_unit_bravo unit_phase_a_1)
    (weapon_assigned_to_phase_b_unit weapon_unit_alpha unit_phase_b_1)
    (weapon_assigned_to_phase_b_unit weapon_unit_bravo unit_phase_b_1)
    (weapon_package_linked weapon_unit_alpha ammo_package_slot_1)
    (weapon_package_linked weapon_unit_bravo ammo_package_slot_1)
    (weapon_has_component weapon_unit_alpha assembly_component_a)
    (weapon_has_component weapon_unit_bravo assembly_component_b)
    (upgrade_module_available upgrade_module_1)
    (upgrade_module_available upgrade_module_2)
    (tactical_module_available tactical_module_1)
    (tactical_module_available tactical_module_2)
    (mission_token_available mission_token_alpha)
    (maintenance_part_available maintenance_part_1)
    (tactical_marker_available tactical_marker_1)
    (weapon_tactical_marker_link weapon_unit_alpha tactical_marker_1)
    (weapon_tactical_marker_link weapon_unit_bravo tactical_marker_2)
    (calibration_kit_available calibration_kit_1)
  )
  (:goal
    (and
      (provisioning_completed unit_phase_a_1)
      (provisioning_completed unit_phase_b_1)
      (provisioning_completed weapon_unit_alpha)
      (provisioning_completed weapon_unit_bravo)
    )
  )
)
