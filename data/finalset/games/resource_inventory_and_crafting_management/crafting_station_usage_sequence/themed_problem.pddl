(define (problem crafting_session_usage_scenario)
  (:domain crafting_station_usage)
  (:objects primary_station_1 - station_instance support_station_1 - support_station_instance blueprint_casing - assembly_job blueprint_cover - assembly_job inventory_stack_a - inventory_stack inventory_stack_b - inventory_stack inventory_stack_c - inventory_stack tool_wrench - tool_item attachment_alignment_jig - equipment_attachment consumable_flux - consumable_item primary_material_batch_a - primary_material_batch secondary_material_batch_a - secondary_material_batch workpiece_slot_1 - workpiece component_plate - component_item component_bracket - component_item upgrade_token_sharpness - optional_upgrade_token upgrade_token_durability - optional_upgrade_token maintenance_kit_small - maintenance_kit maintenance_kit_large - maintenance_kit preservation_marker - preservation_token quality_module_alpha - quality_module fixture_alignment_a - special_fixture fixture_alignment_b - special_fixture stabilizer_unit_alpha - stabilizer_unit)
  (:init
    (inventory_stack_available inventory_stack_a)
    (inventory_stack_available inventory_stack_b)
    (inventory_stack_available inventory_stack_c)
    (tool_available tool_wrench)
    (attachment_available attachment_alignment_jig)
    (consumable_available consumable_flux)
    (station_primary_batch_assigned primary_station_1 primary_material_batch_a)
    (support_station_secondary_batch_assigned support_station_1 secondary_material_batch_a)
    (workpiece_slot_available workpiece_slot_1)
    (component_available component_plate)
    (component_available component_bracket)
    (assembly_job_bound_to_primary_station blueprint_casing primary_station_1)
    (assembly_job_bound_to_primary_station blueprint_cover primary_station_1)
    (assembly_job_bound_to_support_station blueprint_casing support_station_1)
    (assembly_job_bound_to_support_station blueprint_cover support_station_1)
    (assembly_job_has_workpiece blueprint_casing workpiece_slot_1)
    (assembly_job_has_workpiece blueprint_cover workpiece_slot_1)
    (assembly_job_has_component blueprint_casing component_plate)
    (assembly_job_has_component blueprint_cover component_bracket)
    (optional_upgrade_token_available upgrade_token_sharpness)
    (optional_upgrade_token_available upgrade_token_durability)
    (maintenance_kit_available maintenance_kit_small)
    (maintenance_kit_available maintenance_kit_large)
    (preservation_token_available preservation_marker)
    (quality_module_available quality_module_alpha)
    (fixture_available fixture_alignment_a)
    (assembly_job_attached_fixture blueprint_casing fixture_alignment_a)
    (assembly_job_attached_fixture blueprint_cover fixture_alignment_b)
    (stabilizer_unit_available stabilizer_unit_alpha)
  )
  (:goal
    (and
      (entity_released primary_station_1)
      (entity_released support_station_1)
      (entity_released blueprint_casing)
      (entity_released blueprint_cover)
    )
  )
)
