(define (problem crafting_chain_completion_problem)
  (:domain crafting_dependency_chain)
  (:objects subassembly_a_1 - subassembly_a subassembly_b_1 - subassembly_b workstation_alpha - workstation_task workstation_beta - workstation_task iron_ore_batch - raw_resource_batch wood_bundle - raw_resource_batch reagent_stack - raw_resource_batch metal_type - material_type assembly_tool - tool adhesive_packet - consumable variant_a_standard - material_variant_a variant_b_standard - material_variant_b assembly_core_alpha - assembly_core module_slot_1 - module_slot module_slot_2 - module_slot special_component_alpha - special_component special_component_beta - special_component calibration_token_a - calibration_token calibration_token_b - calibration_token preservative_canister - preservative_item station_upgrade_a_booster - station_upgrade_a station_upgrade_b_alpha - station_upgrade_b station_upgrade_b_beta - station_upgrade_b station_upgrade_c_precision - station_upgrade_c)
  (:init
    (resource_batch_available iron_ore_batch)
    (resource_batch_available wood_bundle)
    (resource_batch_available reagent_stack)
    (material_type_available metal_type)
    (tool_available assembly_tool)
    (consumable_available adhesive_packet)
    (subassembly_a_variant_compat subassembly_a_1 variant_a_standard)
    (subassembly_b_variant_compat subassembly_b_1 variant_b_standard)
    (assembly_core_idle assembly_core_alpha)
    (module_slot_available module_slot_1)
    (module_slot_available module_slot_2)
    (workstation_supports_subassembly_a workstation_alpha subassembly_a_1)
    (workstation_supports_subassembly_a workstation_beta subassembly_a_1)
    (workstation_supports_subassembly_b workstation_alpha subassembly_b_1)
    (workstation_supports_subassembly_b workstation_beta subassembly_b_1)
    (workstation_core_compatible workstation_alpha assembly_core_alpha)
    (workstation_core_compatible workstation_beta assembly_core_alpha)
    (workstation_has_module_slot workstation_alpha module_slot_1)
    (workstation_has_module_slot workstation_beta module_slot_2)
    (special_component_available special_component_alpha)
    (special_component_available special_component_beta)
    (calibration_token_available calibration_token_a)
    (calibration_token_available calibration_token_b)
    (preservative_item_available preservative_canister)
    (upgrade_a_available station_upgrade_a_booster)
    (upgrade_b_available station_upgrade_b_alpha)
    (workstation_upgrade_b_attached workstation_alpha station_upgrade_b_alpha)
    (workstation_upgrade_b_attached workstation_beta station_upgrade_b_beta)
    (upgrade_c_available station_upgrade_c_precision)
  )
  (:goal
    (and
      (entity_goal_satisfied subassembly_a_1)
      (entity_goal_satisfied subassembly_b_1)
      (entity_goal_satisfied workstation_alpha)
      (entity_goal_satisfied workstation_beta)
    )
  )
)
