(define (problem rare_consumable_commitment_scenario)
  (:domain rare_consumable_commitment_domain)
  (:objects primary_slot_1 - primary_slot secondary_slot_1 - secondary_slot equipment_weapon_alpha - equipment_item equipment_weapon_beta - equipment_item consumable_unit_1 - consumable_unit consumable_unit_2 - consumable_unit consumable_unit_3 - consumable_unit consumable_effect_alpha - consumable_effect repair_tool_basic - maintenance_tool material_component_1 - material_component class_a_consumable_1 - consumable_class_a class_b_consumable_1 - consumable_class_b prepared_loadout_1 - prepared_loadout enhancement_module_1 - enhancement_module enhancement_module_2 - enhancement_module upgrade_token_1 - upgrade_token upgrade_token_2 - upgrade_token accessory_attachment_1 - accessory_attachment accessory_attachment_2 - accessory_attachment rare_elixir_1 - rare_consumable durability_kit_1 - durability_kit special_catalyst_alpha - special_catalyst special_catalyst_beta - special_catalyst affinity_module_1 - affinity_module)
  (:init
    (consumable_available consumable_unit_1)
    (consumable_available consumable_unit_2)
    (consumable_available consumable_unit_3)
    (consumable_effect_available consumable_effect_alpha)
    (tool_available repair_tool_basic)
    (material_component_available material_component_1)
    (primary_slot_compatible_with_class_a primary_slot_1 class_a_consumable_1)
    (secondary_slot_compatible_with_class_b secondary_slot_1 class_b_consumable_1)
    (loadout_available_for_assembly prepared_loadout_1)
    (module_available enhancement_module_1)
    (module_available enhancement_module_2)
    (equipment_has_primary_slot equipment_weapon_alpha primary_slot_1)
    (equipment_has_primary_slot equipment_weapon_beta primary_slot_1)
    (equipment_has_secondary_slot equipment_weapon_alpha secondary_slot_1)
    (equipment_has_secondary_slot equipment_weapon_beta secondary_slot_1)
    (equipment_compatible_with_loadout equipment_weapon_alpha prepared_loadout_1)
    (equipment_compatible_with_loadout equipment_weapon_beta prepared_loadout_1)
    (equipment_has_module equipment_weapon_alpha enhancement_module_1)
    (equipment_has_module equipment_weapon_beta enhancement_module_2)
    (upgrade_token_available upgrade_token_1)
    (upgrade_token_available upgrade_token_2)
    (accessory_available accessory_attachment_1)
    (accessory_available accessory_attachment_2)
    (rare_consumable_available rare_elixir_1)
    (durability_kit_available durability_kit_1)
    (special_catalyst_available special_catalyst_alpha)
    (equipment_catalyst_assigned equipment_weapon_alpha special_catalyst_alpha)
    (equipment_catalyst_assigned equipment_weapon_beta special_catalyst_beta)
    (affinity_module_available affinity_module_1)
  )
  (:goal
    (and
      (preparation_target_committed primary_slot_1)
      (preparation_target_committed secondary_slot_1)
      (preparation_target_committed equipment_weapon_alpha)
      (preparation_target_committed equipment_weapon_beta)
    )
  )
)
