(define (problem consumable_stockpile_preservation_problem)
  (:domain consumable_stockpile_preservation_domain)
  (:objects batch_a_1 - consumable_batch_a batch_b_1 - consumable_batch_b maintenance_station_1 - maintenance_station maintenance_station_2 - maintenance_station resource_token_1 - resource_token resource_token_2 - resource_token resource_token_3 - resource_token consumable_requirement_1 - consumable_requirement maintenance_tool_1 - tool preservation_material_1 - preservation_material storage_condition_a_1 - storage_condition_a storage_condition_b_1 - storage_condition_b container_unit_1 - container_unit component_1 - component component_2 - component module_1 - special_module module_2 - special_module stability_agent_1 - stability_agent stability_agent_2 - stability_agent preservation_supply_1 - preservation_supply maintenance_part_1 - maintenance_part auth_token_1 - authorization_token auth_token_2 - authorization_token maintenance_kit_1 - maintenance_kit)
  (:init
    (resource_token_available resource_token_1)
    (resource_token_available resource_token_2)
    (resource_token_available resource_token_3)
    (requirement_available consumable_requirement_1)
    (tool_available maintenance_tool_1)
    (preservation_material_available preservation_material_1)
    (batch_a_assigned_condition_a batch_a_1 storage_condition_a_1)
    (batch_b_assigned_condition_b batch_b_1 storage_condition_b_1)
    (container_available container_unit_1)
    (component_available component_1)
    (component_available component_2)
    (station_assigned_batch_a maintenance_station_1 batch_a_1)
    (station_assigned_batch_a maintenance_station_2 batch_a_1)
    (station_assigned_batch_b maintenance_station_1 batch_b_1)
    (station_assigned_batch_b maintenance_station_2 batch_b_1)
    (station_assigned_container maintenance_station_1 container_unit_1)
    (station_assigned_container maintenance_station_2 container_unit_1)
    (station_has_component maintenance_station_1 component_1)
    (station_has_component maintenance_station_2 component_2)
    (module_available module_1)
    (module_available module_2)
    (stability_agent_available stability_agent_1)
    (stability_agent_available stability_agent_2)
    (preservation_supply_available preservation_supply_1)
    (maintenance_part_available maintenance_part_1)
    (authorization_token_available auth_token_1)
    (station_has_authorization maintenance_station_1 auth_token_1)
    (station_has_authorization maintenance_station_2 auth_token_2)
    (maintenance_kit_available maintenance_kit_1)
  )
  (:goal
    (and
      (preservation_completed batch_a_1)
      (preservation_completed batch_b_1)
      (preservation_completed maintenance_station_1)
      (preservation_completed maintenance_station_2)
    )
  )
