    (cache_point_available cache_point_1)
    (resource_node_available resource_node_1)
    (resource_node_available resource_node_2)
    (route_plan_has_primary_site route_plan_alpha primary_site_1)
    (route_plan_has_primary_site route_plan_beta primary_site_1)
    (route_plan_has_secondary_site route_plan_alpha secondary_site_1)
    (route_plan_has_secondary_site route_plan_beta secondary_site_1)
    (route_plan_has_cache route_plan_alpha cache_point_1)
    (route_plan_has_cache route_plan_beta cache_point_1)
    (route_plan_has_resource_node route_plan_alpha resource_node_1)
    (route_plan_has_resource_node route_plan_beta resource_node_2)
    (bonus_objective_available bonus_objective_1)
    (bonus_objective_available bonus_objective_2)
    (module_available module_1)
    (module_available module_2)
    (return_marker_available return_marker_1)
    (special_tool_available special_tool_1)
    (anchor_token_available anchor_token_1)
    (route_plan_anchor_token_link route_plan_alpha anchor_token_1)
    (route_plan_anchor_token_link route_plan_beta anchor_token_2)
    (encounter_marker_available encounter_marker_1)
