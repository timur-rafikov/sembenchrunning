(define (problem portal_network_usage_planning_problem)
  (:domain portal_network_usage_planning_domain)
  (:objects origin_site_a - origin_site destination_site_a - destination_site hub_node_alpha - hub_node hub_node_beta - hub_node portal_device_1 - portal_device portal_device_2 - portal_device portal_device_3 - portal_device probe_unit_1 - probe_unit control_switch_1 - control_switch consumable_resource_1 - consumable_resource entry_interface_1 - entry_interface exit_interface_1 - exit_interface route_plan_slot_1 - route_plan map_fragment_a - map_fragment map_fragment_b - map_fragment upgrade_module_1 - upgrade_module upgrade_module_2 - upgrade_module permission_token_a - permission_token permission_token_b - permission_token hazard_marker_a - hazard_marker special_modifier_a - special_modifier mission_marker_a - mission_marker mission_marker_b - mission_marker timed_event_a - timed_event)
  (:init
    (device_available portal_device_1)
    (device_available portal_device_2)
    (device_available portal_device_3)
    (probe_available probe_unit_1)
    (switch_available control_switch_1)
    (consumable_available consumable_resource_1)
    (origin_has_entry_interface origin_site_a entry_interface_1)
    (destination_has_exit_interface destination_site_a exit_interface_1)
    (route_slot_available route_plan_slot_1)
    (map_fragment_available map_fragment_a)
    (map_fragment_available map_fragment_b)
    (hub_links_origin_site hub_node_alpha origin_site_a)
    (hub_links_origin_site hub_node_beta origin_site_a)
    (hub_links_destination_site hub_node_alpha destination_site_a)
    (hub_links_destination_site hub_node_beta destination_site_a)
    (hub_links_route_plan hub_node_alpha route_plan_slot_1)
    (hub_links_route_plan hub_node_beta route_plan_slot_1)
    (hub_has_map_fragment hub_node_alpha map_fragment_a)
    (hub_has_map_fragment hub_node_beta map_fragment_b)
    (upgrade_module_available upgrade_module_1)
    (upgrade_module_available upgrade_module_2)
    (permission_token_available permission_token_a)
    (permission_token_available permission_token_b)
    (hazard_marker_available hazard_marker_a)
    (special_modifier_available special_modifier_a)
    (mission_marker_available mission_marker_a)
    (hub_has_mission_marker hub_node_alpha mission_marker_a)
    (hub_has_mission_marker hub_node_beta mission_marker_b)
    (timed_event_active timed_event_a)
  )
  (:goal
    (and
      (location_covered origin_site_a)
      (location_covered destination_site_a)
      (location_covered hub_node_alpha)
      (location_covered hub_node_beta)
    )
  )
)
