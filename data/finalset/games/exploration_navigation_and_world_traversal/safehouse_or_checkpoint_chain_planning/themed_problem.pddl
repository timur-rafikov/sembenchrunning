(define (problem safehouse_chain_problem)
  (:domain safehouse_checkpoint_chain_planning)
  (:objects origin_wp_1 - origin_waypoint transit_wp_1 - transit_waypoint base_node_alpha - base_node base_node_beta - base_node link_token_1 - link_token link_token_2 - link_token link_token_3 - link_token scout_unit_1 - scout_unit access_tool_1 - access_tool consumable_1 - consumable_supply approach_vector_1 - approach_vector departure_vector_1 - departure_vector plan_token_1 - plan_token map_fragment_1 - map_fragment map_fragment_2 - map_fragment optional_modifier_1 - optional_modifier optional_modifier_2 - optional_modifier mission_asset_1 - mission_asset mission_asset_2 - mission_asset hazard_marker_1 - hazard_marker equipment_1 - equipment objective_marker_1 - objective_marker objective_marker_2 - objective_marker environmental_tag_1 - environmental_tag)
  (:init
    (link_token_available link_token_1)
    (link_token_available link_token_2)
    (link_token_available link_token_3)
    (scout_available scout_unit_1)
    (access_tool_available access_tool_1)
    (consumable_available consumable_1)
    (has_approach_vector origin_wp_1 approach_vector_1)
    (has_departure_vector transit_wp_1 departure_vector_1)
    (plan_token_available plan_token_1)
    (map_fragment_available map_fragment_1)
    (map_fragment_available map_fragment_2)
    (node_has_origin base_node_alpha origin_wp_1)
    (node_has_origin base_node_beta origin_wp_1)
    (node_has_transit base_node_alpha transit_wp_1)
    (node_has_transit base_node_beta transit_wp_1)
    (node_assigned_plan base_node_alpha plan_token_1)
    (node_assigned_plan base_node_beta plan_token_1)
    (node_has_map_fragment base_node_alpha map_fragment_1)
    (node_has_map_fragment base_node_beta map_fragment_2)
    (optional_modifier_available optional_modifier_1)
    (optional_modifier_available optional_modifier_2)
    (mission_asset_available mission_asset_1)
    (mission_asset_available mission_asset_2)
    (hazard_marker_available hazard_marker_1)
    (equipment_available equipment_1)
    (objective_available objective_marker_1)
    (node_has_objective base_node_alpha objective_marker_1)
    (node_has_objective base_node_beta objective_marker_2)
    (environmental_tag_available environmental_tag_1)
  )
  (:goal
    (and
      (site_activated origin_wp_1)
      (site_activated transit_wp_1)
      (site_activated base_node_alpha)
      (site_activated base_node_beta)
    )
  )
