(define (problem enemy_patrol_avoidance_navigation_problem)
  (:domain enemy_patrol_avoidance_navigation_domain)
  (:objects ingress_a_1 - ingress_lane_a ingress_b_1 - ingress_lane_b objective_alpha - objective_container objective_beta - objective_container patrol_1 - patrol_token patrol_2 - patrol_token patrol_3 - patrol_token timing_window_1 - timing_window cover_1 - cover_spot distraction_1 - distraction_item marker_a_1 - approach_marker_a marker_b_1 - approach_marker_b traversal_1 - traversal_instance scan_1 - scan_result scan_2 - scan_result aux_subgoal_1 - aux_subgoal aux_subgoal_2 - aux_subgoal equipment_1 - equipment equipment_2 - equipment beacon_1 - beacon_marker consumable_tool_1 - consumable_tool_type objective_flag_1 - objective_flag objective_flag_2 - objective_flag time_modifier_1 - objective_time_modifier)
  (:init
    (patrol_available patrol_1)
    (patrol_available patrol_2)
    (patrol_available patrol_3)
    (timing_window_available timing_window_1)
    (cover_available cover_1)
    (distraction_available distraction_1)
    (ingress_a_has_marker_a ingress_a_1 marker_a_1)
    (ingress_b_has_marker_b ingress_b_1 marker_b_1)
    (traversal_slot_available traversal_1)
    (scan_available scan_1)
    (scan_available scan_2)
    (objective_has_ingress_a objective_alpha ingress_a_1)
    (objective_has_ingress_a objective_beta ingress_a_1)
    (objective_has_ingress_b objective_alpha ingress_b_1)
    (objective_has_ingress_b objective_beta ingress_b_1)
    (objective_assigned_traversal objective_alpha traversal_1)
    (objective_assigned_traversal objective_beta traversal_1)
    (objective_has_scan objective_alpha scan_1)
    (objective_has_scan objective_beta scan_2)
    (aux_subgoal_available aux_subgoal_1)
    (aux_subgoal_available aux_subgoal_2)
    (equipment_available equipment_1)
    (equipment_available equipment_2)
    (beacon_available beacon_1)
    (tool_consumable_available consumable_tool_1)
    (objective_flag_available objective_flag_1)
    (objective_has_flag objective_alpha objective_flag_1)
    (objective_has_flag objective_beta objective_flag_2)
    (time_modifier_available time_modifier_1)
  )
  (:goal
    (and
      (site_secured ingress_a_1)
      (site_secured ingress_b_1)
      (site_secured objective_alpha)
      (site_secured objective_beta)
    )
  )
)
