(define (problem day_night_traversal_problem)
  (:domain day_night_traversal)
  (:objects day_node_1 - day_node night_node_1 - night_node waypoint_1 - waypoint waypoint_2 - waypoint permit_1 - route_permit permit_2 - route_permit permit_3 - route_permit scout_report_1 - scout_report companion_1 - companion_unit consumable_1 - consumable_resource day_zone_1 - day_zone_token night_zone_1 - night_zone_token map_tile_1 - map_tile fragment_1 - map_fragment fragment_2 - map_fragment landmark_modifier_1 - landmark_modifier landmark_modifier_2 - landmark_modifier activation_credential_1 - activation_credential activation_credential_2 - activation_credential return_marker_1 - return_marker equipment_module_1 - equipment_module objective_token_1 - objective_token objective_token_2 - objective_token time_tool_1 - time_of_day_tool)
  (:init
    (permit_available permit_1)
    (permit_available permit_2)
    (permit_available permit_3)
    (scout_available scout_report_1)
    (companion_available companion_1)
    (consumable_available consumable_1)
    (day_node_zone_link day_node_1 day_zone_1)
    (night_node_zone_link night_node_1 night_zone_1)
    (tile_unprocessed map_tile_1)
    (fragment_available fragment_1)
    (fragment_available fragment_2)
    (waypoint_link_day_node waypoint_1 day_node_1)
    (waypoint_link_day_node waypoint_2 day_node_1)
    (waypoint_link_night_node waypoint_1 night_node_1)
    (waypoint_link_night_node waypoint_2 night_node_1)
    (waypoint_on_tile waypoint_1 map_tile_1)
    (waypoint_on_tile waypoint_2 map_tile_1)
    (waypoint_has_fragment waypoint_1 fragment_1)
    (waypoint_has_fragment waypoint_2 fragment_2)
    (landmark_modifier_available landmark_modifier_1)
    (landmark_modifier_available landmark_modifier_2)
    (credential_available activation_credential_1)
    (credential_available activation_credential_2)
    (return_marker_available return_marker_1)
    (equipment_available equipment_module_1)
    (objective_available objective_token_1)
    (waypoint_has_objective waypoint_1 objective_token_1)
    (waypoint_has_objective waypoint_2 objective_token_2)
    (time_tool_available time_tool_1)
  )
  (:goal
    (and
      (traversal_unlocked day_node_1)
      (traversal_unlocked night_node_1)
      (traversal_unlocked waypoint_1)
      (traversal_unlocked waypoint_2)
    )
  )
)
