(define (problem fast_travel_unlock_problem)
  (:domain fast_travel_domain)
  (:objects region_entry_a_1 - region_entry_a region_entry_b_1 - region_entry_b fast_travel_hub_alpha - fast_travel_hub fast_travel_hub_beta - fast_travel_hub registration_device_1 - registration_device registration_device_2 - registration_device registration_device_3 - registration_device survey_device_1 - survey_device attaching_agent_1 - attaching_agent consumable_token_1 - consumable_token approach_path_a_1 - approach_path_a approach_path_b_1 - approach_path_b anchor_candidate_1 - anchor_candidate map_tile_1 - map_tile map_tile_2 - map_tile special_key_alpha - special_key special_key_beta - special_key upgrade_module_alpha - upgrade_module upgrade_module_beta - upgrade_module signature_token_1 - signature_token activation_component_1 - activation_component location_stamp_alpha - location_stamp location_stamp_beta - location_stamp relay_module_1 - relay_module)
  (:init
    (registration_device_available registration_device_1)
    (registration_device_available registration_device_2)
    (registration_device_available registration_device_3)
    (survey_device_available survey_device_1)
    (attaching_agent_available attaching_agent_1)
    (consumable_token_available consumable_token_1)
    (entry_a_approach_path region_entry_a_1 approach_path_a_1)
    (entry_b_approach_path region_entry_b_1 approach_path_b_1)
    (anchor_candidate_available anchor_candidate_1)
    (map_tile_available map_tile_1)
    (map_tile_available map_tile_2)
    (hub_link_entry_a fast_travel_hub_alpha region_entry_a_1)
    (hub_link_entry_a fast_travel_hub_beta region_entry_a_1)
    (hub_link_entry_b fast_travel_hub_alpha region_entry_b_1)
    (hub_link_entry_b fast_travel_hub_beta region_entry_b_1)
    (hub_has_candidate fast_travel_hub_alpha anchor_candidate_1)
    (hub_has_candidate fast_travel_hub_beta anchor_candidate_1)
    (hub_tile_slot fast_travel_hub_alpha map_tile_1)
    (hub_tile_slot fast_travel_hub_beta map_tile_2)
    (special_key_available special_key_alpha)
    (special_key_available special_key_beta)
    (upgrade_module_available upgrade_module_alpha)
    (upgrade_module_available upgrade_module_beta)
    (signature_token_available signature_token_1)
    (activation_component_available activation_component_1)
    (location_stamp_available location_stamp_alpha)
    (hub_has_stamp fast_travel_hub_alpha location_stamp_alpha)
    (hub_has_stamp fast_travel_hub_beta location_stamp_beta)
    (relay_module_available relay_module_1)
  )
  (:goal
    (and
      (fast_travel_unlocked region_entry_a_1)
      (fast_travel_unlocked region_entry_b_1)
      (fast_travel_unlocked fast_travel_hub_alpha)
      (fast_travel_unlocked fast_travel_hub_beta)
    )
  )
)
