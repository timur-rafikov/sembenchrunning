(define (problem vertical_route_construction_scenario)
  (:domain vertical_movement_route_construction)
  (:objects lower_anchor_1 - lower_anchor upper_anchor_1 - upper_anchor vertical_route_1 - vertical_route vertical_route_2 - vertical_route grapple_tool_type - traversal_tool_type hook_tool_type - traversal_tool_type winch_tool_type - traversal_tool_type climb_ability - movement_ability anchor_point_primary - anchor_point rope_coil - consumable_part vertical_segment_1 - vertical_segment side_segment_1 - side_segment route_module_1 - route_module module_plate_1 - module_part module_plate_2 - module_part modifier_windy - special_modifier modifier_slick - special_modifier activation_charge_1 - activation_charge activation_charge_2 - activation_charge return_beacon_1 - return_beacon power_cell_1 - power_cell objective_key_1 - objective_key objective_key_2 - objective_key validation_token_1 - validation_token)
  (:init
    (tool_available grapple_tool_type)
    (tool_available hook_tool_type)
    (tool_available winch_tool_type)
    (ability_available climb_ability)
    (anchor_point_available anchor_point_primary)
    (part_available rope_coil)
    (lower_anchor_vertical_segment_link lower_anchor_1 vertical_segment_1)
    (upper_anchor_side_segment_link upper_anchor_1 side_segment_1)
    (module_staged route_module_1)
    (module_part_available module_plate_1)
    (module_part_available module_plate_2)
    (vertical_route_lower_anchor_link vertical_route_1 lower_anchor_1)
    (vertical_route_lower_anchor_link vertical_route_2 lower_anchor_1)
    (vertical_route_upper_anchor_link vertical_route_1 upper_anchor_1)
    (vertical_route_upper_anchor_link vertical_route_2 upper_anchor_1)
    (vertical_route_module_link vertical_route_1 route_module_1)
    (vertical_route_module_link vertical_route_2 route_module_1)
    (vertical_route_part_link vertical_route_1 module_plate_1)
    (vertical_route_part_link vertical_route_2 module_plate_2)
    (modifier_available modifier_windy)
    (modifier_available modifier_slick)
    (activation_charge_available activation_charge_1)
    (activation_charge_available activation_charge_2)
    (return_beacon_available return_beacon_1)
    (power_cell_available power_cell_1)
    (objective_key_available objective_key_1)
    (vertical_route_key_link vertical_route_1 objective_key_1)
    (vertical_route_key_link vertical_route_2 objective_key_2)
    (validation_token_available validation_token_1)
  )
  (:goal
    (and
      (installed lower_anchor_1)
      (installed upper_anchor_1)
      (installed vertical_route_1)
      (installed vertical_route_2)
    )
  )
)
