(define (problem escort_route_safety_optimization_problem)
  (:domain escort_route_safety_optimization_domain)
  (:objects start_point_a - start_point end_point_a - end_point controller_alpha - controller controller_beta - controller route_option_1 - route_option route_option_2 - route_option route_option_3 - route_option scout_unit_1 - scout support_unit_1 - support_unit supply_pack_1 - supply route_segment_a - route_segment encounter_segment_a - encounter_segment traversal_asset_1 - traversal_asset landmark_outpost_1 - landmark landmark_outpost_2 - landmark route_marker_1 - route_marker route_marker_2 - route_marker capability_module_1 - capability_module capability_module_2 - capability_module extraction_beacon_1 - extraction_beacon defensive_upgrade_1 - defensive_upgrade secondary_objective_1 - secondary_objective secondary_objective_2 - secondary_objective dynamic_event_1 - dynamic_event)
  (:init
    (route_option_available route_option_1)
    (route_option_available route_option_2)
    (route_option_available route_option_3)
    (scout_available scout_unit_1)
    (support_available support_unit_1)
    (supply_available supply_pack_1)
    (route_point_segment_link start_point_a route_segment_a)
    (end_point_encounter_link end_point_a encounter_segment_a)
    (asset_available traversal_asset_1)
    (landmark_available landmark_outpost_1)
    (landmark_available landmark_outpost_2)
    (controller_associated_start controller_alpha start_point_a)
    (controller_associated_start controller_beta start_point_a)
    (controller_associated_end controller_alpha end_point_a)
    (controller_associated_end controller_beta end_point_a)
    (controller_asset_binding controller_alpha traversal_asset_1)
    (controller_asset_binding controller_beta traversal_asset_1)
    (controller_landmark_binding controller_alpha landmark_outpost_1)
    (controller_landmark_binding controller_beta landmark_outpost_2)
    (route_marker_available route_marker_1)
    (route_marker_available route_marker_2)
    (capability_module_available capability_module_1)
    (capability_module_available capability_module_2)
    (extraction_beacon_available extraction_beacon_1)
    (defensive_upgrade_available defensive_upgrade_1)
    (secondary_objective_available secondary_objective_1)
    (controller_secondary_binding controller_alpha secondary_objective_1)
    (controller_secondary_binding controller_beta secondary_objective_2)
    (dynamic_event_available dynamic_event_1)
  )
  (:goal
    (and
      (mission_finalized start_point_a)
      (mission_finalized end_point_a)
      (mission_finalized controller_alpha)
      (mission_finalized controller_beta)
    )
  )
)
