(define (problem expedition_route_optimization_problem)
  (:domain mount_route_optimization)
  (:objects sector_node_a_1 - sector_node_a sector_node_b_1 - sector_node_b planner_unit_1 - planner_unit planner_unit_2 - planner_unit mount_option_1 - mount_option mount_option_2 - mount_option mount_option_3 - mount_option waypoint_marker_1 - waypoint_marker support_asset_1 - support_asset consumable_token_1 - consumable_token node_point_a_1 - node_point_a node_point_b_1 - node_point_b route_token_1 - route_token coverage_beacon_1 - coverage_beacon coverage_beacon_2 - coverage_beacon special_checkpoint_1 - special_checkpoint special_checkpoint_2 - special_checkpoint upgrade_module_1 - upgrade_module upgrade_module_2 - upgrade_module return_marker_1 - return_marker performance_modifier_1 - performance_modifier area_trigger_1 - area_trigger area_trigger_2 - area_trigger priority_marker_1 - priority_marker)
  (:init
    (mount_available mount_option_1)
    (mount_available mount_option_2)
    (mount_available mount_option_3)
    (waypoint_available waypoint_marker_1)
    (support_available support_asset_1)
    (consumable_available consumable_token_1)
    (sector_a_has_point sector_node_a_1 node_point_a_1)
    (sector_b_has_point sector_node_b_1 node_point_b_1)
    (route_slot_available route_token_1)
    (coverage_beacon_available coverage_beacon_1)
    (coverage_beacon_available coverage_beacon_2)
    (planner_covers_sector_a planner_unit_1 sector_node_a_1)
    (planner_covers_sector_a planner_unit_2 sector_node_a_1)
    (planner_covers_sector_b planner_unit_1 sector_node_b_1)
    (planner_covers_sector_b planner_unit_2 sector_node_b_1)
    (planner_linked_route planner_unit_1 route_token_1)
    (planner_linked_route planner_unit_2 route_token_1)
    (planner_has_beacon planner_unit_1 coverage_beacon_1)
    (planner_has_beacon planner_unit_2 coverage_beacon_2)
    (special_checkpoint_available special_checkpoint_1)
    (special_checkpoint_available special_checkpoint_2)
    (upgrade_module_available upgrade_module_1)
    (upgrade_module_available upgrade_module_2)
    (return_marker_available return_marker_1)
    (performance_modifier_available performance_modifier_1)
    (area_trigger_available area_trigger_1)
    (planner_assigned_area_trigger planner_unit_1 area_trigger_1)
    (planner_assigned_area_trigger planner_unit_2 area_trigger_2)
    (priority_marker_available priority_marker_1)
  )
  (:goal
    (and
      (return_finalized sector_node_a_1)
      (return_finalized sector_node_b_1)
      (return_finalized planner_unit_1)
      (return_finalized planner_unit_2)
    )
  )
)
