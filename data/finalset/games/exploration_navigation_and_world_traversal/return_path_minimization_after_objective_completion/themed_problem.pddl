(define (problem minimize_return_path_after_objective_completion)
  (:domain return_path_minimization_domain)
  (:objects zone_a_1 - zone_node_a zone_b_1 - zone_node_b traversal_agent_1 - traversal_agent traversal_agent_2 - traversal_agent anchor_1 - anchor_point anchor_2 - anchor_point anchor_3 - anchor_point scout_tool_1 - scout_tool access_token_1 - access_token consumable_1 - consumable_resource edge_a_1 - edge_segment_a edge_b_1 - edge_segment_b path_candidate_1 - path_candidate scan_sector_1 - scan_sector scan_sector_2 - scan_sector special_marker_1 - special_marker special_marker_2 - special_marker validation_token_1 - validation_token validation_token_2 - validation_token return_anchor_1 - return_anchor module_unit_1 - module_unit objective_marker_1 - objective_marker objective_marker_2 - objective_marker special_item_1 - special_item)
  (:init
    (anchor_available anchor_1)
    (anchor_available anchor_2)
    (anchor_available anchor_3)
    (scout_tool_available scout_tool_1)
    (access_token_available access_token_1)
    (consumable_available consumable_1)
    (zone_a_edge_link zone_a_1 edge_a_1)
    (zone_b_edge_link zone_b_1 edge_b_1)
    (path_candidate_slot path_candidate_1)
    (scan_sector_available scan_sector_1)
    (scan_sector_available scan_sector_2)
    (agent_zone_a_link traversal_agent_1 zone_a_1)
    (agent_zone_a_link traversal_agent_2 zone_a_1)
    (agent_zone_b_link traversal_agent_1 zone_b_1)
    (agent_zone_b_link traversal_agent_2 zone_b_1)
    (agent_candidate_link traversal_agent_1 path_candidate_1)
    (agent_candidate_link traversal_agent_2 path_candidate_1)
    (agent_sector_link traversal_agent_1 scan_sector_1)
    (agent_sector_link traversal_agent_2 scan_sector_2)
    (special_marker_available special_marker_1)
    (special_marker_available special_marker_2)
    (validation_token_available validation_token_1)
    (validation_token_available validation_token_2)
    (return_anchor_available return_anchor_1)
    (module_unit_available module_unit_1)
    (entity_marker_available objective_marker_1)
    (agent_marker_link traversal_agent_1 objective_marker_1)
    (agent_marker_link traversal_agent_2 objective_marker_2)
    (special_item_available special_item_1)
  )
  (:goal
    (and
      (return_committed_entity zone_a_1)
      (return_committed_entity zone_b_1)
      (return_committed_entity traversal_agent_1)
      (return_committed_entity traversal_agent_2)
    )
  )
)
