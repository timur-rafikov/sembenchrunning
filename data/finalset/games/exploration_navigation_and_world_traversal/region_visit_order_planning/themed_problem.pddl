(define (problem region_visit_order_problem)
  (:domain region_visit_order_planning)
  (:objects entry_node_1 - entry_node exit_node_1 - exit_node area_hub_1 - hub area_hub_2 - hub traversal_gate_1 - traversal_gate traversal_gate_2 - traversal_gate traversal_gate_3 - traversal_gate recon_report_1 - recon_report escort_unit_1 - escort_unit supply_1 - consumable_supply anchor_a_1 - route_anchor_a anchor_b_1 - route_anchor_b traversal_task_1 - traversal_task map_fragment_1 - map_fragment map_fragment_2 - map_fragment feature_key_1 - feature_key feature_key_2 - feature_key upgrade_token_1 - upgrade_token upgrade_token_2 - upgrade_token hazard_marker_1 - hazard_marker special_tool_1 - special_tool region_feature_1 - region_feature region_feature_2 - region_feature region_slot_1 - region_slot)
  (:init
    (traversal_gate_available traversal_gate_1)
    (traversal_gate_available traversal_gate_2)
    (traversal_gate_available traversal_gate_3)
    (recon_report_available recon_report_1)
    (escort_available escort_unit_1)
    (supply_available supply_1)
    (entry_anchor_a_link entry_node_1 anchor_a_1)
    (exit_anchor_b_link exit_node_1 anchor_b_1)
    (traversal_task_available traversal_task_1)
    (map_fragment_available map_fragment_1)
    (map_fragment_available map_fragment_2)
    (hub_has_entry_node area_hub_1 entry_node_1)
    (hub_has_entry_node area_hub_2 entry_node_1)
    (hub_has_exit_node area_hub_1 exit_node_1)
    (hub_has_exit_node area_hub_2 exit_node_1)
    (hub_has_traversal_task area_hub_1 traversal_task_1)
    (hub_has_traversal_task area_hub_2 traversal_task_1)
    (hub_has_map_fragment area_hub_1 map_fragment_1)
    (hub_has_map_fragment area_hub_2 map_fragment_2)
    (feature_key_available feature_key_1)
    (feature_key_available feature_key_2)
    (upgrade_token_available upgrade_token_1)
    (upgrade_token_available upgrade_token_2)
    (hazard_marker_available hazard_marker_1)
    (special_tool_available special_tool_1)
    (region_feature_available region_feature_1)
    (hub_has_region_feature area_hub_1 region_feature_1)
    (hub_has_region_feature area_hub_2 region_feature_2)
    (region_slot_available region_slot_1)
  )
  (:goal
    (and
      (region_completed entry_node_1)
      (region_completed exit_node_1)
      (region_completed area_hub_1)
      (region_completed area_hub_2)
    )
  )
)
