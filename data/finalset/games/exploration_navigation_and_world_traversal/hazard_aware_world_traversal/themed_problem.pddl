(define (problem hazard_aware_world_traversal_problem)
  (:domain hazard_aware_world_traversal_domain)
  (:objects anchor_node_1 - anchor_node target_node_1 - target_node region_1 - region region_2 - region access_token_red - access_token access_token_blue - access_token access_token_green - access_token scout_unit_1 - scout_unit mechanism_1 - mechanism consumable_1 - consumable path_segment_a_1 - path_segment_type_a path_segment_b_1 - path_segment_type_b route_plan_seed_1 - route_plan map_fragment_alpha - map_fragment map_fragment_beta - map_fragment optional_objective_alpha - optional_objective optional_objective_beta - optional_objective upgrade_module_alpha - upgrade_module upgrade_module_beta - upgrade_module return_marker_1 - return_marker module_type_a_1 - module_type_a artifact_alpha - artifact artifact_beta - artifact module_type_b_1 - module_type_b)
  (:init
    (token_available access_token_red)
    (token_available access_token_blue)
    (token_available access_token_green)
    (scout_available scout_unit_1)
    (mechanism_available mechanism_1)
    (consumable_available consumable_1)
    (anchor_node_to_path_a anchor_node_1 path_segment_a_1)
    (target_node_to_path_b target_node_1 path_segment_b_1)
    (route_plan_seed route_plan_seed_1)
    (map_fragment_available map_fragment_alpha)
    (map_fragment_available map_fragment_beta)
    (region_includes_anchor region_1 anchor_node_1)
    (region_includes_anchor region_2 anchor_node_1)
    (region_includes_target region_1 target_node_1)
    (region_includes_target region_2 target_node_1)
    (region_associated_with_route region_1 route_plan_seed_1)
    (region_associated_with_route region_2 route_plan_seed_1)
    (region_has_map_fragment region_1 map_fragment_alpha)
    (region_has_map_fragment region_2 map_fragment_beta)
    (optional_objective_available optional_objective_alpha)
    (optional_objective_available optional_objective_beta)
    (upgrade_module_available upgrade_module_alpha)
    (upgrade_module_available upgrade_module_beta)
    (return_marker_available return_marker_1)
    (module_a_available module_type_a_1)
    (artifact_available artifact_alpha)
    (region_has_artifact region_1 artifact_alpha)
    (region_has_artifact region_2 artifact_beta)
    (module_b_available module_type_b_1)
  )
  (:goal
    (and
      (node_unlocked anchor_node_1)
      (node_unlocked target_node_1)
      (node_unlocked region_1)
      (node_unlocked region_2)
    )
  )
)
