(define (problem minimize_elevation_gain_scenario)
  (:domain elevation_gain_minimizing_route_design)
  (:objects primary_segment_1 - primary_segment alternate_segment_1 - alternate_segment route_plan_alpha - route_plan route_plan_beta - route_plan traversal_permit_a - traversal_permit traversal_permit_b - traversal_permit traversal_permit_c - traversal_permit elevation_sample_a - elevation_sample traversal_ability_basic - traversal_ability consumable_resource_a - consumable_resource climb_feature_a - climb_feature descent_feature_a - descent_feature map_region_center - map_region objective_marker_1 - objective_marker objective_marker_2 - objective_marker landmark_a - landmark landmark_b - landmark constraint_modifier_a - constraint_modifier constraint_modifier_b - constraint_modifier return_beacon_alpha - return_beacon equipment_climbing_kit - equipment event_trigger_a - event_trigger event_trigger_b - event_trigger weather_modifier_a - weather_modifier)
  (:init
    (permit_available traversal_permit_a)
    (permit_available traversal_permit_b)
    (permit_available traversal_permit_c)
    (elevation_sample_available elevation_sample_a)
    (ability_available traversal_ability_basic)
    (consumable_available consumable_resource_a)
    (segment_has_climb_feature primary_segment_1 climb_feature_a)
    (segment_has_descent_feature alternate_segment_1 descent_feature_a)
    (region_available map_region_center)
    (objective_available objective_marker_1)
    (objective_available objective_marker_2)
    (route_contains_primary_segment route_plan_alpha primary_segment_1)
    (route_contains_primary_segment route_plan_beta primary_segment_1)
    (route_contains_alternate_segment route_plan_alpha alternate_segment_1)
    (route_contains_alternate_segment route_plan_beta alternate_segment_1)
    (route_contains_region route_plan_alpha map_region_center)
    (route_contains_region route_plan_beta map_region_center)
    (route_assigned_marker route_plan_alpha objective_marker_1)
    (route_assigned_marker route_plan_beta objective_marker_2)
    (landmark_available landmark_a)
    (landmark_available landmark_b)
    (constraint_modifier_available constraint_modifier_a)
    (constraint_modifier_available constraint_modifier_b)
    (return_beacon_available return_beacon_alpha)
    (equipment_available equipment_climbing_kit)
    (event_trigger_available event_trigger_a)
    (route_has_event_trigger route_plan_alpha event_trigger_a)
    (route_has_event_trigger route_plan_beta event_trigger_b)
    (weather_modifier_available weather_modifier_a)
  )
  (:goal
    (and
      (traversal_unlocked primary_segment_1)
      (traversal_unlocked alternate_segment_1)
      (traversal_unlocked route_plan_alpha)
      (traversal_unlocked route_plan_beta)
    )
  )
)
