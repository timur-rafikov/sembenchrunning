(define (problem dungeon_floor_progression_navigation_scenario)
  (:domain dungeon_floor_progression_navigation)
  (:objects zone_anchor_1 - zone_anchor adjacent_zone_1 - adjacent_zone floor_instance_1 - registered_floor_instance floor_instance_2 - registered_floor_instance traversal_token_1 - traversal_token traversal_token_2 - traversal_token traversal_token_3 - traversal_token scout_device_1 - scout_device interaction_tool_1 - interaction_tool consumable_resource_1 - consumable_resource endpoint_a_1 - endpoint_a endpoint_b_1 - endpoint_b constructed_connection_1 - constructed_connection map_checkpoint_1 - map_checkpoint map_checkpoint_2 - map_checkpoint construction_plan_1 - construction_plan construction_plan_2 - construction_plan upgrade_module_1 - upgrade_module upgrade_module_2 - upgrade_module hazard_marker_1 - hazard_marker attachment_item_1 - attachment_item special_encounter_marker_1 - special_encounter_marker special_encounter_marker_2 - special_encounter_marker signature_key_1 - signature_key)
  (:init
    (traversal_token_available traversal_token_1)
    (traversal_token_available traversal_token_2)
    (traversal_token_available traversal_token_3)
    (scout_device_available scout_device_1)
    (interaction_tool_available interaction_tool_1)
    (consumable_available consumable_resource_1)
    (anchor_connected_to_endpoint_a zone_anchor_1 endpoint_a_1)
    (adjacent_has_endpoint_b adjacent_zone_1 endpoint_b_1)
    (connection_slot_available constructed_connection_1)
    (checkpoint_available map_checkpoint_1)
    (checkpoint_available map_checkpoint_2)
    (floor_instance_has_anchor floor_instance_1 zone_anchor_1)
    (floor_instance_has_anchor floor_instance_2 zone_anchor_1)
    (floor_instance_has_adjacent floor_instance_1 adjacent_zone_1)
    (floor_instance_has_adjacent floor_instance_2 adjacent_zone_1)
    (floor_instance_has_connection floor_instance_1 constructed_connection_1)
    (floor_instance_has_connection floor_instance_2 constructed_connection_1)
    (instance_has_checkpoint floor_instance_1 map_checkpoint_1)
    (instance_has_checkpoint floor_instance_2 map_checkpoint_2)
    (construction_plan_available construction_plan_1)
    (construction_plan_available construction_plan_2)
    (upgrade_module_available upgrade_module_1)
    (upgrade_module_available upgrade_module_2)
    (hazard_marker_available hazard_marker_1)
    (attachment_item_available attachment_item_1)
    (special_encounter_marker_available special_encounter_marker_1)
    (instance_bound_to_special_marker floor_instance_1 special_encounter_marker_1)
    (instance_bound_to_special_marker floor_instance_2 special_encounter_marker_2)
    (signature_key_available signature_key_1)
  )
  (:goal
    (and
      (floor_unlocked zone_anchor_1)
      (floor_unlocked adjacent_zone_1)
      (floor_unlocked floor_instance_1)
      (floor_unlocked floor_instance_2)
    )
  )
)
