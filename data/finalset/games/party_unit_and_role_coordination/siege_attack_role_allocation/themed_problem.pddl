    (assigned_to_approach_vector_bravo assault_b_member_1 approach_vector_bravo_instance)
    (asset_available siege_tower_1)
    (cache_available resource_cache_1)
    (cache_available resource_cache_2)
    (slot_linked_member_a assignment_slot_1 assault_a_member_1)
    (slot_linked_member_a assignment_slot_2 assault_a_member_1)
    (slot_linked_member_b assignment_slot_1 assault_b_member_1)
    (slot_linked_member_b assignment_slot_2 assault_b_member_1)
    (slot_assigned_to_asset assignment_slot_1 siege_tower_1)
    (slot_assigned_to_asset assignment_slot_2 siege_tower_1)
    (slot_linked_cache assignment_slot_1 resource_cache_1)
    (slot_linked_cache assignment_slot_2 resource_cache_2)
    (objective_marker_available objective_marker_outer)
    (objective_marker_available objective_marker_inner)
    (buff_token_available buff_token_siege_boost)
    (buff_token_available buff_token_morale)
    (mission_marker_available mission_marker_1)
    (equipment_unit_available equipment_unit_reinforced_platform)
    (secondary_objective_available secondary_objective_flank)
    (slot_linked_secondary_objective assignment_slot_1 secondary_objective_flank)
    (slot_linked_secondary_objective assignment_slot_2 secondary_objective_sapper)
    (commander_unit_available commander_unit_captain)
