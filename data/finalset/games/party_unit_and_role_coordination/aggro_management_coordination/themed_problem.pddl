(define (problem aggro_management_scenario)
  (:domain aggro_management_coordination)
  (:objects tank_alpha - tank_unit dps_alpha - dps_unit coordinator_lead - encounter_coordinator coordinator_support - encounter_coordinator aggro_anchor_a - aggro_anchor aggro_anchor_b - aggro_anchor aggro_anchor_c - aggro_anchor enemy_target_a - enemy_target support_agent_a - support_agent consumable_potion - consumable_resource melee_slot_a - melee_threat_slot ranged_slot_a - ranged_threat_slot engagement_marker_a - engagement_marker mechanic_objective_a - mechanic_objective mechanic_objective_b - mechanic_objective tactic_token_a - tactic_token tactic_token_b - tactic_token buff_token_a - buff_token buff_token_b - buff_token taunt_charge_a - taunt_charge special_device_a - special_device priority_flag_a - priority_flag priority_flag_b - priority_flag timed_trigger_a - timed_trigger)
  (:init
    (anchor_available aggro_anchor_a)
    (anchor_available aggro_anchor_b)
    (anchor_available aggro_anchor_c)
    (enemy_target_available enemy_target_a)
    (support_available support_agent_a)
    (consumable_available consumable_potion)
    (assigned_melee_slot tank_alpha melee_slot_a)
    (assigned_ranged_slot dps_alpha ranged_slot_a)
    (marker_available engagement_marker_a)
    (mechanic_available mechanic_objective_a)
    (mechanic_available mechanic_objective_b)
    (coordinator_bound_to_tank coordinator_lead tank_alpha)
    (coordinator_bound_to_tank coordinator_support tank_alpha)
    (coordinator_bound_to_dps coordinator_lead dps_alpha)
    (coordinator_bound_to_dps coordinator_support dps_alpha)
    (coordinator_bound_to_marker coordinator_lead engagement_marker_a)
    (coordinator_bound_to_marker coordinator_support engagement_marker_a)
    (coordinator_assigned_mechanic coordinator_lead mechanic_objective_a)
    (coordinator_assigned_mechanic coordinator_support mechanic_objective_b)
    (tactic_token_available tactic_token_a)
    (tactic_token_available tactic_token_b)
    (buff_token_available buff_token_a)
    (buff_token_available buff_token_b)
    (taunt_charge_available taunt_charge_a)
    (special_device_available special_device_a)
    (priority_flag_available priority_flag_a)
    (coordinator_assigned_priority coordinator_lead priority_flag_a)
    (coordinator_assigned_priority coordinator_support priority_flag_b)
    (timed_trigger_available timed_trigger_a)
  )
  (:goal
    (and
      (engagement_committed tank_alpha)
      (engagement_committed dps_alpha)
      (engagement_committed coordinator_lead)
      (engagement_committed coordinator_support)
    )
  )
)
