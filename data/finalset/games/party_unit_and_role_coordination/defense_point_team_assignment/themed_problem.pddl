(define (problem assign_defenders_scenario)
  (:domain defense_point_team_assignment)
  (:objects primary_slot_a - primary_defender_slot secondary_slot_a - secondary_defender_slot operator_1 - operator_unit operator_2 - operator_unit role_token_sniper - role_token role_token_medic - role_token role_token_assault - role_token class_tag_recon - class_tag support_drone_1 - support_agent consumable_smoke_grenade - consumable_item position_node_a1 - position_node_a position_node_b1 - position_node_b assignment_token_1 - assignment_token equipment_slot_rifle - equipment_slot equipment_slot_armor - equipment_slot attachment_scope - attachment_token attachment_plating - attachment_token secondary_resource_ammo_crate - secondary_resource secondary_resource_med_kit - secondary_resource objective_marker_point - objective_marker temporary_buff_speed - temporary_buff permanent_bonus_veteran - permanent_bonus permanent_bonus_toughness - permanent_bonus special_modifier_stealth - special_modifier)
  (:init
    (role_token_released role_token_sniper)
    (role_token_released role_token_medic)
    (role_token_released role_token_assault)
    (class_tag_available class_tag_recon)
    (support_agent_available support_drone_1)
    (consumable_available consumable_smoke_grenade)
    (slot_link_position_a primary_slot_a position_node_a1)
    (slot_link_position_b secondary_slot_a position_node_b1)
    (assignment_token_available assignment_token_1)
    (equipment_available equipment_slot_rifle)
    (equipment_available equipment_slot_armor)
    (operator_link_primary_slot operator_1 primary_slot_a)
    (operator_link_primary_slot operator_2 primary_slot_a)
    (operator_link_secondary_slot operator_1 secondary_slot_a)
    (operator_link_secondary_slot operator_2 secondary_slot_a)
    (operator_link_assignment_token operator_1 assignment_token_1)
    (operator_link_assignment_token operator_2 assignment_token_1)
    (operator_has_equipment operator_1 equipment_slot_rifle)
    (operator_has_equipment operator_2 equipment_slot_armor)
    (attachment_token_available attachment_scope)
    (attachment_token_available attachment_plating)
    (secondary_resource_available secondary_resource_ammo_crate)
    (secondary_resource_available secondary_resource_med_kit)
    (objective_marker_released objective_marker_point)
    (temporary_buff_available temporary_buff_speed)
    (permanent_bonus_available permanent_bonus_veteran)
    (operator_has_permanent_bonus operator_1 permanent_bonus_veteran)
    (operator_has_permanent_bonus operator_2 permanent_bonus_toughness)
    (special_modifier_available special_modifier_stealth)
  )
  (:goal
    (and
      (assignment_locked primary_slot_a)
      (assignment_locked secondary_slot_a)
      (assignment_locked operator_1)
      (assignment_locked operator_2)
    )
  )
)
