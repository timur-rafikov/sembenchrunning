(define (problem party_collapse_revive_scenario)
  (:domain revive_priority_coordination)
  (:objects member_a_1 - subforce_member_a member_b_1 - subforce_member_b coordinator_alpha - coordinator_agent coordinator_beta - coordinator_agent revive_item_1 - revive_item revive_item_2 - revive_item revive_item_3 - revive_item healer_slot_1 - healer_resource support_assist_1 - support_assist utility_item_1 - utility_item anchor_point_a_1 - anchor_point_a anchor_point_b_1 - anchor_point_b revival_site_1 - revival_site consumable_pack_1 - consumable_pack consumable_pack_2 - consumable_pack tactic_marker_1 - tactic_marker tactic_marker_2 - tactic_marker buff_token_1 - buff_token buff_token_2 - buff_token timing_token_1 - timing_token priority_resource_1 - priority_resource custom_marker_1 - custom_marker custom_marker_2 - custom_marker specialist_token_1 - specialist_token)
  (:init
    (revive_item_available revive_item_1)
    (revive_item_available revive_item_2)
    (revive_item_available revive_item_3)
    (healer_slot_available healer_slot_1)
    (support_assist_available support_assist_1)
    (utility_item_available utility_item_1)
    (member_a_anchor_assigned member_a_1 anchor_point_a_1)
    (member_b_anchor_assigned member_b_1 anchor_point_b_1)
    (revival_site_available revival_site_1)
    (consumable_pack_available consumable_pack_1)
    (consumable_pack_available consumable_pack_2)
    (coordinator_member_link_a coordinator_alpha member_a_1)
    (coordinator_member_link_a coordinator_beta member_a_1)
    (coordinator_member_link_b coordinator_alpha member_b_1)
    (coordinator_member_link_b coordinator_beta member_b_1)
    (coordinator_attached_site coordinator_alpha revival_site_1)
    (coordinator_attached_site coordinator_beta revival_site_1)
    (coordinator_has_pack coordinator_alpha consumable_pack_1)
    (coordinator_has_pack coordinator_beta consumable_pack_2)
    (tactic_marker_available tactic_marker_1)
    (tactic_marker_available tactic_marker_2)
    (buff_token_available buff_token_1)
    (buff_token_available buff_token_2)
    (timing_token_available timing_token_1)
    (priority_resource_available priority_resource_1)
    (custom_marker_available custom_marker_1)
    (coordinator_has_custom_marker coordinator_alpha custom_marker_1)
    (coordinator_has_custom_marker coordinator_beta custom_marker_2)
    (specialist_token_available specialist_token_1)
  )
  (:goal
    (and
      (member_revived member_a_1)
      (member_revived member_b_1)
      (member_revived coordinator_alpha)
      (member_revived coordinator_beta)
    )
  )
)
