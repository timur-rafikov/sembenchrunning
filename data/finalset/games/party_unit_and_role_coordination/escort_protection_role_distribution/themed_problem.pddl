(define (problem escort_protection_scenario)
  (:domain escort_protection_role_distribution)
  (:objects escort_target_convoy - escort_target roving_escort_scout - rover team_alpha - mission_team team_bravo - mission_team role_slot_tank - role_slot role_slot_healer - role_slot role_slot_support - role_slot specialization_healer - specialization support_agent_drone_1 - support_agent equipment_kit_1 - equipment_token coverage_zone_alpha - coverage_zone encounter_alpha - encounter maneuver_flank_alpha - maneuver_token support_point_outpost_a - support_point support_point_outpost_b - support_point modifier_attack_boost - modifier_token modifier_defense_boost - modifier_token behavior_aggressive - behavior_profile behavior_defensive - behavior_profile escort_protocol_standard - escort_protocol upgrade_module_reinforcement - upgrade_module mission_objective_secure_bridge - mission_objective mission_objective_establish_perimeter - mission_objective comm_marker_channel_1 - comm_marker)
  (:init
    (slot_free role_slot_tank)
    (slot_free role_slot_healer)
    (slot_free role_slot_support)
    (specialization_available specialization_healer)
    (support_available support_agent_drone_1)
    (equipment_available equipment_kit_1)
    (assigned_zone escort_target_convoy coverage_zone_alpha)
    (rover_assigned_encounter roving_escort_scout encounter_alpha)
    (maneuver_available maneuver_flank_alpha)
    (support_point_available support_point_outpost_a)
    (support_point_available support_point_outpost_b)
    (team_assigned_target team_alpha escort_target_convoy)
    (team_assigned_target team_bravo escort_target_convoy)
    (team_assigned_rover team_alpha roving_escort_scout)
    (team_assigned_rover team_bravo roving_escort_scout)
    (team_has_maneuver team_alpha maneuver_flank_alpha)
    (team_has_maneuver team_bravo maneuver_flank_alpha)
    (team_has_support_point team_alpha support_point_outpost_a)
    (team_has_support_point team_bravo support_point_outpost_b)
    (modifier_available modifier_attack_boost)
    (modifier_available modifier_defense_boost)
    (behavior_profile_available behavior_aggressive)
    (behavior_profile_available behavior_defensive)
    (protocol_available escort_protocol_standard)
    (upgrade_available upgrade_module_reinforcement)
    (objective_available mission_objective_secure_bridge)
    (team_assigned_objective team_alpha mission_objective_secure_bridge)
    (team_assigned_objective team_bravo mission_objective_establish_perimeter)
    (comm_marker_available comm_marker_channel_1)
  )
  (:goal
    (and
      (activated escort_target_convoy)
      (activated roving_escort_scout)
      (activated team_alpha)
      (activated team_bravo)
    )
  )
)
