(define (problem mission_type_party_selection_problem)
  (:domain party_composition_selection_for_mission_type)
  (:objects frontline_unit_1 - frontline_unit ranged_unit_1 - ranged_unit party_alpha - mission_party party_beta - mission_party role_tank - role_token role_healer - role_token role_damage - role_token archetype_tank - class_archetype equipment_bundle_standard - equipment_bundle consumable_resource_1 - consumable_resource encounter_node_a1 - encounter_node_a encounter_node_b1 - encounter_node_b assignment_token_1 - assignment_token tactic_card_alpha - tactic_card tactic_card_beta - tactic_card party_marker_flag1 - party_marker party_marker_flag2 - party_marker synergy_token_alpha - synergy_token synergy_token_beta - synergy_token deployment_resource_1 - deployment_resource equipment_module_1 - equipment_module persona_badge_alpha - persona_badge persona_badge_beta - persona_badge signature_tactic_alpha - signature_tactic)
  (:init
    (role_token_available role_tank)
    (role_token_available role_healer)
    (role_token_available role_damage)
    (archetype_available archetype_tank)
    (equipment_bundle_available equipment_bundle_standard)
    (consumable_available consumable_resource_1)
    (frontline_node_link frontline_unit_1 encounter_node_a1)
    (ranged_node_link ranged_unit_1 encounter_node_b1)
    (assignment_token_available assignment_token_1)
    (tactic_card_available tactic_card_alpha)
    (tactic_card_available tactic_card_beta)
    (party_has_frontline_slot party_alpha frontline_unit_1)
    (party_has_frontline_slot party_beta frontline_unit_1)
    (party_has_ranged_slot party_alpha ranged_unit_1)
    (party_has_ranged_slot party_beta ranged_unit_1)
    (party_assignment_link party_alpha assignment_token_1)
    (party_assignment_link party_beta assignment_token_1)
    (party_has_tactic_card party_alpha tactic_card_alpha)
    (party_has_tactic_card party_beta tactic_card_beta)
    (party_marker_available party_marker_flag1)
    (party_marker_available party_marker_flag2)
    (synergy_token_available synergy_token_alpha)
    (synergy_token_available synergy_token_beta)
    (deployment_resource_available deployment_resource_1)
    (equipment_module_available equipment_module_1)
    (persona_badge_available persona_badge_alpha)
    (party_persona_binding party_alpha persona_badge_alpha)
    (party_persona_binding party_beta persona_badge_beta)
    (signature_tactic_available signature_tactic_alpha)
  )
  (:goal
    (and
      (deployed frontline_unit_1)
      (deployed ranged_unit_1)
      (deployed party_alpha)
      (deployed party_beta)
    )
  )
)
