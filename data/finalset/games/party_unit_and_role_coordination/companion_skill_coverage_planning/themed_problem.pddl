(define (problem companion_skill_coverage_problem)
  (:domain companion_skill_coverage_planning)
  (:objects frontline_companion_1 - frontline_companion rearguard_companion_1 - rearguard_companion planner_agent_alpha - planner_agent planner_agent_beta - planner_agent role_token_tank - role_token role_token_healer - role_token role_token_dps - role_token skill_proficiency_1 - skill equipment_armor_1 - equipment consumable_potion_1 - consumable frontline_point_alpha - encounter_point_frontline rearguard_point_alpha - encounter_point_rearguard tactic_slot_alpha - tactic_slot support_node_alpha - support_node support_node_beta - support_node buff_card_power - buff_card buff_card_speed - buff_card trait_module_combo_1 - trait_module trait_module_combo_2 - trait_module resource_marker_1 - resource_marker equipment_upgrade_1 - equipment_upgrade bond_modifier_ally_1 - bond_modifier bond_modifier_ally_2 - bond_modifier signature_talent_1 - signature_talent)
  (:init
    (role_token_available role_token_tank)
    (role_token_available role_token_healer)
    (role_token_available role_token_dps)
    (skill_available skill_proficiency_1)
    (equipment_available equipment_armor_1)
    (consumable_available consumable_potion_1)
    (frontline_assigned_point frontline_companion_1 frontline_point_alpha)
    (rearguard_assigned_point rearguard_companion_1 rearguard_point_alpha)
    (tactic_slot_available tactic_slot_alpha)
    (support_node_available support_node_alpha)
    (support_node_available support_node_beta)
    (planner_link_frontline_companion planner_agent_alpha frontline_companion_1)
    (planner_link_frontline_companion planner_agent_beta frontline_companion_1)
    (planner_link_rearguard_companion planner_agent_alpha rearguard_companion_1)
    (planner_link_rearguard_companion planner_agent_beta rearguard_companion_1)
    (planner_link_tactic_slot planner_agent_alpha tactic_slot_alpha)
    (planner_link_tactic_slot planner_agent_beta tactic_slot_alpha)
    (planner_link_support_node planner_agent_alpha support_node_alpha)
    (planner_link_support_node planner_agent_beta support_node_beta)
    (buff_card_available buff_card_power)
    (buff_card_available buff_card_speed)
    (trait_module_available trait_module_combo_1)
    (trait_module_available trait_module_combo_2)
    (resource_marker_available resource_marker_1)
    (equipment_upgrade_available equipment_upgrade_1)
    (bond_modifier_available bond_modifier_ally_1)
    (planner_link_bond_modifier planner_agent_alpha bond_modifier_ally_1)
    (planner_link_bond_modifier planner_agent_beta bond_modifier_ally_2)
    (signature_talent_available signature_talent_1)
  )
  (:goal
    (and
      (actor_deployed frontline_companion_1)
      (actor_deployed rearguard_companion_1)
      (actor_deployed planner_agent_alpha)
      (actor_deployed planner_agent_beta)
    )
  )
)
