    (role_token_available role_token_a)
    (role_token_available role_token_b)
    (role_token_available role_token_c)
    (tactic_available tactic_entry)
    (gear_available gear_breacher_kit)
    (utility_available utility_smoke)
    (element_assigned_route assault_element_alpha entry_route_alpha)
    (support_assigned_sector support_element_alpha cover_sector_alpha)
    (subteam_available subteam_alpha)
    (objective_marker_available objective_marker_a)
    (objective_marker_available objective_marker_b)
    (coordinator_assigned_assault_element coordinator_alpha assault_element_alpha)
    (coordinator_assigned_assault_element coordinator_bravo assault_element_alpha)
    (coordinator_assigned_support_element coordinator_alpha support_element_alpha)
    (coordinator_assigned_support_element coordinator_bravo support_element_alpha)
    (coordinator_assigned_subteam coordinator_alpha subteam_alpha)
    (coordinator_assigned_subteam coordinator_bravo subteam_alpha)
    (coordinator_objective_binding coordinator_alpha objective_marker_a)
    (coordinator_objective_binding coordinator_bravo objective_marker_b)
    (secondary_objective_available secondary_objective_a)
    (secondary_objective_available secondary_objective_b)
    (sync_marker_available sync_marker_a)
    (sync_marker_available sync_marker_b)
    (signal_marker_available signal_marker_primary)
    (breach_charge_available breach_charge_1)
    (target_tag_available target_tag_alpha)
    (coordinator_target_tag_binding coordinator_alpha target_tag_alpha)
    (coordinator_target_tag_binding coordinator_bravo target_tag_bravo)
    (extraction_marker_available extraction_marker_1)
