(define (problem party_combo_sequencing_problem)
  (:domain cooperative_ability_combo_sequencing_domain)
  (:objects strike_member_alpha - strike_squad_member support_member_alpha - support_squad_member planner_agent_primary - planner_slot planner_agent_secondary - planner_slot ability_token_assault - ability_token ability_token_shield - ability_token ability_token_heal - ability_token ability_component_core - ability_component equipment_module_sensor - equipment_module consumable_kit_alpha - consumable_resource left_flank_node_a - left_flank_node right_flank_node_a - right_flank_node encounter_point_alpha - encounter_point tactical_module_alpha - tactical_module tactical_module_beta - tactical_module field_upgrade_armor - field_upgrade field_upgrade_range - field_upgrade synergy_modifier_1 - synergy_modifier synergy_modifier_2 - synergy_modifier recovery_pack_1 - recovery_resource special_gadget_a1 - special_gadget_a priority_marker_1 - priority_marker priority_marker_2 - priority_marker special_gadget_b1 - special_gadget_b)
  (:init
    (ability_token_available ability_token_assault)
    (ability_token_available ability_token_shield)
    (ability_token_available ability_token_heal)
    (ability_component_available ability_component_core)
    (equipment_module_available equipment_module_sensor)
    (consumable_resource_available consumable_kit_alpha)
    (strike_member_left_flank_link strike_member_alpha left_flank_node_a)
    (support_member_right_flank_link support_member_alpha right_flank_node_a)
    (encounter_point_open encounter_point_alpha)
    (tactical_module_available tactical_module_alpha)
    (tactical_module_available tactical_module_beta)
    (planner_strike_member_link planner_agent_primary strike_member_alpha)
    (planner_strike_member_link planner_agent_secondary strike_member_alpha)
    (planner_support_member_link planner_agent_primary support_member_alpha)
    (planner_support_member_link planner_agent_secondary support_member_alpha)
    (planner_encounter_assignment planner_agent_primary encounter_point_alpha)
    (planner_encounter_assignment planner_agent_secondary encounter_point_alpha)
    (planner_has_tactical_module planner_agent_primary tactical_module_alpha)
    (planner_has_tactical_module planner_agent_secondary tactical_module_beta)
    (field_upgrade_available field_upgrade_armor)
    (field_upgrade_available field_upgrade_range)
    (synergy_modifier_available synergy_modifier_1)
    (synergy_modifier_available synergy_modifier_2)
    (recovery_resource_available recovery_pack_1)
    (special_gadget_a_available special_gadget_a1)
    (priority_marker_available priority_marker_1)
    (planner_priority_marker_link planner_agent_primary priority_marker_1)
    (planner_priority_marker_link planner_agent_secondary priority_marker_2)
    (special_gadget_b_available special_gadget_b1)
  )
  (:goal
    (and
      (slot_reconfigured strike_member_alpha)
      (slot_reconfigured support_member_alpha)
      (slot_reconfigured planner_agent_primary)
      (slot_reconfigured planner_agent_secondary)
    )
  )
)
