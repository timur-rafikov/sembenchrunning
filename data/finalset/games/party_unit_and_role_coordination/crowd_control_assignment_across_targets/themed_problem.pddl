    (secondary_bound_to_cluster_b secondary_unit_1 cluster_b_1)
    (bundle_available assignment_bundle_1)
    (marker_available tactical_marker_1)
    (marker_available tactical_marker_2)
    (controller_assigned_primary assignment_controller_1 primary_unit_1)
    (controller_assigned_primary assignment_controller_2 primary_unit_1)
    (controller_assigned_secondary assignment_controller_1 secondary_unit_1)
    (controller_assigned_secondary assignment_controller_2 secondary_unit_1)
    (controller_bound_to_bundle assignment_controller_1 assignment_bundle_1)
    (controller_bound_to_bundle assignment_controller_2 assignment_bundle_1)
    (controller_marker_bound assignment_controller_1 tactical_marker_1)
    (controller_marker_bound assignment_controller_2 tactical_marker_2)
    (priority_marker_available priority_marker_1)
    (priority_marker_available priority_marker_2)
    (talent_slot_available talent_slot_1)
    (talent_slot_available talent_slot_2)
    (assignment_tag_available assignment_tag_1)
    (auxiliary_support_available auxiliary_support_1)
    (priority_token_available priority_token_1)
    (controller_priority_bound assignment_controller_1 priority_token_1)
    (controller_priority_bound assignment_controller_2 priority_token_2)
    (phase_token_available phase_token_1)
