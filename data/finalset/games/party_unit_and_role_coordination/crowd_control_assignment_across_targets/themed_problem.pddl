(define (problem crowd_control_assignment_scenario)
  (:domain crowd_control_assignment_across_targets)
  (:objects primary_unit_1 - primary_cc_unit secondary_unit_1 - secondary_cc_unit assignment_controller_1 - assignment_controller assignment_controller_2 - assignment_controller cc_token_1 - cc_token cc_token_2 - cc_token cc_token_3 - cc_token ability_1 - cc_ability support_actor_1 - support_actor consumable_resource_1 - consumable_resource cluster_a_1 - target_cluster_a cluster_b_1 - target_cluster_b assignment_bundle_1 - assignment_bundle tactical_marker_1 - tactical_marker tactical_marker_2 - tactical_marker priority_marker_1 - priority_marker priority_marker_2 - priority_marker talent_slot_1 - talent_slot talent_slot_2 - talent_slot assignment_tag_1 - assignment_tag auxiliary_support_1 - auxiliary_support priority_token_1 - priority_token priority_token_2 - priority_token phase_token_1 - phase_token)
  (:init
