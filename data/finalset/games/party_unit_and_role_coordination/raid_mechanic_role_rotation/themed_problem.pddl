(define (problem raid_rotation_scenario)
  (:domain raid_mechanic_role_rotation)
  (:objects subteam_a_member_1 - subteam_a_member subteam_b_member_1 - subteam_b_member player_1 - player player_2 - player role_token_1 - role_token role_token_2 - role_token role_token_3 - role_token mechanic_marker_1 - mechanic_marker support_device_1 - support_device consumable_1 - consumable_item position_node_a_1 - position_node_a position_node_b_1 - position_node_b rotation_window_1 - rotation_window objective_check_1 - objective_check objective_check_2 - objective_check modifier_trigger_1 - modifier_trigger modifier_trigger_2 - modifier_trigger synergy_buff_1 - synergy_buff synergy_buff_2 - synergy_buff priority_marker_1 - priority_marker aux_tool_1 - aux_tool tactic_1 - tactic tactic_2 - tactic phase_flag_1 - phase_flag)
  (:init
    (role_token_available role_token_1)
    (role_token_available role_token_2)
    (role_token_available role_token_3)
    (mechanic_marker_available mechanic_marker_1)
    (support_device_available support_device_1)
    (consumable_available consumable_1)
    (subteam_a_at_position subteam_a_member_1 position_node_a_1)
    (subteam_b_at_position subteam_b_member_1 position_node_b_1)
    (rotation_window_available rotation_window_1)
    (objective_check_available objective_check_1)
    (objective_check_available objective_check_2)
    (player_linked_to_subteam_a player_1 subteam_a_member_1)
    (player_linked_to_subteam_a player_2 subteam_a_member_1)
    (player_linked_to_subteam_b player_1 subteam_b_member_1)
    (player_linked_to_subteam_b player_2 subteam_b_member_1)
    (player_assigned_to_window player_1 rotation_window_1)
    (player_assigned_to_window player_2 rotation_window_1)
    (player_has_objective_check player_1 objective_check_1)
    (player_has_objective_check player_2 objective_check_2)
    (modifier_trigger_available modifier_trigger_1)
    (modifier_trigger_available modifier_trigger_2)
    (synergy_buff_available synergy_buff_1)
    (synergy_buff_available synergy_buff_2)
    (priority_marker_available priority_marker_1)
    (aux_tool_available aux_tool_1)
    (tactic_available tactic_1)
    (player_has_tactic player_1 tactic_1)
    (player_has_tactic player_2 tactic_2)
    (phase_flag_available phase_flag_1)
  )
  (:goal
    (and
      (assignment_committed subteam_a_member_1)
      (assignment_committed subteam_b_member_1)
      (assignment_committed player_1)
      (assignment_committed player_2)
    )
  )
)
