(define (problem multi_party_supply_sharing_scenario)
  (:domain multi_party_supply_sharing_coordination_domain)
  (:objects subteam_a_1 - subteam_a subteam_b_1 - subteam_b coordinator_alpha - party_coordinator coordinator_beta - party_coordinator supply_node_1 - supply_node supply_node_2 - supply_node supply_node_3 - supply_node specialist_1 - specialist_unit support_unit_1 - support_unit resource_token_1 - resource_token route_a_1 - route_a route_b_1 - route_b shared_container_1 - shared_container resource_crate_1 - resource_crate resource_crate_2 - resource_crate upgrade_token_1 - upgrade_token upgrade_token_2 - upgrade_token role_tool_1 - role_tool role_tool_2 - role_tool mission_marker_1 - mission_marker upgrade_module_1 - upgrade_module mission_asset_1 - mission_asset mission_asset_2 - mission_asset mission_seed_1 - mission_seed)
  (:init
    (supply_node_available supply_node_1)
    (supply_node_available supply_node_2)
    (supply_node_available supply_node_3)
    (specialist_available specialist_1)
    (support_unit_available support_unit_1)
    (resource_token_available resource_token_1)
    (subteam_a_has_route subteam_a_1 route_a_1)
    (subteam_b_has_route subteam_b_1 route_b_1)
    (container_available shared_container_1)
    (crate_available resource_crate_1)
    (crate_available resource_crate_2)
    (coordinator_assigned_subteam_a coordinator_alpha subteam_a_1)
    (coordinator_assigned_subteam_a coordinator_beta subteam_a_1)
    (coordinator_assigned_subteam_b coordinator_alpha subteam_b_1)
    (coordinator_assigned_subteam_b coordinator_beta subteam_b_1)
    (coordinator_assigned_container coordinator_alpha shared_container_1)
    (coordinator_assigned_container coordinator_beta shared_container_1)
    (coordinator_has_crate coordinator_alpha resource_crate_1)
    (coordinator_has_crate coordinator_beta resource_crate_2)
    (upgrade_token_available upgrade_token_1)
    (upgrade_token_available upgrade_token_2)
    (role_tool_available role_tool_1)
    (role_tool_available role_tool_2)
    (mission_marker_available mission_marker_1)
    (upgrade_module_available upgrade_module_1)
    (mission_asset_available mission_asset_1)
    (coordinator_bound_mission_asset coordinator_alpha mission_asset_1)
    (coordinator_bound_mission_asset coordinator_beta mission_asset_2)
    (mission_seed_available mission_seed_1)
  )
  (:goal
    (and
      (participant_delivery_committed subteam_a_1)
      (participant_delivery_committed subteam_b_1)
      (participant_delivery_committed coordinator_alpha)
      (participant_delivery_committed coordinator_beta)
    )
  )
)
