(define (problem faction_lockout_recovery_problem)
  (:domain faction_lockout_alternative_progression_domain)
  (:objects primary_actor_slot_obj - primary_actor_slot secondary_actor_slot_obj - secondary_actor_slot agent_profile_obj_1 - agent_profile agent_profile_obj_2 - agent_profile faction_option_obj_1 - faction_option faction_option_obj_2 - faction_option faction_option_obj_3 - faction_option loadout_option_obj - loadout_option support_unit_obj - support_unit consumable_item_obj - consumable_item route_option_a_obj - route_option_a route_option_b_obj - route_option_b mission_instance_obj - mission_instance upgrade_module_obj_1 - upgrade_module upgrade_module_obj_2 - upgrade_module asset_token_obj_1 - asset_token asset_token_obj_2 - asset_token tactical_modifier_obj_1 - tactical_modifier tactical_modifier_obj_2 - tactical_modifier mission_token_obj - mission_token equipment_attachment_obj - equipment_attachment faction_marker_obj_1 - faction_marker faction_marker_obj_2 - faction_marker leadership_trait_obj - leadership_trait)
  (:init
    (faction_option_available faction_option_obj_1)
    (faction_option_available faction_option_obj_2)
    (faction_option_available faction_option_obj_3)
    (loadout_available loadout_option_obj)
    (support_unit_available support_unit_obj)
    (consumable_available consumable_item_obj)
    (primary_slot_assigned_route primary_actor_slot_obj route_option_a_obj)
    (secondary_slot_assigned_route secondary_actor_slot_obj route_option_b_obj)
    (mission_seed_available mission_instance_obj)
    (upgrade_module_available upgrade_module_obj_1)
    (upgrade_module_available upgrade_module_obj_2)
    (agent_assigned_primary_slot agent_profile_obj_1 primary_actor_slot_obj)
    (agent_assigned_primary_slot agent_profile_obj_2 primary_actor_slot_obj)
    (agent_assigned_secondary_slot agent_profile_obj_1 secondary_actor_slot_obj)
    (agent_assigned_secondary_slot agent_profile_obj_2 secondary_actor_slot_obj)
    (agent_assigned_to_mission agent_profile_obj_1 mission_instance_obj)
    (agent_assigned_to_mission agent_profile_obj_2 mission_instance_obj)
    (agent_has_upgrade agent_profile_obj_1 upgrade_module_obj_1)
    (agent_has_upgrade agent_profile_obj_2 upgrade_module_obj_2)
    (asset_token_available asset_token_obj_1)
    (asset_token_available asset_token_obj_2)
    (tactical_modifier_available tactical_modifier_obj_1)
    (tactical_modifier_available tactical_modifier_obj_2)
    (salvage_token_available mission_token_obj)
    (equipment_attachment_available equipment_attachment_obj)
    (faction_marker_available faction_marker_obj_1)
    (agent_bound_faction_marker agent_profile_obj_1 faction_marker_obj_1)
    (agent_bound_faction_marker agent_profile_obj_2 faction_marker_obj_2)
    (leadership_trait_available leadership_trait_obj)
  )
  (:goal
    (and
      (ready_for_deployment primary_actor_slot_obj)
      (ready_for_deployment secondary_actor_slot_obj)
      (ready_for_deployment agent_profile_obj_1)
      (ready_for_deployment agent_profile_obj_2)
    )
  )
)
