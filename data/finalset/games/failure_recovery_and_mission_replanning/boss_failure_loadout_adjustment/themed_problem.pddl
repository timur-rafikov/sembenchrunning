(define (problem boss_failure_recovery_scenario)
  (:domain boss_failure_loadout_adjustment)
  (:objects attacker_slot_1 - attacker_slot support_slot_1 - support_slot mission_coordinator_1 - operator mission_coordinator_2 - operator loadout_template_a - loadout_template loadout_template_b - loadout_template loadout_template_c - loadout_template weapon_option_1 - weapon_option support_unit_alpha - support_unit inventory_item_frag - inventory_item primary_equipment_slot_1 - primary_equipment_slot secondary_equipment_slot_1 - secondary_equipment_slot loadout_bundle_template - loadout_bundle attachment_module_1 - attachment_module attachment_module_2 - attachment_module tactic_module_a - tactic_module tactic_module_b - tactic_module consumable_buff_a - consumable_buff consumable_buff_b - consumable_buff recovery_token_1 - recovery_resource special_equipment_1 - special_equipment tactical_trait_a - tactical_trait tactical_trait_b - tactical_trait synergy_modifier_a - synergy_modifier)
  (:init
    (loadout_template_available loadout_template_a)
    (loadout_template_available loadout_template_b)
    (loadout_template_available loadout_template_c)
    (weapon_available weapon_option_1)
    (support_unit_available support_unit_alpha)
    (inventory_item_available inventory_item_frag)
    (has_primary_slot attacker_slot_1 primary_equipment_slot_1)
    (has_secondary_slot support_slot_1 secondary_equipment_slot_1)
    (bundle_template_available loadout_bundle_template)
    (attachment_module_available attachment_module_1)
    (attachment_module_available attachment_module_2)
    (operator_has_attacker_slot mission_coordinator_1 attacker_slot_1)
    (operator_has_attacker_slot mission_coordinator_2 attacker_slot_1)
    (operator_has_support_slot mission_coordinator_1 support_slot_1)
    (operator_has_support_slot mission_coordinator_2 support_slot_1)
    (operator_has_bundle mission_coordinator_1 loadout_bundle_template)
    (operator_has_bundle mission_coordinator_2 loadout_bundle_template)
    (operator_attachment_slot mission_coordinator_1 attachment_module_1)
    (operator_attachment_slot mission_coordinator_2 attachment_module_2)
    (tactic_module_available tactic_module_a)
    (tactic_module_available tactic_module_b)
    (consumable_buff_available consumable_buff_a)
    (consumable_buff_available consumable_buff_b)
    (recovery_resource_available recovery_token_1)
    (special_equipment_available special_equipment_1)
    (tactical_trait_available tactical_trait_a)
    (operator_tactical_trait_assigned mission_coordinator_1 tactical_trait_a)
    (operator_tactical_trait_assigned mission_coordinator_2 tactical_trait_b)
    (synergy_modifier_available synergy_modifier_a)
  )
  (:goal
    (and
      (recovery_allocated attacker_slot_1)
      (recovery_allocated support_slot_1)
      (recovery_allocated mission_coordinator_1)
      (recovery_allocated mission_coordinator_2)
    )
  )
)
