(define (problem failed_defense_recovery_scenario)
  (:domain failed_defense_recovery)
  (:objects garrison_alpha - local_defender_element support_alpha - support_element leader_alpha - squad_leader leader_bravo - squad_leader reinforcement_alpha - reinforcement_asset reinforcement_bravo - reinforcement_asset reinforcement_charlie - reinforcement_asset fallback_route_1 - route_option engineer_role - support_role repair_kit_1 - consumable_supply approach_primary_lane_1 - approach_primary_lane approach_secondary_lane_1 - approach_secondary_lane recovery_plan_alpha - recovery_plan_profile fort_module_a - fortification_module fort_module_b - fortification_module tactical_marker_a - tactical_marker tactical_marker_b - tactical_marker upgrade_module_a - upgrade_module upgrade_module_b - upgrade_module salvage_token_alpha - salvage_token equipment_variant_standard - equipment_variant mission_flag_alpha - mission_flag mission_flag_bravo - mission_flag specialist_upgrade_alpha - specialist_upgrade)
  (:init
    (reinforcement_available reinforcement_alpha)
    (reinforcement_available reinforcement_bravo)
    (reinforcement_available reinforcement_charlie)
    (route_available fallback_route_1)
    (support_role_available engineer_role)
    (supply_available repair_kit_1)
    (defender_assigned_primary_lane garrison_alpha approach_primary_lane_1)
    (support_assigned_secondary_lane support_alpha approach_secondary_lane_1)
    (plan_profile_available recovery_plan_alpha)
    (module_available fort_module_a)
    (module_available fort_module_b)
    (leader_assigned_to_defender leader_alpha garrison_alpha)
    (leader_assigned_to_defender leader_bravo garrison_alpha)
    (leader_assigned_to_support leader_alpha support_alpha)
    (leader_assigned_to_support leader_bravo support_alpha)
    (leader_assigned_plan leader_alpha recovery_plan_alpha)
    (leader_assigned_plan leader_bravo recovery_plan_alpha)
    (leader_reserved_module leader_alpha fort_module_a)
    (leader_reserved_module leader_bravo fort_module_b)
    (tactical_marker_available tactical_marker_a)
    (tactical_marker_available tactical_marker_b)
    (upgrade_module_available upgrade_module_a)
    (upgrade_module_available upgrade_module_b)
    (salvage_token_available salvage_token_alpha)
    (equipment_variant_available equipment_variant_standard)
    (mission_flag_available mission_flag_alpha)
    (leader_has_mission_flag leader_alpha mission_flag_alpha)
    (leader_has_mission_flag leader_bravo mission_flag_bravo)
    (specialist_upgrade_available specialist_upgrade_alpha)
  )
  (:goal
    (and
      (entity_restored garrison_alpha)
      (entity_restored support_alpha)
      (entity_restored leader_alpha)
      (entity_restored leader_bravo)
    )
  )
)
