(define (problem broken_equipment_repair_scenario)
  (:domain broken_equipment_emergency_reconfiguration)
  (:objects vehicle_1 - vehicle_unit infantry_1 - infantry_unit agent_1 - configurable_agent agent_2 - configurable_agent slot_port_a - component_slot slot_port_b - component_slot slot_port_c - component_slot spare_part_alpha - spare_part repair_tool_wrench - repair_tool consumable_patch_kit - consumable_resource damage_signature_1 - damage_signature repair_task_1 - repair_task repair_kit_alpha - repair_kit resource_pool_a - resource_pool resource_pool_b - resource_pool module_token_a - module_token module_token_b - module_token skill_token_tech - skill_token skill_token_field - skill_token priority_marker_high - priority_marker special_module_alpha - special_module modifier_alpha - mission_modifier modifier_beta - mission_modifier patch_bundle_v1 - patch_bundle)
  (:init
    (slot_available slot_port_a)
    (slot_available slot_port_b)
    (slot_available slot_port_c)
    (spare_available spare_part_alpha)
    (tool_available repair_tool_wrench)
    (consumable_available consumable_patch_kit)
    (vehicle_has_signature vehicle_1 damage_signature_1)
    (unit_task_assigned infantry_1 repair_task_1)
    (kit_available repair_kit_alpha)
    (resource_pool_available resource_pool_a)
    (resource_pool_available resource_pool_b)
    (agent_assigned_to_vehicle agent_1 vehicle_1)
    (agent_assigned_to_vehicle agent_2 vehicle_1)
    (agent_assigned_to_unit agent_1 infantry_1)
    (agent_assigned_to_unit agent_2 infantry_1)
    (agent_has_assigned_kit agent_1 repair_kit_alpha)
    (agent_has_assigned_kit agent_2 repair_kit_alpha)
    (agent_linked_to_pool agent_1 resource_pool_a)
    (agent_linked_to_pool agent_2 resource_pool_b)
    (module_token_available module_token_a)
    (module_token_available module_token_b)
    (skill_token_available skill_token_tech)
    (skill_token_available skill_token_field)
    (priority_marker_available priority_marker_high)
    (special_module_available special_module_alpha)
    (modifier_available modifier_alpha)
    (agent_has_modifier agent_1 modifier_alpha)
    (agent_has_modifier agent_2 modifier_beta)
    (patch_bundle_available patch_bundle_v1)
  )
  (:goal
    (and
      (asset_operational vehicle_1)
      (asset_operational infantry_1)
      (asset_operational agent_1)
      (asset_operational agent_2)
    )
  )
)
