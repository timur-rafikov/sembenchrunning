(define (problem interrupted_crafting_scenario)
  (:domain interrupted_crafting_replanning_domain)
  (:objects primary_slot_1 - primary_crafter_slot secondary_slot_1 - secondary_crafter_slot crafting_actor_alpha - crafting_actor crafting_actor_beta - crafting_actor iron_hammer_tool - loadout_item steel_chisel_tool - loadout_item forge_tongs - loadout_item raw_iron_ore - material_unit forge_station - crafting_station component_plate - component_item iron_vein - resource_node_ore timber_stump - resource_node_wood sword_blueprint - assembly_product blade_slot - subcomponent_slot hilt_slot - subcomponent_slot rune_attachment_token - attachment_token engraving_attachment_token - attachment_token smithing_skill_module - skill_module tempering_skill_module - skill_module catalyst_crystal - catalyst_condition sharpening_modifier - optional_modifier_a gold_variant_token - variant_token runic_variant_token - variant_token balance_adjust_modifier - optional_modifier_b)
  (:init
    (loadout_available iron_hammer_tool)
    (loadout_available steel_chisel_tool)
    (loadout_available forge_tongs)
    (material_available raw_iron_ore)
    (station_available forge_station)
    (component_available component_plate)
    (primary_slot_resource_ore_assigned primary_slot_1 iron_vein)
    (secondary_slot_resource_wood_assigned secondary_slot_1 timber_stump)
    (product_blueprint_available sword_blueprint)
    (subcomponent_available blade_slot)
    (subcomponent_available hilt_slot)
    (actor_primary_slot_link crafting_actor_alpha primary_slot_1)
    (actor_primary_slot_link crafting_actor_beta primary_slot_1)
    (actor_secondary_slot_link crafting_actor_alpha secondary_slot_1)
    (actor_secondary_slot_link crafting_actor_beta secondary_slot_1)
    (actor_product_link crafting_actor_alpha sword_blueprint)
    (actor_product_link crafting_actor_beta sword_blueprint)
    (actor_subcomponent_slot crafting_actor_alpha blade_slot)
    (actor_subcomponent_slot crafting_actor_beta hilt_slot)
    (attachment_available rune_attachment_token)
    (attachment_available engraving_attachment_token)
    (skill_module_available smithing_skill_module)
    (skill_module_available tempering_skill_module)
    (catalyst_available catalyst_crystal)
    (optional_modifier_a_available sharpening_modifier)
    (variant_available gold_variant_token)
    (actor_variant_link crafting_actor_alpha gold_variant_token)
    (actor_variant_link crafting_actor_beta runic_variant_token)
    (optional_modifier_b_available balance_adjust_modifier)
  )
  (:goal
    (and
      (continuation_enabled primary_slot_1)
      (continuation_enabled secondary_slot_1)
      (continuation_enabled crafting_actor_alpha)
      (continuation_enabled crafting_actor_beta)
    )
  )
)
