(define (problem mission_abort_reentry_problem)
  (:domain mission_abort_reentry_domain)
  (:objects primary_unit_1 - primary_unit secondary_unit_1 - secondary_unit mission_unit_1 - mission_unit mission_unit_2 - mission_unit extraction_asset_1 - extraction_asset extraction_asset_2 - extraction_asset extraction_asset_3 - extraction_asset trajectory_option_1 - trajectory_option crew_member_1 - crew_member equipment_item_1 - equipment_item approach_slot_1 - approach_slot support_slot_1 - support_slot reentry_craft_1 - reentry_craft integration_module_1 - integration_module integration_module_2 - integration_module upgrade_module_1 - upgrade_module upgrade_module_2 - upgrade_module consumable_1 - consumable_item consumable_2 - consumable_item recovery_point_1 - recovery_point special_tool_1 - special_tool priority_marker_1 - priority_marker priority_marker_2 - priority_marker certification_token_1 - certification_token)
  (:init
    (asset_available extraction_asset_1)
    (asset_available extraction_asset_2)
    (asset_available extraction_asset_3)
    (trajectory_available trajectory_option_1)
    (crew_available crew_member_1)
    (equipment_available equipment_item_1)
    (primary_bound_to_approach_slot primary_unit_1 approach_slot_1)
    (secondary_bound_to_support_slot secondary_unit_1 support_slot_1)
    (craft_available reentry_craft_1)
    (module_available integration_module_1)
    (module_available integration_module_2)
    (unit_has_primary mission_unit_1 primary_unit_1)
    (unit_has_primary mission_unit_2 primary_unit_1)
    (unit_has_secondary mission_unit_1 secondary_unit_1)
    (unit_has_secondary mission_unit_2 secondary_unit_1)
    (unit_assigned_to_craft mission_unit_1 reentry_craft_1)
    (unit_assigned_to_craft mission_unit_2 reentry_craft_1)
    (unit_has_integration_module mission_unit_1 integration_module_1)
    (unit_has_integration_module mission_unit_2 integration_module_2)
    (upgrade_available upgrade_module_1)
    (upgrade_available upgrade_module_2)
    (consumable_available consumable_1)
    (consumable_available consumable_2)
    (recovery_point_available recovery_point_1)
    (special_tool_available special_tool_1)
    (priority_marker_available priority_marker_1)
    (unit_assigned_priority_marker mission_unit_1 priority_marker_1)
    (unit_assigned_priority_marker mission_unit_2 priority_marker_2)
    (certification_available certification_token_1)
  )
  (:goal
    (and
      (reentry_ready primary_unit_1)
      (reentry_ready secondary_unit_1)
      (reentry_ready mission_unit_1)
      (reentry_ready mission_unit_2)
    )
  )
)
