(define (problem blocked_region_recovery_scenario)
  (:domain blocked_region_recovery)
  (:objects scout_alpha - scout_unit assault_bravo - assault_unit op_slot_omega - operation_slot op_slot_sigma - operation_slot asset_drone_01 - asset_unit asset_drone_02 - asset_unit asset_vehicle_01 - asset_unit route_alpha - route_option operator_lead - operator supply_kit_alpha - consumable_supply segment_alpha - map_segment detour_alpha - detour_option transport_01 - transport_vehicle supply_cache_alpha - supply_cache supply_cache_beta - supply_cache mod_slot_alpha - mod_slot mod_slot_beta - mod_slot upgrade_module_alpha - upgrade_module upgrade_module_beta - upgrade_module checkpoint_alpha - checkpoint_marker equipment_alpha - equipment_unit intel_packet_alpha - intel_packet intel_packet_beta - intel_packet tactic_profile_alpha - tactic_profile)
  (:init
    (asset_available asset_drone_01)
    (asset_available asset_drone_02)
    (asset_available asset_vehicle_01)
    (route_available route_alpha)
    (operator_available operator_lead)
    (supply_available supply_kit_alpha)
    (unit_associated_segment scout_alpha segment_alpha)
    (unit_associated_detour assault_bravo detour_alpha)
    (vehicle_available transport_01)
    (supply_cache_available supply_cache_alpha)
    (supply_cache_available supply_cache_beta)
    (op_slot_assigned_scout op_slot_omega scout_alpha)
    (op_slot_assigned_scout op_slot_sigma scout_alpha)
    (op_slot_assigned_assault op_slot_omega assault_bravo)
    (op_slot_assigned_assault op_slot_sigma assault_bravo)
    (op_slot_assigned_vehicle op_slot_omega transport_01)
    (op_slot_assigned_vehicle op_slot_sigma transport_01)
    (op_slot_has_supply_cache op_slot_omega supply_cache_alpha)
    (op_slot_has_supply_cache op_slot_sigma supply_cache_beta)
    (mod_slot_available mod_slot_alpha)
    (mod_slot_available mod_slot_beta)
    (upgrade_module_available upgrade_module_alpha)
    (upgrade_module_available upgrade_module_beta)
    (checkpoint_marker_available checkpoint_alpha)
    (equipment_unit_available equipment_alpha)
    (intel_packet_available intel_packet_alpha)
    (op_slot_has_intel_packet op_slot_omega intel_packet_alpha)
    (op_slot_has_intel_packet op_slot_sigma intel_packet_beta)
    (tactic_profile_available tactic_profile_alpha)
  )
  (:goal
    (and
      (region_unblocked scout_alpha)
      (region_unblocked assault_bravo)
      (region_unblocked op_slot_omega)
      (region_unblocked op_slot_sigma)
    )
  )
)
