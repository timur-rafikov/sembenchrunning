(define (problem material_shortage_after_failed_run_scenario)
  (:domain material_shortage_recovery_domain)
  (:objects scavenger_slot_1 - scavenger_slot responder_slot_1 - responder_slot squad_alpha - squad_unit squad_bravo - squad_unit supply_pack_a - supply_pack supply_pack_b - supply_pack supply_pack_c - supply_pack route_option_north - route_option support_tool_drone - support_tool material_fragment - material_unit scout_report_alpha - scout_report support_report_alpha - support_report supply_cache_slot - supply_cache upgrade_module_mk1 - upgrade_module upgrade_module_mk2 - upgrade_module optional_asset_a1 - optional_asset_a optional_asset_a2 - optional_asset_a consumable_boost_a - consumable_type consumable_boost_b - consumable_type resource_token_1 - resource_token module_variant_red - module_variant blueprint_asset_alpha - blueprint_asset blueprint_asset_beta - blueprint_asset key_component_prime - key_component)
  (:init
    (supply_pack_available supply_pack_a)
    (supply_pack_available supply_pack_b)
    (supply_pack_available supply_pack_c)
    (route_option_available route_option_north)
    (support_tool_available support_tool_drone)
    (material_unit_available material_fragment)
    (slot_has_scout_report scavenger_slot_1 scout_report_alpha)
    (responder_assigned_support_report responder_slot_1 support_report_alpha)
    (supply_cache_available supply_cache_slot)
    (upgrade_module_available upgrade_module_mk1)
    (upgrade_module_available upgrade_module_mk2)
    (squad_has_scavenger_slot squad_alpha scavenger_slot_1)
    (squad_has_scavenger_slot squad_bravo scavenger_slot_1)
    (squad_has_responder_slot squad_alpha responder_slot_1)
    (squad_has_responder_slot squad_bravo responder_slot_1)
    (squad_assigned_cache squad_alpha supply_cache_slot)
    (squad_assigned_cache squad_bravo supply_cache_slot)
    (squad_has_upgrade_module squad_alpha upgrade_module_mk1)
    (squad_has_upgrade_module squad_bravo upgrade_module_mk2)
    (optional_asset_available optional_asset_a1)
    (optional_asset_available optional_asset_a2)
    (consumable_available consumable_boost_a)
    (consumable_available consumable_boost_b)
    (resource_token_available resource_token_1)
    (module_variant_available module_variant_red)
    (blueprint_asset_available blueprint_asset_alpha)
    (squad_has_blueprint_asset squad_alpha blueprint_asset_alpha)
    (squad_has_blueprint_asset squad_bravo blueprint_asset_beta)
    (key_component_available key_component_prime)
  )
  (:goal
    (and
      (ready_for_redeploy scavenger_slot_1)
      (ready_for_redeploy responder_slot_1)
      (ready_for_redeploy squad_alpha)
      (ready_for_redeploy squad_bravo)
    )
  )
)
