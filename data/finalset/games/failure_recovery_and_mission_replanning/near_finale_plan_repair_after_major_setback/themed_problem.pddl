(define (problem near_finale_repair_problem)
  (:domain near_finale_plan_repair)
  (:objects primary_objective_alpha - primary_objective secondary_objective_beta - secondary_objective team_member_leader - team_member team_member_support - team_member equipment_rifle - equipment equipment_shield - equipment equipment_repair_kit - equipment tactic_stealth_entry - tactic specialist_demolition - specialist consumable_medpack - consumable_resource route_alpha - route_option approach_flank - approach_option strategy_blueprint_alpha - replanned_strategy module_nav_array - module module_suppression_array - module enhancement_armor - enhancement enhancement_targeting - enhancement behavior_aggressive - behavior_modifier behavior_defensive - behavior_modifier revival_token_generic - revival_token gear_upgrade_mk2 - gear_upgrade intel_asset_recon - intelligence_asset intel_asset_surveillance - intelligence_asset contingency_asset_emergency - contingency_asset)
  (:init
    (equipment_available equipment_rifle)
    (equipment_available equipment_shield)
    (equipment_available equipment_repair_kit)
    (tactic_available tactic_stealth_entry)
    (specialist_available specialist_demolition)
    (consumable_available consumable_medpack)
    (primary_has_route primary_objective_alpha route_alpha)
    (secondary_has_approach secondary_objective_beta approach_flank)
    (strategy_blueprint_available strategy_blueprint_alpha)
    (module_available module_nav_array)
    (module_available module_suppression_array)
    (member_assigned_primary_slot team_member_leader primary_objective_alpha)
    (member_assigned_primary_slot team_member_support primary_objective_alpha)
    (member_assigned_secondary_slot team_member_leader secondary_objective_beta)
    (member_assigned_secondary_slot team_member_support secondary_objective_beta)
    (member_linked_to_strategy team_member_leader strategy_blueprint_alpha)
    (member_linked_to_strategy team_member_support strategy_blueprint_alpha)
    (member_module_slot team_member_leader module_nav_array)
    (member_module_slot team_member_support module_suppression_array)
    (enhancement_available enhancement_armor)
    (enhancement_available enhancement_targeting)
    (behavior_modifier_available behavior_aggressive)
    (behavior_modifier_available behavior_defensive)
    (revival_token_available revival_token_generic)
    (gear_upgrade_available gear_upgrade_mk2)
    (intel_asset_available intel_asset_recon)
    (member_has_intel_asset team_member_leader intel_asset_recon)
    (member_has_intel_asset team_member_support intel_asset_surveillance)
    (contingency_asset_available contingency_asset_emergency)
  )
  (:goal
    (and
      (mission_element_recovered primary_objective_alpha)
      (mission_element_recovered secondary_objective_beta)
      (mission_element_recovered team_member_leader)
      (mission_element_recovered team_member_support)
    )
  )
)
