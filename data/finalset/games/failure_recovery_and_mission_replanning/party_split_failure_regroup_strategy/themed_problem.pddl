    (equipment_pack_available equipment_pack_1)
    (equipment_pack_available equipment_pack_2)
    (coordinator_alpha_link recovery_coordinator_1 alpha_member_1)
    (coordinator_alpha_link recovery_coordinator_2 alpha_member_1)
    (coordinator_bravo_link recovery_coordinator_1 bravo_member_1)
    (coordinator_bravo_link recovery_coordinator_2 bravo_member_1)
    (coordinator_site_link recovery_coordinator_1 rendezvous_site_1)
    (coordinator_site_link recovery_coordinator_2 rendezvous_site_1)
    (coordinator_equipment_bound recovery_coordinator_1 equipment_pack_1)
    (coordinator_equipment_bound recovery_coordinator_2 equipment_pack_2)
    (tactic_card_available tactic_card_1)
    (tactic_card_available tactic_card_2)
    (role_modifier_available role_modifier_1)
    (role_modifier_available role_modifier_2)
    (signal_token_available signal_token_1)
    (equipment_module_available equipment_module_1)
    (brief_available mission_brief_1)
