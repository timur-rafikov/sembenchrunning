(define (problem loadout_rebuild_scenario)
  (:domain loadout_failure_rebuild_domain)
  (:objects player_slot_1 - player_slot ally_slot_1 - ally_slot recovery_agent_1 - agent_template recovery_agent_2 - agent_template component_option_1 - component_option component_option_2 - component_option component_option_3 - component_option attachment_item_1 - attachment_pool_item support_item_1 - support_item_pool consumable_item_1 - consumable_item primary_weapon_1 - primary_weapon_type secondary_weapon_1 - secondary_weapon_type kit_template_1 - kit_template upgrade_module_1 - upgrade_module upgrade_module_2 - upgrade_module cosmetic_variant_1 - cosmetic_variant cosmetic_variant_2 - cosmetic_variant perk_token_1 - perk_token perk_token_2 - perk_token override_token_1 - override_token attachment_config_1 - attachment_configuration mission_modifier_1 - mission_modifier mission_modifier_2 - mission_modifier special_modifier_1 - special_modifier)
  (:init
    (component_available component_option_1)
    (component_available component_option_2)
    (component_available component_option_3)
    (attachment_available attachment_item_1)
    (support_item_available support_item_1)
    (consumable_available consumable_item_1)
    (slot_primary_type player_slot_1 primary_weapon_1)
    (ally_secondary_type ally_slot_1 secondary_weapon_1)
    (kit_template_available kit_template_1)
    (module_available upgrade_module_1)
    (module_available upgrade_module_2)
    (agent_assigned_to_slot recovery_agent_1 player_slot_1)
    (agent_assigned_to_slot recovery_agent_2 player_slot_1)
    (agent_assigned_to_ally_slot recovery_agent_1 ally_slot_1)
    (agent_assigned_to_ally_slot recovery_agent_2 ally_slot_1)
    (agent_has_template recovery_agent_1 kit_template_1)
    (agent_has_template recovery_agent_2 kit_template_1)
    (agent_has_module recovery_agent_1 upgrade_module_1)
    (agent_has_module recovery_agent_2 upgrade_module_2)
    (cosmetic_available cosmetic_variant_1)
    (cosmetic_available cosmetic_variant_2)
    (perk_available perk_token_1)
    (perk_available perk_token_2)
    (override_token_available override_token_1)
    (attachment_configuration_available attachment_config_1)
    (mission_modifier_available mission_modifier_1)
    (agent_has_mission_modifier recovery_agent_1 mission_modifier_1)
    (agent_has_mission_modifier recovery_agent_2 mission_modifier_2)
    (special_modifier_available special_modifier_1)
  )
  (:goal
    (and
      (loadout_applied player_slot_1)
      (loadout_applied ally_slot_1)
      (loadout_applied recovery_agent_1)
      (loadout_applied recovery_agent_2)
    )
  )
)
