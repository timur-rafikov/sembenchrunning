(define (problem defense_mission_wave_scenario)
  (:domain defense_mission_wave_progression)
  (:objects attacker_slot_1 - attacker_wave_slot ally_slot_1 - ally_wave_slot mission_instance_1 - mission_instance mission_instance_2 - mission_instance spawn_group_alpha - spawn_group_template spawn_group_beta - spawn_group_template spawn_group_gamma - spawn_group_template enemy_template_1 - enemy_unit_template defender_structure_1 - defender_structure_template support_item_1 - support_item sector_slot_1 - sector_slot sector_node_1 - sector_node reward_node_1 - reward_node module_component_a - module_component module_component_b - module_component condition_token_a - condition_token condition_token_b - condition_token milestone_token_a - milestone_token milestone_token_b - milestone_token consumable_resource_a - consumable_resource equipment_modifier_a - equipment_modifier affiliation_marker_a - affiliation_marker affiliation_marker_b - affiliation_marker narrative_flag_a - narrative_flag)
  (:init
    (spawn_group_available spawn_group_alpha)
    (spawn_group_available spawn_group_beta)
    (spawn_group_available spawn_group_gamma)
    (enemy_unit_available enemy_template_1)
    (structure_available defender_structure_1)
    (support_item_available support_item_1)
    (attacker_wave_slot_bound_to_sector_slot attacker_slot_1 sector_slot_1)
    (ally_wave_slot_bound_to_sector_node ally_slot_1 sector_node_1)
    (reward_node_unpopulated reward_node_1)
    (module_component_available module_component_a)
    (module_component_available module_component_b)
    (instance_has_attacker_slot mission_instance_1 attacker_slot_1)
    (instance_has_attacker_slot mission_instance_2 attacker_slot_1)
    (instance_has_ally_slot mission_instance_1 ally_slot_1)
    (instance_has_ally_slot mission_instance_2 ally_slot_1)
    (instance_has_reward_node mission_instance_1 reward_node_1)
    (instance_has_reward_node mission_instance_2 reward_node_1)
    (instance_has_module_component mission_instance_1 module_component_a)
    (instance_has_module_component mission_instance_2 module_component_b)
    (condition_token_available condition_token_a)
    (condition_token_available condition_token_b)
    (milestone_token_available milestone_token_a)
    (milestone_token_available milestone_token_b)
    (consumable_resource_available consumable_resource_a)
    (equipment_modifier_available equipment_modifier_a)
    (affiliation_marker_available affiliation_marker_a)
    (instance_has_affiliation_marker mission_instance_1 affiliation_marker_a)
    (instance_has_affiliation_marker mission_instance_2 affiliation_marker_b)
    (narrative_flag_available narrative_flag_a)
  )
  (:goal
    (and
      (mission_component_completed attacker_slot_1)
      (mission_component_completed ally_slot_1)
      (mission_component_completed mission_instance_1)
      (mission_component_completed mission_instance_2)
    )
  )
)
