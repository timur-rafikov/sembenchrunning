(define (problem campaign_progress_scenario)
  (:domain objective_ordering_campaign)
  (:objects mission_slot_a_1 - mission_slot_a mission_slot_b_1 - mission_slot_b campaign_node_alpha - campaign_node campaign_node_beta - campaign_node unlock_token_red - unlock_token unlock_token_blue - unlock_token unlock_token_green - unlock_token action_recon - action_type npc_support - supporting_npc consumable_charge - consumable_item path_variant_a1 - path_variant_a path_variant_b1 - path_variant_b mission_package_alpha - mission_package optional_challenge_1 - optional_challenge optional_challenge_2 - optional_challenge special_modifier_stealth - special_modifier special_modifier_brutal - special_modifier upgrade_speed - upgrade upgrade_power - upgrade checkpoint_token_1 - checkpoint_token reward_standard - reward plot_token_a - plot_token plot_token_b - plot_token story_key_main - story_key)
  (:init
    (unlock_token_available unlock_token_red)
    (unlock_token_available unlock_token_blue)
    (unlock_token_available unlock_token_green)
    (action_available action_recon)
    (npc_available npc_support)
    (consumable_available consumable_charge)
    (slot_a_assigned_path mission_slot_a_1 path_variant_a1)
    (slot_b_assigned_path mission_slot_b_1 path_variant_b1)
    (mission_package_unassembled mission_package_alpha)
    (optional_challenge_available optional_challenge_1)
    (optional_challenge_available optional_challenge_2)
    (node_contains_slot_a campaign_node_alpha mission_slot_a_1)
    (node_contains_slot_a campaign_node_beta mission_slot_a_1)
    (node_contains_slot_b campaign_node_alpha mission_slot_b_1)
    (node_contains_slot_b campaign_node_beta mission_slot_b_1)
    (node_contains_package campaign_node_alpha mission_package_alpha)
    (node_contains_package campaign_node_beta mission_package_alpha)
    (node_has_optional_challenge campaign_node_alpha optional_challenge_1)
    (node_has_optional_challenge campaign_node_beta optional_challenge_2)
    (special_modifier_available special_modifier_stealth)
    (special_modifier_available special_modifier_brutal)
    (upgrade_available upgrade_speed)
    (upgrade_available upgrade_power)
    (checkpoint_token_available checkpoint_token_1)
    (reward_available reward_standard)
    (plot_token_available plot_token_a)
    (node_has_plot_token campaign_node_alpha plot_token_a)
    (node_has_plot_token campaign_node_beta plot_token_b)
    (story_key_available story_key_main)
  )
  (:goal
    (and
      (mission_entity_completed mission_slot_a_1)
      (mission_entity_completed mission_slot_b_1)
      (mission_entity_completed campaign_node_alpha)
      (mission_entity_completed campaign_node_beta)
    )
  )
)
