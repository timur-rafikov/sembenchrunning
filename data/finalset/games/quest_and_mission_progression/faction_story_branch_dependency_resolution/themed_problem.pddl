(define (problem faction_story_branch_resolution_problem)
  (:domain faction_story_branch_dependency_resolution)
  (:objects faction_a_slot_1 - faction_slot_a faction_b_slot_1 - faction_slot_b story_branch_alpha - story_branch_instance story_branch_beta - story_branch_instance assignment_token_banner_1 - assignment_token assignment_token_banner_2 - assignment_token assignment_token_banner_3 - assignment_token objective_template_secure_point - objective_template agent_role_commander - agent_role consumable_resource_supply_crate - consumable_resource site_context_a_outpost - site_context_a site_context_b_outpost - site_context_b stage_item_emblem - stage_item artifact_relic_fragment - artifact artifact_ancient_icon - artifact optional_trigger_ambush - optional_trigger optional_trigger_diplomacy - optional_trigger modifier_token_stealth - modifier_token modifier_token_force - modifier_token commitment_key_scroll - commitment_key special_condition_a_rain - special_condition_a faction_flag_northern - faction_flag faction_flag_southern - faction_flag special_condition_b_dawn - special_condition_b)
  (:init
    (assignment_token_available assignment_token_banner_1)
    (assignment_token_available assignment_token_banner_2)
    (assignment_token_available assignment_token_banner_3)
    (objective_available objective_template_secure_point)
    (agent_available agent_role_commander)
    (consumable_available consumable_resource_supply_crate)
    (slot_a_site_link faction_a_slot_1 site_context_a_outpost)
    (slot_b_site_link faction_b_slot_1 site_context_b_outpost)
    (stage_item_available stage_item_emblem)
    (artifact_available artifact_relic_fragment)
    (artifact_available artifact_ancient_icon)
    (faction_slot_a_bound_to_branch story_branch_alpha faction_a_slot_1)
    (faction_slot_a_bound_to_branch story_branch_beta faction_a_slot_1)
    (faction_slot_b_bound_to_branch story_branch_alpha faction_b_slot_1)
    (faction_slot_b_bound_to_branch story_branch_beta faction_b_slot_1)
    (stage_item_bound_to_branch story_branch_alpha stage_item_emblem)
    (stage_item_bound_to_branch story_branch_beta stage_item_emblem)
    (artifact_bound_to_branch story_branch_alpha artifact_relic_fragment)
    (artifact_bound_to_branch story_branch_beta artifact_ancient_icon)
    (optional_trigger_available optional_trigger_ambush)
    (optional_trigger_available optional_trigger_diplomacy)
    (modifier_token_available modifier_token_stealth)
    (modifier_token_available modifier_token_force)
    (commitment_key_available commitment_key_scroll)
    (special_condition_a_available special_condition_a_rain)
    (faction_flag_available faction_flag_northern)
    (faction_flag_bound_to_branch story_branch_alpha faction_flag_northern)
    (faction_flag_bound_to_branch story_branch_beta faction_flag_southern)
    (special_condition_b_available special_condition_b_dawn)
  )
  (:goal
    (and
      (entity_committed faction_a_slot_1)
      (entity_committed faction_b_slot_1)
      (entity_committed story_branch_alpha)
      (entity_committed story_branch_beta)
    )
  )
)
