(define (problem stealth_objective_progression_problem)
  (:domain stealth_objective_progression_domain)
  (:objects infiltration_objective_1 - infiltration_objective exfiltration_objective_1 - exfiltration_objective mission_instance_alpha - mission_instance mission_instance_beta - mission_instance unlock_token_red - unlock_token unlock_token_blue - unlock_token unlock_token_green - unlock_token silent_takedown_capability - capability security_console_interactable - interactable consumable_smoke_grenade - consumable_resource zone_entry_alpha - area_zone patrol_route_alpha - route_pattern progression_package_alpha - progression_package reward_node_alpha - reward_node reward_node_beta - reward_node modifier_tempo - modifier_bonus modifier_difficulty - modifier_bonus checkpoint_bonus_alpha - checkpoint_bonus checkpoint_bonus_beta - checkpoint_bonus gating_flag_alpha - gating_flag optional_condition_secondary - optional_condition mission_tag_primary - mission_tag mission_tag_secondary - mission_tag variant_tag_a - variant_tag)
  (:init
    (unlock_token_available unlock_token_red)
    (unlock_token_available unlock_token_blue)
    (unlock_token_available unlock_token_green)
    (capability_available silent_takedown_capability)
    (interactable_available security_console_interactable)
    (consumable_available consumable_smoke_grenade)
    (infiltration_zone_association infiltration_objective_1 zone_entry_alpha)
    (exfiltration_route_assignment exfiltration_objective_1 patrol_route_alpha)
    (package_available progression_package_alpha)
    (reward_available reward_node_alpha)
    (reward_available reward_node_beta)
    (mission_contains_infiltration mission_instance_alpha infiltration_objective_1)
    (mission_contains_infiltration mission_instance_beta infiltration_objective_1)
    (mission_contains_exfiltration mission_instance_alpha exfiltration_objective_1)
    (mission_contains_exfiltration mission_instance_beta exfiltration_objective_1)
    (mission_assigned_package mission_instance_alpha progression_package_alpha)
    (mission_assigned_package mission_instance_beta progression_package_alpha)
    (mission_contains_reward mission_instance_alpha reward_node_alpha)
    (mission_contains_reward mission_instance_beta reward_node_beta)
    (modifier_available modifier_tempo)
    (modifier_available modifier_difficulty)
    (checkpoint_available checkpoint_bonus_alpha)
    (checkpoint_available checkpoint_bonus_beta)
    (gating_flag_available gating_flag_alpha)
    (optional_condition_available optional_condition_secondary)
    (mission_tag_available mission_tag_primary)
    (mission_has_tag mission_instance_alpha mission_tag_primary)
    (mission_has_tag mission_instance_beta mission_tag_secondary)
    (variant_available variant_tag_a)
  )
  (:goal
    (and
      (task_completed infiltration_objective_1)
      (task_completed exfiltration_objective_1)
      (task_completed mission_instance_alpha)
      (task_completed mission_instance_beta)
    )
  )
)
