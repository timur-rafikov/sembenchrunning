(define (problem optional_true_ending_scenario)
  (:domain quest_progression_true_ending)
  (:objects region_branch_1 - region_branch side_branch_1 - side_branch player_profile_1 - player_profile player_profile_2 - player_profile mission_giver_a - mission_giver mission_giver_b - mission_giver mission_giver_c - mission_giver objective_token_1 - objective_token npc_actor_1 - npc_actor consumable_resource_1 - consumable_resource region_flag_1 - region_flag side_flag_1 - side_flag ending_trigger_main - ending_trigger optional_artifact_a - optional_artifact optional_artifact_b - optional_artifact challenge_token_a - challenge_token challenge_token_b - challenge_token unlock_modifier_a - unlock_modifier unlock_modifier_b - unlock_modifier true_ending_key_a - true_ending_key upgrade_token_a - upgrade_token ally_token_a - ally_token ally_token_b - ally_token ritual_component_a - ritual_component)
  (:init
    (mission_giver_available mission_giver_a)
    (mission_giver_available mission_giver_b)
    (mission_giver_available mission_giver_c)
    (objective_available objective_token_1)
    (npc_available npc_actor_1)
    (consumable_resource_available consumable_resource_1)
    (region_branch_has_flag region_branch_1 region_flag_1)
    (side_branch_has_flag side_branch_1 side_flag_1)
    (ending_trigger_available ending_trigger_main)
    (optional_artifact_available optional_artifact_a)
    (optional_artifact_available optional_artifact_b)
    (profile_link_region_branch player_profile_1 region_branch_1)
    (profile_link_region_branch player_profile_2 region_branch_1)
    (profile_link_side_branch player_profile_1 side_branch_1)
    (profile_link_side_branch player_profile_2 side_branch_1)
    (profile_link_ending_trigger player_profile_1 ending_trigger_main)
    (profile_link_ending_trigger player_profile_2 ending_trigger_main)
    (profile_has_artifact player_profile_1 optional_artifact_a)
    (profile_has_artifact player_profile_2 optional_artifact_b)
    (challenge_token_available challenge_token_a)
    (challenge_token_available challenge_token_b)
    (unlock_modifier_available unlock_modifier_a)
    (unlock_modifier_available unlock_modifier_b)
    (true_ending_key_available true_ending_key_a)
    (upgrade_token_available upgrade_token_a)
    (ally_token_available ally_token_a)
    (profile_has_ally_token player_profile_1 ally_token_a)
    (profile_has_ally_token player_profile_2 ally_token_b)
    (ritual_component_available ritual_component_a)
  )
  (:goal
    (and
      (quest_component_completed region_branch_1)
      (quest_component_completed side_branch_1)
      (quest_component_completed player_profile_1)
      (quest_component_completed player_profile_2)
    )
  )
)
