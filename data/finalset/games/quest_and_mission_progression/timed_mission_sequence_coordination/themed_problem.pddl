(define (problem timed_mission_sequence_scenario)
  (:domain timed_mission_sequence_coordination)
  (:objects branch_a_node_1 - branch_a_node branch_b_node_1 - branch_b_node master_mission_alpha - master_mission master_mission_beta - master_mission activation_token_1 - activation_token activation_token_2 - activation_token activation_token_3 - activation_token trigger_event_1 - trigger_event agent_1 - agent consumable_1 - consumable sync_channel_a_1 - sync_channel_a sync_channel_b_1 - sync_channel_b sequence_artifact_1 - sequence_artifact sub_objective_1 - sub_objective sub_objective_2 - sub_objective modifier_token_a_1 - modifier_token_a modifier_token_a_2 - modifier_token_a modifier_token_b_1 - modifier_token_b modifier_token_b_2 - modifier_token_b timer_token_1 - timer_token optional_objective_a_1 - optional_objective_a special_condition_token_1 - special_condition_token special_condition_token_2 - special_condition_token finalization_token_1 - finalization_token)
  (:init
    (activation_token_available activation_token_1)
    (activation_token_available activation_token_2)
    (activation_token_available activation_token_3)
    (trigger_available trigger_event_1)
    (agent_available agent_1)
    (consumable_available consumable_1)
    (branch_a_channel_link branch_a_node_1 sync_channel_a_1)
    (branch_b_channel_link branch_b_node_1 sync_channel_b_1)
    (sequence_artifact_available sequence_artifact_1)
    (sub_objective_available sub_objective_1)
    (sub_objective_available sub_objective_2)
    (master_requires_branch_a master_mission_alpha branch_a_node_1)
    (master_requires_branch_a master_mission_beta branch_a_node_1)
    (master_requires_branch_b master_mission_alpha branch_b_node_1)
    (master_requires_branch_b master_mission_beta branch_b_node_1)
    (master_has_sequence_artifact master_mission_alpha sequence_artifact_1)
    (master_has_sequence_artifact master_mission_beta sequence_artifact_1)
    (master_has_sub_objective master_mission_alpha sub_objective_1)
    (master_has_sub_objective master_mission_beta sub_objective_2)
    (modifier_token_a_available modifier_token_a_1)
    (modifier_token_a_available modifier_token_a_2)
    (modifier_token_b_available modifier_token_b_1)
    (modifier_token_b_available modifier_token_b_2)
    (timer_token_available timer_token_1)
    (optional_objective_a_available optional_objective_a_1)
    (special_condition_token_available special_condition_token_1)
    (master_has_special_condition master_mission_alpha special_condition_token_1)
    (master_has_special_condition master_mission_beta special_condition_token_2)
    (finalization_token_available finalization_token_1)
  )
  (:goal
    (and
      (node_completed branch_a_node_1)
      (node_completed branch_b_node_1)
      (node_completed master_mission_alpha)
      (node_completed master_mission_beta)
    )
  )
)
