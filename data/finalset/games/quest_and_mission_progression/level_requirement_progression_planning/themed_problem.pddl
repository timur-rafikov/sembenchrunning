(define (problem level_requirement_progression_problem)
  (:domain level_requirement_progression_planning_domain)
  (:objects primary_track_node_1 - primary_track_node secondary_track_node_1 - secondary_track_node mission_alpha - mission mission_beta - mission unlock_key_1 - unlock_key unlock_key_2 - unlock_key unlock_key_3 - unlock_key objective_type_1 - objective_type gatekeeper_npc_1 - gatekeeper consumable_item_1 - consumable_item checkpoint_a_1 - requirement_checkpoint_a checkpoint_b_1 - requirement_checkpoint_b stage_1 - stage asset_alpha - asset asset_beta - asset side_objective_1 - side_objective side_objective_2 - side_objective scenario_variant_1 - scenario_variant scenario_variant_2 - scenario_variant level_gate_token_1 - level_gate_token mechanic_resource_1 - mechanic_resource narrative_trigger_1 - narrative_trigger narrative_trigger_2 - narrative_trigger conditional_trigger_1 - conditional_trigger)
  (:init
    (unlock_key_available unlock_key_1)
    (unlock_key_available unlock_key_2)
    (unlock_key_available unlock_key_3)
    (objective_available objective_type_1)
    (gatekeeper_available gatekeeper_npc_1)
    (consumable_available consumable_item_1)
    (primary_node_has_checkpoint_a primary_track_node_1 checkpoint_a_1)
    (secondary_node_has_checkpoint_b secondary_track_node_1 checkpoint_b_1)
    (stage_available stage_1)
    (asset_available asset_alpha)
    (asset_available asset_beta)
    (mission_associated_primary_node mission_alpha primary_track_node_1)
    (mission_associated_primary_node mission_beta primary_track_node_1)
    (mission_associated_secondary_node mission_alpha secondary_track_node_1)
    (mission_associated_secondary_node mission_beta secondary_track_node_1)
    (mission_has_stage mission_alpha stage_1)
    (mission_has_stage mission_beta stage_1)
    (mission_bound_asset mission_alpha asset_alpha)
    (mission_bound_asset mission_beta asset_beta)
    (side_objective_available side_objective_1)
    (side_objective_available side_objective_2)
    (scenario_variant_available scenario_variant_1)
    (scenario_variant_available scenario_variant_2)
    (level_gate_token_available level_gate_token_1)
    (mechanic_resource_available mechanic_resource_1)
    (narrative_trigger_available narrative_trigger_1)
    (mission_bound_narrative_trigger mission_alpha narrative_trigger_1)
    (mission_bound_narrative_trigger mission_beta narrative_trigger_2)
    (conditional_trigger_available conditional_trigger_1)
  )
  (:goal
    (and
      (progression_node_completed primary_track_node_1)
      (progression_node_completed secondary_track_node_1)
      (progression_node_completed mission_alpha)
      (progression_node_completed mission_beta)
    )
  )
)
