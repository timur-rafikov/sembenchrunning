(define (problem prerequisite_quest_chain_problem)
  (:domain quest_chain_unlocking)
  (:objects mainline_node_1 - mainline_node sidechain_node_1 - sidechain_node quest_line_1 - quest_line quest_line_2 - quest_line unlock_token_a - unlock_token unlock_token_b - unlock_token unlock_token_c - unlock_token requirement_1 - requirement npc_agent_1 - npc_agent collectible_item_1 - collectible_item checkpoint_a_1 - checkpoint_flag_a checkpoint_b_1 - checkpoint_flag_b unlockable_package_1 - unlockable_package subobjective_a - collection_subobjective subobjective_b - collection_subobjective credential_token_a - credential_token credential_token_b - credential_token consumable_permit_a - consumable_permit consumable_permit_b - consumable_permit progression_marker_1 - progression_marker reward_variant_1 - reward_variant unique_artifact_a - unique_artifact unique_artifact_b - unique_artifact special_modifier_1 - special_modifier)
  (:init
    (unlock_token_available unlock_token_a)
    (unlock_token_available unlock_token_b)
    (unlock_token_available unlock_token_c)
    (requirement_available requirement_1)
    (npc_available npc_agent_1)
    (collectible_available collectible_item_1)
    (node_flag_a_binding mainline_node_1 checkpoint_a_1)
    (node_flag_b_binding sidechain_node_1 checkpoint_b_1)
    (unlockable_candidate unlockable_package_1)
    (subobjective_available subobjective_a)
    (subobjective_available subobjective_b)
    (quest_line_includes_mainline quest_line_1 mainline_node_1)
    (quest_line_includes_mainline quest_line_2 mainline_node_1)
    (quest_line_includes_sidechain quest_line_1 sidechain_node_1)
    (quest_line_includes_sidechain quest_line_2 sidechain_node_1)
    (quest_line_includes_unlockable quest_line_1 unlockable_package_1)
    (quest_line_includes_unlockable quest_line_2 unlockable_package_1)
    (quest_line_has_subobjective quest_line_1 subobjective_a)
    (quest_line_has_subobjective quest_line_2 subobjective_b)
    (credential_available credential_token_a)
    (credential_available credential_token_b)
    (permit_available consumable_permit_a)
    (permit_available consumable_permit_b)
    (progression_marker_available progression_marker_1)
    (reward_variant_available reward_variant_1)
    (artifact_available unique_artifact_a)
    (line_bound_to_artifact quest_line_1 unique_artifact_a)
    (line_bound_to_artifact quest_line_2 unique_artifact_b)
    (special_modifier_available special_modifier_1)
  )
  (:goal
    (and
      (quest_unlocked mainline_node_1)
      (quest_unlocked sidechain_node_1)
      (quest_unlocked quest_line_1)
      (quest_unlocked quest_line_2)
    )
  )
)
