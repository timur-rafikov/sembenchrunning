(define (problem parallel_questline_conflict_resolution_problem)
  (:domain parallel_questline_conflict_resolution_domain)
  (:objects branch_a_node_1 - branch_node_a branch_b_node_1 - branch_node_b reconciliation_unit_1 - reconciliation_unit reconciliation_unit_2 - reconciliation_unit resource_token_1 - resource_token resource_token_2 - resource_token resource_token_3 - resource_token objective_marker_1 - objective_marker npc_actor_1 - npc_actor consumable_item_1 - consumable_item checkpoint_a_1 - checkpoint_a checkpoint_b_1 - checkpoint_b synchronization_point_1 - synchronization_point evidence_item_alpha - evidence_item evidence_item_beta - evidence_item optional_trigger_alpha - optional_trigger optional_trigger_beta - optional_trigger secondary_reward_alpha - secondary_reward secondary_reward_beta - secondary_reward resolution_token_1 - resolution_token special_resource_1 - special_resource ally_marker_1 - ally_marker ally_marker_2 - ally_marker key_witness_1 - key_witness)
  (:init
    (resource_available resource_token_1)
    (resource_available resource_token_2)
    (resource_available resource_token_3)
    (objective_available objective_marker_1)
    (npc_available npc_actor_1)
    (item_available consumable_item_1)
    (branch_a_checkpoint_link branch_a_node_1 checkpoint_a_1)
    (branch_b_checkpoint_link branch_b_node_1 checkpoint_b_1)
    (sync_point_available synchronization_point_1)
    (evidence_available evidence_item_alpha)
    (evidence_available evidence_item_beta)
    (reconciliation_unit_bound_branch_a reconciliation_unit_1 branch_a_node_1)
    (reconciliation_unit_bound_branch_a reconciliation_unit_2 branch_a_node_1)
    (reconciliation_unit_bound_branch_b reconciliation_unit_1 branch_b_node_1)
    (reconciliation_unit_bound_branch_b reconciliation_unit_2 branch_b_node_1)
    (reconciliation_unit_attached_sync_point reconciliation_unit_1 synchronization_point_1)
    (reconciliation_unit_attached_sync_point reconciliation_unit_2 synchronization_point_1)
    (evidence_attached_to_reconciliation_unit reconciliation_unit_1 evidence_item_alpha)
    (evidence_attached_to_reconciliation_unit reconciliation_unit_2 evidence_item_beta)
    (optional_trigger_available optional_trigger_alpha)
    (optional_trigger_available optional_trigger_beta)
    (secondary_reward_available secondary_reward_alpha)
    (secondary_reward_available secondary_reward_beta)
    (resolution_token_available_case resolution_token_1)
    (special_resource_available special_resource_1)
    (ally_available ally_marker_1)
    (ally_assigned_to_reconciliation_unit reconciliation_unit_1 ally_marker_1)
    (ally_assigned_to_reconciliation_unit reconciliation_unit_2 ally_marker_2)
    (key_witness_available key_witness_1)
  )
  (:goal
    (and
      (case_finalization_flag branch_a_node_1)
      (case_finalization_flag branch_b_node_1)
      (case_finalization_flag reconciliation_unit_1)
      (case_finalization_flag reconciliation_unit_2)
    )
  )
)
