(define (problem faction_reputation_gate_problem)
  (:domain faction_reputation_gate_domain)
  (:objects outpost_alpha - outpost_node squad_alpha - squad_node branch_red - faction_branch branch_blue - faction_branch contribution_token_a - contribution_token contribution_token_b - contribution_token contribution_token_c - contribution_token consumable_supply_1 - consumable_resource npc_agent_1 - npc_contact commodity_crate_1 - commodity_item region_a_flag_01 - region_flag_a region_b_flag_01 - region_flag_b gate_alpha - gate_mechanism blueprint_alpha - blueprint_document blueprint_beta - blueprint_document policy_economy - policy_module policy_security - policy_module cert_badge_alpha - certification_badge cert_badge_beta - certification_badge reputation_badge_1 - reputation_badge limited_offer_alpha - limited_offer quest_chip_alpha - quest_chip quest_chip_beta - quest_chip key_fragment_1 - key_resource)
  (:init
    (token_available contribution_token_a)
    (token_available contribution_token_b)
    (token_available contribution_token_c)
    (resource_available consumable_supply_1)
    (npc_available npc_agent_1)
    (commodity_available commodity_crate_1)
    (outpost_flag_a_link outpost_alpha region_a_flag_01)
    (squad_flag_b_link squad_alpha region_b_flag_01)
    (gate_registered gate_alpha)
    (blueprint_available blueprint_alpha)
    (blueprint_available blueprint_beta)
    (branch_has_outpost branch_red outpost_alpha)
    (branch_has_outpost branch_blue outpost_alpha)
    (branch_has_squad branch_red squad_alpha)
    (branch_has_squad branch_blue squad_alpha)
    (branch_gate_link branch_red gate_alpha)
    (branch_gate_link branch_blue gate_alpha)
    (branch_blueprint_attached branch_red blueprint_alpha)
    (branch_blueprint_attached branch_blue blueprint_beta)
    (policy_module_available policy_economy)
    (policy_module_available policy_security)
    (certification_badge_available cert_badge_alpha)
    (certification_badge_available cert_badge_beta)
    (reputation_badge_available reputation_badge_1)
    (limited_offer_available limited_offer_alpha)
    (quest_chip_available quest_chip_alpha)
    (branch_quest_chip_attached branch_red quest_chip_alpha)
    (branch_quest_chip_attached branch_blue quest_chip_beta)
    (key_resource_available key_fragment_1)
  )
  (:goal
    (and
      (node_advanced outpost_alpha)
      (node_advanced squad_alpha)
      (node_advanced branch_red)
      (node_advanced branch_blue)
    )
  )
)
