(define (problem mainline_priority_problem)
  (:domain quest_progression_domain)
  (:objects mainline_node_1 - mainline_quest_node side_node_1 - side_quest_node milestone_alpha - milestone_node milestone_beta - milestone_node unlock_token_a - unlock_token unlock_token_b - unlock_token unlock_token_c - unlock_token interaction_method_primary - interaction_method agent_npc_1 - quest_agent side_item_alpha - side_content_item encounter_instance_1 - encounter_instance encounter_variant_1 - encounter_variant mission_composite_1 - mission_composite reward_component_a - reward_component reward_component_b - reward_component optional_tag_alpha - optional_modifier_tag optional_tag_beta - optional_modifier_tag challenge_modifier_a - challenge_modifier challenge_modifier_b - challenge_modifier narrative_tag_alpha - narrative_tag special_resource_rare - special_resource companion_tag_1 - companion_tag companion_tag_2 - companion_tag time_limited_event_tag_1 - time_limited_event_tag)
  (:init
    (unlock_token_available unlock_token_a)
    (unlock_token_available unlock_token_b)
    (unlock_token_available unlock_token_c)
    (interaction_available interaction_method_primary)
    (agent_available agent_npc_1)
    (side_item_available side_item_alpha)
    (mainline_has_encounter mainline_node_1 encounter_instance_1)
    (side_has_encounter_variant side_node_1 encounter_variant_1)
    (composite_unassembled mission_composite_1)
    (reward_component_available reward_component_a)
    (reward_component_available reward_component_b)
    (milestone_requires_mainline milestone_alpha mainline_node_1)
    (milestone_requires_mainline milestone_beta mainline_node_1)
    (milestone_requires_side milestone_alpha side_node_1)
    (milestone_requires_side milestone_beta side_node_1)
    (milestone_requires_composite milestone_alpha mission_composite_1)
    (milestone_requires_composite milestone_beta mission_composite_1)
    (milestone_has_reward_component milestone_alpha reward_component_a)
    (milestone_has_reward_component milestone_beta reward_component_b)
    (optional_modifier_tag_available optional_tag_alpha)
    (optional_modifier_tag_available optional_tag_beta)
    (challenge_modifier_available challenge_modifier_a)
    (challenge_modifier_available challenge_modifier_b)
    (narrative_tag_available narrative_tag_alpha)
    (special_resource_available special_resource_rare)
    (companion_tag_available companion_tag_1)
    (companion_attached_to_milestone milestone_alpha companion_tag_1)
    (companion_attached_to_milestone milestone_beta companion_tag_2)
    (event_token_available time_limited_event_tag_1)
  )
  (:goal
    (and
      (quest_completed mainline_node_1)
      (quest_completed side_node_1)
      (quest_completed milestone_alpha)
      (quest_completed milestone_beta)
    )
  )
)
