(define (problem companion_unlock_scenario)
  (:domain companion_unlock_domain)
  (:objects primary_node_1 - primary_unlock_node secondary_node_1 - secondary_unlock_node companion_profile_a - companion_profile companion_profile_b - companion_profile unlock_token_1 - unlock_token unlock_token_2 - unlock_token unlock_token_3 - unlock_token task_objective_1 - task_objective gating_npc_1 - gating_npc_or_actor consumable_asset_1 - consumable_asset stage_flag_1 - stage_flag branch_variant_1 - branch_variant reward_bundle_1 - reward_bundle_entry staged_asset_1 - staged_asset staged_asset_2 - staged_asset optional_modifier_1 - optional_modifier optional_modifier_2 - optional_modifier promotion_token_1 - promotion_token promotion_token_2 - promotion_token companion_credential_1 - companion_credential affinity_material_1 - affinity_material special_requirement_1 - special_requirement special_requirement_2 - special_requirement unique_requirement_item_1 - unique_requirement_item)
  (:init
    (unlock_token_available unlock_token_1)
    (unlock_token_available unlock_token_2)
    (unlock_token_available unlock_token_3)
    (objective_available task_objective_1)
    (gating_npc_available gating_npc_1)
    (consumable_available consumable_asset_1)
    (primary_node_stage_slot_link primary_node_1 stage_flag_1)
    (secondary_node_variant_link secondary_node_1 branch_variant_1)
    (reward_bundle_seeded reward_bundle_1)
    (staged_asset_available staged_asset_1)
    (staged_asset_available staged_asset_2)
    (profile_link_primary_node companion_profile_a primary_node_1)
    (profile_link_primary_node companion_profile_b primary_node_1)
    (profile_link_secondary_node companion_profile_a secondary_node_1)
    (profile_link_secondary_node companion_profile_b secondary_node_1)
    (profile_link_bundle_entry companion_profile_a reward_bundle_1)
    (profile_link_bundle_entry companion_profile_b reward_bundle_1)
    (profile_staged_asset_link companion_profile_a staged_asset_1)
    (profile_staged_asset_link companion_profile_b staged_asset_2)
    (optional_modifier_available optional_modifier_1)
    (optional_modifier_available optional_modifier_2)
    (promotion_token_available promotion_token_1)
    (promotion_token_available promotion_token_2)
    (companion_credential_available companion_credential_1)
    (affinity_material_available affinity_material_1)
    (special_requirement_available special_requirement_1)
    (profile_has_special_requirement companion_profile_a special_requirement_1)
    (profile_has_special_requirement companion_profile_b special_requirement_2)
    (unique_requirement_item_available unique_requirement_item_1)
  )
  (:goal
    (and
      (unlockable_entity_completed primary_node_1)
      (unlockable_entity_completed secondary_node_1)
      (unlockable_entity_completed companion_profile_a)
      (unlockable_entity_completed companion_profile_b)
    )
  )
)
