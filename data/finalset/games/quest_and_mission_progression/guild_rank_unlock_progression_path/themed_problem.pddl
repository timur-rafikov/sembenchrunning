(define (problem guild_rank_unlock_progression_problem)
  (:domain guild_rank_unlock_progression_domain)
  (:objects progression_slot_a_1 - progression_slot_a progression_slot_b_1 - progression_slot_b rank_profile_alpha - rank_profile rank_profile_beta - rank_profile unlock_token_1 - unlock_token unlock_token_2 - unlock_token unlock_token_3 - unlock_token quest_initiation - quest guild_agent_marshal - agent consumable_item_1 - consumable_item milestone_a_primary - milestone_type_a milestone_b_primary - milestone_type_b rank_seal_1 - rank_seal resource_pack_alpha - resource_pack resource_pack_beta - resource_pack conditional_key_alpha - conditional_key conditional_key_beta - conditional_key certification_alpha - certification certification_beta - certification badge_alpha - badge special_objective_alpha - special_objective sponsor_alpha - sponsor sponsor_beta - sponsor endorsement_alpha - endorsement)
  (:init
    (unlock_token_available unlock_token_1)
    (unlock_token_available unlock_token_2)
    (unlock_token_available unlock_token_3)
    (quest_available quest_initiation)
    (agent_available guild_agent_marshal)
    (consumable_available consumable_item_1)
    (slot_a_has_milestone_a progression_slot_a_1 milestone_a_primary)
    (slot_b_has_milestone_b progression_slot_b_1 milestone_b_primary)
    (rank_seal_available rank_seal_1)
    (resource_pack_available resource_pack_alpha)
    (resource_pack_available resource_pack_beta)
    (rank_profile_has_slot_a rank_profile_alpha progression_slot_a_1)
    (rank_profile_has_slot_a rank_profile_beta progression_slot_a_1)
    (rank_profile_has_slot_b rank_profile_alpha progression_slot_b_1)
    (rank_profile_has_slot_b rank_profile_beta progression_slot_b_1)
    (rank_profile_has_seal rank_profile_alpha rank_seal_1)
    (rank_profile_has_seal rank_profile_beta rank_seal_1)
    (rank_profile_has_resource_pack rank_profile_alpha resource_pack_alpha)
    (rank_profile_has_resource_pack rank_profile_beta resource_pack_beta)
    (conditional_key_available conditional_key_alpha)
    (conditional_key_available conditional_key_beta)
    (certification_available certification_alpha)
    (certification_available certification_beta)
    (badge_available badge_alpha)
    (special_objective_available special_objective_alpha)
    (sponsor_available sponsor_alpha)
    (rank_profile_has_sponsor rank_profile_alpha sponsor_alpha)
    (rank_profile_has_sponsor rank_profile_beta sponsor_beta)
    (endorsement_available endorsement_alpha)
  )
  (:goal
    (and
      (progression_entity_unlocked progression_slot_a_1)
      (progression_entity_unlocked progression_slot_b_1)
      (progression_entity_unlocked rank_profile_alpha)
      (progression_entity_unlocked rank_profile_beta)
    )
  )
)
