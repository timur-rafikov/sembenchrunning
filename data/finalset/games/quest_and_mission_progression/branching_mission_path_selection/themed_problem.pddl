(define (problem branching_mission_path_selection_problem)
  (:domain branching_mission_path_selection_domain)
  (:objects branch_anchor_a_1 - branch_anchor_a branch_anchor_b_1 - branch_anchor_b quest_arc_1 - quest_arc quest_arc_2 - quest_arc branch_token_1 - branch_token branch_token_2 - branch_token branch_token_3 - branch_token objective_marker_1 - objective_marker support_agent_1 - support_agent consumable_item_1 - consumable_item branch_flag_a_1 - branch_flag_a branch_flag_b_1 - branch_flag_b outcome_container_1 - outcome_container checkpoint_1 - checkpoint checkpoint_2 - checkpoint variant_modifier_1 - variant_modifier variant_modifier_2 - variant_modifier reward_token_1 - reward_token reward_token_2 - reward_token gating_clue_1 - gating_clue unlock_key_1 - unlock_key special_requirement_1 - special_requirement special_requirement_2 - special_requirement requirement_key_1 - requirement_key)
  (:init
    (branch_token_available branch_token_1)
    (branch_token_available branch_token_2)
    (branch_token_available branch_token_3)
    (objective_marker_available objective_marker_1)
    (agent_available support_agent_1)
    (consumable_item_available consumable_item_1)
    (branch_anchor_a_has_flag branch_anchor_a_1 branch_flag_a_1)
    (branch_anchor_b_has_flag branch_anchor_b_1 branch_flag_b_1)
    (outcome_container_available outcome_container_1)
    (checkpoint_available checkpoint_1)
    (checkpoint_available checkpoint_2)
    (quest_arc_has_branch_anchor_a quest_arc_1 branch_anchor_a_1)
    (quest_arc_has_branch_anchor_a quest_arc_2 branch_anchor_a_1)
    (quest_arc_has_branch_anchor_b quest_arc_1 branch_anchor_b_1)
    (quest_arc_has_branch_anchor_b quest_arc_2 branch_anchor_b_1)
    (quest_arc_has_outcome_container quest_arc_1 outcome_container_1)
    (quest_arc_has_outcome_container quest_arc_2 outcome_container_1)
    (quest_arc_has_checkpoint quest_arc_1 checkpoint_1)
    (quest_arc_has_checkpoint quest_arc_2 checkpoint_2)
    (variant_modifier_available variant_modifier_1)
    (variant_modifier_available variant_modifier_2)
    (reward_token_available reward_token_1)
    (reward_token_available reward_token_2)
    (gating_clue_available gating_clue_1)
    (unlock_key_available unlock_key_1)
    (special_requirement_available special_requirement_1)
    (quest_arc_has_special_requirement quest_arc_1 special_requirement_1)
    (quest_arc_has_special_requirement quest_arc_2 special_requirement_2)
    (requirement_key_available requirement_key_1)
  )
  (:goal
    (and
      (mission_node_resolved branch_anchor_a_1)
      (mission_node_resolved branch_anchor_b_1)
      (mission_node_resolved quest_arc_1)
      (mission_node_resolved quest_arc_2)
    )
  )
)
