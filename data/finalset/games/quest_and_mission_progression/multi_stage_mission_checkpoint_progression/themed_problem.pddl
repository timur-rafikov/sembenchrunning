(define (problem mission_progression_problem)
  (:domain multi_stage_mission_checkpoint_progression_domain)
  (:objects primary_stage_1 - primary_stage secondary_stage_1 - secondary_stage mission_definition_alpha - mission_definition mission_definition_beta - mission_definition activation_token_1 - activation_token activation_token_2 - activation_token activation_token_3 - activation_token objective_type_standard - objective_type interaction_node_gate_1 - interaction_node consumable_resource_1 - consumable_resource primary_checkpoint_1 - primary_checkpoint secondary_checkpoint_1 - secondary_checkpoint checkpoint_record_1 - checkpoint_record optional_artifact_1 - optional_artifact optional_artifact_2 - optional_artifact variant_flag_a - variant_flag variant_flag_b - variant_flag milestone_modifier_1 - milestone_modifier milestone_modifier_2 - milestone_modifier stage_seal_1 - stage_seal modifier_a_1 - modifier_a modifier_b_1 - modifier_b modifier_b_2 - modifier_b modifier_c_1 - modifier_c)
  (:init
    (activation_token_available activation_token_1)
    (activation_token_available activation_token_2)
    (activation_token_available activation_token_3)
    (objective_type_available objective_type_standard)
    (interaction_node_available interaction_node_gate_1)
    (consumable_available consumable_resource_1)
    (primary_stage_has_checkpoint primary_stage_1 primary_checkpoint_1)
    (secondary_stage_has_checkpoint secondary_stage_1 secondary_checkpoint_1)
    (checkpoint_record_available checkpoint_record_1)
    (artifact_available optional_artifact_1)
    (artifact_available optional_artifact_2)
    (definition_element_has_primary_stage mission_definition_alpha primary_stage_1)
    (definition_element_has_primary_stage mission_definition_beta primary_stage_1)
    (definition_element_has_secondary_stage mission_definition_alpha secondary_stage_1)
    (definition_element_has_secondary_stage mission_definition_beta secondary_stage_1)
    (definition_element_has_checkpoint_record mission_definition_alpha checkpoint_record_1)
    (definition_element_has_checkpoint_record mission_definition_beta checkpoint_record_1)
    (definition_element_has_artifact mission_definition_alpha optional_artifact_1)
    (definition_element_has_artifact mission_definition_beta optional_artifact_2)
    (variant_flag_available variant_flag_a)
    (variant_flag_available variant_flag_b)
    (milestone_modifier_available milestone_modifier_1)
    (milestone_modifier_available milestone_modifier_2)
    (stage_seal_available stage_seal_1)
    (modifier_a_available modifier_a_1)
    (modifier_b_available modifier_b_1)
    (definition_element_has_modifier_b mission_definition_alpha modifier_b_1)
    (definition_element_has_modifier_b mission_definition_beta modifier_b_2)
    (modifier_c_available modifier_c_1)
  )
  (:goal
    (and
      (definition_element_completed primary_stage_1)
      (definition_element_completed secondary_stage_1)
      (definition_element_completed mission_definition_alpha)
      (definition_element_completed mission_definition_beta)
    )
  )
)
