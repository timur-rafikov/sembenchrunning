(define (problem mission_reward_choice_problem)
  (:domain mission_reward_driven_progression)
  (:objects branch_alpha - mission_branch variant_beta - mission_variant mission_profile_a - mission_profile mission_profile_b - mission_profile reward_option_a - reward_option reward_option_b - reward_option reward_option_c - reward_option choice_token_01 - player_choice_token modifier_npc_01 - modifier_token consumable_resource_01 - consumable_resource branch_marker_01 - branch_marker variant_marker_01 - variant_marker constructed_reward_01 - constructed_reward resource_slot_a - resource_slot resource_slot_b - resource_slot feature_tag_alpha - feature_tag feature_tag_beta - feature_tag upgrade_token_a - upgrade_token upgrade_token_b - upgrade_token progression_marker_01 - progression_marker attachment_token_01 - attachment_token trait_token_alpha - trait_token trait_token_beta - trait_token confirmation_token_01 - confirmation_token)
  (:init
    (reward_option_available reward_option_a)
    (reward_option_available reward_option_b)
    (reward_option_available reward_option_c)
    (player_choice_token_available choice_token_01)
    (modifier_token_available modifier_npc_01)
    (consumable_resource_available consumable_resource_01)
    (mission_branch_has_marker branch_alpha branch_marker_01)
    (mission_variant_has_marker variant_beta variant_marker_01)
    (constructed_reward_uninitialized constructed_reward_01)
    (resource_slot_available resource_slot_a)
    (resource_slot_available resource_slot_b)
    (mission_profile_links_branch mission_profile_a branch_alpha)
    (mission_profile_links_branch mission_profile_b branch_alpha)
    (mission_profile_links_variant mission_profile_a variant_beta)
    (mission_profile_links_variant mission_profile_b variant_beta)
    (mission_profile_links_constructed_reward mission_profile_a constructed_reward_01)
    (mission_profile_links_constructed_reward mission_profile_b constructed_reward_01)
    (mission_profile_has_resource_slot mission_profile_a resource_slot_a)
    (mission_profile_has_resource_slot mission_profile_b resource_slot_b)
    (feature_tag_available feature_tag_alpha)
    (feature_tag_available feature_tag_beta)
    (upgrade_token_available upgrade_token_a)
    (upgrade_token_available upgrade_token_b)
    (progression_marker_available progression_marker_01)
    (attachment_token_available attachment_token_01)
    (trait_token_available trait_token_alpha)
    (mission_profile_has_trait mission_profile_a trait_token_alpha)
    (mission_profile_has_trait mission_profile_b trait_token_beta)
    (confirmation_token_available confirmation_token_01)
  )
  (:goal
    (and
      (entity_completed branch_alpha)
      (entity_completed variant_beta)
      (entity_completed mission_profile_a)
      (entity_completed mission_profile_b)
    )
  )
)
