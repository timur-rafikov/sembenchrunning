(define (problem preservative_system_selection_problem)
  (:domain preservative_system_selection)
  (:objects formulation_variant_1 - formulation_variant manufacturing_route_1 - manufacturing_route development_case_alpha - development_case development_case_beta - development_case material_sample_a - preservative_material_sample material_sample_b - preservative_material_sample material_sample_c - preservative_material_sample microbial_assay_method_1 - assay_method formulation_batch_1 - formulation_batch analytical_resource_1 - analytical_resource compatibility_condition_1 - compatibility_condition scaleup_parameter_1 - scaleup_parameter evidence_package_initial - evidence_package data_set_stability - data_set data_set_microbiology - data_set regulatory_input_guideline_a - regulatory_input regulatory_input_guideline_b - regulatory_input stakeholder_approval_qa - stakeholder_approval stakeholder_approval_regulatory - stakeholder_approval logistics_resource_shipment_unit - logistics_resource equipment_bioburden_chamber - equipment external_expert_microbiology - external_expert external_expert_regulatory - external_expert risk_assessment_initial - risk_assessment)
  (:init
    (material_sample_available material_sample_a)
    (material_sample_available material_sample_b)
    (material_sample_available material_sample_c)
    (assay_method_available microbial_assay_method_1)
    (formulation_batch_available formulation_batch_1)
    (analytical_resource_available analytical_resource_1)
    (variant_compatibility_condition_association formulation_variant_1 compatibility_condition_1)
    (manufacturing_route_scaleup_parameter_association manufacturing_route_1 scaleup_parameter_1)
    (evidence_package_available evidence_package_initial)
    (data_set_available data_set_stability)
    (data_set_available data_set_microbiology)
    (case_includes_formulation_variant development_case_alpha formulation_variant_1)
    (case_includes_formulation_variant development_case_beta formulation_variant_1)
    (case_includes_manufacturing_route development_case_alpha manufacturing_route_1)
    (case_includes_manufacturing_route development_case_beta manufacturing_route_1)
    (case_includes_evidence_package development_case_alpha evidence_package_initial)
    (case_includes_evidence_package development_case_beta evidence_package_initial)
    (case_includes_data_set development_case_alpha data_set_stability)
    (case_includes_data_set development_case_beta data_set_microbiology)
    (regulatory_input_available regulatory_input_guideline_a)
    (regulatory_input_available regulatory_input_guideline_b)
    (stakeholder_approval_available stakeholder_approval_qa)
    (stakeholder_approval_available stakeholder_approval_regulatory)
    (logistics_resource_available logistics_resource_shipment_unit)
    (equipment_available equipment_bioburden_chamber)
    (external_expert_available external_expert_microbiology)
    (case_external_expert_assignment development_case_alpha external_expert_microbiology)
    (case_external_expert_assignment development_case_beta external_expert_regulatory)
    (risk_assessment_available risk_assessment_initial)
  )
  (:goal
    (and
      (finalized_for_handoff formulation_variant_1)
      (finalized_for_handoff manufacturing_route_1)
      (finalized_for_handoff development_case_alpha)
      (finalized_for_handoff development_case_beta)
    )
  )
)
