(define (problem scaleup_feasibility_review_problem)
  (:domain pharmaceutics_scaleup_feasibility_domain)
  (:objects formulation_variant_a - formulation_variant process_prototype_a - process_prototype scaleup_case_001 - scaleup_feasibility_case scaleup_case_002 - scaleup_feasibility_case hplc_equipment_1 - equipment_resource tablet_press_1 - equipment_resource granulator_1 - equipment_resource assay_method_potency - analytical_assay sme_formulation_scientist - subject_matter_expert initial_material_sample_record - material_sample_document lab_experiment_run_1 - lab_scale_experiment pilot_experiment_run_1 - pilot_scale_experiment process_fit_document_draft_1 - process_fit_document stability_protocol_short_term - stability_study_protocol stability_protocol_long_term - stability_study_protocol regulatory_requirement_gmp - regulatory_requirement regulatory_requirement_labeling - regulatory_requirement quality_attribute_potency - quality_attribute quality_attribute_impurity - quality_attribute evidence_certificate_analysis - evidence_artifact critical_process_parameter_temperature - critical_process_parameter executive_approval_record_1 - executive_approval_record executive_approval_record_2 - executive_approval_record supplier_qualification_record_1 - supplier_qualification_record)
  (:init
    (equipment_available hplc_equipment_1)
    (equipment_available tablet_press_1)
    (equipment_available granulator_1)
    (assay_available assay_method_potency)
    (sme_available sme_formulation_scientist)
    (sample_available initial_material_sample_record)
    (formulation_assigned_to_lab_experiment formulation_variant_a lab_experiment_run_1)
    (process_prototype_assigned_to_pilot_experiment process_prototype_a pilot_experiment_run_1)
    (process_fit_document_ready_for_compilation process_fit_document_draft_1)
    (stability_protocol_available stability_protocol_short_term)
    (stability_protocol_available stability_protocol_long_term)
    (development_item_includes_formulation_variant scaleup_case_001 formulation_variant_a)
    (development_item_includes_formulation_variant scaleup_case_002 formulation_variant_a)
    (development_item_includes_process_prototype scaleup_case_001 process_prototype_a)
    (development_item_includes_process_prototype scaleup_case_002 process_prototype_a)
    (development_item_includes_process_fit_document scaleup_case_001 process_fit_document_draft_1)
    (development_item_includes_process_fit_document scaleup_case_002 process_fit_document_draft_1)
    (development_item_includes_stability_protocol scaleup_case_001 stability_protocol_short_term)
    (development_item_includes_stability_protocol scaleup_case_002 stability_protocol_long_term)
    (regulatory_requirement_available regulatory_requirement_gmp)
    (regulatory_requirement_available regulatory_requirement_labeling)
    (quality_attribute_available quality_attribute_potency)
    (quality_attribute_available quality_attribute_impurity)
    (evidence_artifact_available evidence_certificate_analysis)
    (critical_process_parameter_available critical_process_parameter_temperature)
    (executive_approval_available executive_approval_record_1)
    (development_item_has_executive_approval_record scaleup_case_001 executive_approval_record_1)
    (development_item_has_executive_approval_record scaleup_case_002 executive_approval_record_2)
    (supplier_qualification_available supplier_qualification_record_1)
  )
  (:goal
    (and
      (approved_for_scale_up formulation_variant_a)
      (approved_for_scale_up process_prototype_a)
      (approved_for_scale_up scaleup_case_001)
      (approved_for_scale_up scaleup_case_002)
    )
  )
)
