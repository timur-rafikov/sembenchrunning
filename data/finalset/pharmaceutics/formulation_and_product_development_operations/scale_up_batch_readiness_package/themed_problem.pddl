(define (problem scaleup_batch_readiness_case)
  (:domain pharmaceutics_scaleup_batch_readiness)
  (:objects primary_process_alpha - primary_process secondary_process_alpha - secondary_process formulation_dossier_alpha - formulation_dossier formulation_dossier_beta - formulation_dossier manufacturing_site_north_facility - manufacturing_site manufacturing_site_south_cmo - manufacturing_site manufacturing_site_east_cmo - manufacturing_site analyst_lab_analyst1 - analytical_scientist process_engineer_jones - process_engineer assay_method_hplc - analytical_method reactor_config_100l - primary_equipment_config fill_finish_config_2000 - secondary_equipment_config scaleup_package_draft_1 - scaleup_package stability_plan_short_term - stability_plan stability_plan_long_term - stability_plan regulatory_checklist_type_a - regulatory_checklist regulatory_checklist_type_b - regulatory_checklist qa_checklist_initial - qa_assessment qa_checklist_followup - qa_assessment evidence_report_initial - evidence_artifact sop_manufacturing_procedure_001 - manufacturing_procedure risk_assessment_initial - risk_assessment risk_assessment_followup - risk_assessment sponsor_signoff_initial - sponsor_approval)
  (:init
    (site_available manufacturing_site_north_facility)
    (site_available manufacturing_site_south_cmo)
    (site_available manufacturing_site_east_cmo)
    (analytical_scientist_available analyst_lab_analyst1)
    (engineer_available process_engineer_jones)
    (analytical_method_available assay_method_hplc)
    (primary_process_equipment_match primary_process_alpha reactor_config_100l)
    (secondary_process_equipment_match secondary_process_alpha fill_finish_config_2000)
    (scaleup_package_draft_available scaleup_package_draft_1)
    (stability_plan_available stability_plan_short_term)
    (stability_plan_available stability_plan_long_term)
    (dossier_links_primary_process formulation_dossier_alpha primary_process_alpha)
    (dossier_links_primary_process formulation_dossier_beta primary_process_alpha)
    (dossier_links_secondary_process formulation_dossier_alpha secondary_process_alpha)
    (dossier_links_secondary_process formulation_dossier_beta secondary_process_alpha)
    (dossier_links_package formulation_dossier_alpha scaleup_package_draft_1)
    (dossier_links_package formulation_dossier_beta scaleup_package_draft_1)
    (dossier_links_stability_plan formulation_dossier_alpha stability_plan_short_term)
    (dossier_links_stability_plan formulation_dossier_beta stability_plan_long_term)
    (regulatory_checklist_available regulatory_checklist_type_a)
    (regulatory_checklist_available regulatory_checklist_type_b)
    (qa_assessment_available qa_checklist_initial)
    (qa_assessment_available qa_checklist_followup)
    (evidence_artifact_available evidence_report_initial)
    (manufacturing_procedure_available sop_manufacturing_procedure_001)
    (risk_assessment_available risk_assessment_initial)
    (dossier_linked_risk_assessment formulation_dossier_alpha risk_assessment_initial)
    (dossier_linked_risk_assessment formulation_dossier_beta risk_assessment_followup)
    (sponsor_approval_available sponsor_signoff_initial)
  )
  (:goal
    (and
      (is_scaleup_ready primary_process_alpha)
      (is_scaleup_ready secondary_process_alpha)
      (is_scaleup_ready formulation_dossier_alpha)
      (is_scaleup_ready formulation_dossier_beta)
    )
  )
)
