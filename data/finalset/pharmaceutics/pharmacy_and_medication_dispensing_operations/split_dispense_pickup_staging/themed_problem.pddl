(define (problem split_dispense_pickup_staging_case)
  (:domain pharmacy_split_dispense_pickup_staging)
  (:objects primary_segment_1 - primary_dispense_segment secondary_segment_1 - secondary_dispense_segment workorder_1 - dispensing_workorder workorder_2 - dispensing_workorder inventory_item_1 - inventory_item inventory_item_2 - inventory_item inventory_item_3 - inventory_item formulary_task_1 - formulary_check_task staff_member_1 - pharmacy_staff_member packaging_component_1 - packaging_component primary_slot_1 - staging_slot_primary secondary_slot_1 - staging_slot_secondary dispense_package_1 - dispense_package label_template_1 - label_template label_template_2 - label_template special_handling_1 - special_handling_requirement special_handling_2 - special_handling_requirement auxiliary_label_1 - auxiliary_label auxiliary_label_2 - auxiliary_label patient_instruction_1 - patient_instruction_material equipment_check_1 - equipment_or_device_check authorization_doc_1 - authorization_document authorization_doc_2 - authorization_document auth_token_1 - regulatory_authorization_token)
  (:init
    (inventory_available inventory_item_1)
    (inventory_available inventory_item_2)
    (inventory_available inventory_item_3)
    (formulary_task_available formulary_task_1)
    (staff_available staff_member_1)
    (packaging_available packaging_component_1)
    (primary_segment_staged_in_slot primary_segment_1 primary_slot_1)
    (secondary_segment_staged_in_slot secondary_segment_1 secondary_slot_1)
    (dispense_package_available dispense_package_1)
    (label_template_available label_template_1)
    (label_template_available label_template_2)
    (workorder_includes_primary_segment workorder_1 primary_segment_1)
    (workorder_includes_primary_segment workorder_2 primary_segment_1)
    (workorder_includes_secondary_segment workorder_1 secondary_segment_1)
    (workorder_includes_secondary_segment workorder_2 secondary_segment_1)
    (workorder_associated_with_package workorder_1 dispense_package_1)
    (workorder_associated_with_package workorder_2 dispense_package_1)
    (workorder_label_template_bound workorder_1 label_template_1)
    (workorder_label_template_bound workorder_2 label_template_2)
    (special_handling_available special_handling_1)
    (special_handling_available special_handling_2)
    (auxiliary_label_available auxiliary_label_1)
    (auxiliary_label_available auxiliary_label_2)
    (patient_instruction_available patient_instruction_1)
    (equipment_check_available equipment_check_1)
    (authorization_document_available authorization_doc_1)
    (workorder_authorization_document_bound workorder_1 authorization_doc_1)
    (workorder_authorization_document_bound workorder_2 authorization_doc_2)
    (auth_token_available auth_token_1)
  )
  (:goal
    (and
      (released_for_pickup primary_segment_1)
      (released_for_pickup secondary_segment_1)
      (released_for_pickup workorder_1)
      (released_for_pickup workorder_2)
    )
  )
)
