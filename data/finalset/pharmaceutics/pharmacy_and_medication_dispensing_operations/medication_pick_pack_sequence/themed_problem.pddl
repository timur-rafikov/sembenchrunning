(define (problem medication_pick_pack_case)
  (:domain medication_pick_pack_sequence)
  (:objects pick_task_obj - pick_task pack_task_obj - pack_task dispense_job_obj_1 - dispense_job dispense_job_obj_2 - dispense_job stock_unit_obj_1 - stock_unit stock_unit_obj_2 - stock_unit stock_unit_obj_3 - stock_unit medication_product_obj - medication_product staff_obj - staff accessory_item_obj - accessory_item pick_bin_obj - pick_bin pack_station_obj - pack_station package_obj - package label_template_obj_1 - label_template label_template_obj_2 - label_template packaging_material_obj_1 - packaging_material packaging_material_obj_2 - packaging_material instruction_template_obj_1 - instruction_template instruction_template_obj_2 - instruction_template patient_profile_obj - patient_profile clinical_check_obj - clinical_check prior_auth_document_obj_1 - prior_auth_document prior_auth_document_obj_2 - prior_auth_document regulatory_document_obj - regulatory_document)
  (:init
    (stock_unit_available stock_unit_obj_1)
    (stock_unit_available stock_unit_obj_2)
    (stock_unit_available stock_unit_obj_3)
    (medication_product_available medication_product_obj)
    (staff_available staff_obj)
    (accessory_item_available accessory_item_obj)
    (pick_task_assigned_bin pick_task_obj pick_bin_obj)
    (pack_task_assigned_station pack_task_obj pack_station_obj)
    (package_available package_obj)
    (label_template_available label_template_obj_1)
    (label_template_available label_template_obj_2)
    (dispense_job_has_pick_task dispense_job_obj_1 pick_task_obj)
    (dispense_job_has_pick_task dispense_job_obj_2 pick_task_obj)
    (dispense_job_has_pack_task dispense_job_obj_1 pack_task_obj)
    (dispense_job_has_pack_task dispense_job_obj_2 pack_task_obj)
    (dispense_job_assigned_package dispense_job_obj_1 package_obj)
    (dispense_job_assigned_package dispense_job_obj_2 package_obj)
    (dispense_job_assigned_label_template dispense_job_obj_1 label_template_obj_1)
    (dispense_job_assigned_label_template dispense_job_obj_2 label_template_obj_2)
    (packaging_material_available packaging_material_obj_1)
    (packaging_material_available packaging_material_obj_2)
    (instruction_template_available instruction_template_obj_1)
    (instruction_template_available instruction_template_obj_2)
    (patient_profile_available patient_profile_obj)
    (clinical_check_available clinical_check_obj)
    (prior_auth_document_available prior_auth_document_obj_1)
    (dispense_job_attached_prior_auth dispense_job_obj_1 prior_auth_document_obj_1)
    (dispense_job_attached_prior_auth dispense_job_obj_2 prior_auth_document_obj_2)
    (regulatory_document_available regulatory_document_obj)
  )
  (:goal
    (and
      (ready_for_dispensing pick_task_obj)
      (ready_for_dispensing pack_task_obj)
      (ready_for_dispensing dispense_job_obj_1)
      (ready_for_dispensing dispense_job_obj_2)
    )
  )
)
