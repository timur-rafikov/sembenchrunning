(define (problem high_risk_double_check_scenario)
  (:domain pharmacy_high_risk_double_check_domain)
  (:objects prep_tech_1 - preparer_technician checker_tech_1 - independent_check_technician dispensing_task_1 - dispensing_task dispensing_task_2 - dispensing_task verifier_slot_pharm_1 - verifier_slot verifier_slot_pharm_2 - verifier_slot verifier_slot_pharm_3 - verifier_slot medication_product_high_risk - medication_product checker_slot_1 - checker_slot component_item_vial - component_item dosage_form_solution - dosage_form package_type_bottle - package_type medication_batch_001 - medication_batch label_template_standard_1 - label_template label_template_standard_2 - label_template ancillary_supply_1 - ancillary_supply ancillary_supply_2 - ancillary_supply patient_education_leaflet_1 - patient_education_material patient_education_leaflet_2 - patient_education_material counseling_topic_dispense_instructions - counseling_topic clinical_check_flag_allergy - clinical_check_flag approval_token_pharmacist_1 - approval_token approval_token_pharmacist_2 - approval_token override_token_senior_pharmacist - override_token)
  (:init
    (verifier_slot_available verifier_slot_pharm_1)
    (verifier_slot_available verifier_slot_pharm_2)
    (verifier_slot_available verifier_slot_pharm_3)
    (medication_product_available medication_product_high_risk)
    (checker_slot_available checker_slot_1)
    (component_available component_item_vial)
    (preparer_selected_dosage_form prep_tech_1 dosage_form_solution)
    (checker_assigned_package_type checker_tech_1 package_type_bottle)
    (batch_pending medication_batch_001)
    (label_template_available label_template_standard_1)
    (label_template_available label_template_standard_2)
    (task_assigned_preparer dispensing_task_1 prep_tech_1)
    (task_assigned_preparer dispensing_task_2 prep_tech_1)
    (task_assigned_checker dispensing_task_1 checker_tech_1)
    (task_assigned_checker dispensing_task_2 checker_tech_1)
    (task_assigned_batch dispensing_task_1 medication_batch_001)
    (task_assigned_batch dispensing_task_2 medication_batch_001)
    (task_assigned_label_template dispensing_task_1 label_template_standard_1)
    (task_assigned_label_template dispensing_task_2 label_template_standard_2)
    (ancillary_supply_available ancillary_supply_1)
    (ancillary_supply_available ancillary_supply_2)
    (patient_education_available patient_education_leaflet_1)
    (patient_education_available patient_education_leaflet_2)
    (counseling_topic_available counseling_topic_dispense_instructions)
    (clinical_check_flag_available clinical_check_flag_allergy)
    (approval_token_available approval_token_pharmacist_1)
    (task_has_approval_token dispensing_task_1 approval_token_pharmacist_1)
    (task_has_approval_token dispensing_task_2 approval_token_pharmacist_2)
    (override_token_available override_token_senior_pharmacist)
  )
  (:goal
    (and
      (entity_released_to_patient prep_tech_1)
      (entity_released_to_patient checker_tech_1)
      (entity_released_to_patient dispensing_task_1)
      (entity_released_to_patient dispensing_task_2)
    )
  )
)
