(define (problem therapeutic_substitution_case)
  (:domain pharmacy_therapeutic_substitution_domain)
  (:objects pharmacist_dispense_task_1 - pharmacist_dispense_task technician_dispense_task_1 - technician_dispense_task prescription_line_primary - prescription_line prescription_line_secondary - prescription_line candidate_product_a - drug_product_candidate candidate_product_b - drug_product_candidate candidate_product_c - drug_product_candidate pharmacist_1 - pharmacist prescriber_1 - prescriber_clinician resource_token_1 - transient_resource_token formulation_component_1 - formulation_component packaging_component_1 - packaging_component package_unit_1 - package_unit label_template_standard - label_template label_template_alternate - label_template special_handling_refrigeration - special_handling_option special_handling_controlled_substance - special_handling_option patient_instruction_template_standard - patient_instruction_template patient_instruction_template_condensed - patient_instruction_template patient_instruction_asset_1 - patient_instruction_asset clinical_check_record_1 - clinical_check_record insurance_authorization_record_a - insurance_authorization_record insurance_authorization_record_b - insurance_authorization_record clinical_override_record_1 - clinical_override_record)
  (:init
    (candidate_available candidate_product_a)
    (candidate_available candidate_product_b)
    (candidate_available candidate_product_c)
    (pharmacist_available pharmacist_1)
    (prescriber_available prescriber_1)
    (transient_resource_available resource_token_1)
    (dispense_task_requires_component pharmacist_dispense_task_1 formulation_component_1)
    (technician_task_requires_packaging_component technician_dispense_task_1 packaging_component_1)
    (package_unit_available package_unit_1)
    (label_template_available label_template_standard)
    (label_template_available label_template_alternate)
    (prescription_line_assigned_to_pharmacist_task prescription_line_primary pharmacist_dispense_task_1)
    (prescription_line_assigned_to_pharmacist_task prescription_line_secondary pharmacist_dispense_task_1)
    (prescription_line_assigned_to_technician_task prescription_line_primary technician_dispense_task_1)
    (prescription_line_assigned_to_technician_task prescription_line_secondary technician_dispense_task_1)
    (prescription_line_assigned_package_unit prescription_line_primary package_unit_1)
    (prescription_line_assigned_package_unit prescription_line_secondary package_unit_1)
    (line_label_template_association prescription_line_primary label_template_standard)
    (line_label_template_association prescription_line_secondary label_template_alternate)
    (special_handling_option_available special_handling_refrigeration)
    (special_handling_option_available special_handling_controlled_substance)
    (patient_instruction_template_available patient_instruction_template_standard)
    (patient_instruction_template_available patient_instruction_template_condensed)
    (patient_instruction_asset_available patient_instruction_asset_1)
    (clinical_check_record_available clinical_check_record_1)
    (authorization_record_available insurance_authorization_record_a)
    (prescription_line_has_authorization_record prescription_line_primary insurance_authorization_record_a)
    (prescription_line_has_authorization_record prescription_line_secondary insurance_authorization_record_b)
    (clinical_override_record_available clinical_override_record_1)
  )
  (:goal
    (and
      (dispense_finalized_for_entity pharmacist_dispense_task_1)
      (dispense_finalized_for_entity technician_dispense_task_1)
      (dispense_finalized_for_entity prescription_line_primary)
      (dispense_finalized_for_entity prescription_line_secondary)
    )
  )
)
