(define (problem patient_order_stock_reservation_problem)
  (:domain pharmacy_stock_reservation)
  (:objects patient_order_001 - patient_order prescription_line_001 - prescription_line dispensing_task_001 - dispensing_task dispensing_task_002 - dispensing_task inventory_unit_a - inventory_unit inventory_unit_b - inventory_unit inventory_unit_c - inventory_unit clinical_resource_1 - clinical_check_resource pharmacist_1 - authorizing_pharmacist packaging_material_1 - packaging_material storage_location_1 - storage_location packaging_station_1 - packaging_station medication_package_1 - medication_package packaging_component_1 - packaging_component packaging_component_2 - packaging_component auxiliary_label_1 - auxiliary_label auxiliary_label_2 - auxiliary_label instruction_template_1 - outbound_instruction_template instruction_template_2 - outbound_instruction_template patient_instruction_1 - patient_instruction lot_information_1 - lot_information insurance_auth_record_1 - insurance_authorization_record insurance_auth_record_2 - insurance_authorization_record clinical_approval_record_1 - clinical_approval_record)
  (:init
