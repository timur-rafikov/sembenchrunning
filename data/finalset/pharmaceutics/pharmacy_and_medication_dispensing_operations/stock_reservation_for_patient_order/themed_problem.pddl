    (inventory_available inventory_unit_b)
    (inventory_available inventory_unit_c)
    (clinical_resource_available clinical_resource_1)
    (pharmacist_available pharmacist_1)
    (packaging_material_available packaging_material_1)
    (order_assigned_storage_location patient_order_001 storage_location_1)
