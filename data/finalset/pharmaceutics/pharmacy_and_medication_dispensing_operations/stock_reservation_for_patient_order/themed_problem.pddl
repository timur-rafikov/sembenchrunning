    (medication_package_creation_slot_available medication_package_1)
    (packaging_component_available packaging_component_1)
    (packaging_component_available packaging_component_2)
    (dispensing_task_assigned_to_patient_order dispensing_task_001 patient_order_001)
    (dispensing_task_assigned_to_patient_order dispensing_task_002 patient_order_001)
    (dispensing_task_assigned_to_prescription_line dispensing_task_001 prescription_line_001)
    (dispensing_task_assigned_to_prescription_line dispensing_task_002 prescription_line_001)
    (dispensing_task_associated_with_package dispensing_task_001 medication_package_1)
    (dispensing_task_associated_with_package dispensing_task_002 medication_package_1)
    (dispensing_task_attached_component dispensing_task_001 packaging_component_1)
    (dispensing_task_attached_component dispensing_task_002 packaging_component_2)
    (auxiliary_label_available auxiliary_label_1)
    (auxiliary_label_available auxiliary_label_2)
    (instruction_template_available instruction_template_1)
    (instruction_template_available instruction_template_2)
    (patient_instruction_available patient_instruction_1)
    (lot_information_available lot_information_1)
    (insurance_authorization_available insurance_auth_record_1)
    (dispensing_task_insurance_authorization_link dispensing_task_001 insurance_auth_record_1)
    (dispensing_task_insurance_authorization_link dispensing_task_002 insurance_auth_record_2)
    (clinical_approval_available clinical_approval_record_1)
  )
  (:goal
    (and
      (stock_released patient_order_001)
      (stock_released prescription_line_001)
      (stock_released dispensing_task_001)
      (stock_released dispensing_task_002)
    )
  )
)
