(define (problem dosage_strength_selection_problem)
  (:domain pharmacy_dosage_strength_selection)
  (:objects outpatient_order_rx1 - outpatient_order inpatient_order_rx1 - inpatient_order dispensing_unit_pkg1 - dispensing_unit dispensing_unit_pkg2 - dispensing_unit stock_unit_lot_a - inventory_stock_unit stock_unit_lot_b - inventory_stock_unit stock_unit_lot_c - inventory_stock_unit pharmacist_reviewer_1 - pharmacist_reviewer pharmacy_technician_1 - pharmacy_technician accessory_leaflet_1 - accessory_item strength_profile_outpatient_10mg - strength_profile_outpatient strength_profile_inpatient_5mg - strength_profile_inpatient packaging_unit_box1 - packaging_unit packaging_component_vial - packaging_component_type packaging_component_blister - packaging_component_type special_authorization_pa1 - special_authorization special_authorization_pa2 - special_authorization label_template_standard - label_template label_template_hospital - label_template patient_instruction_template_standard - patient_instruction_template handling_requirement_refrigeration - handling_requirement prior_authorization_provider1 - prior_authorization prior_authorization_provider2 - prior_authorization clinical_reason_code_medically_necessary - clinical_reason_code)
  (:init
    (stock_available stock_unit_lot_a)
    (stock_available stock_unit_lot_b)
    (stock_available stock_unit_lot_c)
    (pharmacist_available pharmacist_reviewer_1)
    (technician_available pharmacy_technician_1)
    (accessory_available accessory_leaflet_1)
    (outpatient_order_strength_option outpatient_order_rx1 strength_profile_outpatient_10mg)
    (inpatient_order_strength_option inpatient_order_rx1 strength_profile_inpatient_5mg)
    (packaging_unit_available packaging_unit_box1)
    (packaging_component_type_available packaging_component_vial)
    (packaging_component_type_available packaging_component_blister)
    (dispensing_unit_linked_outpatient_order dispensing_unit_pkg1 outpatient_order_rx1)
    (dispensing_unit_linked_outpatient_order dispensing_unit_pkg2 outpatient_order_rx1)
    (dispensing_unit_linked_inpatient_order dispensing_unit_pkg1 inpatient_order_rx1)
    (dispensing_unit_linked_inpatient_order dispensing_unit_pkg2 inpatient_order_rx1)
    (dispensing_unit_assigned_packaging_unit dispensing_unit_pkg1 packaging_unit_box1)
    (dispensing_unit_assigned_packaging_unit dispensing_unit_pkg2 packaging_unit_box1)
    (dispensing_unit_has_component_type dispensing_unit_pkg1 packaging_component_vial)
    (dispensing_unit_has_component_type dispensing_unit_pkg2 packaging_component_blister)
    (special_authorization_available special_authorization_pa1)
    (special_authorization_available special_authorization_pa2)
    (label_template_available label_template_standard)
    (label_template_available label_template_hospital)
    (patient_instruction_template_available patient_instruction_template_standard)
    (handling_requirement_available handling_requirement_refrigeration)
    (prior_authorization_available prior_authorization_provider1)
    (dispensing_unit_has_prior_authorization dispensing_unit_pkg1 prior_authorization_provider1)
    (dispensing_unit_has_prior_authorization dispensing_unit_pkg2 prior_authorization_provider2)
    (clinical_reason_code_available clinical_reason_code_medically_necessary)
  )
  (:goal
    (and
      (item_finalized outpatient_order_rx1)
      (item_finalized inpatient_order_rx1)
      (item_finalized dispensing_unit_pkg1)
      (item_finalized dispensing_unit_pkg2)
    )
  )
)
