(define (problem batch_hold_point_decision_problem)
  (:domain pharmaceutics_batch_hold_point_decisioning)
  (:objects upstream_batch_unit_a - upstream_batch_unit downstream_batch_unit_a - downstream_batch_unit manufacturing_order_a - manufacturing_order manufacturing_order_b - manufacturing_order production_line_a - production_line production_line_b - production_line production_line_c - production_line operation_task_1 - operation_task equipment_reactor_1 - equipment_unit material_lot_1 - material_lot upstream_hold_point_1 - upstream_hold_point downstream_hold_point_1 - downstream_hold_point batch_record_a - batch_record sample_1 - sample_or_test sample_2 - sample_or_test technical_reviewer_1 - technical_reviewer technical_reviewer_2 - technical_reviewer qa_checklist_1 - qa_checklist qa_checklist_2 - qa_checklist hold_ticket_1 - hold_reason_ticket calibration_certificate_1 - calibration_certificate release_document_1 - release_document release_document_2 - release_document final_approval_document_1 - final_approval_document)
  (:init
    (production_line_available production_line_a)
    (production_line_available production_line_b)
    (production_line_available production_line_c)
    (operation_task_available operation_task_1)
    (equipment_available equipment_reactor_1)
    (material_lot_available material_lot_1)
    (upstream_unit_assigned_to_hold_point upstream_batch_unit_a upstream_hold_point_1)
    (downstream_unit_assigned_to_hold_point downstream_batch_unit_a downstream_hold_point_1)
    (batch_record_draft_available batch_record_a)
    (sample_available sample_1)
    (sample_available sample_2)
    (manufacturing_order_linked_to_upstream_unit manufacturing_order_a upstream_batch_unit_a)
    (manufacturing_order_linked_to_upstream_unit manufacturing_order_b upstream_batch_unit_a)
    (manufacturing_order_linked_to_downstream_unit manufacturing_order_a downstream_batch_unit_a)
    (manufacturing_order_linked_to_downstream_unit manufacturing_order_b downstream_batch_unit_a)
    (manufacturing_order_linked_to_record manufacturing_order_a batch_record_a)
    (manufacturing_order_linked_to_record manufacturing_order_b batch_record_a)
    (manufacturing_order_has_sample manufacturing_order_a sample_1)
    (manufacturing_order_has_sample manufacturing_order_b sample_2)
    (technical_reviewer_available technical_reviewer_1)
    (technical_reviewer_available technical_reviewer_2)
    (qa_checklist_available qa_checklist_1)
    (qa_checklist_available qa_checklist_2)
    (hold_reason_ticket_available hold_ticket_1)
    (calibration_certificate_available calibration_certificate_1)
    (release_document_available release_document_1)
    (manufacturing_order_associated_with_release_document manufacturing_order_a release_document_1)
    (manufacturing_order_associated_with_release_document manufacturing_order_b release_document_2)
    (final_approval_document_available final_approval_document_1)
  )
  (:goal
    (and
      (release_authorized_for_item upstream_batch_unit_a)
      (release_authorized_for_item downstream_batch_unit_a)
      (release_authorized_for_item manufacturing_order_a)
      (release_authorized_for_item manufacturing_order_b)
    )
  )
)
