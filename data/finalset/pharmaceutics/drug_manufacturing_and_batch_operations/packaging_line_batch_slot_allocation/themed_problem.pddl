    (line_supports_secondary_batch packaging_line_1 secondary_batch_1)
    (line_supports_secondary_batch packaging_line_2 secondary_batch_1)
    (line_linked_to_run_record packaging_line_1 run_record_1)
    (line_linked_to_run_record packaging_line_2 run_record_1)
