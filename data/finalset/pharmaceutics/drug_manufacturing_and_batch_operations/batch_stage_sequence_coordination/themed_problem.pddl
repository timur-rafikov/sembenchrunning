    (container_available container_unit_2)
    (stage_linked_to_upstream_instance stage_reaction upstream_batch_instance_1)
    (stage_linked_to_upstream_instance stage_filtration upstream_batch_instance_1)
    (stage_linked_to_downstream_instance stage_reaction downstream_batch_instance_1)
    (stage_linked_to_downstream_instance stage_filtration downstream_batch_instance_1)
    (stage_linked_to_production_order stage_reaction production_order_1)
