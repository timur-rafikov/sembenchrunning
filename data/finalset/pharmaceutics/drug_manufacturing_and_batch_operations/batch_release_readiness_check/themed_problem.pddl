(define (problem batch_release_readiness_scenario)
  (:domain pharm_batch_release_readiness)
  (:objects bulk_batch_1 - bulk_batch packaging_batch_1 - packaging_batch release_unit_1 - release_unit release_unit_2 - release_unit line_slot_1 - line_slot line_slot_2 - line_slot line_slot_3 - line_slot process_step_1 - process_step operator_1 - operator material_lot_1 - material_lot equipment_1 - equipment packaging_line_1 - packaging_line batch_record_1 - batch_record quality_sample_1 - quality_sample quality_sample_2 - quality_sample regulatory_document_1 - regulatory_document regulatory_document_2 - regulatory_document signatory_1 - signatory signatory_2 - signatory release_form_1 - release_form calibration_certificate_1 - calibration_certificate validation_record_1 - validation_record validation_record_2 - validation_record environmental_record_1 - environmental_record)
  (:init
    (line_slot_available line_slot_1)
    (line_slot_available line_slot_2)
    (line_slot_available line_slot_3)
    (process_step_available process_step_1)
    (operator_available operator_1)
    (material_lot_available material_lot_1)
    (bulk_batch_assigned_equipment bulk_batch_1 equipment_1)
    (packaging_batch_assigned_to_line packaging_batch_1 packaging_line_1)
    (batch_record_unpopulated batch_record_1)
    (quality_sample_available quality_sample_1)
    (quality_sample_available quality_sample_2)
    (release_unit_includes_bulk_batch release_unit_1 bulk_batch_1)
    (release_unit_includes_bulk_batch release_unit_2 bulk_batch_1)
    (release_unit_includes_packaging_batch release_unit_1 packaging_batch_1)
    (release_unit_includes_packaging_batch release_unit_2 packaging_batch_1)
    (release_unit_has_batch_record release_unit_1 batch_record_1)
    (release_unit_has_batch_record release_unit_2 batch_record_1)
    (release_unit_linked_quality_sample release_unit_1 quality_sample_1)
    (release_unit_linked_quality_sample release_unit_2 quality_sample_2)
    (regulatory_document_available regulatory_document_1)
    (regulatory_document_available regulatory_document_2)
    (signatory_available signatory_1)
    (signatory_available signatory_2)
    (release_form_available release_form_1)
    (calibration_certificate_available calibration_certificate_1)
    (validation_record_available validation_record_1)
    (release_unit_linked_validation_record release_unit_1 validation_record_1)
    (release_unit_linked_validation_record release_unit_2 validation_record_2)
    (environmental_record_available environmental_record_1)
  )
  (:goal
    (and
      (production_item_released bulk_batch_1)
      (production_item_released packaging_batch_1)
      (production_item_released release_unit_1)
      (production_item_released release_unit_2)
    )
  )
)
