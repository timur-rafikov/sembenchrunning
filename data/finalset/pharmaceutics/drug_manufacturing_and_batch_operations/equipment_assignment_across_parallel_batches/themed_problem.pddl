    (process_tool_available process_tool_1)
    (operator_available operator_1)
    (consumable_available consumable_kit_1)
    (batch_compatible_with_station_a line_a_batch_1 station_a_1)
    (batch_compatible_with_station_b line_b_batch_1 station_b_1)
    (equipment_unit_available equipment_unit_1)
    (container_available single_use_container_1)
    (container_available single_use_container_2)
    (lot_mapped_to_parallel_line_a lot_1 line_a_batch_1)
    (lot_mapped_to_parallel_line_a lot_2 line_a_batch_1)
    (lot_mapped_to_parallel_line_b lot_1 line_b_batch_1)
    (lot_mapped_to_parallel_line_b lot_2 line_b_batch_1)
    (lot_mapped_to_equipment_unit lot_1 equipment_unit_1)
    (lot_mapped_to_equipment_unit lot_2 equipment_unit_1)
    (lot_requires_container lot_1 single_use_container_1)
    (lot_requires_container lot_2 single_use_container_2)
    (label_available label_tag_1)
    (label_available label_tag_2)
    (qa_package_available qa_package_1)
    (qa_package_available qa_package_2)
    (release_document_available release_document_1)
    (calibration_tag_available calibration_tag_1)
    (validation_certificate_available validation_certificate_1)
    (validation_certificate_assigned_to_lot lot_1 validation_certificate_1)
    (validation_certificate_assigned_to_lot lot_2 validation_certificate_2)
    (sterility_certificate_available sterility_certificate_1)
  )
  (:goal
    (and
      (equipment_assignment_complete line_a_batch_1)
      (equipment_assignment_complete line_b_batch_1)
      (equipment_assignment_complete lot_1)
      (equipment_assignment_complete lot_2)
    )
  )
