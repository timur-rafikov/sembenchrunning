(define (problem pharmaceutics_adverse_event_case_triage_problem)
  (:domain pharmaceutics_adverse_event_case_triage_domain)
  (:objects manufacturing_site_case_alpha - manufacturing_site_case distribution_site_case_alpha - distribution_site_case primary_investigation_workstream - investigation_workstream secondary_investigation_workstream - investigation_workstream response_resource_alpha - response_resource response_resource_beta - response_resource response_resource_gamma - response_resource adverse_event_report - report_document triage_responder - responder mitigation_kit - mitigation_resource manufacturing_site_unit_alpha - manufacturing_site_unit distribution_node_alpha - distribution_node recall_order - remediation_order laboratory_sample_alpha - laboratory_sample laboratory_sample_beta - laboratory_sample regulatory_document_alpha - regulatory_document regulatory_document_beta - regulatory_document supplier_alpha - supplier supplier_beta - supplier notification_template_alpha - notification_template technical_resource_alpha - technical_resource regulatory_authority_primary - regulatory_authority regulatory_authority_secondary - regulatory_authority external_expert_primary - external_expert)
  (:init
    (response_resource_available response_resource_alpha)
    (response_resource_available response_resource_beta)
    (response_resource_available response_resource_gamma)
    (report_document_available adverse_event_report)
    (responder_available triage_responder)
    (mitigation_resource_available mitigation_kit)
    (manufacturing_case_assigned_site_unit manufacturing_site_case_alpha manufacturing_site_unit_alpha)
    (distribution_case_assigned_distribution_node distribution_site_case_alpha distribution_node_alpha)
    (remediation_order_planned recall_order)
    (laboratory_sample_available laboratory_sample_alpha)
    (laboratory_sample_available laboratory_sample_beta)
    (workstream_scoped_to_manufacturing_site_case primary_investigation_workstream manufacturing_site_case_alpha)
    (workstream_scoped_to_manufacturing_site_case secondary_investigation_workstream manufacturing_site_case_alpha)
    (workstream_scoped_to_distribution_site_case primary_investigation_workstream distribution_site_case_alpha)
    (workstream_scoped_to_distribution_site_case secondary_investigation_workstream distribution_site_case_alpha)
    (workstream_linked_to_remediation_order primary_investigation_workstream recall_order)
    (workstream_linked_to_remediation_order secondary_investigation_workstream recall_order)
    (workstream_has_laboratory_sample primary_investigation_workstream laboratory_sample_alpha)
    (workstream_has_laboratory_sample secondary_investigation_workstream laboratory_sample_beta)
    (regulatory_document_available regulatory_document_alpha)
    (regulatory_document_available regulatory_document_beta)
    (supplier_available supplier_alpha)
    (supplier_available supplier_beta)
    (notification_template_available notification_template_alpha)
    (technical_resource_available technical_resource_alpha)
    (regulatory_authority_available regulatory_authority_primary)
    (workstream_assigned_regulatory_authority primary_investigation_workstream regulatory_authority_primary)
    (workstream_assigned_regulatory_authority secondary_investigation_workstream regulatory_authority_secondary)
    (external_expert_available external_expert_primary)
  )
  (:goal
    (and
      (case_closed manufacturing_site_case_alpha)
      (case_closed distribution_site_case_alpha)
      (case_closed primary_investigation_workstream)
      (case_closed secondary_investigation_workstream)
    )
  )
)
