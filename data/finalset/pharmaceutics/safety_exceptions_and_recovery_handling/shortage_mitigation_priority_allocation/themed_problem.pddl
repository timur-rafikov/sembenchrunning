(define (problem shortage_mitigation_priority_allocation_problem)
  (:domain pharm_shortage_mitigation_priority_allocation)
  (:objects primary_distribution_site_a - primary_distribution_site secondary_distribution_site_a - secondary_distribution_site response_team_alpha - response_team_unit response_team_beta - response_team_unit priority_slot_1 - priority_slot_token priority_slot_2 - priority_slot_token priority_slot_3 - priority_slot_token justification_doc_1 - clinical_justification_document containment_action_team_1 - containment_or_recall_action substitute_product_1 - substitute_product_unit primary_supplier_1 - primary_supplier secondary_supplier_1 - secondary_supplier allocation_package_1 - allocation_package product_lot_a - product_lot product_lot_b - product_lot regulatory_waiver_1 - regulatory_waiver_document regulatory_waiver_2 - regulatory_waiver_document distribution_channel_a - distribution_channel distribution_channel_b - distribution_channel notification_template_1 - notification_template clinical_priority_category_1 - clinical_priority_category external_stakeholder_1 - external_stakeholder external_stakeholder_2 - external_stakeholder regulatory_constraint_1 - regulatory_constraint)
  (:init
    (priority_slot_available priority_slot_1)
    (priority_slot_available priority_slot_2)
    (priority_slot_available priority_slot_3)
    (justification_available justification_doc_1)
    (containment_action_available containment_action_team_1)
    (substitute_product_available substitute_product_1)
    (primary_supplier_linked_to_site primary_distribution_site_a primary_supplier_1)
    (secondary_supplier_linked_to_site secondary_distribution_site_a secondary_supplier_1)
    (allocation_package_open allocation_package_1)
    (lot_available product_lot_a)
    (lot_available product_lot_b)
    (team_covers_primary_site response_team_alpha primary_distribution_site_a)
    (team_covers_primary_site response_team_beta primary_distribution_site_a)
    (team_covers_secondary_site response_team_alpha secondary_distribution_site_a)
    (team_covers_secondary_site response_team_beta secondary_distribution_site_a)
    (team_assigned_package response_team_alpha allocation_package_1)
    (team_assigned_package response_team_beta allocation_package_1)
    (team_has_lot response_team_alpha product_lot_a)
    (team_has_lot response_team_beta product_lot_b)
    (regulatory_waiver_available regulatory_waiver_1)
    (regulatory_waiver_available regulatory_waiver_2)
    (distribution_channel_available distribution_channel_a)
    (distribution_channel_available distribution_channel_b)
    (notification_template_available notification_template_1)
    (clinical_priority_category_available clinical_priority_category_1)
    (external_stakeholder_available external_stakeholder_1)
    (team_engaged_with_external_stakeholder response_team_alpha external_stakeholder_1)
    (team_engaged_with_external_stakeholder response_team_beta external_stakeholder_2)
    (regulatory_constraint_available regulatory_constraint_1)
  )
  (:goal
    (and
      (allocation_committed primary_distribution_site_a)
      (allocation_committed secondary_distribution_site_a)
      (allocation_committed response_team_alpha)
      (allocation_committed response_team_beta)
    )
  )
)
