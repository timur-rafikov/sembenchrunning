(define (problem nosql_integration_provisioning_scenario)
  (:domain nosql_database_integration)
  (:objects primary_app_instance_1 - primary_app_instance secondary_app_instance_1 - secondary_app_instance integration_pipeline_1 - integration_pipeline integration_pipeline_2 - integration_pipeline credential_token_a - credential_token credential_token_b - credential_token credential_token_c - credential_token connection_pool_1 - connection_pool driver_binary_1 - driver_binary payload_template_1 - payload_template primary_endpoint_1 - primary_endpoint secondary_endpoint_1 - secondary_endpoint database_namespace_1 - database_namespace schema_artifact_1 - schema_artifact schema_artifact_2 - schema_artifact feature_flag_a - feature_flag feature_flag_b - feature_flag deployment_parameter_a - deployment_parameter deployment_parameter_b - deployment_parameter observation_config_a - observation_config index_directive_a - index_directive access_policy_a - access_policy access_policy_b - access_policy migration_plan_a - migration_plan)
  (:init
    (credential_available credential_token_a)
    (credential_available credential_token_b)
    (credential_available credential_token_c)
    (connection_pool_available connection_pool_1)
    (driver_available driver_binary_1)
    (payload_template_available payload_template_1)
    (primary_instance_assigned_endpoint primary_app_instance_1 primary_endpoint_1)
    (secondary_instance_assigned_endpoint secondary_app_instance_1 secondary_endpoint_1)
    (namespace_pending_provision database_namespace_1)
    (schema_artifact_available schema_artifact_1)
    (schema_artifact_available schema_artifact_2)
    (pipeline_assigned_primary_instance integration_pipeline_1 primary_app_instance_1)
    (pipeline_assigned_primary_instance integration_pipeline_2 primary_app_instance_1)
    (pipeline_assigned_secondary_instance integration_pipeline_1 secondary_app_instance_1)
    (pipeline_assigned_secondary_instance integration_pipeline_2 secondary_app_instance_1)
    (pipeline_assigned_database_namespace integration_pipeline_1 database_namespace_1)
    (pipeline_assigned_database_namespace integration_pipeline_2 database_namespace_1)
    (pipeline_assigned_schema_artifact integration_pipeline_1 schema_artifact_1)
    (pipeline_assigned_schema_artifact integration_pipeline_2 schema_artifact_2)
    (feature_flag_available feature_flag_a)
    (feature_flag_available feature_flag_b)
    (deployment_parameter_available deployment_parameter_a)
    (deployment_parameter_available deployment_parameter_b)
    (observation_config_available observation_config_a)
    (index_directive_available index_directive_a)
    (access_policy_available access_policy_a)
    (pipeline_assigned_access_policy integration_pipeline_1 access_policy_a)
    (pipeline_assigned_access_policy integration_pipeline_2 access_policy_b)
    (migration_plan_available migration_plan_a)
  )
  (:goal
    (and
      (component_deployed primary_app_instance_1)
      (component_deployed secondary_app_instance_1)
      (component_deployed integration_pipeline_1)
      (component_deployed integration_pipeline_2)
    )
  )
)
