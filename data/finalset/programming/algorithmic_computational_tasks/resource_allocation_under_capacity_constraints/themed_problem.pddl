(define (problem resource_allocation_instance)
  (:domain resource_allocation_under_capacity)
  (:objects primary_provider_1 - primary_provider secondary_provider_1 - secondary_provider allocator_agent_1 - allocator_agent allocator_agent_2 - allocator_agent resource_pool_1 - resource_pool resource_pool_2 - resource_pool resource_pool_3 - resource_pool resource_instance_1 - resource_instance operator_1 - operator consumable_1 - consumable provider_feature_1 - provider_feature placement_feature_1 - placement_feature candidate_1 - allocation_candidate component_1 - component component_2 - component optional_feature_1 - optional_feature optional_feature_2 - optional_feature attachment_1 - attachment attachment_2 - attachment external_claim_1 - external_claim specialized_capability_1 - specialized_capability tagged_policy_1 - tagged_policy tagged_policy_2 - tagged_policy policy_variant_1 - policy_variant)
  (:init
    (resource_pool_available resource_pool_1)
    (resource_pool_available resource_pool_2)
    (resource_pool_available resource_pool_3)
    (resource_instance_available resource_instance_1)
    (operator_available operator_1)
    (consumable_available consumable_1)
    (provider_has_feature primary_provider_1 provider_feature_1)
    (secondary_provider_has_placement_feature secondary_provider_1 placement_feature_1)
    (candidate_available candidate_1)
    (component_available component_1)
    (component_available component_2)
    (allocator_assigned_primary_provider allocator_agent_1 primary_provider_1)
    (allocator_assigned_primary_provider allocator_agent_2 primary_provider_1)
    (allocator_assigned_secondary_provider allocator_agent_1 secondary_provider_1)
    (allocator_assigned_secondary_provider allocator_agent_2 secondary_provider_1)
    (allocator_binds_candidate allocator_agent_1 candidate_1)
    (allocator_binds_candidate allocator_agent_2 candidate_1)
    (allocator_has_component allocator_agent_1 component_1)
    (allocator_has_component allocator_agent_2 component_2)
    (optional_feature_available optional_feature_1)
    (optional_feature_available optional_feature_2)
    (attachment_available attachment_1)
    (attachment_available attachment_2)
    (external_claim_available external_claim_1)
    (specialized_capability_available specialized_capability_1)
    (tagged_policy_available tagged_policy_1)
    (allocator_bound_tagged_policy allocator_agent_1 tagged_policy_1)
    (allocator_bound_tagged_policy allocator_agent_2 tagged_policy_2)
    (policy_variant_available policy_variant_1)
  )
  (:goal
    (and
      (binding_committed primary_provider_1)
      (binding_committed secondary_provider_1)
      (binding_committed allocator_agent_1)
      (binding_committed allocator_agent_2)
    )
  )
)
