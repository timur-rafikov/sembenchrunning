(define (problem constrained_best_candidate_selection_instance)
  (:domain constrained_best_candidate_selection)
  (:objects selector_a_1 - selector_a selector_b_1 - selector_b selection_unit_1 - selection_unit selection_unit_2 - selection_unit slot_token_1 - slot_token slot_token_2 - slot_token slot_token_3 - slot_token qualification_test_1 - qualification_test provider_1 - provider consumable_1 - consumable_token feature_x_1 - primary_feature feature_y_1 - secondary_feature package_1 - package subcomponent_1 - subcomponent subcomponent_2 - subcomponent optional_flag_1 - optional_flag_a optional_flag_2 - optional_flag_a preference_token_1 - preference_token preference_token_2 - preference_token assignment_key_1 - assignment_key attribute_m_1 - attribute_m attribute_n_1 - attribute_n attribute_n_2 - attribute_n attribute_o_1 - attribute_o)
  (:init
    (slot_available slot_token_1)
    (slot_available slot_token_2)
    (slot_available slot_token_3)
    (qualification_available qualification_test_1)
    (provider_available provider_1)
    (consumable_available consumable_1)
    (selector_a_primary_feature selector_a_1 feature_x_1)
    (selector_b_secondary_feature selector_b_1 feature_y_1)
    (package_available package_1)
    (subcomponent_available subcomponent_1)
    (subcomponent_available subcomponent_2)
    (unit_link_selector_a selection_unit_1 selector_a_1)
    (unit_link_selector_a selection_unit_2 selector_a_1)
    (unit_link_selector_b selection_unit_1 selector_b_1)
    (unit_link_selector_b selection_unit_2 selector_b_1)
    (selection_unit_has_package selection_unit_1 package_1)
    (selection_unit_has_package selection_unit_2 package_1)
    (unit_subcomponent_compatible selection_unit_1 subcomponent_1)
    (unit_subcomponent_compatible selection_unit_2 subcomponent_2)
    (optional_flag_available optional_flag_1)
    (optional_flag_available optional_flag_2)
    (preference_token_available preference_token_1)
    (preference_token_available preference_token_2)
    (assignment_key_available assignment_key_1)
    (attribute_m_available attribute_m_1)
    (attribute_n_available attribute_n_1)
    (unit_attribute_n_link selection_unit_1 attribute_n_1)
    (unit_attribute_n_link selection_unit_2 attribute_n_2)
    (attribute_o_available attribute_o_1)
  )
  (:goal
    (and
      (assignment_committed selector_a_1)
      (assignment_committed selector_b_1)
      (assignment_committed selection_unit_1)
      (assignment_committed selection_unit_2)
    )
  )
)
