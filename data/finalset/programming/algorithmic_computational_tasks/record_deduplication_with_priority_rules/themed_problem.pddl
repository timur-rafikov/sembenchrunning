(define (problem deduplication_run)
  (:domain record_deduplication_priority)
  (:objects input_record_a1 - input_record_a input_record_b1 - input_record_b candidate_1 - merged_candidate candidate_2 - merged_candidate priority_slot_1 - priority_slot priority_slot_2 - priority_slot priority_slot_3 - priority_slot attribute_slot_1 - attribute_slot matcher_worker_1 - matcher_worker feature_slot_1 - feature_slot bucket_key_a1 - bucket_key_a bucket_key_b1 - bucket_key_b container_1 - container secondary_key_1 - secondary_key secondary_key_2 - secondary_key preference_token_a1 - preference_token_a preference_token_a2 - preference_token_a preference_token_b1 - preference_token_b preference_token_b2 - preference_token_b priority_marker_1 - priority_marker attribute_priority_token_1 - attribute_priority_token tie_breaker_token_1 - tie_breaker_token tie_breaker_token_2 - tie_breaker_token finalizer_token_1 - finalizer_token)
  (:init
    (priority_slot_available priority_slot_1)
    (priority_slot_available priority_slot_2)
    (priority_slot_available priority_slot_3)
    (attribute_slot_available attribute_slot_1)
    (matcher_worker_available matcher_worker_1)
    (feature_slot_available feature_slot_1)
    (bucket_key_map_a input_record_a1 bucket_key_a1)
    (bucket_key_map_b input_record_b1 bucket_key_b1)
    (container_available container_1)
    (secondary_key_available secondary_key_1)
    (secondary_key_available secondary_key_2)
    (candidate_contains_input_a candidate_1 input_record_a1)
    (candidate_contains_input_a candidate_2 input_record_a1)
    (candidate_contains_input_b candidate_1 input_record_b1)
    (candidate_contains_input_b candidate_2 input_record_b1)
    (candidate_assigned_container candidate_1 container_1)
    (candidate_assigned_container candidate_2 container_1)
    (candidate_has_secondary_key candidate_1 secondary_key_1)
    (candidate_has_secondary_key candidate_2 secondary_key_2)
    (preference_token_a_available preference_token_a1)
    (preference_token_a_available preference_token_a2)
    (preference_token_b_available preference_token_b1)
    (preference_token_b_available preference_token_b2)
    (priority_marker_available priority_marker_1)
    (attribute_priority_token_available attribute_priority_token_1)
    (tie_breaker_available tie_breaker_token_1)
    (candidate_has_tie_breaker candidate_1 tie_breaker_token_1)
    (candidate_has_tie_breaker candidate_2 tie_breaker_token_2)
    (finalizer_token_available finalizer_token_1)
  )
  (:goal
    (and
      (output_mark input_record_a1)
      (output_mark input_record_b1)
      (output_mark candidate_1)
      (output_mark candidate_2)
    )
  )
)
