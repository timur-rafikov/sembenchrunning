(define (problem reconcile_incremental_snapshot_case)
  (:domain incremental_state_snapshot_reconciliation)
  (:objects source_a_record_1 - source_a_record source_b_record_1 - source_b_record reconciliation_unit_1 - reconciliation_unit reconciliation_unit_2 - reconciliation_unit allocation_slot_1 - allocation_slot allocation_slot_2 - allocation_slot allocation_slot_3 - allocation_slot state_delta_1 - state_delta binding_handle_1 - binding_handle auxiliary_token_1 - auxiliary_token candidate_version_a_1 - candidate_version_a candidate_version_b_1 - candidate_version_b merged_snapshot_candidate_1 - merged_candidate validation_artifact_1 - validation_artifact validation_artifact_2 - validation_artifact configuration_flag_1 - configuration_flag configuration_flag_2 - configuration_flag optional_modifier_1 - optional_modifier optional_modifier_2 - optional_modifier commit_marker_1 - commit_marker resource_attachment_1 - resource_attachment external_constraint_1 - external_constraint external_constraint_2 - external_constraint policy_attachment_1 - policy_attachment)
  (:init
    (allocation_slot_available allocation_slot_1)
    (allocation_slot_available allocation_slot_2)
    (allocation_slot_available allocation_slot_3)
    (state_delta_available state_delta_1)
    (binding_handle_available binding_handle_1)
    (auxiliary_token_available auxiliary_token_1)
    (source_a_has_candidate_version source_a_record_1 candidate_version_a_1)
    (source_b_has_candidate_version source_b_record_1 candidate_version_b_1)
    (merged_candidate_available merged_snapshot_candidate_1)
    (validation_artifact_available validation_artifact_1)
    (validation_artifact_available validation_artifact_2)
    (reconciliation_unit_bound_source_a reconciliation_unit_1 source_a_record_1)
    (reconciliation_unit_bound_source_a reconciliation_unit_2 source_a_record_1)
    (reconciliation_unit_bound_source_b reconciliation_unit_1 source_b_record_1)
    (reconciliation_unit_bound_source_b reconciliation_unit_2 source_b_record_1)
    (reconciliation_unit_has_merged_candidate reconciliation_unit_1 merged_snapshot_candidate_1)
    (reconciliation_unit_has_merged_candidate reconciliation_unit_2 merged_snapshot_candidate_1)
    (reconciliation_unit_has_validation_artifact reconciliation_unit_1 validation_artifact_1)
    (reconciliation_unit_has_validation_artifact reconciliation_unit_2 validation_artifact_2)
    (configuration_flag_available configuration_flag_1)
    (configuration_flag_available configuration_flag_2)
    (optional_modifier_available optional_modifier_1)
    (optional_modifier_available optional_modifier_2)
    (commit_marker_available commit_marker_1)
    (resource_attachment_available resource_attachment_1)
    (external_constraint_available external_constraint_1)
    (reconciliation_unit_external_constraint reconciliation_unit_1 external_constraint_1)
    (reconciliation_unit_external_constraint reconciliation_unit_2 external_constraint_2)
    (policy_attachment_available policy_attachment_1)
  )
  (:goal
    (and
      (entity_reconciled source_a_record_1)
      (entity_reconciled source_b_record_1)
      (entity_reconciled reconciliation_unit_1)
      (entity_reconciled reconciliation_unit_2)
    )
  )
)
