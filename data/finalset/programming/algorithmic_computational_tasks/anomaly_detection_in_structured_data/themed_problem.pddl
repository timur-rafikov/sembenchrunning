(define (problem anomaly_detection_problem)
  (:domain anomaly_detection_pipeline)
  (:objects raw_record_1 - raw_record aggregated_record_1 - aggregated_record detection_pipeline_1 - detection_pipeline detection_pipeline_2 - detection_pipeline detector_worker_1 - detector_worker detector_worker_2 - detector_worker detector_worker_3 - detector_worker feature_1 - computed_feature validator_1 - validator calibration_param_1 - calibration_param feature_bin_raw_1 - feature_bin_raw feature_bin_agg_1 - feature_bin_agg anomaly_candidate_1 - anomaly_candidate data_segment_1 - data_segment data_segment_2 - data_segment explanation_method_1 - explanation_method explanation_method_2 - explanation_method postprocessor_1 - postprocessor postprocessor_2 - postprocessor evidence_token_1 - evidence_token scoring_model_1 - scoring_model reference_profile_1 - reference_profile reference_profile_2 - reference_profile explanation_template_1 - explanation_template)
  (:init
    (worker_available detector_worker_1)
    (worker_available detector_worker_2)
    (worker_available detector_worker_3)
    (feature_available feature_1)
    (validator_available validator_1)
    (calibration_param_available calibration_param_1)
    (has_feature_bin_raw raw_record_1 feature_bin_raw_1)
    (has_feature_bin_agg aggregated_record_1 feature_bin_agg_1)
    (candidate_slot_available anomaly_candidate_1)
    (data_segment_available data_segment_1)
    (data_segment_available data_segment_2)
    (pipeline_includes_raw_record detection_pipeline_1 raw_record_1)
    (pipeline_includes_raw_record detection_pipeline_2 raw_record_1)
    (pipeline_includes_agg_record detection_pipeline_1 aggregated_record_1)
    (pipeline_includes_agg_record detection_pipeline_2 aggregated_record_1)
    (pipeline_associated_with_candidate detection_pipeline_1 anomaly_candidate_1)
    (pipeline_associated_with_candidate detection_pipeline_2 anomaly_candidate_1)
    (pipeline_has_data_segment detection_pipeline_1 data_segment_1)
    (pipeline_has_data_segment detection_pipeline_2 data_segment_2)
    (explanation_method_available explanation_method_1)
    (explanation_method_available explanation_method_2)
    (postprocessor_available postprocessor_1)
    (postprocessor_available postprocessor_2)
    (evidence_token_available evidence_token_1)
    (scoring_model_available scoring_model_1)
    (reference_profile_available reference_profile_1)
    (pipeline_has_reference_profile detection_pipeline_1 reference_profile_1)
    (pipeline_has_reference_profile detection_pipeline_2 reference_profile_2)
    (explanation_template_available explanation_template_1)
  )
  (:goal
    (and
      (anomaly_flagged raw_record_1)
      (anomaly_flagged aggregated_record_1)
      (anomaly_flagged detection_pipeline_1)
      (anomaly_flagged detection_pipeline_2)
    )
  )
)
