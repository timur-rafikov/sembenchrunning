(define (problem detect_cycles_in_dependency_graph)
  (:domain dependency_cycle_detection)
  (:objects source_node_1 - source_node target_node_1 - target_node analysis_unit_1 - analysis_unit analysis_unit_2 - analysis_unit edge_slot_1 - edge_identifier edge_slot_2 - edge_identifier edge_slot_3 - edge_identifier visit_token_1 - visit_token worker_1 - worker dependency_tag_1 - dependency_tag neighbor_bucket_left_1 - neighbor_bucket_left neighbor_bucket_right_1 - neighbor_bucket_right merge_candidate_slot_1 - merge_candidate resource_bucket_1 - resource_bucket resource_bucket_2 - resource_bucket feature_flag_1 - feature_flag feature_flag_2 - feature_flag priority_label_1 - priority_label priority_label_2 - priority_label evidence_token_1 - evidence_token attribute_a_1 - attribute_a attribute_b_1 - attribute_b attribute_b_2 - attribute_b attribute_c_1 - attribute_c)
  (:init
    (edge_available edge_slot_1)
    (edge_available edge_slot_2)
    (edge_available edge_slot_3)
    (visit_token_available visit_token_1)
    (worker_available worker_1)
    (dependency_tag_available dependency_tag_1)
    (source_has_left_bucket source_node_1 neighbor_bucket_left_1)
    (target_has_right_bucket target_node_1 neighbor_bucket_right_1)
    (candidate_slot_available merge_candidate_slot_1)
    (resource_bucket_available resource_bucket_1)
    (resource_bucket_available resource_bucket_2)
    (unit_has_source analysis_unit_1 source_node_1)
    (unit_has_source analysis_unit_2 source_node_1)
    (unit_has_target analysis_unit_1 target_node_1)
    (unit_has_target analysis_unit_2 target_node_1)
    (unit_has_candidate analysis_unit_1 merge_candidate_slot_1)
    (unit_has_candidate analysis_unit_2 merge_candidate_slot_1)
    (unit_has_bucket analysis_unit_1 resource_bucket_1)
    (unit_has_bucket analysis_unit_2 resource_bucket_2)
    (feature_flag_available feature_flag_1)
    (feature_flag_available feature_flag_2)
    (priority_label_available priority_label_1)
    (priority_label_available priority_label_2)
    (evidence_token_available evidence_token_1)
    (attribute_a_available attribute_a_1)
    (attribute_b_available attribute_b_1)
    (unit_has_attribute_b analysis_unit_1 attribute_b_1)
    (unit_has_attribute_b analysis_unit_2 attribute_b_2)
    (attribute_c_available attribute_c_1)
  )
  (:goal
    (and
      (node_reset source_node_1)
      (node_reset target_node_1)
      (node_reset analysis_unit_1)
      (node_reset analysis_unit_2)
    )
  )
)
