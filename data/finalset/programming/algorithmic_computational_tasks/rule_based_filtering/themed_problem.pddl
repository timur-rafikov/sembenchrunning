(define (problem rule_based_filtering_instance)
  (:domain rule_based_filtering_domain)
  (:objects source_primary_1 - source_item_primary source_secondary_1 - source_item_secondary candidate_1 - filter_candidate candidate_2 - filter_candidate rule_token_1 - rule_token rule_token_2 - rule_token rule_token_3 - rule_token matcher_1 - matcher handler_1 - handler aux_resource_1 - aux_resource selection_key_primary_1 - selection_key_primary selection_key_secondary_1 - selection_key_secondary output_slot_1 - output_slot attribute_group_1 - attribute_group attribute_group_2 - attribute_group preference_tag_1 - preference_tag preference_tag_2 - preference_tag modifier_1 - modifier modifier_2 - modifier validation_token_1 - validation_token capability_1 - capability annotation_1 - annotation annotation_2 - annotation extension_1 - extension)
  (:init
    (rule_token_available rule_token_1)
    (rule_token_available rule_token_2)
    (rule_token_available rule_token_3)
    (matcher_available matcher_1)
    (handler_available handler_1)
    (aux_resource_available aux_resource_1)
    (has_selection_key_primary source_primary_1 selection_key_primary_1)
    (has_selection_key_secondary source_secondary_1 selection_key_secondary_1)
    (output_slot_available output_slot_1)
    (attribute_group_available attribute_group_1)
    (attribute_group_available attribute_group_2)
    (candidate_associated_with_source_primary candidate_1 source_primary_1)
    (candidate_associated_with_source_primary candidate_2 source_primary_1)
    (candidate_associated_with_source_secondary candidate_1 source_secondary_1)
    (candidate_associated_with_source_secondary candidate_2 source_secondary_1)
    (candidate_assigned_to_slot candidate_1 output_slot_1)
    (candidate_assigned_to_slot candidate_2 output_slot_1)
    (candidate_has_attribute_group candidate_1 attribute_group_1)
    (candidate_has_attribute_group candidate_2 attribute_group_2)
    (preference_tag_available preference_tag_1)
    (preference_tag_available preference_tag_2)
    (modifier_available modifier_1)
    (modifier_available modifier_2)
    (validation_token_available validation_token_1)
    (capability_available capability_1)
    (annotation_available annotation_1)
    (candidate_has_annotation candidate_1 annotation_1)
    (candidate_has_annotation candidate_2 annotation_2)
    (extension_available extension_1)
  )
  (:goal
    (and
      (accepted source_primary_1)
      (accepted source_secondary_1)
      (accepted candidate_1)
      (accepted candidate_2)
    )
  )
)
