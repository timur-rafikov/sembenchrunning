(define (problem grouped_aggregation_instance)
  (:domain grouped_aggregation)
  (:objects partition_instance_a_1 - partition_instance_a partition_instance_b_1 - partition_instance_b aggregation_job_1 - aggregation_job aggregation_job_2 - aggregation_job compute_slot_1 - compute_slot compute_slot_2 - compute_slot compute_slot_3 - compute_slot input_record_1 - input_record worker_1 - worker_token value_token_1 - value_token grouping_key_a_1 - grouping_key_a grouping_key_b_1 - grouping_key_b result_candidate_1 - result_candidate partition_key_component_1 - partition_key_component partition_key_component_2 - partition_key_component config_flag_a_1 - config_flag_a config_flag_a_2 - config_flag_a merge_strategy_1 - merge_strategy merge_strategy_2 - merge_strategy finalizer_token_1 - finalizer_token aggregator_option_a_1 - aggregator_option_a aggregator_option_c_1 - aggregator_option_c aggregator_option_c_2 - aggregator_option_c aggregator_option_b_1 - aggregator_option_b)
  (:init
    (compute_slot_available compute_slot_1)
    (compute_slot_available compute_slot_2)
    (compute_slot_available compute_slot_3)
    (input_record_unconsumed input_record_1)
    (worker_available worker_1)
    (value_token_available value_token_1)
    (partition_a_has_key_a partition_instance_a_1 grouping_key_a_1)
    (partition_b_has_key_b partition_instance_b_1 grouping_key_b_1)
    (result_candidate_available result_candidate_1)
    (partition_key_component_available partition_key_component_1)
    (partition_key_component_available partition_key_component_2)
    (aggregation_job_bound_to_partition_a aggregation_job_1 partition_instance_a_1)
    (aggregation_job_bound_to_partition_a aggregation_job_2 partition_instance_a_1)
    (aggregation_job_bound_to_partition_b aggregation_job_1 partition_instance_b_1)
    (aggregation_job_bound_to_partition_b aggregation_job_2 partition_instance_b_1)
    (aggregation_job_bound_to_candidate aggregation_job_1 result_candidate_1)
    (aggregation_job_bound_to_candidate aggregation_job_2 result_candidate_1)
    (aggregation_job_has_partition_key_component aggregation_job_1 partition_key_component_1)
    (aggregation_job_has_partition_key_component aggregation_job_2 partition_key_component_2)
    (config_flag_a_available config_flag_a_1)
    (config_flag_a_available config_flag_a_2)
    (merge_strategy_available merge_strategy_1)
    (merge_strategy_available merge_strategy_2)
    (finalizer_token_available finalizer_token_1)
    (aggregator_option_a_available aggregator_option_a_1)
    (aggregator_option_c_available aggregator_option_c_1)
    (aggregation_job_has_aggregator_option_c aggregation_job_1 aggregator_option_c_1)
    (aggregation_job_has_aggregator_option_c aggregation_job_2 aggregator_option_c_2)
    (aggregator_option_b_available aggregator_option_b_1)
  )
  (:goal
    (and
      (aggregate_group_finalized partition_instance_a_1)
      (aggregate_group_finalized partition_instance_b_1)
      (aggregate_group_finalized aggregation_job_1)
      (aggregate_group_finalized aggregation_job_2)
    )
  )
)
