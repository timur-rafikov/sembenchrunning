(define (problem normalize_input_records)
  (:domain structured_input_parsing_and_normalization)
  (:objects primary_block_1 - primary_block secondary_block_1 - secondary_block profile_1 - profile profile_2 - profile field_mapper_1 - field_mapper field_mapper_2 - field_mapper field_mapper_3 - field_mapper field_token_1 - field_token parser_module_1 - parser_module normalization_rule_1 - normalization_rule primary_key_1 - primary_key secondary_key_1 - secondary_key output_slot_1 - output_slot temporary_buffer_1 - temporary_buffer temporary_buffer_2 - temporary_buffer format_option_1 - format_option format_option_2 - format_option postprocess_option_1 - postprocess_option postprocess_option_2 - postprocess_option context_token_1 - context_token schema_annotation_1 - schema_annotation lookup_entry_1 - lookup_entry lookup_entry_2 - lookup_entry external_reference_1 - external_reference)
  (:init
    (mapper_available field_mapper_1)
    (mapper_available field_mapper_2)
    (mapper_available field_mapper_3)
    (token_available field_token_1)
    (parser_available parser_module_1)
    (normalization_rule_available normalization_rule_1)
    (block_has_primary_key primary_block_1 primary_key_1)
    (secondary_block_has_key secondary_block_1 secondary_key_1)
    (slot_available output_slot_1)
    (buffer_available temporary_buffer_1)
    (buffer_available temporary_buffer_2)
    (profile_primary_block_link profile_1 primary_block_1)
    (profile_primary_block_link profile_2 primary_block_1)
    (profile_secondary_block_link profile_1 secondary_block_1)
    (profile_secondary_block_link profile_2 secondary_block_1)
    (profile_assigned_to_slot profile_1 output_slot_1)
    (profile_assigned_to_slot profile_2 output_slot_1)
    (profile_has_temporary_buffer profile_1 temporary_buffer_1)
    (profile_has_temporary_buffer profile_2 temporary_buffer_2)
    (format_option_available format_option_1)
    (format_option_available format_option_2)
    (postprocess_option_available postprocess_option_1)
    (postprocess_option_available postprocess_option_2)
    (context_token_available context_token_1)
    (schema_annotation_available schema_annotation_1)
    (lookup_entry_available lookup_entry_1)
    (profile_bound_to_lookup_entry profile_1 lookup_entry_1)
    (profile_bound_to_lookup_entry profile_2 lookup_entry_2)
    (external_reference_available external_reference_1)
  )
  (:goal
    (and
      (is_finalized primary_block_1)
      (is_finalized secondary_block_1)
      (is_finalized profile_1)
      (is_finalized profile_2)
    )
  )
)
