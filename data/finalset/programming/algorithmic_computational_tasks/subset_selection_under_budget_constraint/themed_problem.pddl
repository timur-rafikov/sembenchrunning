(define (problem subset_selection_instance)
  (:domain subset_selection_under_budget)
  (:objects slot_primary_1 - candidate_slot_primary slot_secondary_1 - candidate_slot_secondary composite_candidate_a - composite_candidate composite_candidate_b - composite_candidate resource_token_a - resource_token resource_token_b - resource_token resource_token_c - resource_token feature_descriptor_a - feature_descriptor operator_agent_a - operator_agent consumable_item_a - consumable_item resource_class_a_1 - resource_class_a resource_class_b_1 - resource_class_b package_template_a - package_entity module_component_a - module_component module_component_b - module_component tag_token_a - tag_token tag_token_b - tag_token attribute_token_a - attribute_token attribute_token_b - attribute_token budget_item_a - budget_item capability_token_a - capability_token label_token_a - label_token label_token_b - label_token constraint_flag_a - constraint_flag)
  (:init
    (resource_token_available resource_token_a)
    (resource_token_available resource_token_b)
    (resource_token_available resource_token_c)
    (feature_descriptor_available feature_descriptor_a)
    (operator_available operator_agent_a)
    (consumable_available consumable_item_a)
    (slot_offers_resource_class_a slot_primary_1 resource_class_a_1)
    (slot_offers_resource_class_b slot_secondary_1 resource_class_b_1)
    (package_available package_template_a)
    (module_component_available module_component_a)
    (module_component_available module_component_b)
    (composite_has_primary_slot composite_candidate_a slot_primary_1)
    (composite_has_primary_slot composite_candidate_b slot_primary_1)
    (composite_has_secondary_slot composite_candidate_a slot_secondary_1)
    (composite_has_secondary_slot composite_candidate_b slot_secondary_1)
    (composite_has_package composite_candidate_a package_template_a)
    (composite_has_package composite_candidate_b package_template_a)
    (composite_has_module composite_candidate_a module_component_a)
    (composite_has_module composite_candidate_b module_component_b)
    (tag_token_available tag_token_a)
    (tag_token_available tag_token_b)
    (attribute_token_available attribute_token_a)
    (attribute_token_available attribute_token_b)
    (budget_item_available budget_item_a)
    (capability_token_available capability_token_a)
    (label_token_available label_token_a)
    (composite_has_label composite_candidate_a label_token_a)
    (composite_has_label composite_candidate_b label_token_b)
    (constraint_flag_available constraint_flag_a)
  )
  (:goal
    (and
      (candidate_finalized slot_primary_1)
      (candidate_finalized slot_secondary_1)
      (candidate_finalized composite_candidate_a)
      (candidate_finalized composite_candidate_b)
    )
  )
)
