(define (problem validation_problem_instance)
  (:domain constraint_satisfaction_validation)
  (:objects primary_var_1 - primary_variable secondary_var_1 - secondary_variable solver_component_1 - solver_component solver_component_2 - solver_component resource_slot_1 - resource_slot resource_slot_2 - resource_slot resource_slot_3 - resource_slot domain_value_1 - domain_value operator_1 - operator transient_token_1 - transient_token component_role_a_1 - component_role_a component_role_b_1 - component_role_b composite_candidate_1 - composite_candidate component_instance_1 - component_instance component_instance_2 - component_instance attribute_x_1 - attribute_x attribute_x_2 - attribute_x attribute_y_1 - attribute_y attribute_y_2 - attribute_y commit_marker_1 - commit_marker feature_token_1 - feature_token qualifier_1 - named_qualifier qualifier_2 - named_qualifier variant_token_1 - variant_token)
  (:init
    (resource_slot_available resource_slot_1)
    (resource_slot_available resource_slot_2)
    (resource_slot_available resource_slot_3)
    (domain_value_available domain_value_1)
    (operator_available operator_1)
    (transient_token_available transient_token_1)
    (primary_compatible_with_role_a primary_var_1 component_role_a_1)
    (secondary_compatible_with_role_b secondary_var_1 component_role_b_1)
    (composite_candidate_available composite_candidate_1)
    (component_instance_available component_instance_1)
    (component_instance_available component_instance_2)
    (component_associated_primary_variable solver_component_1 primary_var_1)
    (component_associated_primary_variable solver_component_2 primary_var_1)
    (component_associated_secondary_variable solver_component_1 secondary_var_1)
    (component_associated_secondary_variable solver_component_2 secondary_var_1)
    (component_associated_candidate solver_component_1 composite_candidate_1)
    (component_associated_candidate solver_component_2 composite_candidate_1)
    (component_has_instance solver_component_1 component_instance_1)
    (component_has_instance solver_component_2 component_instance_2)
    (attribute_x_available attribute_x_1)
    (attribute_x_available attribute_x_2)
    (attribute_y_available attribute_y_1)
    (attribute_y_available attribute_y_2)
    (commit_marker_available commit_marker_1)
    (feature_token_available feature_token_1)
    (qualifier_available qualifier_1)
    (component_associated_qualifier solver_component_1 qualifier_1)
    (component_associated_qualifier solver_component_2 qualifier_2)
    (variant_token_available variant_token_1)
  )
  (:goal
    (and
      (entity_committed primary_var_1)
      (entity_committed secondary_var_1)
      (entity_committed solver_component_1)
      (entity_committed solver_component_2)
    )
  )
)
