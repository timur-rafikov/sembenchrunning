(define (problem shortest_path_search_instance)
  (:domain bidirectional_shortest_path_search_domain)
  (:objects forward_node_1 - forward_node backward_node_1 - backward_node search_task_1 - search_task search_task_2 - search_task worker_token_1 - worker_token worker_token_2 - worker_token worker_token_3 - worker_token operation_token_1 - operation_token processing_unit_1 - processing_unit cost_token_1 - cost_token forward_frontier_entry_1 - forward_frontier_entry backward_frontier_entry_1 - backward_frontier_entry candidate_entry_1 - candidate_entry materialization_token_1 - materialization_token materialization_token_2 - materialization_token metadata_tag_1 - metadata_tag metadata_tag_2 - metadata_tag policy_tag_1 - policy_tag policy_tag_2 - policy_tag solution_tag_1 - solution_tag resource_type_token_1 - resource_type_token constraint_token_1 - constraint_token constraint_token_2 - constraint_token preference_token_1 - preference_token)
  (:init
    (worker_available worker_token_1)
    (worker_available worker_token_2)
    (worker_available worker_token_3)
    (operation_token_available operation_token_1)
    (processing_unit_available processing_unit_1)
    (cost_token_available cost_token_1)
    (forward_frontier_link forward_node_1 forward_frontier_entry_1)
    (backward_frontier_link backward_node_1 backward_frontier_entry_1)
    (candidate_slot_available candidate_entry_1)
    (materialization_token_available materialization_token_1)
    (materialization_token_available materialization_token_2)
    (task_bind_forward_node search_task_1 forward_node_1)
    (task_bind_forward_node search_task_2 forward_node_1)
    (task_bind_backward_node search_task_1 backward_node_1)
    (task_bind_backward_node search_task_2 backward_node_1)
    (task_has_candidate search_task_1 candidate_entry_1)
    (task_has_candidate search_task_2 candidate_entry_1)
    (task_has_materialization_token search_task_1 materialization_token_1)
    (task_has_materialization_token search_task_2 materialization_token_2)
    (metadata_tag_available metadata_tag_1)
    (metadata_tag_available metadata_tag_2)
    (policy_tag_available policy_tag_1)
    (policy_tag_available policy_tag_2)
    (solution_tag_available solution_tag_1)
    (resource_type_available resource_type_token_1)
    (constraint_token_available constraint_token_1)
    (task_constraint_requested search_task_1 constraint_token_1)
    (task_constraint_requested search_task_2 constraint_token_2)
    (preference_token_available preference_token_1)
  )
  (:goal
    (and
      (entity_solution_integrated forward_node_1)
      (entity_solution_integrated backward_node_1)
      (entity_solution_integrated search_task_1)
      (entity_solution_integrated search_task_2)
    )
  )
)
