(define (problem plugin_extension_deployment_scenario)
  (:domain extension_architecture_design)
  (:objects host_primary - host_instance host_peer_1 - peer_host extension_manager_alpha - extension_manager extension_manager_beta - extension_manager slot_a - extension_slot slot_b - extension_slot slot_c - extension_slot capability_service_1 - capability_provider connector_adapter_1 - connector config_profile_default - configuration_profile host_region_1 - host_region host_zone_1 - host_zone extension_package_1 - extension_package resource_artifact_1 - resource_artifact resource_artifact_2 - resource_artifact metadata_record_1 - metadata_record metadata_record_2 - metadata_record policy_rule_default - policy_rule policy_rule_strict - policy_rule resource_quota_unit - resource_quota binary_module_core - binary_module platform_binding_linux - platform_binding platform_binding_windows - platform_binding feature_flag_experimental - feature_flag)
  (:init
    (extension_slot_available slot_a)
    (extension_slot_available slot_b)
    (extension_slot_available slot_c)
    (capability_available capability_service_1)
    (connector_available connector_adapter_1)
    (configuration_profile_available config_profile_default)
    (host_region_assigned host_primary host_region_1)
    (peer_host_zone_assigned host_peer_1 host_zone_1)
    (package_staged extension_package_1)
    (artifact_available resource_artifact_1)
    (artifact_available resource_artifact_2)
