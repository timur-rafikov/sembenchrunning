    (manager_controls_host extension_manager_beta host_primary)
    (manager_controls_peer_host extension_manager_alpha host_peer_1)
    (manager_controls_peer_host extension_manager_beta host_peer_1)
    (manager_owns_package extension_manager_alpha extension_package_1)
    (manager_owns_package extension_manager_beta extension_package_1)
    (manager_staged_artifact extension_manager_alpha resource_artifact_1)
    (manager_staged_artifact extension_manager_beta resource_artifact_2)
    (metadata_record_available metadata_record_1)
    (metadata_record_available metadata_record_2)
    (policy_rule_available policy_rule_default)
    (policy_rule_available policy_rule_strict)
    (resource_quota_available resource_quota_unit)
    (binary_module_available binary_module_core)
    (platform_binding_available platform_binding_linux)
    (manager_platform_binding extension_manager_alpha platform_binding_linux)
    (manager_platform_binding extension_manager_beta platform_binding_windows)
    (feature_flag_available feature_flag_experimental)
  )
  (:goal
    (and
      (actor_deployment_approved host_primary)
      (actor_deployment_approved host_peer_1)
      (actor_deployment_approved extension_manager_alpha)
      (actor_deployment_approved extension_manager_beta)
    )
  )
)
