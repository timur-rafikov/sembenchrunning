(define (problem internal_event_notification_problem)
  (:domain internal_event_notification)
  (:objects publisher_service_a - publisher subscriber_service_a - subscriber notifier_coordinator_primary - notifier_coordinator notifier_coordinator_secondary - notifier_coordinator subscription_record_1 - subscription_record subscription_record_2 - subscription_record subscription_record_3 - subscription_record event_type_generic - event_type delivery_handler_default - delivery_handler filter_transform_standard - filter_transform publisher_slot_1 - publisher_slot subscriber_slot_1 - subscriber_slot message_envelope_1 - message_envelope payload_template_1 - payload_template payload_template_2 - payload_template priority_tag_high - priority_tag priority_tag_low - priority_tag delivery_policy_fast - delivery_policy delivery_policy_retry - delivery_policy ack_channel_primary - ack_channel capability_token_renderer - capability_token routing_affinity_zone_1 - routing_affinity routing_affinity_zone_2 - routing_affinity retry_config_default - retry_config)
  (:init
    (subscription_record_available subscription_record_1)
    (subscription_record_available subscription_record_2)
    (subscription_record_available subscription_record_3)
    (service_type_available event_type_generic)
    (delivery_handler_available delivery_handler_default)
    (filter_transform_available filter_transform_standard)
    (publisher_slot_binding publisher_service_a publisher_slot_1)
    (subscriber_slot_binding subscriber_service_a subscriber_slot_1)
    (envelope_available message_envelope_1)
    (payload_template_available payload_template_1)
    (payload_template_available payload_template_2)
    (coordinator_publisher_binding notifier_coordinator_primary publisher_service_a)
    (coordinator_publisher_binding notifier_coordinator_secondary publisher_service_a)
    (coordinator_subscriber_binding notifier_coordinator_primary subscriber_service_a)
    (coordinator_subscriber_binding notifier_coordinator_secondary subscriber_service_a)
    (coordinator_envelope_assigned notifier_coordinator_primary message_envelope_1)
    (coordinator_envelope_assigned notifier_coordinator_secondary message_envelope_1)
    (coordinator_payload_template_assigned notifier_coordinator_primary payload_template_1)
    (coordinator_payload_template_assigned notifier_coordinator_secondary payload_template_2)
    (priority_tag_available priority_tag_high)
    (priority_tag_available priority_tag_low)
    (delivery_policy_available delivery_policy_fast)
    (delivery_policy_available delivery_policy_retry)
    (ack_channel_available ack_channel_primary)
    (capability_token_available capability_token_renderer)
    (routing_affinity_available routing_affinity_zone_1)
    (coordinator_routing_affinity notifier_coordinator_primary routing_affinity_zone_1)
    (coordinator_routing_affinity notifier_coordinator_secondary routing_affinity_zone_2)
    (retry_config_available retry_config_default)
  )
  (:goal
    (and
      (service_completed publisher_service_a)
      (service_completed subscriber_service_a)
      (service_completed notifier_coordinator_primary)
      (service_completed notifier_coordinator_secondary)
    )
  )
)
