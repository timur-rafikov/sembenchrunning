(define (problem state_transition_enforcement_problem)
  (:domain state_transition_enforcement_domain)
  (:objects primary_actor_1 - primary_actor secondary_actor_1 - secondary_actor workflow_instance_1 - workflow_instance workflow_instance_2 - workflow_instance assignee_token_1 - assignee_token assignee_token_2 - assignee_token assignee_token_3 - assignee_token validator_token_1 - validator_token approver_token_1 - approver_token attachment_artifact_1 - attachment_artifact resource_slot_a_1 - resource_slot_a resource_slot_b_1 - resource_slot_b deliverable_1 - deliverable subdocument_1 - subdocument subdocument_2 - subdocument policy_definition_1 - policy_definition policy_definition_2 - policy_definition configuration_profile_1 - configuration_profile configuration_profile_2 - configuration_profile audit_token_1 - audit_token attachment_type_a_1 - attachment_type_a policy_binding_1 - policy_binding policy_binding_2 - policy_binding binding_token_1 - binding_token)
  (:init
