    (assignee_token_available assignee_token_2)
    (assignee_token_available assignee_token_3)
    (validator_token_available validator_token_1)
    (approver_token_available approver_token_1)
    (attachment_artifact_available attachment_artifact_1)
    (primary_actor_slot_a_assigned primary_actor_1 resource_slot_a_1)
    (secondary_actor_slot_b_assigned secondary_actor_1 resource_slot_b_1)
    (deliverable_pending deliverable_1)
    (subdocument_unprocessed subdocument_1)
    (subdocument_unprocessed subdocument_2)
    (workflow_primary_actor_link workflow_instance_1 primary_actor_1)
    (workflow_primary_actor_link workflow_instance_2 primary_actor_1)
    (workflow_secondary_actor_link workflow_instance_1 secondary_actor_1)
    (workflow_secondary_actor_link workflow_instance_2 secondary_actor_1)
    (workflow_deliverable_attached workflow_instance_1 deliverable_1)
    (workflow_deliverable_attached workflow_instance_2 deliverable_1)
    (workflow_subdocument_attached workflow_instance_1 subdocument_1)
    (workflow_subdocument_attached workflow_instance_2 subdocument_2)
    (policy_definition_available policy_definition_1)
    (policy_definition_available policy_definition_2)
    (configuration_profile_available configuration_profile_1)
    (configuration_profile_available configuration_profile_2)
    (audit_token_available audit_token_1)
    (attachment_type_a_available attachment_type_a_1)
    (policy_binding_available policy_binding_1)
    (workflow_policy_binding_association workflow_instance_1 policy_binding_1)
    (workflow_policy_binding_association workflow_instance_2 policy_binding_2)
    (binding_token_available binding_token_1)
