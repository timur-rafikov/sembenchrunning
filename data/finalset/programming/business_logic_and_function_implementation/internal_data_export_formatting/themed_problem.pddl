(define (problem internal_data_export_formatting_problem)
  (:domain internal_data_export_formatting_domain)
  (:objects producer_ctx_main - producer_context consumer_ctx_main - consumer_context export_job_alpha - export_job export_job_beta - export_job format_slot_1 - format_slot format_slot_2 - format_slot format_slot_3 - format_slot field_def_1 - field_definition binding_resource_1 - binding_resource auxiliary_asset_1 - auxiliary_asset format_profile_default - format_profile layout_profile_standard - layout_profile export_file_slot_1 - export_file component_template_header - component_template component_template_footer - component_template attachment_template_invoice - attachment_template attachment_template_receipt - attachment_template presentation_style_modern - presentation_style presentation_style_classic - presentation_style target_channel_internal_api - target_channel processing_module_cleaner - processing_module policy_tag_confidential - policy_tag policy_tag_public - policy_tag policy_module_compliance - policy_module)
  (:init
    (format_slot_available format_slot_1)
    (format_slot_available format_slot_2)
    (format_slot_available format_slot_3)
    (field_definition_available field_def_1)
    (binding_resource_available binding_resource_1)
    (auxiliary_asset_available auxiliary_asset_1)
    (context_assigned_format_profile producer_ctx_main format_profile_default)
    (consumer_assigned_layout_profile consumer_ctx_main layout_profile_standard)
    (export_file_available export_file_slot_1)
    (component_template_available component_template_header)
    (component_template_available component_template_footer)
    (job_linked_producer_context export_job_alpha producer_ctx_main)
    (job_linked_producer_context export_job_beta producer_ctx_main)
    (job_linked_consumer_context export_job_alpha consumer_ctx_main)
    (job_linked_consumer_context export_job_beta consumer_ctx_main)
    (job_associated_export_file export_job_alpha export_file_slot_1)
    (job_associated_export_file export_job_beta export_file_slot_1)
    (job_has_component_template export_job_alpha component_template_header)
    (job_has_component_template export_job_beta component_template_footer)
    (attachment_template_available attachment_template_invoice)
    (attachment_template_available attachment_template_receipt)
    (presentation_style_available presentation_style_modern)
    (presentation_style_available presentation_style_classic)
    (target_channel_available target_channel_internal_api)
    (processing_module_available processing_module_cleaner)
    (policy_tag_available policy_tag_confidential)
    (job_has_policy_tag export_job_alpha policy_tag_confidential)
    (job_has_policy_tag export_job_beta policy_tag_public)
    (policy_module_available policy_module_compliance)
  )
  (:goal
    (and
      (entity_committed producer_ctx_main)
      (entity_committed consumer_ctx_main)
      (entity_committed export_job_alpha)
      (entity_committed export_job_beta)
    )
  )
)
