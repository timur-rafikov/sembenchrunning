(define (problem rbac_onboarding_and_authorization_problem)
  (:domain rbac_enforcement_domain)
  (:objects end_user_alice - end_user service_account_sync - service_account policy_engine_primary - policy_engine policy_engine_secondary - policy_engine role_admin - rbac_role role_developer - rbac_role role_viewer - rbac_role permission_read - permission approval_token_initial - approval_token entitlement_trial - entitlement scope_a_prod - context_scope_a scope_b_standard - context_scope_b access_request_seed - access_request resource_db - resource resource_cache - resource feature_flag_beta - feature_flag feature_flag_experimental - feature_flag constraint_time_window - constraint constraint_location - constraint policy_doc_standard - policy_document credential_initial - credential delegation_ticket_alpha - delegation_ticket delegation_ticket_beta - delegation_ticket audit_record_initial - audit_record)
  (:init
    (role_available role_admin)
    (role_available role_developer)
    (role_available role_viewer)
    (permission_available permission_read)
    (approval_token_available approval_token_initial)
    (entitlement_available entitlement_trial)
    (end_user_scope_a_binding end_user_alice scope_a_prod)
    (service_account_scope_b_binding service_account_sync scope_b_standard)
    (access_request_pending access_request_seed)
    (resource_available resource_db)
    (resource_available resource_cache)
    (policy_engine_end_user_binding policy_engine_primary end_user_alice)
    (policy_engine_end_user_binding policy_engine_secondary end_user_alice)
    (policy_engine_service_account_binding policy_engine_primary service_account_sync)
    (policy_engine_service_account_binding policy_engine_secondary service_account_sync)
    (policy_engine_access_request_binding policy_engine_primary access_request_seed)
    (policy_engine_access_request_binding policy_engine_secondary access_request_seed)
    (policy_engine_resource_binding policy_engine_primary resource_db)
    (policy_engine_resource_binding policy_engine_secondary resource_cache)
    (feature_flag_available feature_flag_beta)
    (feature_flag_available feature_flag_experimental)
    (constraint_available constraint_time_window)
    (constraint_available constraint_location)
    (policy_document_available policy_doc_standard)
    (credential_available credential_initial)
    (delegation_ticket_available delegation_ticket_alpha)
    (policy_engine_delegation_binding policy_engine_primary delegation_ticket_alpha)
    (policy_engine_delegation_binding policy_engine_secondary delegation_ticket_beta)
    (audit_record_available audit_record_initial)
  )
  (:goal
    (and
      (principal_active end_user_alice)
      (principal_active service_account_sync)
      (principal_active policy_engine_primary)
      (principal_active policy_engine_secondary)
    )
  )
)
