(define (problem batch_processing_run_instance)
  (:domain batch_processing_pipeline)
  (:objects source_record_1 - source_record destination_record_1 - destination_record batch_job_alpha - batch_job batch_job_beta - batch_job resource_token_1 - resource_token resource_token_2 - resource_token resource_token_3 - resource_token rule_token_1 - rule_token handler_primary - handler option_default - option channel_primary - channel channel_peer_primary - channel_peer output_artifact_1 - output_artifact dataset_alpha - dataset dataset_beta - dataset configuration_primary - configuration configuration_secondary - configuration policy_alpha - policy policy_beta - policy signature_primary - signature plugin_validator - plugin constraint_alpha - constraint constraint_beta - constraint hook_primary - hook)
  (:init
    (resource_token_available resource_token_1)
    (resource_token_available resource_token_2)
    (resource_token_available resource_token_3)
    (rule_token_available rule_token_1)
    (handler_available handler_primary)
    (option_available option_default)
    (record_assigned_channel source_record_1 channel_primary)
    (destination_record_assigned_peer destination_record_1 channel_peer_primary)
    (artifact_pending output_artifact_1)
    (dataset_available dataset_alpha)
    (dataset_available dataset_beta)
    (batch_job_has_source_record batch_job_alpha source_record_1)
    (batch_job_has_source_record batch_job_beta source_record_1)
    (batch_job_has_destination_record batch_job_alpha destination_record_1)
    (batch_job_has_destination_record batch_job_beta destination_record_1)
    (batch_job_produces_artifact batch_job_alpha output_artifact_1)
    (batch_job_produces_artifact batch_job_beta output_artifact_1)
    (batch_job_attached_dataset batch_job_alpha dataset_alpha)
    (batch_job_attached_dataset batch_job_beta dataset_beta)
    (configuration_available configuration_primary)
    (configuration_available configuration_secondary)
    (policy_available policy_alpha)
    (policy_available policy_beta)
    (signature_available signature_primary)
    (plugin_available plugin_validator)
    (constraint_available constraint_alpha)
    (batch_job_has_constraint batch_job_alpha constraint_alpha)
    (batch_job_has_constraint batch_job_beta constraint_beta)
    (hook_available hook_primary)
  )
  (:goal
    (and
      (work_item_completed source_record_1)
      (work_item_completed destination_record_1)
      (work_item_completed batch_job_alpha)
      (work_item_completed batch_job_beta)
    )
  )
)
