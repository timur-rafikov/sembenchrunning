(define (problem discount_adjustment_problem)
  (:domain discount_adjustment_domain)
  (:objects order_context_1 - order_context invoice_context_1 - invoice_context processor_alpha - processor_session processor_beta - processor_session discount_def_a - discount_definition discount_def_b - discount_definition discount_def_c - discount_definition pricing_request_1 - pricing_request approver_1 - approver coupon_token_1 - coupon_token order_slot_1 - order_adjustment_slot invoice_slot_1 - invoice_adjustment_slot adjustment_record_template - adjustment_record pricing_component_a - pricing_component pricing_component_b - pricing_component promotion_tag_a - promotion_tag promotion_tag_b - promotion_tag reporting_profile_a - reporting_profile reporting_profile_b - reporting_profile reason_code_standard - reason_code monetary_attribute_default - monetary_attribute entitlement_flag_a - entitlement_flag entitlement_flag_b - entitlement_flag policy_flag_default - policy_flag)
  (:init
    (discount_available discount_def_a)
    (discount_available discount_def_b)
    (discount_available discount_def_c)
    (pricing_request_available pricing_request_1)
    (approver_available approver_1)
    (coupon_available coupon_token_1)
    (order_has_adjustment_slot order_context_1 order_slot_1)
    (invoice_has_adjustment_slot invoice_context_1 invoice_slot_1)
    (adjustment_record_available adjustment_record_template)
    (component_available pricing_component_a)
    (component_available pricing_component_b)
    (processor_bound_to_order_context processor_alpha order_context_1)
    (processor_bound_to_order_context processor_beta order_context_1)
    (processor_bound_to_invoice_context processor_alpha invoice_context_1)
    (processor_bound_to_invoice_context processor_beta invoice_context_1)
    (processor_has_adjustment_record processor_alpha adjustment_record_template)
    (processor_has_adjustment_record processor_beta adjustment_record_template)
    (processor_has_component processor_alpha pricing_component_a)
    (processor_has_component processor_beta pricing_component_b)
    (promotion_tag_available promotion_tag_a)
    (promotion_tag_available promotion_tag_b)
    (reporting_profile_available reporting_profile_a)
    (reporting_profile_available reporting_profile_b)
    (reason_code_available reason_code_standard)
    (monetary_attribute_available monetary_attribute_default)
    (entitlement_flag_available entitlement_flag_a)
    (processor_entitlement_binding processor_alpha entitlement_flag_a)
    (processor_entitlement_binding processor_beta entitlement_flag_b)
    (policy_flag_available policy_flag_default)
  )
  (:goal
    (and
      (applied order_context_1)
      (applied invoice_context_1)
      (applied processor_alpha)
      (applied processor_beta)
    )
  )
)
