(define (problem multi_step_internal_workflow_execution_problem)
  (:domain multi_step_internal_workflow_execution_domain)
  (:objects primary_participant_instance - primary_participant secondary_participant_instance - secondary_participant lead_orchestrator - orchestrator support_orchestrator - orchestrator resource_token_a - resource_token resource_token_b - resource_token resource_token_c - resource_token standard_operation_type - operation_type processing_capability - capability supporting_artifact - artifact signal_channel_alpha - signal_channel_a signal_channel_beta - signal_channel_b consolidated_output_bundle - output_bundle attachment_a - attachment_record attachment_b - attachment_record policy_a - policy_rule policy_b - policy_rule metadata_a - metadata_record metadata_b - metadata_record audit_token_main - audit_token execution_parameter_main - execution_parameter approval_reference_a - approval_reference approval_reference_b - approval_reference notification_template_main - notification_template)
  (:init
    (resource_available resource_token_a)
    (resource_available resource_token_b)
    (resource_available resource_token_c)
    (operation_type_available standard_operation_type)
    (capability_available processing_capability)
    (artifact_available supporting_artifact)
    (primary_channel_binding primary_participant_instance signal_channel_alpha)
    (secondary_channel_binding secondary_participant_instance signal_channel_beta)
    (output_bundle_available consolidated_output_bundle)
    (attachment_available attachment_a)
    (attachment_available attachment_b)
    (orchestrator_primary_link lead_orchestrator primary_participant_instance)
    (orchestrator_primary_link support_orchestrator primary_participant_instance)
    (orchestrator_secondary_link lead_orchestrator secondary_participant_instance)
    (orchestrator_secondary_link support_orchestrator secondary_participant_instance)
    (orchestrator_output_link lead_orchestrator consolidated_output_bundle)
    (orchestrator_output_link support_orchestrator consolidated_output_bundle)
    (orchestrator_attachment_link lead_orchestrator attachment_a)
    (orchestrator_attachment_link support_orchestrator attachment_b)
    (policy_available policy_a)
    (policy_available policy_b)
    (metadata_available metadata_a)
    (metadata_available metadata_b)
    (audit_token_available audit_token_main)
    (execution_parameter_available execution_parameter_main)
    (approval_reference_available approval_reference_a)
    (orchestrator_approval_reference_link lead_orchestrator approval_reference_a)
    (orchestrator_approval_reference_link support_orchestrator approval_reference_b)
    (notification_template_available notification_template_main)
  )
  (:goal
    (and
      (finalized primary_participant_instance)
      (finalized secondary_participant_instance)
      (finalized lead_orchestrator)
      (finalized support_orchestrator)
    )
  )
)
