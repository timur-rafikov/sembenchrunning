(define (problem internal_report_generation_problem)
  (:domain report_generation_domain)
  (:objects primary_aggregation_context_instance - primary_aggregation_context secondary_aggregation_context_instance - secondary_aggregation_context report_processor_1 - report_processor report_processor_2 - report_processor data_source_1 - data_source data_source_2 - data_source data_source_3 - data_source metric_definition_1 - metric_definition processor_unit_1 - processor_unit parameter_1 - parameter_token aggregation_key_a_1 - aggregation_key_a aggregation_key_b_1 - aggregation_key_b report_draft_template_1 - report_draft content_fragment_1 - content_fragment content_fragment_2 - content_fragment signature_template_1 - signature_template signature_template_2 - signature_template output_format_pdf - output_format output_format_csv - output_format policy_token_1 - policy_token content_block_1 - content_block approval_token_1 - approval_token approval_token_2 - approval_token reviewer_1 - reviewer)
  (:init
    (data_source_available data_source_1)
    (data_source_available data_source_2)
    (data_source_available data_source_3)
    (metric_available metric_definition_1)
    (processor_unit_available processor_unit_1)
    (parameter_available parameter_1)
    (primary_context_has_key primary_aggregation_context_instance aggregation_key_a_1)
    (secondary_context_has_key secondary_aggregation_context_instance aggregation_key_b_1)
    (draft_slot_available report_draft_template_1)
    (fragment_available content_fragment_1)
    (fragment_available content_fragment_2)
    (processor_assigned_to_primary_context report_processor_1 primary_aggregation_context_instance)
    (processor_assigned_to_primary_context report_processor_2 primary_aggregation_context_instance)
    (processor_assigned_to_secondary_context report_processor_1 secondary_aggregation_context_instance)
    (processor_assigned_to_secondary_context report_processor_2 secondary_aggregation_context_instance)
    (processor_has_draft report_processor_1 report_draft_template_1)
    (processor_has_draft report_processor_2 report_draft_template_1)
    (processor_has_fragment_template report_processor_1 content_fragment_1)
    (processor_has_fragment_template report_processor_2 content_fragment_2)
    (signature_template_available signature_template_1)
    (signature_template_available signature_template_2)
    (output_format_available output_format_pdf)
    (output_format_available output_format_csv)
    (policy_token_available policy_token_1)
    (content_block_available content_block_1)
    (approval_token_available approval_token_1)
    (processor_associated_with_approval_token report_processor_1 approval_token_1)
    (processor_associated_with_approval_token report_processor_2 approval_token_2)
    (reviewer_available reviewer_1)
  )
  (:goal
    (and
      (entity_finalized primary_aggregation_context_instance)
      (entity_finalized secondary_aggregation_context_instance)
      (entity_finalized report_processor_1)
      (entity_finalized report_processor_2)
    )
  )
)
