(define (problem normalize_submissions_problem)
  (:domain user_input_normalization_pipeline_domain)
  (:objects primary_field_group - field_group_context locale_field_variant - field_variant_context normalizer_alpha - normalizer_context normalizer_beta - normalizer_context worker_slot_1 - processing_slot worker_slot_2 - processing_slot worker_slot_3 - processing_slot default_parser_rule - parser_rule default_validator_rule - validator_rule canonical_sample_value - canonical_value primary_field_key - field_key default_format_profile - field_format_profile artifact_alpha - output_artifact schema_element_a - schema_element schema_element_b - schema_element compact_style_profile - style_profile readable_style_profile - style_profile masking_postprocess_action - postprocess_action trimming_postprocess_action - postprocess_action initial_metadata_bundle - metadata_bundle default_transformer_module - transformer_module privacy_policy_binding_a - policy_binding privacy_policy_binding_b - policy_binding privacy_policy_rule - policy_rule)
  (:init
    (processing_slot_available worker_slot_1)
    (processing_slot_available worker_slot_2)
    (processing_slot_available worker_slot_3)
    (parser_rule_available default_parser_rule)
    (validator_rule_available default_validator_rule)
    (canonical_value_available canonical_sample_value)
    (field_group_resolves_key primary_field_group primary_field_key)
    (field_variant_has_format_profile locale_field_variant default_format_profile)
    (artifact_registered_for_assembly artifact_alpha)
    (schema_element_available schema_element_a)
    (schema_element_available schema_element_b)
    (normalizer_handles_field_group normalizer_alpha primary_field_group)
    (normalizer_handles_field_group normalizer_beta primary_field_group)
    (normalizer_handles_field_variant normalizer_alpha locale_field_variant)
    (normalizer_handles_field_variant normalizer_beta locale_field_variant)
    (normalizer_assigned_artifact normalizer_alpha artifact_alpha)
    (normalizer_assigned_artifact normalizer_beta artifact_alpha)
    (normalizer_uses_schema_element normalizer_alpha schema_element_a)
    (normalizer_uses_schema_element normalizer_beta schema_element_b)
    (style_profile_available compact_style_profile)
    (style_profile_available readable_style_profile)
    (postprocess_action_available masking_postprocess_action)
    (postprocess_action_available trimming_postprocess_action)
    (metadata_bundle_available initial_metadata_bundle)
    (transformer_module_available default_transformer_module)
    (policy_binding_available privacy_policy_binding_a)
    (normalizer_has_policy_binding normalizer_alpha privacy_policy_binding_a)
    (normalizer_has_policy_binding normalizer_beta privacy_policy_binding_b)
    (policy_rule_available privacy_policy_rule)
  )
  (:goal
    (and
      (normalization_complete primary_field_group)
      (normalization_complete locale_field_variant)
      (normalization_complete normalizer_alpha)
      (normalization_complete normalizer_beta)
    )
  )
)
