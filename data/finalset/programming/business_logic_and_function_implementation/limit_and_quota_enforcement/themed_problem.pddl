(define (problem quota_enforcement_scenario)
  (:domain quota_enforcement)
  (:objects tenant_1 - tenant_scope project_1 - project_scope enforcer_a - enforcement_agent enforcer_b - enforcement_agent slot_1 - quota_slot slot_2 - quota_slot slot_3 - quota_slot usage_metric_1 - usage_metric operator_token_1 - operator_token credit_unit_1 - credit_unit metric_key_1 - metric_key metric_dimension_1 - metric_dimension quota_bucket_1 - quota_bucket capability_flag_alpha - capability_flag capability_flag_beta - capability_flag proposal_bundle_1 - proposal_bundle proposal_bundle_2 - proposal_bundle policy_attachment_1 - policy_attachment policy_attachment_2 - policy_attachment validation_credential_1 - validation_credential allocation_rule_1 - allocation_rule assignment_tag_1 - assignment_tag assignment_tag_2 - assignment_tag policy_tag_1 - policy_tag)
  (:init
    (slot_available slot_1)
    (slot_available slot_2)
    (slot_available slot_3)
    (metric_available usage_metric_1)
    (operator_token_available operator_token_1)
    (credit_available credit_unit_1)
    (scope_metric_key_association tenant_1 metric_key_1)
    (project_metric_dimension_association project_1 metric_dimension_1)
    (bucket_pending quota_bucket_1)
    (capability_flag_available capability_flag_alpha)
    (capability_flag_available capability_flag_beta)
    (enforcer_tenant_association enforcer_a tenant_1)
    (enforcer_tenant_association enforcer_b tenant_1)
    (enforcer_project_association enforcer_a project_1)
    (enforcer_project_association enforcer_b project_1)
    (enforcer_bucket_association enforcer_a quota_bucket_1)
    (enforcer_bucket_association enforcer_b quota_bucket_1)
    (enforcer_capability_binding enforcer_a capability_flag_alpha)
    (enforcer_capability_binding enforcer_b capability_flag_beta)
    (proposal_bundle_available proposal_bundle_1)
    (proposal_bundle_available proposal_bundle_2)
    (policy_attachment_available policy_attachment_1)
    (policy_attachment_available policy_attachment_2)
    (validation_credential_available validation_credential_1)
    (allocation_rule_available allocation_rule_1)
    (assignment_tag_available assignment_tag_1)
    (enforcer_assignment_tag_binding enforcer_a assignment_tag_1)
    (enforcer_assignment_tag_binding enforcer_b assignment_tag_2)
    (policy_tag_available policy_tag_1)
  )
  (:goal
    (and
      (enforcement_applied tenant_1)
      (enforcement_applied project_1)
      (enforcement_applied enforcer_a)
      (enforcement_applied enforcer_b)
    )
  )
)
