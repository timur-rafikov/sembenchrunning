(define (problem cache_staleness_remediation_problem)
  (:domain cache_invalidation_domain)
  (:objects primary_cache_1 - primary_cache_instance secondary_cache_1 - secondary_cache_instance remediation_agent_1 - remediation_agent remediation_agent_2 - remediation_agent worker_1 - invalidation_worker worker_2 - invalidation_worker worker_3 - invalidation_worker diagnostic_1 - diagnostic_artifact operator_1 - operator_role patch_1 - repair_patch dependency_key_1 - dependency_key target_key_1 - dependency_key_secondary invalidation_job_1 - invalidation_job data_partition_1 - data_partition data_partition_2 - data_partition approval_token_1 - approval_token approval_token_2 - approval_token deployment_config_1 - deployment_config deployment_config_2 - deployment_config verification_artifact_1 - verification_artifact test_case_1 - test_case audit_record_1 - audit_record audit_record_2 - audit_record credential_1 - credential)
  (:init
    (worker_available worker_1)
    (worker_available worker_2)
    (worker_available worker_3)
    (diagnostic_available diagnostic_1)
    (operator_available operator_1)
    (repair_patch_available patch_1)
    (primary_dependency_key primary_cache_1 dependency_key_1)
    (secondary_dependency_key secondary_cache_1 target_key_1)
    (job_pending invalidation_job_1)
    (partition_available data_partition_1)
    (partition_available data_partition_2)
    (agent_manages_primary_cache remediation_agent_1 primary_cache_1)
    (agent_manages_primary_cache remediation_agent_2 primary_cache_1)
    (agent_manages_secondary_cache remediation_agent_1 secondary_cache_1)
    (agent_manages_secondary_cache remediation_agent_2 secondary_cache_1)
    (agent_has_job remediation_agent_1 invalidation_job_1)
    (agent_has_job remediation_agent_2 invalidation_job_1)
    (agent_claims_partition remediation_agent_1 data_partition_1)
    (agent_claims_partition remediation_agent_2 data_partition_2)
    (approval_token_available approval_token_1)
    (approval_token_available approval_token_2)
    (deployment_config_available deployment_config_1)
    (deployment_config_available deployment_config_2)
    (verification_artifact_available verification_artifact_1)
    (test_case_available test_case_1)
    (audit_record_available audit_record_1)
    (agent_has_audit_record remediation_agent_1 audit_record_1)
    (agent_has_audit_record remediation_agent_2 audit_record_2)
    (credential_available credential_1)
  )
  (:goal
    (and
      (remediation_completed primary_cache_1)
      (remediation_completed secondary_cache_1)
      (remediation_completed remediation_agent_1)
      (remediation_completed remediation_agent_2)
    )
  )
)
